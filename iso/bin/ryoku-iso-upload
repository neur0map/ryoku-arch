#!/bin/bash

if [ $# -eq 0 ]; then
  echo "Usage: ryoku-iso-upload [release/ryoku.iso]"
  exit 1
fi

if [[ ! -f ~/.config/rclone/rclone.conf ]]; then
  echo "You must first configure rclone with the R2 credentials: ryoku-iso-rclone-config"
  exit 1
fi

rclone copy $1 Ryoku:ryoku/ -P

if [[ -f $1.sig ]]; then
  rclone copy $1.sig Ryoku:ryoku/ -P
fi
