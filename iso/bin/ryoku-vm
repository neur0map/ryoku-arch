#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VM_DIR="$(dirname "$SCRIPT_DIR")/vm-saves"
TMP_DISK="/tmp/ryoku-iso-boot.qcow2"
TMP_OVMF="/tmp/OVMF_VARS.4m.fd"

mkdir -p "$VM_DIR"

save_vm() {
  local name="$1"

  if [[ -z "$name" ]]; then
    if command -v ryoku-tui >/dev/null 2>&1; then
      name=$(ryoku-tui input --placeholder "Enter VM snapshot name")
    else
      read -r -p "Enter VM snapshot name: " name
    fi
    [[ -z "$name" ]] && exit 1
  fi

  if [[ ! -f "$TMP_DISK" || ! -f "$TMP_OVMF" ]]; then
    echo "Error: No active VM found in /tmp"
    echo "Boot a VM first with: ryoku-iso-boot [iso]"
    exit 1
  fi

  local vm_path="$VM_DIR/$name"

  if [[ -d "$vm_path" ]]; then
    if command -v ryoku-tui >/dev/null 2>&1; then
      ryoku-tui confirm "VM '$name' exists. Overwrite?" || exit 0
    else
      read -r -p "VM '$name' exists. Overwrite? [y/N] " a
      [[ $a == [yY]* ]] || exit 0
    fi
  fi

  mkdir -p "$vm_path"

  echo "Saving VM snapshot '$name'..."
  cp "$TMP_DISK" "$vm_path/ryoku-iso-boot.qcow2"
  cp "$TMP_OVMF" "$vm_path/OVMF_VARS.4m.fd"

  if command -v ryoku-tui >/dev/null 2>&1; then
    ryoku-tui style --foreground 212 "✓ Saved to $vm_path"
  else
    printf '%s\n' "✓ Saved to $vm_path"
  fi
}

list_vms() {
  if [[ ! -d "$VM_DIR" ]] || [[ -z "$(ls -A "$VM_DIR")" ]]; then
    echo "No VM snapshots found"
    return 1
  fi

  echo "Available VM snapshots:"
  for vm in "$VM_DIR"/*; do
    [[ -d "$vm" ]] && echo "  • $(basename "$vm")"
  done
}

boot_vm() {
  local name="$1"

  if [[ -z "$(ls -A "$VM_DIR" 2>/dev/null)" ]]; then
    echo "No VM snapshots available"
    exit 1
  fi

  if [[ -z "$name" ]]; then
    if command -v ryoku-tui >/dev/null 2>&1; then
      name=$(ls -1 "$VM_DIR" | ryoku-tui choose --header "Select VM to boot:")
    else
      name=$(ls -1 "$VM_DIR" | head -n1)
    fi
    [[ -z "$name" ]] && exit 0
  fi

  local vm_path="$VM_DIR/$name"

  if [[ ! -d "$vm_path" ]]; then
    echo "Error: VM '$name' not found"
    list_vms
    exit 1
  fi

  if [[ -f "$TMP_DISK" ]]; then
    if command -v ryoku-tui >/dev/null 2>&1; then
      ryoku-tui confirm "Override existing /tmp VM?" || exit 0
    else
      read -r -p "Override existing /tmp VM? [y/N] " a
      [[ $a == [yY]* ]] || exit 0
    fi
  fi

  echo "Copying VM '$name' to /tmp..."
  cp "$vm_path/ryoku-iso-boot.qcow2" "$TMP_DISK"
  cp "$vm_path/OVMF_VARS.4m.fd" "$TMP_OVMF"

  if command -v ryoku-tui >/dev/null 2>&1; then
    ryoku-tui style --foreground 212 "✓ VM ready. Booting..."
  else
    printf '%s\n' "✓ VM ready. Booting..."
  fi

  exec ryoku-iso-boot /dev/null reuse
}

case "${1:-}" in
  save)
    save_vm "$2"
    ;;
  boot)
    boot_vm "$2"
    ;;
  list)
    list_vms
    ;;
  *)
    if command -v ryoku-tui >/dev/null 2>&1; then
      ryoku-tui style --border rounded --padding "0 1" --border-foreground 212 \
        "$(ryoku-tui style --bold 'ryoku-vm') - VM snapshot manager" \
        "" \
        "$(ryoku-tui style --foreground 245 'Commands:')" \
        "  save [name]  Save current VM from /tmp" \
        "  boot [name]  Boot saved VM (interactive if no name)" \
        "  list         List available VMs" \
        "" \
        "$(ryoku-tui style --foreground 245 'Current VMs:')"
    else
      printf '%s\n' \
        "ryoku-vm - VM snapshot manager" \
        "" \
        "Commands:" \
        "  save [name]  Save current VM from /tmp" \
        "  boot [name]  Boot saved VM (interactive if no name)" \
        "  list         List available VMs" \
        "" \
        "Current VMs:"
    fi
    list_vms 2>/dev/null || echo "  None"
    ;;
esac
