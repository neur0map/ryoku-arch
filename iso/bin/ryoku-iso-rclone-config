#!/bin/bash
ryoku-pkg-add rclone
mkdir -p ~/.config/rclone

access_key=$(op read "op://Shared/Cloudflare Buckets/iso.github.com/neur0map/ryoku-arch/access_key_id" --account Ryoku)
secret_access_key=$(op read "op://Shared/Cloudflare Buckets/iso.github.com/neur0map/ryoku-arch/secret_access_key" --account Ryoku)
endpoint=$(op read "op://Shared/Cloudflare Buckets/iso.github.com/neur0map/ryoku-arch/endpoint" --account Ryoku)

cat > ~/.config/rclone/rclone.conf << EOF
[Ryoku]
type = s3
provider = Cloudflare
access_key_id = $access_key
secret_access_key = $secret_access_key
endpoint = $endpoint
EOF
