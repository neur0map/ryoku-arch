#!/bin/bash
#
# Ryoku live ISO welcome greeter, run inside Alacritty on first boot.
# Truecolor renders here because Alacritty is a real graphical terminal.
# Shows the brand banner for a moment, then drops the user straight into
# `ryoku-install` (matching archinstall's flow on omarchy).

ORANGE='\033[38;2;242;86;35m'
SUBDUED='\033[38;2;174;171;148m'
RESET='\033[0m'

clear

printf "${ORANGE}"
cat <<'BANNER'

                   ████████
                   ████████
                   ████████
                   ████████
     ██████████████████████████████████████████
   ██████████████████████████████████████████████
   ██████████████████████████████████████████████
                   ████████              ████████
                   ██████                ██████
                 ████████                ██████
               ████████                  ██████
             ██████████                  ██████
         ██████████                    ████████
       ██████████                      ██████
   ████████████              ████████████████
     ████                      ████████

 ██████╗ ██╗   ██╗ ██████╗ ██╗  ██╗██╗   ██╗
 ██╔══██╗╚██╗ ██╔╝██╔═══██╗██║ ██╔╝██║   ██║
 ██████╔╝ ╚████╔╝ ██║   ██║█████╔╝ ██║   ██║
 ██╔══██╗  ╚██╔╝  ██║   ██║██╔═██╗ ██║   ██║
 ██║  ██║   ██║   ╚██████╔╝██║  ██╗╚██████╔╝
 ╚═╝  ╚═╝   ╚═╝    ╚═════╝ ╚═╝  ╚═╝ ╚═════╝
BANNER
printf "${RESET}\n"
printf "${SUBDUED}            力と美のために  :  For the sake of power and beauty.${RESET}\n\n"

sleep 2

# Hand straight off to the gum-styled installer. If it exits (cancel /
# error), drop the user at a bash prompt so they can troubleshoot or
# rerun manually.
ryoku-install
exec bash
