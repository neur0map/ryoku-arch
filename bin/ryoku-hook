#!/bin/bash

set -e
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Run a named hook, like post-update (available in ~/.config/ryoku/hooks/post-update
# and ~/.config/ryoku/hooks/post-update.d/).

if (( $# < 1 )); then
  echo "Usage: ryoku-hook [name] [args...]"
  exit 1
fi

HOOK=$1
HOOK_PATH="$RYOKU_CONFIG_PATH/hooks/$HOOK"
HOOK_DIR="$HOOK_PATH.d"
shift

if [[ -f $HOOK_PATH ]]; then
  bash "$HOOK_PATH" "$@" || echo "Hook failed: $HOOK_PATH"
fi

if [[ -d $HOOK_DIR ]]; then
  for hook in "$HOOK_DIR"/*; do
    [[ -f $hook ]] || continue
    [[ $hook == *.sample ]] && continue
    bash "$hook" "$@" || echo "Hook failed: $hook"
  done
fi
