#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

for name_file in /sys/class/input/event*/device/name; do
  [[ -f $name_file ]] || continue
  device="$(<"$name_file")"
  if [[ $device =~ [Tt]ouchpad|[Tt]rackpad ]]; then
    echo "$device"
    exit 0
  fi
done
