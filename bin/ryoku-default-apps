#!/bin/bash

# ryoku-default-apps - back the "Default applications" selector in
# Settings -> Launcher -> Apps.
#
#   list                     JSON of installed candidates per category, shaped
#                            for NComboBox: {cat: [{key, name}, ...], ...}
#   get-browser              the binary of the current xdg default browser
#   set-browser <bin>        make <bin> the xdg default browser (+ web mimetypes)
#   set-filemanager <bin>    make <bin> the xdg handler for directories
#   set-media <bin>          make <bin> the xdg handler for audio/video
#
# The shell stores terminal/explorer/playback/audio in GlobalConfig and consumes
# them directly; the browser and file/media mimetypes are system-wide xdg
# defaults, so those are set here. An app appears in a category once its binary
# is on PATH - extend the candidate lists below to offer more choices.

set -euo pipefail

candidates() {
  case "$1" in
  terminal)
    cat <<'EOF'
kitty|Kitty
alacritty|Alacritty
ghostty|Ghostty
foot|Foot
wezterm|WezTerm
konsole|Konsole
gnome-terminal|GNOME Terminal
kgx|Console
tilix|Tilix
xterm|XTerm
EOF
    ;;
  browser)
    cat <<'EOF'
firefox|Firefox
zen-browser|Zen
librewolf|LibreWolf
chromium|Chromium
helium|Helium
brave|Brave
vivaldi-stable|Vivaldi
google-chrome-stable|Google Chrome
microsoft-edge-stable|Microsoft Edge
qutebrowser|qutebrowser
EOF
    ;;
  filemanager)
    cat <<'EOF'
nautilus|Files
dolphin|Dolphin
thunar|Thunar
nemo|Nemo
pcmanfm|PCManFM
pcmanfm-qt|PCManFM-Qt
caja|Caja
EOF
    ;;
  media)
    cat <<'EOF'
mpv|mpv
vlc|VLC
celluloid|Celluloid
totem|Videos
haruna|Haruna
EOF
    ;;
  mixer)
    cat <<'EOF'
pavucontrol|Volume Control
pwvucontrol|pwvucontrol
easyeffects|EasyEffects
qpwgraph|qpwgraph
helvum|Helvum
EOF
    ;;
  esac
}

# Resolve a launcher .desktop id for a binary: exact <bin>.desktop first, then
# any entry whose Exec runs the binary. Falls back to "<bin>.desktop".
desktop_for_binary() {
  local bin="$1" dir f exec_line first
  local dirs=(
    "$HOME/.local/share/applications"
    /usr/local/share/applications
    /usr/share/applications
    /var/lib/flatpak/exports/share/applications
  )
  for dir in "${dirs[@]}"; do
    [[ -f "$dir/$bin.desktop" ]] && {
      printf '%s\n' "$bin.desktop"
      return 0
    }
  done
  # Match the entry whose Exec's first token (the program) is exactly $bin, so
  # e.g. nautilus -> org.gnome.Nautilus.desktop without matching unrelated apps.
  for dir in "${dirs[@]}"; do
    [[ -d $dir ]] || continue
    for f in "$dir"/*.desktop; do
      [[ -f $f ]] || continue
      exec_line=$(awk '/^Exec=/{sub(/^Exec=/, ""); print; exit}' "$f")
      first=$(basename "${exec_line%% *}")
      [[ $first == "$bin" ]] && {
        basename "$f"
        return 0
      }
    done
  done
  printf '%s\n' "$bin.desktop"
}

list_json() {
  local cat bin name
  for cat in terminal browser filemanager media mixer; do
    while IFS='|' read -r bin name; do
      [[ -n $bin ]] || continue
      command -v "$bin" >/dev/null 2>&1 && printf '%s\t%s\t%s\n' "$cat" "$bin" "$name"
    done < <(candidates "$cat")
  done | jq -Rn '
    {terminal: [], browser: [], filemanager: [], media: [], mixer: []} as $base
    | reduce (inputs | split("\t")) as $r ($base;
        .[$r[0]] += [{key: $r[1], name: $r[2]}])
  '
}

get_browser() {
  local desktop dir exec_bin
  desktop=$(xdg-settings get default-web-browser 2>/dev/null || true)
  [[ -n $desktop ]] || return 0
  for dir in "$HOME/.local/share/applications" /usr/local/share/applications /usr/share/applications; do
    if [[ -f "$dir/$desktop" ]]; then
      exec_bin=$(awk -F= '/^Exec=/{print $2; exit}' "$dir/$desktop" | awk '{print $1}')
      exec_bin=$(basename "${exec_bin:-}")
      [[ -n $exec_bin ]] && {
        printf '%s\n' "$exec_bin"
        return 0
      }
    fi
  done
  printf '%s\n' "${desktop%.desktop}"
}

set_browser() {
  local bin="$1" desktop mime
  desktop=$(desktop_for_binary "$bin")
  xdg-settings set default-web-browser "$desktop" 2>/dev/null || true
  for mime in x-scheme-handler/http x-scheme-handler/https x-scheme-handler/mailto text/html application/xhtml+xml; do
    xdg-mime default "$desktop" "$mime" 2>/dev/null || true
  done
}

set_filemanager() {
  local bin="$1" desktop
  desktop=$(desktop_for_binary "$bin")
  xdg-mime default "$desktop" inode/directory 2>/dev/null || true
}

set_media() {
  local bin="$1" desktop mime
  desktop=$(desktop_for_binary "$bin")
  for mime in audio/mpeg audio/flac audio/x-wav audio/ogg video/mp4 video/x-matroska video/webm; do
    xdg-mime default "$desktop" "$mime" 2>/dev/null || true
  done
}

case "${1:-}" in
list) list_json ;;
get-browser) get_browser ;;
set-browser) set_browser "${2:?binary required}" ;;
set-filemanager) set_filemanager "${2:?binary required}" ;;
set-media) set_media "${2:?binary required}" ;;
*)
  echo "usage: ryoku-default-apps {list | get-browser | set-browser <bin> | set-filemanager <bin> | set-media <bin>}" >&2
  exit 2
  ;;
esac
