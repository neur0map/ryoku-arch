#!/bin/bash

# ryoku-hypr-colors — regenerate Hyprland's themed palette from the live Material-3
# scheme and reload, so a theme switch recolors the window borders/shadows.
#
# The shell's palette lives in ~/.local/state/ryoku-shell/scheme.json (the only
# palette source the live shell reads). Hyprland's border/shadow colors live in a
# separate config file it loads at startup (colors.lua in Lua mode, colors.conf in
# hyprlang mode), which nothing else regenerates — so without this, Hyprland keeps
# its install-time palette regardless of the active theme. This bridges the two:
# read the M3 roles Hyprland uses out of scheme.json, write them in the active
# config format, and hyprctl reload. Invoked from ryoku-theme-set-shell after the
# scheme is written; safe to run by hand.

set -euo pipefail

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/hypr-config.sh"

scheme="${XDG_STATE_HOME:-$HOME/.local/state}/ryoku-shell/scheme.json"
dir="$(hypr_dir)"

[[ -f $scheme ]] || exit 0
command -v jq >/dev/null 2>&1 || exit 0
[[ -d $dir ]] || exit 0

# M3 roles Hyprland's shipped config consumes (hex, no leading '#').
read -r background surface surface_container primary secondary tertiary outline < <(
  jq -r '.colours | "\(.background) \(.surface) \(.surfaceContainer) \(.primary) \(.secondary) \(.tertiary) \(.outline)"' \
    "$scheme" 2>/dev/null
)
# Bail if the scheme is missing the roles (avoid writing "rgb(null)").
for v in "$background" "$surface" "$surface_container" "$primary" "$secondary" "$tertiary" "$outline"; do
  [[ -n ${v:-} && $v != null ]] || exit 0
done

if hypr_is_lua; then
  cat >"$dir/colors.lua" <<EOF
-- Ryoku Hyprland palette — regenerated from the active theme by ryoku-hypr-colors.
-- hyprland.lua reads these globals (require("colors")) for border/shadow colors.
var_background = "rgb($background)"
var_surface = "rgb($surface)"
var_surface_container = "rgb($surface_container)"
var_primary = "rgb($primary)"
var_secondary = "rgb($secondary)"
var_tertiary = "rgb($tertiary)"
var_outline = "rgb($outline)"
var_shadow = "rgba(00000099)"
EOF
else
  cat >"$dir/colors.conf" <<EOF
\$background = rgb($background)
\$surface = rgb($surface)
\$surface_container = rgb($surface_container)
\$primary = rgb($primary)
\$secondary = rgb($secondary)
\$tertiary = rgb($tertiary)
\$outline = rgb($outline)
\$shadow = rgba(00000099)
EOF
fi

# Apply live if Hyprland is reachable (best-effort; takes effect next login otherwise).
if command -v hyprctl >/dev/null 2>&1; then
  hyprctl reload >/dev/null 2>&1 || true
fi
