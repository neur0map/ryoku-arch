#!/bin/bash

set -euo pipefail

confirm=false
allow_auth_prompt=false
force=false

packages=(
  niri
  xdg-desktop-portal-gnome
)

usage() {
  cat <<'EOF'
Usage: ryoku-rebirth-purge-niri-live --confirm-niri-free [--allow-auth-prompt] [--force]

Removes live Niri session wiring only after the rebirth Hyprland session is
active. It snapshots first and keeps user apps/tools intact. Package removal is
skipped when root authorization is unavailable.
EOF
}

while (($# > 0)); do
  case "$1" in
    --confirm-niri-free)
      confirm=true
      ;;
    --allow-auth-prompt)
      allow_auth_prompt=true
      ;;
    --force)
      force=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ryoku-rebirth-purge-niri-live: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

[[ $confirm == true ]] || {
  usage >&2
  exit 2
}

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
xdg_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
systemd_user_dir="$xdg_config_home/systemd/user"

command_present() {
  command -v "$1" >/dev/null 2>&1
}

package_present() {
  local package="$1"

  if command_present ryoku-pkg-present; then
    ryoku-pkg-present "$package" >/dev/null 2>&1
    return
  fi

  pacman -Q "$package" >/dev/null 2>&1
}

can_install_without_prompt() {
  ((EUID == 0)) && return 0
  command_present sudo && sudo -n true >/dev/null 2>&1
}

hyprland_active() {
  [[ $force == true ]] && return 0
  [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] && return 0
  [[ ${XDG_CURRENT_DESKTOP:-} == *"Hyprland"* ]] && return 0
  command_present hyprctl && hyprctl monitors -j >/dev/null 2>&1
}

require_rebirth_hyprland() {
  [[ -f $xdg_config_home/hypr/hyprland.conf ]] || {
    echo "ryoku-rebirth-purge-niri-live: missing $xdg_config_home/hypr/hyprland.conf" >&2
    exit 77
  }

  grep -Eq 'systemctl --user .*ryoku-shell[.]service' "$xdg_config_home/hypr/hyprland.conf" || {
    echo "ryoku-rebirth-purge-niri-live: Hyprland config does not look like rebirth Hyprland" >&2
    exit 77
  }

  if grep -q 'ryoku-rebirth-shell\|ryoku-vroomies-shell' "$xdg_config_home/hypr/hyprland.conf"; then
    echo "ryoku-rebirth-purge-niri-live: Hyprland config still starts an experimental shell" >&2
    exit 77
  fi
}

packages_to_remove=()
for package in "${packages[@]}"; do
  if package_present "$package"; then
    packages_to_remove+=("$package")
  fi
done

if ! hyprland_active; then
  echo "ryoku-rebirth-purge-niri-live: refusing to purge outside an active Hyprland session" >&2
  exit 77
fi

require_rebirth_hyprland

snapshot_output="$("$repo_root/bin/ryoku-rebirth-snapshot")"
snapshot_dir="$(sed -n 's/^Snapshot: //p' <<<"$snapshot_output" | tail -1)"
[[ -d $snapshot_dir ]] || {
  echo "ryoku-rebirth-purge-niri-live: snapshot failed" >&2
  exit 1
}

move_to_snapshot() {
  local source="$1"
  local relative_dest="$2"
  local target="$snapshot_dir/removed/$relative_dest"

  [[ -e $source || -L $source ]] || return 0
  mkdir -p "$(dirname "$target")"
  mv "$source" "$target"
  printf 'moved=%s -> %s\n' "$relative_dest" "$target" >> "$snapshot_dir/manifest.txt"
}

move_config_to_snapshot() {
  local relative="$1"

  move_to_snapshot "$xdg_config_home/$relative" "config/$relative"
}

move_config_glob_to_snapshot() {
  local pattern="$1"
  local source

  for source in "$xdg_config_home"/$pattern; do
    [[ -e $source || -L $source ]] || continue
    move_to_snapshot "$source" "config/${source#"$xdg_config_home"/}"
  done
}

move_data_to_snapshot() {
  local relative="$1"

  move_to_snapshot "$xdg_data_home/$relative" "local-share/$relative"
}

move_config_to_snapshot "niri"
move_config_glob_to_snapshot "niri.before-*"
move_config_glob_to_snapshot "alacritty/*.inir-only-*"
move_config_to_snapshot "xdg-desktop-portal/niri-portals.conf"
move_config_to_snapshot "fish/auto-Niri.fish"
move_config_to_snapshot "fish/auto-Niri.fish.old"
move_config_to_snapshot "fish/conf.d/inir-env.fish"
move_config_to_snapshot "fish/conf.d/inir-path.fish"
move_config_to_snapshot "illogical-impulse"
move_config_to_snapshot "quickshell/ii"

move_config_glob_to_snapshot "quickshell/ryoku-shell/scripts/__pycache__/*niri*"
move_config_glob_to_snapshot "quickshell/ryoku-shell/scripts/__pycache__/*inir*"

move_data_to_snapshot "inir"
move_data_to_snapshot "ryoku-shell/defaults/niri"
move_data_to_snapshot "ryoku-shell/dots/.config/niri"
move_data_to_snapshot "ryoku-shell/dots/.config/fish/auto-Niri.fish"
move_data_to_snapshot "ryoku-shell/dots/.config/fish/auto-Niri.fish.old"
move_data_to_snapshot "ryoku-shell/dots/.config/fish/conf.d/inir-env.fish"
move_data_to_snapshot "ryoku-shell/dots/.config/fish/conf.d/inir-path.fish"
move_data_to_snapshot "ryoku-shell/dots/.config/xdg-desktop-portal/niri-portals.conf"
move_data_to_snapshot "ryoku-shell/modules/overview/OverviewNiriWidget.qml"
move_data_to_snapshot "ryoku-shell/modules/settings/NiriConfig.qml"
move_data_to_snapshot "ryoku-shell/modules/settings/NiriDisplayConfigurator.qml"
move_data_to_snapshot "ryoku-shell/scripts/niri-config.py"
move_data_to_snapshot "ryoku-shell/scripts/parse_niri_keybinds.py"
move_data_to_snapshot "ryoku-shell/sdata/migrations/018-modularize-niri-config.sh"
move_data_to_snapshot "ryoku-shell/services/NiriKeybinds.qml"
move_data_to_snapshot "ryoku-shell/services/NiriService.qml"
move_data_to_snapshot "ryoku-shell/assets/wallpapers/qs-niri.jpg"

rm -f "$systemd_user_dir/niri.service.wants/ryoku-shell.service"
rmdir "$systemd_user_dir/niri.service.wants" 2>/dev/null || true

if command_present systemctl; then
  systemctl --user daemon-reload >/dev/null 2>&1 || true
fi

if ((${#packages_to_remove[@]} > 0)) && { [[ $allow_auth_prompt == true ]] || can_install_without_prompt; }; then
  printf 'Removing packages: %s\n' "${packages_to_remove[*]}"
  if command_present ryoku-pkg-remove; then
    ryoku-pkg-remove "${packages_to_remove[@]}"
  else
    sudo pacman -Rns --noconfirm "${packages_to_remove[@]}"
  fi
elif ((${#packages_to_remove[@]} > 0)); then
  printf 'Skipped package removal, root authorization is not available: %s\n' "${packages_to_remove[*]}"
else
  printf 'No Niri packages found to remove.\n'
fi

printf 'Snapshot: %s\n' "$snapshot_dir"
printf 'Niri live purge completed.\n'
