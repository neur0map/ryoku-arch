#!/bin/bash

set -euo pipefail

confirm=false
allow_auth_prompt=false
force=false

packages=(
  niri
  xdg-desktop-portal-gnome
)

usage() {
  cat <<'EOF'
Usage: ryoku-rebirth-purge-niri-live --confirm-niri-free [--allow-auth-prompt] [--force]

Removes live Niri session wiring only after the rebirth Hyprland session is
active. It snapshots first and keeps user apps/tools intact.
EOF
}

while (($# > 0)); do
  case "$1" in
    --confirm-niri-free)
      confirm=true
      ;;
    --allow-auth-prompt)
      allow_auth_prompt=true
      ;;
    --force)
      force=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ryoku-rebirth-purge-niri-live: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

[[ $confirm == true ]] || {
  usage >&2
  exit 2
}

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
systemd_user_dir="$xdg_config_home/systemd/user"
rebirth_shell_dir="$xdg_config_home/quickshell/ryoku-rebirth-shell"

command_present() {
  command -v "$1" >/dev/null 2>&1
}

package_present() {
  local package="$1"

  if command_present ryoku-pkg-present; then
    ryoku-pkg-present "$package" >/dev/null 2>&1
    return
  fi

  pacman -Q "$package" >/dev/null 2>&1
}

can_install_without_prompt() {
  ((EUID == 0)) && return 0
  command_present sudo && sudo -n true >/dev/null 2>&1
}

hyprland_active() {
  [[ $force == true ]] && return 0
  [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] && return 0
  [[ ${XDG_CURRENT_DESKTOP:-} == *"Hyprland"* ]] && return 0
  command_present hyprctl && hyprctl monitors -j >/dev/null 2>&1
}

require_rebirth_runtime() {
  [[ -f $rebirth_shell_dir/shell.qml ]] || {
    echo "ryoku-rebirth-purge-niri-live: missing $rebirth_shell_dir/shell.qml" >&2
    exit 77
  }

  [[ -f $xdg_config_home/hypr/hyprland.conf ]] || {
    echo "ryoku-rebirth-purge-niri-live: missing $xdg_config_home/hypr/hyprland.conf" >&2
    exit 77
  }

  grep -q 'ryoku-rebirth-shell' "$xdg_config_home/hypr/hyprland.conf" || {
    echo "ryoku-rebirth-purge-niri-live: Hyprland config does not start ryoku-rebirth-shell" >&2
    exit 77
  }
}

packages_to_remove=()
for package in "${packages[@]}"; do
  if package_present "$package"; then
    packages_to_remove+=("$package")
  fi
done

if ! hyprland_active; then
  echo "ryoku-rebirth-purge-niri-live: refusing to purge outside an active Hyprland session" >&2
  exit 77
fi

require_rebirth_runtime

if ((${#packages_to_remove[@]} > 0)) && [[ $allow_auth_prompt == false ]] && ! can_install_without_prompt; then
  cat >&2 <<'EOF'
ryoku-rebirth-purge-niri-live: root authorization is required and no cached sudo session is available.
Re-run while present with:
  ryoku-rebirth-purge-niri-live --confirm-niri-free --allow-auth-prompt
EOF
  exit 77
fi

snapshot_output="$("$repo_root/bin/ryoku-rebirth-snapshot")"
snapshot_dir="$(sed -n 's/^Snapshot: //p' <<<"$snapshot_output" | tail -1)"
[[ -d $snapshot_dir ]] || {
  echo "ryoku-rebirth-purge-niri-live: snapshot failed" >&2
  exit 1
}

if [[ -e $xdg_config_home/niri || -L $xdg_config_home/niri ]]; then
  mkdir -p "$snapshot_dir/removed/config"
  mv "$xdg_config_home/niri" "$snapshot_dir/removed/config/niri"
  printf 'moved=config/niri -> %s/removed/config/niri\n' "$snapshot_dir" >> "$snapshot_dir/manifest.txt"
fi

rm -f "$systemd_user_dir/niri.service.wants/ryoku-shell.service"
rmdir "$systemd_user_dir/niri.service.wants" 2>/dev/null || true

if command_present systemctl; then
  systemctl --user daemon-reload >/dev/null 2>&1 || true
fi

if ((${#packages_to_remove[@]} > 0)); then
  printf 'Removing packages: %s\n' "${packages_to_remove[*]}"
  if command_present ryoku-pkg-remove; then
    ryoku-pkg-remove "${packages_to_remove[@]}"
  else
    sudo pacman -Rns --noconfirm "${packages_to_remove[@]}"
  fi
else
  printf 'No Niri packages found to remove.\n'
fi

printf 'Snapshot: %s\n' "$snapshot_dir"
printf 'Niri live purge completed.\n'
