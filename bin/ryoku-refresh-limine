#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Overwrite the user config for the Limine bootloader, rebuild the UKI, and
# regenerate the boot menu.

extract_current_cmdline() {
  if [[ -f /etc/default/limine ]]; then
    sed -n 's/^KERNEL_CMDLINE\[default\]+="\([^"]*\)".*/\1/p' /etc/default/limine \
      | grep -E '(^| )root=|(^| )cryptdevice=' \
      | head -n1 || true
    return 0
  fi

  if [[ -f /boot/limine.conf ]]; then
    grep "^[[:space:]]*cmdline:" /boot/limine.conf \
      | head -n1 \
      | sed 's/^[[:space:]]*cmdline:[[:space:]]*//' || true
  fi
}

ensure_limine_defaults() {
  local cmdline temp_file

  if [[ -f /etc/default/limine ]]; then
    sudo sed -i \
      -e 's/^TARGET_OS_NAME=.*/TARGET_OS_NAME="Ryoku"/' \
      -e 's/^CUSTOM_UKI_NAME=.*/CUSTOM_UKI_NAME="ryoku"/' \
      /etc/default/limine

    if ! grep -q '^TARGET_OS_NAME=' /etc/default/limine; then
      sudo sed -i '1iTARGET_OS_NAME="Ryoku"' /etc/default/limine
    fi

    if grep -q '^ENABLE_UKI=yes' /etc/default/limine \
      && ! grep -q '^CUSTOM_UKI_NAME=' /etc/default/limine; then
      sudo sed -i '/^ENABLE_UKI=yes/a CUSTOM_UKI_NAME="ryoku"' /etc/default/limine
    fi

    return 0
  fi

  cmdline="$(extract_current_cmdline || true)"
  temp_file="$(mktemp)"
  CMDLINE="$cmdline" perl -pe 's/\@\@CMDLINE\@\@/$ENV{CMDLINE}/g' \
    "$RYOKU_PATH/default/limine/default.conf" >"$temp_file"
  sudo install -m 0644 "$temp_file" /etc/default/limine
  rm -f "$temp_file"
}

rename_mkinitcpio_dropin() {
  local legacy="$1"
  local target="$2"

  if [[ -f $legacy && ! -f $target ]]; then
    sudo mv "$legacy" "$target"
  elif [[ -f $legacy && -f $target ]] && cmp -s "$legacy" "$target"; then
    sudo rm -f "$legacy"
  fi
}

rename_mkinitcpio_dropins() {
  rename_mkinitcpio_dropin \
    /etc/mkinitcpio.conf.d/omarchy_hooks.conf \
    /etc/mkinitcpio.conf.d/ryoku_hooks.conf
  rename_mkinitcpio_dropin \
    /etc/mkinitcpio.conf.d/omarchy_resume.conf \
    /etc/mkinitcpio.conf.d/ryoku_resume.conf
}

cleanup_legacy_ukis() {
  local machine_uki="/boot/EFI/Linux/$(cat /etc/machine-id)_linux.efi"

  if [[ -f /boot/EFI/Linux/ryoku_linux.efi && -f $machine_uki ]]; then
    echo "Cleanup extra UKI"
    sudo rm -f "$machine_uki"
  fi

  if [[ -f /boot/EFI/Linux/ryoku_linux.efi && -f /boot/EFI/Linux/omarchy_linux.efi ]]; then
    echo "Cleanup legacy Omarchy UKI"
    sudo rm -f /boot/EFI/Linux/omarchy_linux.efi
  fi
}

ensure_limine_defaults
rename_mkinitcpio_dropins

echo "Resetting limine config"

if [[ -f /boot/limine.conf ]]; then
  sudo cp -f /boot/limine.conf /boot/limine.conf.bak
fi

sudo cp -f "$RYOKU_PATH/default/limine/limine.conf" /boot/limine.conf

if grep -q '^ENABLE_UKI=yes' /etc/default/limine && command -v limine-mkinitcpio >/dev/null 2>&1; then
  sudo limine-mkinitcpio
elif command -v mkinitcpio >/dev/null 2>&1; then
  sudo mkinitcpio -P
fi

sudo limine-update

# Force-sync the NVRAM-targeted limine binary. limine-update (via
# limine-install) refuses to upgrade past limine 11 because the
# Arch limine-mkinitcpio-hook tool's limine-entry-tool only supports
# limine <= 11, while the limine package is now 12. Without this
# copy, /boot/EFI/limine/limine_x64.efi stays at the old version
# while the limine.conf gets written in 12-only syntax (notably
# the hex interface_branding_color), so UEFI boots a stale binary
# that cannot render the new branding.
if [[ -f /usr/share/limine/BOOTX64.EFI && -f /boot/EFI/limine/limine_x64.efi ]]; then
  sudo cp -f /usr/share/limine/BOOTX64.EFI /boot/EFI/limine/limine_x64.efi
fi

if grep -q '^ENABLE_UKI=yes' /etc/default/limine \
  && [[ ! -f /boot/EFI/Linux/ryoku_linux.efi ]]; then
  echo "Error: missing /boot/EFI/Linux/ryoku_linux.efi after Limine refresh" >&2
  exit 1
fi

grep -q '^/+Ryoku' /boot/limine.conf || {
  echo "Error: /boot/limine.conf is missing Ryoku branded entries" >&2
  exit 1
}

sudo limine-snapper-sync || true
cleanup_legacy_ukis
