#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Launch the TUI command passed in as an argument in the default terminal with an org.ryoku.COMMAND app id for styling.

exec setsid xdg-terminal-exec --app-id="org.ryoku.$(basename "$1")" -e "$1" "${@:2}"
