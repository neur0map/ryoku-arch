#!/bin/bash

set -euo pipefail

_RYOKU_SELF="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
source "$_RYOKU_SELF/lib/runtime-env.sh"
source "$_RYOKU_SELF/lib/wallpaper-backends.sh"

_settings_gui_settings="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/settings-gui/settings.json"

_settings_get() {
  local key="$1" default="$2"
  if [[ -f $_settings_gui_settings ]]; then
    local val
    val="$(jq -r --arg d "$default" "$key | if . == null then \$d else tostring end" "$_settings_gui_settings" 2>/dev/null)" || val="$default"
    printf '%s' "$val"
  else
    printf '%s' "$default"
  fi
}

pause_enabled="$(_settings_get '.wallpaper.pauseOnFullscreen' "true")"
[[ $pause_enabled == "true" ]] || exit 0

type_file="$(ryoku_wp_state_dir)/type.txt"
type="$(head -n1 "$type_file" 2>/dev/null || echo image)"

[[ $type == "image" ]] && exit 0

path_file="$(ryoku_wp_state_dir)/path.txt"
path="$(head -n1 "$path_file" 2>/dev/null || true)"
[[ -n $path ]] || exit 0

ryoku-wallpaper-apply --type "$type" "$path"
