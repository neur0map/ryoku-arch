#!/bin/bash

# Remove preinstalled Ryoku applications (web apps, TUIs, and selected packages).
# This removes all web apps, TUIs, plus specific desktop applications.

if gum confirm "Are you sure you want to remove all preinstalled web apps, TUI wrappers, and desktop applications?"; then
  echo -e "Removing preinstalled Ryoku applications...\n"

  ryoku-webapp-remove-all
  ryoku-tui-remove-all

  ryoku-pkg-drop \
    aether \
    typora \
    spotify \
    libreoffice-fresh \
    1password-beta \
    1password-cli \
    gradia \
    xournalpp \
    signal-desktop \
    pinta \
    obsidian \
    obs-studio \
    kdenlive \
    lazydocker
fi
