#!/bin/bash

webapps=(
  "HEY"
  "Basecamp"
  "WhatsApp"
  "Google Photos"
  "Google Contacts"
  "Google Messages"
  "Google Maps"
  "X"
  "Figma"
  "Zoom"
  "Fizzy"
)

tuis=(
  "Disk Usage"
)

packages=(
  aether
  typora
  spotify
  libreoffice-fresh
  1password-beta
  1password-cli
  xournalpp
  signal-desktop
  pinta
  kdenlive
  satty
  bluetui
  impala
  wiremix
  plocate
  swappy
  usage
  xmlstarlet
)

if gum confirm "Remove optional preinstalled apps and tools outside the compact keep set?"; then
  echo -e "Removing preinstalled Ryoku applications...\n"

  ryoku-webapp-remove "${webapps[@]}"
  ryoku-tui-remove "${tuis[@]}"

  ryoku-pkg-drop "${packages[@]}"
fi
