#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Open a small, centered, floating terminal that shows the Ryoku logo, runs the command
# passed in, then waits on a "done" screen. Used by GUI actions (Update, channel switch,
# MedEvac, voxtype model download) that hand off to a terminal.
#
# Launch a known terminal directly (RYOKU_TUI_TERMINAL, default kitty - a base package)
# rather than xdg-terminal-exec: the GUI runs this from quickshell's environment, where
# the indirection could silently fail to spawn (the Update action then looked broken
# while the same update worked from the TUI). The "ryoku-update" window class is
# floated/centered/sized by a windowrule in config/hypr/hyprland.conf.

cmd="$*"
inner="export PATH=\"$RYOKU_PATH/bin:\$PATH\"; ryoku-show-logo; $cmd; if (( \$? != 130 )); then ryoku-show-done; fi"

term="${RYOKU_TUI_TERMINAL:-kitty}"
if command -v "$term" >/dev/null 2>&1; then
  exec setsid "$term" --class ryoku-update -e bash -c "$inner"
fi

# Fallback to ryoku's own terminal picker (kitty/alacritty/ghostty). It maps --app-id to
# each terminal's class flag, so the windowrule still matches. ryoku-terminal-exec is
# unambiguous (no system binary by that name can shadow it).
exec setsid ryoku-terminal-exec --app-id=ryoku-update --title=Ryoku -e bash -c "$inner"
