#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

usage() {
  cat <<'EOF'
Usage:
  ryoku-ipc --help
  ryoku-ipc shell command wallpaper
  ryoku-ipc shell command launcher
  ryoku-ipc shell command toolbox
  ryoku-ipc shell command screenshot
  ryoku-ipc shell command screen-record
  ryoku-ipc shell command battery-warning
  ryoku-ipc shell preview battery-warning
  ryoku-ipc shell toolbox open
  ryoku-ipc shell toolbox previous
  ryoku-ipc shell toolbox next
  ryoku-ipc shell toolbox activate
  ryoku-ipc shell toolbox close
  ryoku-ipc shell command themes
  ryoku-ipc shell command fonts
  ryoku-ipc shell command cursors
  ryoku-ipc shell command dotfiles
  ryoku-ipc shell command system-menu
  ryoku-ipc shell command settings-menu
  ryoku-ipc shell command settings-menu-home
  ryoku-ipc shell command settings-menu-share
  ryoku-ipc shell command settings-menu-hardware
  ryoku-ipc shell toggle wallpaper
  ryoku-ipc shell toggle launcher
  ryoku-ipc shell toggle toolbox
  ryoku-ipc shell toggle screenshot
  ryoku-ipc shell toggle screen-record
  ryoku-ipc shell toggle themes
  ryoku-ipc shell toggle fonts
  ryoku-ipc shell toggle cursors
  ryoku-ipc shell toggle dotfiles
  ryoku-ipc shell toggle system-menu
  ryoku-ipc shell toggle settings-menu
  ryoku-ipc shell settings-menu home
  ryoku-ipc shell settings-menu share
  ryoku-ipc shell settings-menu hardware
  ryoku-ipc theme list --jsonl
  ryoku-ipc theme apply THEME
  ryoku-ipc font list --jsonl
  ryoku-ipc font apply FONT_FAMILY
  ryoku-ipc font install FONT_ID
  ryoku-ipc cursor list --jsonl
  ryoku-ipc cursor apply THEME [SIZE]
  ryoku-ipc cursor install THEME [SIZE]
  ryoku-ipc wallpaper settings get --json
  ryoku-ipc wallpaper list --jsonl
  ryoku-ipc wallpaper cache rebuild
  ryoku-ipc wallpaper apply --type image PATH
  ryoku-ipc wallpaper apply --type video PATH
  ryoku-ipc wallpaper wallhaven search --query QUERY --page PAGE --json
  ryoku-ipc wallpaper wallhaven download ID URL
EOF
}

shell_command() {
  local target="${1:-}"

  if (( $# != 1 )); then
    echo "ryoku-ipc: expected shell command wallpaper|launcher|toolbox|screenshot|screen-record|battery-warning|themes|fonts|cursors|dotfiles|system-menu|settings-menu|settings-menu-home|settings-menu-share|settings-menu-hardware" >&2
    return 2
  fi

  case "$target" in
    wallpaper)
      printf '%s\n' "qs -c ryoku ipc call popups toggleWallpaper"
      ;;
    launcher)
      printf '%s\n' "qs -c ryoku ipc call popups toggleLauncher"
      ;;
    toolbox)
      printf '%s\n' "ryoku-ipc shell toolbox open"
      ;;
    screenshot)
      printf '%s\n' "qs -c ryoku ipc call popups toggleScreenshot"
      ;;
    screen-record)
      printf '%s\n' "qs -c ryoku ipc call popups toggleScreenRecorder"
      ;;
    battery-warning)
      printf '%s\n' "qs -c ryoku ipc call popups previewBatteryWarning"
      ;;
    themes)
      printf '%s\n' "qs -c ryoku ipc call popups toggleThemes"
      ;;
    fonts)
      printf '%s\n' "qs -c ryoku ipc call popups toggleFonts"
      ;;
    cursors)
      printf '%s\n' "qs -c ryoku ipc call popups toggleCursors"
      ;;
    dotfiles)
      printf '%s\n' "qs -c ryoku ipc call popups toggleDotfiles"
      ;;
    system-menu)
      printf '%s\n' "qs -c ryoku ipc call popups toggleSystemMenu"
      ;;
    settings-menu)
      printf '%s\n' "qs -c ryoku ipc call popups toggleSettingsMenu"
      ;;
    settings-menu-home)
      printf '%s\n' "qs -c ryoku ipc call popups openSettingsMenuHome"
      ;;
    settings-menu-share)
      printf '%s\n' "qs -c ryoku ipc call popups openSettingsMenuShare"
      ;;
    settings-menu-hardware)
      printf '%s\n' "qs -c ryoku ipc call popups openSettingsMenuHardware"
      ;;
    *)
      echo "ryoku-ipc: unknown shell command target: $target" >&2
      return 2
      ;;
  esac
}

shell_toolbox() {
  local action="${1:-}"

  if (( $# != 1 )); then
    echo "ryoku-ipc: expected shell toolbox open|previous|next|activate|close" >&2
    return 2
  fi

  case "$action" in
    open)
      qs -c ryoku ipc call popups openToolbox
      hyprctl dispatch submap toolbox >/dev/null 2>&1 || true
      ;;
    previous)
      exec qs -c ryoku ipc call popups toolboxPrevious
      ;;
    next)
      exec qs -c ryoku ipc call popups toolboxNext
      ;;
    activate)
      qs -c ryoku ipc call popups toolboxActivate
      hyprctl dispatch submap reset >/dev/null 2>&1 || true
      ;;
    close)
      qs -c ryoku ipc call popups toolboxClose
      hyprctl dispatch submap reset >/dev/null 2>&1 || true
      ;;
    *)
      echo "ryoku-ipc: unknown shell toolbox action: $action" >&2
      return 2
      ;;
  esac
}

shell_preview() {
  local target="${1:-}"
  shift || true

  case "$target" in
    battery-warning)
      if (( $# != 0 )); then
        echo "ryoku-ipc: expected shell preview battery-warning" >&2
        return 2
      fi
      exec qs -c ryoku ipc call popups previewBatteryWarning
      ;;
    *)
      echo "ryoku-ipc: unknown shell preview target: $target" >&2
      return 2
      ;;
  esac
}

shell_toggle() {
  local target="${1:-}"

  if (( $# != 1 )); then
    echo "ryoku-ipc: expected shell toggle wallpaper|launcher|toolbox|screenshot|screen-record|themes|fonts|cursors|dotfiles|system-menu|settings-menu" >&2
    return 2
  fi

  case "$target" in
    wallpaper)
      exec qs -c ryoku ipc call popups toggleWallpaper
      ;;
    launcher)
      exec qs -c ryoku ipc call popups toggleLauncher
      ;;
    toolbox)
      exec qs -c ryoku ipc call popups toggleToolbox
      ;;
    screenshot)
      exec qs -c ryoku ipc call popups toggleScreenshot
      ;;
    screen-record)
      exec qs -c ryoku ipc call popups toggleScreenRecorder
      ;;
    themes)
      exec qs -c ryoku ipc call popups toggleThemes
      ;;
    fonts)
      exec qs -c ryoku ipc call popups toggleFonts
      ;;
    cursors)
      exec qs -c ryoku ipc call popups toggleCursors
      ;;
    dotfiles)
      exec qs -c ryoku ipc call popups toggleDotfiles
      ;;
    system-menu)
      exec qs -c ryoku ipc call popups toggleSystemMenu
      ;;
    settings-menu)
      exec qs -c ryoku ipc call popups toggleSettingsMenu
      ;;
    *)
      echo "ryoku-ipc: unknown shell toggle target: $target" >&2
      return 2
      ;;
  esac
}

shell_settings_menu() {
  local route="${1:-}"

  if (( $# != 1 )); then
    echo "ryoku-ipc: expected shell settings-menu home|share|hardware" >&2
    return 2
  fi

  case "$route" in
    home|quick|quick-controls)
      exec qs -c ryoku ipc call popups openSettingsMenuHome
      ;;
    share)
      exec qs -c ryoku ipc call popups openSettingsMenuShare
      ;;
    hardware)
      exec qs -c ryoku ipc call popups openSettingsMenuHardware
      ;;
    *)
      echo "ryoku-ipc: unknown settings-menu route: $route" >&2
      return 2
      ;;
  esac
}

wallpaper_settings_get() {
  local theme_file="$RYOKU_CONFIG_PATH/current/theme.name"
  local theme_name=""
  local user_dir="$RYOKU_WALLPAPER_DIR"
  local state_dir="$RYOKU_STATE_PATH/wallpaper"

  if [[ -f $theme_file ]]; then
    theme_name="$(<"$theme_file")"
  fi

  jq -n \
    --arg theme_name "$theme_name" \
    --arg user_dir "$user_dir" \
    --arg state_dir "$state_dir" \
    '{
      theme_name: $theme_name,
      wallpaper_dirs: [$user_dir],
      state_dir: $state_dir,
      wallhaven: {
        categories: "111",
        purity: "100",
        sorting: "date_added",
        order: "desc",
        api_key_env: "WALLHAVEN_API_KEY"
      },
      video: {
        backend: "mpvpaper",
        mute: true
      }
    }'
}

theme_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
    list)
      if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
        echo "ryoku-ipc: expected theme list --jsonl" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-theme-list" --jsonl
      ;;
    apply)
      if (( $# != 1 )); then
        echo "ryoku-ipc: expected theme apply THEME" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-theme-set" "$1"
      ;;
    *)
      echo "ryoku-ipc: unknown theme action: $action" >&2
      return 2
      ;;
  esac
}

font_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
    list)
      if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
        echo "ryoku-ipc: expected font list --jsonl" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-font-list" --jsonl
      ;;
    apply)
      if (( $# != 1 )); then
        echo "ryoku-ipc: expected font apply FONT_FAMILY" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-font-set" "$1"
      ;;
    install)
      if (( $# != 1 )); then
        echo "ryoku-ipc: expected font install FONT_ID" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-font-install" "$1"
      ;;
    *)
      echo "ryoku-ipc: unknown font action: $action" >&2
      return 2
      ;;
  esac
}

cursor_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
    list)
      if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
        echo "ryoku-ipc: expected cursor list --jsonl" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-cursor-list" --jsonl
      ;;
    apply)
      if (( $# < 1 || $# > 2 )); then
        echo "ryoku-ipc: expected cursor apply THEME [SIZE]" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-cursor-set" "$@"
      ;;
    install)
      if (( $# < 1 || $# > 2 )); then
        echo "ryoku-ipc: expected cursor install THEME [SIZE]" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-cursor-install" "$@"
      ;;
    *)
      echo "ryoku-ipc: unknown cursor action: $action" >&2
      return 2
      ;;
  esac
}

wallpaper_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
    settings)
      if (( $# != 2 )) || [[ ${1:-} != "get" || ${2:-} != "--json" ]]; then
        echo "ryoku-ipc: expected wallpaper settings get --json" >&2
        return 2
      fi
      wallpaper_settings_get
      ;;
    list)
      if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
        echo "ryoku-ipc: expected wallpaper list --jsonl" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-wallpaper-list" --jsonl
      ;;
    cache)
      if (( $# != 1 )) || [[ ${1:-} != "rebuild" ]]; then
        echo "ryoku-ipc: expected wallpaper cache rebuild" >&2
        return 2
      fi
      exec "$RYOKU_PATH/bin/ryoku-wallpaper-cache" rebuild
      ;;
    apply)
      exec "$RYOKU_PATH/bin/ryoku-wallpaper-apply" "$@"
      ;;
    wallhaven)
      exec "$RYOKU_PATH/bin/ryoku-wallhaven-search" "$@"
      ;;
    *)
      echo "ryoku-ipc: unknown wallpaper action: $action" >&2
      return 2
      ;;
  esac
}

main() {
  case "${1:-}" in
    --help|-h|"")
      usage
      ;;
    shell)
      shift
      case "${1:-}" in
        command)
          shift
          shell_command "$@"
          ;;
        toggle)
          shift
          shell_toggle "$@"
          ;;
        settings-menu)
          shift
          shell_settings_menu "$@"
          ;;
        toolbox)
          shift
          shell_toolbox "$@"
          ;;
        preview)
          shift
          shell_preview "$@"
          ;;
        *)
          echo "ryoku-ipc: unknown shell action: ${1:-}" >&2
          return 2
          ;;
      esac
      ;;
    wallpaper)
      shift
      wallpaper_dispatch "$@"
      ;;
    theme)
      shift
      theme_dispatch "$@"
      ;;
    font)
      shift
      font_dispatch "$@"
      ;;
    cursor)
      shift
      cursor_dispatch "$@"
      ;;
    *)
      echo "ryoku-ipc: unknown namespace: ${1:-}" >&2
      return 2
      ;;
  esac
}

main "$@"
