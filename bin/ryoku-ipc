#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

usage() {
  cat <<'EOF'
Usage:
  ryoku-ipc --help
  ryoku-ipc overview toggle
  ryoku-ipc clipboard toggle
  ryoku-ipc settings open
  ryoku-ipc settings toggle
  ryoku-ipc lock activate
  ryoku-ipc session toggle
  ryoku-ipc launcher toggle
  ryoku-ipc region screenshot
  ryoku-ipc region ocr
  ryoku-ipc region record
  ryoku-ipc region record-with-sound
  ryoku-ipc theme list --jsonl
  ryoku-ipc theme apply THEME
  ryoku-ipc font list --jsonl
  ryoku-ipc font apply FONT_FAMILY
  ryoku-ipc font install FONT_ID
  ryoku-ipc cursor list --jsonl
  ryoku-ipc cursor apply THEME [SIZE]
  ryoku-ipc cursor install THEME [SIZE]
  ryoku-ipc wallpaper settings get --json
  ryoku-ipc wallpaper list --jsonl
  ryoku-ipc wallpaper cache rebuild
  ryoku-ipc wallpaper apply --type image PATH
  ryoku-ipc wallpaper apply --type video PATH
  ryoku-ipc wallpaper wallhaven search --query QUERY --page PAGE --json
  ryoku-ipc wallpaper wallhaven download ID URL
EOF
}

exec_inir() {
  if ! ryoku-cmd-present inir; then
    echo "ryoku-ipc: inir is not installed or not on PATH" >&2
    return 127
  fi

  exec inir "$@"
}

expect_one() {
  local expected="$1"
  local actual="${2:-}"
  local usage_text="$3"

  if (( $# != 3 )) || [[ $actual != "$expected" ]]; then
    echo "ryoku-ipc: expected $usage_text" >&2
    return 2
  fi
}

overview_dispatch() {
  if (( $# != 1 )) || [[ ${1:-} != "toggle" ]]; then
    echo "ryoku-ipc: expected overview toggle" >&2
    return 2
  fi

  exec_inir overview toggle
}

clipboard_dispatch() {
  if (( $# != 1 )) || [[ ${1:-} != "toggle" ]]; then
    echo "ryoku-ipc: expected clipboard toggle" >&2
    return 2
  fi

  exec_inir clipboard toggle
}

settings_dispatch() {
  if (( $# != 1 )); then
    echo "ryoku-ipc: expected settings open|toggle" >&2
    return 2
  fi

  case "$1" in
  open)
    exec_inir settings
    ;;
  toggle)
    exec_inir settings toggle
    ;;
  *)
    echo "ryoku-ipc: unknown settings action: $1" >&2
    return 2
    ;;
  esac
}

lock_dispatch() {
  if (( $# != 1 )) || [[ ${1:-} != "activate" ]]; then
    echo "ryoku-ipc: expected lock activate" >&2
    return 2
  fi

  exec_inir lock activate
}

session_dispatch() {
  if (( $# != 1 )) || [[ ${1:-} != "toggle" ]]; then
    echo "ryoku-ipc: expected session toggle" >&2
    return 2
  fi

  exec_inir session toggle
}

launcher_dispatch() {
  if (( $# != 1 )) || [[ ${1:-} != "toggle" ]]; then
    echo "ryoku-ipc: expected launcher toggle" >&2
    return 2
  fi

  exec_inir overview toggle
}

region_dispatch() {
  if (( $# != 1 )); then
    echo "ryoku-ipc: expected region screenshot|ocr|record|record-with-sound" >&2
    return 2
  fi

  case "$1" in
  screenshot)
    exec_inir region screenshot
    ;;
  ocr)
    exec_inir region ocr
    ;;
  record)
    exec_inir region record
    ;;
  record-with-sound)
    exec_inir region recordWithSound
    ;;
  *)
    echo "ryoku-ipc: unknown region action: $1" >&2
    return 2
    ;;
  esac
}

wallpaper_settings_get() {
  local theme_file="$RYOKU_CONFIG_PATH/current/theme.name"
  local theme_name=""
  local user_dir="$RYOKU_WALLPAPER_DIR"
  local state_dir="$RYOKU_STATE_PATH/wallpaper"

  if [[ -f $theme_file ]]; then
    theme_name="$(<"$theme_file")"
  fi

  jq -n \
    --arg theme_name "$theme_name" \
    --arg user_dir "$user_dir" \
    --arg state_dir "$state_dir" \
    '{
      theme_name: $theme_name,
      wallpaper_dirs: [$user_dir],
      state_dir: $state_dir,
      wallhaven: {
        categories: "111",
        purity: "100",
        sorting: "date_added",
        order: "desc",
        api_key_env: "WALLHAVEN_API_KEY"
      },
      video: {
        backend: "mpvpaper",
        mute: true
      }
    }'
}

theme_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
  list)
    if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
      echo "ryoku-ipc: expected theme list --jsonl" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-theme-list" --jsonl
    ;;
  apply)
    if (( $# != 1 )); then
      echo "ryoku-ipc: expected theme apply THEME" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-theme-set" "$1"
    ;;
  *)
    echo "ryoku-ipc: unknown theme action: $action" >&2
    return 2
    ;;
  esac
}

font_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
  list)
    if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
      echo "ryoku-ipc: expected font list --jsonl" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-font-list" --jsonl
    ;;
  apply)
    if (( $# != 1 )); then
      echo "ryoku-ipc: expected font apply FONT_FAMILY" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-font-set" "$1"
    ;;
  install)
    if (( $# != 1 )); then
      echo "ryoku-ipc: expected font install FONT_ID" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-font-install" "$1"
    ;;
  *)
    echo "ryoku-ipc: unknown font action: $action" >&2
    return 2
    ;;
  esac
}

cursor_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
  list)
    if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
      echo "ryoku-ipc: expected cursor list --jsonl" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-cursor-list" --jsonl
    ;;
  apply)
    if (( $# < 1 || $# > 2 )); then
      echo "ryoku-ipc: expected cursor apply THEME [SIZE]" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-cursor-set" "$@"
    ;;
  install)
    if (( $# < 1 || $# > 2 )); then
      echo "ryoku-ipc: expected cursor install THEME [SIZE]" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-cursor-install" "$@"
    ;;
  *)
    echo "ryoku-ipc: unknown cursor action: $action" >&2
    return 2
    ;;
  esac
}

wallpaper_dispatch() {
  local action="${1:-}"
  shift || true

  case "$action" in
  settings)
    if (( $# != 2 )) || [[ ${1:-} != "get" || ${2:-} != "--json" ]]; then
      echo "ryoku-ipc: expected wallpaper settings get --json" >&2
      return 2
    fi
    wallpaper_settings_get
    ;;
  list)
    if (( $# != 1 )) || [[ ${1:-} != "--jsonl" ]]; then
      echo "ryoku-ipc: expected wallpaper list --jsonl" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-wallpaper-list" --jsonl
    ;;
  cache)
    if (( $# != 1 )) || [[ ${1:-} != "rebuild" ]]; then
      echo "ryoku-ipc: expected wallpaper cache rebuild" >&2
      return 2
    fi
    exec "$RYOKU_PATH/bin/ryoku-wallpaper-cache" rebuild
    ;;
  apply)
    exec "$RYOKU_PATH/bin/ryoku-wallpaper-apply" "$@"
    ;;
  wallhaven)
    exec "$RYOKU_PATH/bin/ryoku-wallhaven-search" "$@"
    ;;
  *)
    echo "ryoku-ipc: unknown wallpaper action: $action" >&2
    return 2
    ;;
  esac
}

main() {
  case "${1:-}" in
  --help|-h|"")
    usage
    ;;
  overview)
    shift
    overview_dispatch "$@"
    ;;
  clipboard)
    shift
    clipboard_dispatch "$@"
    ;;
  settings)
    shift
    settings_dispatch "$@"
    ;;
  lock)
    shift
    lock_dispatch "$@"
    ;;
  session)
    shift
    session_dispatch "$@"
    ;;
  launcher)
    shift
    launcher_dispatch "$@"
    ;;
  region)
    shift
    region_dispatch "$@"
    ;;
  wallpaper)
    shift
    wallpaper_dispatch "$@"
    ;;
  theme)
    shift
    theme_dispatch "$@"
    ;;
  font)
    shift
    font_dispatch "$@"
    ;;
  cursor)
    shift
    cursor_dispatch "$@"
    ;;
  *)
    echo "ryoku-ipc: unknown namespace: ${1:-}" >&2
    return 2
    ;;
  esac
}

main "$@"
