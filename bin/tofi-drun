#!/bin/bash

set -euo pipefail

args=(--namespace=tofi)

while (($# > 0)); do
  case $1 in
    --config)
      shift 2
      ;;
    --config=*)
      shift
      ;;
    --drun-launch|--drun-launch=*)
      shift
      ;;
    --prompt-text)
      args+=("--prompt=${2:-}")
      shift 2
      ;;
    --prompt-text=*)
      args+=("--prompt=${1#*=}")
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

exec fuzzel "${args[@]}"
