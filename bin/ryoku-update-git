#!/bin/bash

set -e
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

echo -e "\e[32mUpdate Ryoku\e[0m"

ryoku-update-time

update_remote="${RYOKU_UPDATE_REMOTE_URL:-https://github.com/neur0map/ryoku-arch.git}"
release_branch="${RYOKU_UPDATE_BRANCH:-main}"

ryoku_git() {
  GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" "$@"
}

backup_untracked_update_conflicts() {
  local remote_ref="$1"
  local backup_dir="$RYOKU_STATE_PATH/update-backups/$(date +%Y%m%d-%H%M%S)"
  local backup_count=0
  local path full_path backup_path

  while IFS= read -r -d '' path; do
    [[ -n $path ]] || continue
    full_path="$RYOKU_PATH/$path"
    [[ -e $full_path || -L $full_path ]] || continue

    if ryoku_git ls-files --error-unmatch -- "$path" >/dev/null 2>&1; then
      continue
    fi

    backup_path="$backup_dir/$path"
    mkdir -p "$(dirname "$backup_path")"
    mv -- "$full_path" "$backup_path"
    ((backup_count += 1))
  done < <(ryoku_git diff --name-only -z --diff-filter=ACMRT "HEAD..$remote_ref")

  if (( backup_count > 0 )); then
    echo -e "\e[33mMoved $backup_count local file(s) that would block the update to:\e[0m"
    echo "$backup_dir"
  fi
}

stash_ref=""
if [[ -n $(ryoku_git status --porcelain --untracked-files=normal) ]]; then
  ryoku_git stash push --include-untracked -m "ryoku-update autostash $(date -Iseconds)"
  stash_ref="stash@{0}"
fi

if ryoku_git remote get-url origin >/dev/null 2>&1; then
  ryoku_git remote set-url origin "$update_remote"
else
  ryoku_git remote add origin "$update_remote"
fi

ryoku_git fetch --prune origin "+refs/heads/${release_branch}:refs/remotes/origin/${release_branch}"

remote_ref="origin/$release_branch"

backup_untracked_update_conflicts "$remote_ref"

if ! ryoku_git merge --ff-only "$remote_ref"; then
  echo
  echo -e "\e[31mRyoku update could not fast-forward to $remote_ref.\e[0m"
  echo "This usually means the installed Ryoku checkout has local commits."
  if [[ -n $stash_ref ]]; then
    echo "Local file changes were saved in: $stash_ref"
  fi
  exit 1
fi

if [[ -n $stash_ref ]]; then
  if ryoku_git stash apply --index "$stash_ref"; then
    ryoku_git stash drop "$stash_ref" >/dev/null
  else
    echo
    echo -e "\e[33mLocal changes were preserved in git stash because they conflict with the update.\e[0m"
    echo "Review them with: git -C \"$RYOKU_PATH\" stash show -p $stash_ref"
    ryoku_git reset --merge || true
  fi
fi

ryoku_git --no-pager diff --check || ryoku_git reset --merge
niri msg action load-config-file >/dev/null 2>&1 || true
