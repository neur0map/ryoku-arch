#!/bin/bash

set -e
# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/ryoku-update-core.sh"

echo -e "\e[32mUpdate Ryoku\e[0m"

# Self-heal common breakage before any git work: trust the repo dir even if a
# prior sudo run left dubious ownership, and hand root-owned files back.
ryoku_git_mark_safe_directory
ryoku_repo_fix_ownership

ryoku-update-time

update_remote="${RYOKU_UPDATE_REMOTE_URL:-https://github.com/neur0map/ryoku-arch.git}"

release_branch="$(ryoku_resolve_channel)"
ryoku_persist_channel "$release_branch"

echo "Update channel: $release_branch"

command_realpath() {
  local command_name="$1"
  local command_path=""

  command_path="$(command -v "$command_name" 2>/dev/null || true)"
  [[ -n $command_path ]] || return 1
  readlink -f "$command_path" 2>/dev/null || printf '%s\n' "$command_path"
}

update_runtime_bridge_summary() {
  local bridge="$HOME/.local/lib/runtime-env.sh"
  local target=""

  if [[ -L $bridge ]]; then
    target="$(readlink "$bridge" 2>/dev/null || true)"
    printf '%s -> %s\n' "$bridge" "${target:-unknown}"
  elif [[ -e $bridge ]]; then
    printf '%s (present, not symlink)\n' "$bridge"
  else
    printf '%s (missing)\n' "$bridge"
  fi
}

write_update_result_state() {
  local checkout_branch="$1"
  local checkout_commit="$2"
  local remote_tip="$3"
  local active_doctor="$4"
  local tui_path="$5"
  local runtime_bridge="$6"

  mkdir -p "$RYOKU_STATE_PATH" 2>/dev/null || return 0
  {
    printf 'updated_at=%s\n' "$(date -Iseconds 2>/dev/null || date)"
    printf 'path=%s\n' "$RYOKU_PATH"
    printf 'channel=%s\n' "$release_branch"
    printf 'checkout=%s@%s\n' "$checkout_branch" "$checkout_commit"
    printf 'remote_tip=%s\n' "$remote_tip"
    printf 'expected_doctor=%s\n' "$RYOKU_PATH/bin/ryoku-doctor"
    printf 'active_doctor=%s\n' "$active_doctor"
    printf 'tui=%s\n' "$tui_path"
    printf 'runtime_bridge=%s\n' "$runtime_bridge"
  } > "$RYOKU_STATE_PATH/last-update" || true
}

update_remote_tip_summary() {
  local remote_ref="origin/$release_branch"
  local remote_commit="unknown"

  if ryoku_git rev-parse --verify --quiet "$remote_ref" >/dev/null; then
    remote_commit="$(ryoku_git rev-parse --short "$remote_ref" 2>/dev/null || printf '%s\n' "unknown")"
  fi

  printf '%s@%s\n' "$remote_ref" "$remote_commit"
}

print_update_result() {
  local checkout_branch="unknown"
  local checkout_commit="unknown"
  local remote_tip=""
  local expected_doctor="$RYOKU_PATH/bin/ryoku-doctor"
  local active_doctor=""
  local tui_path=""
  local runtime_bridge=""

  checkout_branch="$(ryoku_git rev-parse --abbrev-ref HEAD 2>/dev/null || printf '%s\n' "unknown")"
  checkout_commit="$(ryoku_git rev-parse --short HEAD 2>/dev/null || printf '%s\n' "unknown")"
  remote_tip="$(update_remote_tip_summary)"
  active_doctor="$(command_realpath ryoku-doctor || true)"
  tui_path="$(command_realpath ryoku-tui || true)"
  runtime_bridge="$(update_runtime_bridge_summary)"

  [[ -n $active_doctor ]] || active_doctor="missing"
  [[ -n $tui_path ]] || tui_path="missing"

  write_update_result_state "$checkout_branch" "$checkout_commit" "$remote_tip" "$active_doctor" "$tui_path" "$runtime_bridge"

  echo
  echo "Ryoku update result:"
  echo "  Path: $RYOKU_PATH"
  echo "  Channel: $release_branch"
  echo "  Checkout: ${checkout_branch}@${checkout_commit}"
  echo "  Remote tip: $remote_tip"
  echo "  Expected doctor: $expected_doctor"
  echo "  Active doctor: $active_doctor"
  echo "  TUI: $tui_path"
  echo "  Runtime bridge: $runtime_bridge"

  if [[ -x $expected_doctor && $active_doctor != "$expected_doctor" ]]; then
    echo -e "\e[33mWarning: ryoku-doctor resolves outside the installed checkout; PATH or legacy wrappers may be stale.\e[0m"
  fi

  if [[ $tui_path == "missing" ]]; then
    echo -e "\e[33mWarning: ryoku-tui is missing, so ryoku-doctor will use fallback UI until packages finish installing.\e[0m"
  fi
}

clear_stale_auth_headers() {
  local key

  while IFS= read -r key; do
    [[ -n $key ]] || continue
    ryoku_git config --unset-all "$key" || true
  done < <(ryoku_git config --name-only --get-regexp 'extraheader' 2>/dev/null || true)
}

backup_untracked_update_conflicts() {
  local remote_ref="$1"
  local backup_dir=""
  local backup_count=0
  local path full_path backup_path

  backup_dir="$RYOKU_STATE_PATH/update-backups/$(date +%Y%m%d-%H%M%S)"

  while IFS= read -r -d '' path; do
    [[ -n $path ]] || continue
    full_path="$RYOKU_PATH/$path"
    [[ -e $full_path || -L $full_path ]] || continue

    if ryoku_git ls-files --error-unmatch -- "$path" >/dev/null 2>&1; then
      continue
    fi

    backup_path="$backup_dir/$path"
    mkdir -p "$(dirname "$backup_path")"
    mv -- "$full_path" "$backup_path"
    ((backup_count += 1))
  done < <(ryoku_git diff --name-only -z --diff-filter=ACMRT "HEAD..$remote_ref")

  if (( backup_count > 0 )); then
    echo -e "\e[33mMoved $backup_count local file(s) that would block the update to:\e[0m"
    echo "$backup_dir"
  fi
}

fetch_release_ref() {
  local branch="$1"

  ryoku_git fetch --prune origin "+refs/heads/${branch}:refs/remotes/origin/${branch}"
}

fetch_optional_official_refs() {
  local branch

  for branch in main unstable-dev; do
    [[ $branch == "$release_branch" ]] && continue
    fetch_release_ref "$branch" >/dev/null 2>&1 || true
  done
}

official_remote_contains_head() {
  local head ref reflog_head

  head="$(ryoku_git rev-parse HEAD 2>/dev/null || true)"
  [[ -n $head ]] || return 1

  for ref in origin/main origin/unstable-dev; do
    ryoku_git rev-parse --verify --quiet "$ref" >/dev/null || continue
    if ryoku_git merge-base --is-ancestor HEAD "$ref"; then
      return 0
    fi

    while IFS= read -r reflog_head; do
      [[ $reflog_head == "$head" ]] && return 0
    done < <(ryoku_git reflog show --format=%H "$ref" 2>/dev/null || true)
  done

  return 1
}

ensure_release_branch_checked_out() {
  local remote_ref="$1"
  local current_branch=""
  local local_branch_ref="refs/heads/$release_branch"

  current_branch="$(ryoku_git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")"
  case "$current_branch" in
    "$release_branch") return 0 ;;
  esac

  if [[ $current_branch == "HEAD" ]]; then
    echo -e "\e[33mDetached Ryoku checkout; switching to $release_branch for release update.\e[0m"
  else
    echo -e "\e[33mSwitching Ryoku checkout from $current_branch to $release_branch for release update.\e[0m"
  fi

  if ryoku_git show-ref --verify --quiet "$local_branch_ref"; then
    ryoku_git switch "$release_branch"
  else
    ryoku_git switch --track -c "$release_branch" "$remote_ref"
  fi
}

realign_release_branch_if_safe() {
  local remote_ref="$1"

  if ryoku_git merge-base --is-ancestor HEAD "$remote_ref"; then
    return 0
  fi

  if official_remote_contains_head; then
    echo -e "\e[33mRealigning stale Ryoku $release_branch branch to $remote_ref.\e[0m"
    ryoku_git switch -C "$release_branch" "$remote_ref"
  fi
}

stash_ref=""
if [[ -n $(ryoku_git status --porcelain --untracked-files=normal) ]]; then
  ryoku_git stash push --include-untracked -m "ryoku-update autostash $(date -Iseconds)"
  stash_ref="stash@{0}"
fi

if ryoku_git remote get-url origin >/dev/null 2>&1; then
  ryoku_git remote set-url origin "$update_remote"
else
  ryoku_git remote add origin "$update_remote"
fi
clear_stale_auth_headers

fetch_release_ref "$release_branch"
fetch_optional_official_refs

remote_ref="origin/$release_branch"

ensure_release_branch_checked_out "$remote_ref"
realign_release_branch_if_safe "$remote_ref"
backup_untracked_update_conflicts "$remote_ref"

if ! ryoku_git merge --ff-only "$remote_ref"; then
  echo
  echo -e "\e[31mRyoku update could not fast-forward to $remote_ref.\e[0m"
  echo "This usually means the installed Ryoku checkout has local commits."
  if [[ -n $stash_ref ]]; then
    echo "Local file changes were saved in: $stash_ref"
  fi
  exit 1
fi

if [[ -n $stash_ref ]]; then
  if ryoku_git stash apply --index "$stash_ref"; then
    ryoku_git stash drop "$stash_ref" >/dev/null
  else
    echo
    echo -e "\e[33mLocal changes were preserved in git stash because they conflict with the update.\e[0m"
    echo "Review them with: git -C \"$RYOKU_PATH\" stash show -p $stash_ref"
    ryoku_git reset --merge || true
  fi
fi

ryoku_git --no-pager diff --check || ryoku_git reset --merge
print_update_result

if command -v hyprctl >/dev/null 2>&1 \
  && { [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] || hyprctl version >/dev/null 2>&1; }; then
  hyprctl reload >/dev/null 2>&1 || true
fi
