#!/bin/bash

set -euo pipefail

info() {
  printf '\033[1;36m%s\033[0m\n' "$*"
}

fail() {
  printf '\033[1;31m%s\033[0m\n' "$*" >&2
  exit 1
}

ryoku_path="${RYOKU_PATH:-$HOME/.local/share/ryoku}"
state_path="${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}"
channel_file="$state_path/channel"

[[ -d $ryoku_path/.git ]] \
  || fail "Ryoku checkout not found at $ryoku_path"

channel=""
if [[ -r $channel_file ]]; then
  channel="$(<"$channel_file")"
fi
if [[ -z $channel ]]; then
  channel="$(git -C "$ryoku_path" branch --show-current 2>/dev/null || true)"
fi

case "$channel" in
  main|unstable-dev)
    ;;
  *)
    channel="main"
    ;;
esac

info "Repairing Ryoku update migrations on $channel"
info "Updating installed checkout"
git -C "$ryoku_path" fetch origin
git -C "$ryoku_path" checkout "$channel"
git -C "$ryoku_path" pull --ff-only origin "$channel"

info "Repairing migration baseline"
RYOKU_PATH="$ryoku_path" \
RYOKU_STATE_PATH="$state_path" \
  bash "$ryoku_path/install/preflight/migrations.sh"

rm -f "$state_path/independence-cutover.started"

if [[ -x $ryoku_path/bin/ryoku-migrate ]]; then
  RYOKU_PATH="$ryoku_path" \
  RYOKU_STATE_PATH="$state_path" \
    "$ryoku_path/bin/ryoku-migrate" --repair-baseline
fi

info "Refreshing shell runtime"
bash "$ryoku_path/install/config/shell.sh"

info "Restarting shell"
systemctl --user restart ryoku-shell.service 2>/dev/null \
  || systemctl --user start ryoku-shell.service

info "Repair complete. Run ryoku-doctor if anything still looks wrong."
