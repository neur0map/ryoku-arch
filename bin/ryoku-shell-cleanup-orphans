#!/bin/bash

# Clean stale Ryoku shell helpers that can survive Quickshell restarts.

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

QUIET=false

usage() {
  cat <<'USAGE'
Usage:
  ryoku-shell-cleanup-orphans [--quiet]

Cleans Ryoku shell-owned helper processes that can be left behind after
Quickshell crashes, restarts, or suspend/resume recovery.
USAGE
}

for arg in "$@"; do
  case "$arg" in
  --quiet)
    QUIET=true
    ;;
  --help)
    usage
    exit 0
    ;;
  *)
    echo "ryoku-shell-cleanup-orphans: unknown option: $arg" >&2
    usage >&2
    exit 2
    ;;
  esac
done

log() {
  if [[ $QUIET == "false" ]]; then
    printf '%s\n' "$1"
  fi
}

command_present() {
  ryoku-cmd-present "$1"
}

terminate_exact() {
  local process="$1"
  local label="$2"

  if ! pgrep -x "$process" >/dev/null 2>&1; then
    return 0
  fi

  log "cleanup $label"
  pkill -TERM -x "$process" >/dev/null 2>&1 || true
}

terminate_pattern() {
  local pattern="$1"
  local label="$2"

  if ! pgrep -f "$pattern" >/dev/null 2>&1; then
    return 0
  fi

  log "cleanup $label"
  pkill -TERM -f "$pattern" >/dev/null 2>&1 || true
}

if command_present ryoku-shell; then
  ryoku-shell cleanup-orphans >/dev/null 2>&1 || true
fi

terminate_exact swayidle "idle daemon"
terminate_exact awww-daemon "wallpaper daemon"
terminate_pattern '/quickshell/ryoku-shell/scripts/daemon/keyboard_lock_state_daemon\.py' "keyboard indicator daemon"
terminate_pattern '(^|/)nmcli monitor$' "network monitor"
terminate_pattern '/quickshell/ryoku-shell/scripts/colors/switchwall\.sh' "wallpaper color worker"
terminate_pattern '/\.local/state/quickshell/\.venv/bin/kde-material-you-colors( |$)' "KDE color worker"
terminate_pattern '(^|/)notify-send .* -a Wallpaper switcher' "wallpaper notification action"
