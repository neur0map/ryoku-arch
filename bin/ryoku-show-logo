#!/bin/bash

# Display the Ryoku logo in the terminal using Japanese old red (#8F1D21).
# Used by various presentation scripts to show branding.

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

clear
echo -e "\033[38;2;143;29;33m"
cat "$RYOKU_PATH/assets/brand/logo.txt"
echo -e "\033[0m"
echo
