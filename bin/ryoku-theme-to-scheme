#!/usr/bin/env python3
"""Convert a ryoku theme colors.toml into a full Material-3 scheme.json payload.

The live shell (Colours.qml) reads ~/.local/state/ryoku-shell/scheme.json and maps
each `colours.<role>` to `m3<role>`. This converter maps a flat ryoku theme palette
(background/foreground/accent/color0-15) onto the full M3 role set, deriving the
tonal surface-container steps from the theme's own background so the theme keeps its
identity (e.g. Tokyo Night's blue-black surfaces) instead of the shell's neutral grays.

Usage: ryoku-theme-to-scheme <colors.toml> [--name NAME] [--mode dark|light]
Prints the scheme.json object to stdout.
"""
import argparse
import json
import re
import sys


def parse_toml(path):
    colors = {}
    with open(path, encoding="utf-8") as fh:
        for line in fh:
            m = re.match(r'\s*([A-Za-z0-9_]+)\s*=\s*["\']?#?([0-9A-Fa-f]{6})\b', line)
            if m:
                colors[m.group(1).lower()] = m.group(2).upper()
    return colors


def rgb(h):
    h = h.lstrip("#")
    return [int(h[i:i + 2], 16) for i in (0, 2, 4)]


def hx(r, g, b):
    return "".join(f"{max(0, min(255, round(v))):02X}" for v in (r, g, b))


def lum(h):
    r, g, b = rgb(h)
    return (0.2126 * r + 0.7152 * g + 0.0722 * b) / 255


def mix(a, b, t):
    A, B = rgb(a), rgb(b)
    return hx(*[A[i] + (B[i] - A[i]) * t for i in range(3)])


def lighten(h, t):
    return mix(h, "FFFFFF", t)


def darken(h, t):
    return mix(h, "000000", t)


def on(h):
    # Readable foreground over a given color.
    return "0B0B0B" if lum(h) > 0.5 else "F4F4F4"


def build(colors, name, mode=None, flavour="custom"):
    def c(key, fallback):
        return colors.get(key, fallback)

    bg = c("background", "171717")
    fg = c("foreground", "CCD0CF")
    accent = c("accent", c("color4", "F25623"))
    light = (lum(bg) > 0.5) if mode is None else (mode == "light")
    mode = "light" if light else "dark"

    # Surface elevation: dark themes get lighter containers, light themes darker.
    def tone(t):
        return darken(bg, t * 0.55) if light else lighten(bg, t)

    def container(base):
        return lighten(base, 0.35) if light else darken(base, 0.42)

    def on_container(base):
        return darken(base, 0.55) if light else lighten(base, 0.45)

    primary = accent
    secondary = c("color6", c("color4", accent))   # cyan-ish second accent
    tertiary = c("color5", c("color3", accent))    # magenta/violet third accent
    error = c("color1", "BA1A1A")
    success = c("color2", "3F6B49")
    outline_c = c("color8", mix(fg, bg, 0.55))
    neutral_key = mix(fg, bg, 0.5)

    colours = {
        "primary_paletteKeyColor": primary,
        "secondary_paletteKeyColor": secondary,
        "tertiary_paletteKeyColor": tertiary,
        "neutral_paletteKeyColor": neutral_key,
        "neutral_variant_paletteKeyColor": neutral_key,
        "background": bg,
        "onBackground": fg,
        "surface": bg,
        "surfaceDim": darken(bg, 0.06) if light else darken(bg, 0.03),
        "surfaceBright": tone(0.14),
        "surfaceContainerLowest": lighten(bg, 0.02) if light else darken(bg, 0.04),
        "surfaceContainerLow": tone(0.03),
        "surfaceContainer": tone(0.06),
        "surfaceContainerHigh": tone(0.09),
        "surfaceContainerHighest": tone(0.12),
        "onSurface": fg,
        "surfaceVariant": tone(0.10),
        "onSurfaceVariant": mix(fg, bg, 0.30),
        "inverseSurface": fg,
        "inverseOnSurface": bg,
        "outline": outline_c,
        "outlineVariant": mix(outline_c, bg, 0.5),
        "shadow": "000000",
        "scrim": "000000",
        "surfaceTint": primary,
        "primary": primary,
        "onPrimary": on(primary),
        "primaryContainer": container(primary),
        "onPrimaryContainer": on_container(primary),
        "inversePrimary": darken(primary, 0.25) if not light else lighten(primary, 0.25),
        "secondary": secondary,
        "onSecondary": on(secondary),
        "secondaryContainer": container(secondary),
        "onSecondaryContainer": on_container(secondary),
        "tertiary": tertiary,
        "onTertiary": on(tertiary),
        "tertiaryContainer": container(tertiary),
        "onTertiaryContainer": on_container(tertiary),
        "error": error,
        "onError": on(error),
        "errorContainer": container(error),
        "onErrorContainer": on_container(error),
        "success": success,
        "onSuccess": on(success),
        "successContainer": container(success),
        "onSuccessContainer": on_container(success),
        "primaryFixed": lighten(primary, 0.4),
        "primaryFixedDim": primary,
        "onPrimaryFixed": darken(primary, 0.6),
        "onPrimaryFixedVariant": darken(primary, 0.3),
        "secondaryFixed": lighten(secondary, 0.4),
        "secondaryFixedDim": secondary,
        "onSecondaryFixed": darken(secondary, 0.6),
        "onSecondaryFixedVariant": darken(secondary, 0.3),
        "tertiaryFixed": lighten(tertiary, 0.4),
        "tertiaryFixedDim": tertiary,
        "onTertiaryFixed": darken(tertiary, 0.6),
        "onTertiaryFixedVariant": darken(tertiary, 0.3),
    }
    return {"name": name, "flavour": flavour, "mode": mode, "variant": "tonalspot", "colours": colours}


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("toml")
    ap.add_argument("--name", default="custom")
    ap.add_argument("--mode", choices=["dark", "light"], default=None)
    ap.add_argument("--flavour", default="custom")
    args = ap.parse_args()
    try:
        colors = parse_toml(args.toml)
    except OSError as exc:
        print(f"ryoku-theme-to-scheme: cannot read {args.toml}: {exc}", file=sys.stderr)
        return 1
    if "background" not in colors and "color0" not in colors:
        print(f"ryoku-theme-to-scheme: no usable colors in {args.toml}", file=sys.stderr)
        return 1
    print(json.dumps(build(colors, args.name, args.mode, args.flavour)))
    return 0


if __name__ == "__main__":
    sys.exit(main())
