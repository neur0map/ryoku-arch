#!/bin/bash

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

config_path_helper="$RYOKU_PATH/shell/scripts/lib/config-path.sh"
if [[ -f $config_path_helper ]]; then
  # shellcheck disable=SC1090
  source "$config_path_helper"
fi

# Launch the Ryoku screensaver in the default terminal on the system with the correct font configuration.

# Exit early if we don't have the tte show
if ! command -v tte &>/dev/null; then
  exit 1
fi

# Exit early if screensave is already running
pgrep -f org.ryoku.screensaver && exit 0

# Never run the screensaver over the lockscreen. qylock owns the screen when the
# session is locked; a screensaver behind it just burns CPU (tte at 120fps) and
# can starve and crash the ext-session lock client.
if pgrep -f 'lock_shell\.qml' >/dev/null 2>&1; then
  exit 0
fi

# Allow screensaver to be turned off but also force started
if ryoku-toggle-enabled screensaver-off && [[ ${1:-} != "force" ]]; then
  exit 1
fi

screensaver_command="$RYOKU_PATH/bin/ryoku-cmd-screensaver"

# The screensaver terminal is GlobalConfig.general.idle.screensaverTerminal, editable in
# the Idle settings tab. GlobalConfig only writes non-default keys, so an absent value
# means the default: kitty (ryoku's default terminal). Falls back to kitty for anything
# we don't have a screensaver profile for.
configured_screensaver_terminal() {
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/shell.json"
  [[ -f $config_file ]] || return 0
  ryoku-cmd-present jq || return 0
  jq -r '.general.idle.screensaverTerminal // empty' "$config_file" 2>/dev/null
}

terminal="$(configured_screensaver_terminal)"
case "${terminal:-kitty}" in
alacritty) terminal="Alacritty.desktop" ;;
ghostty) terminal="com.mitchellh.ghostty.desktop" ;;
*) terminal="kitty.desktop" ;;
esac

build_command() {
  case $terminal in
  *Alacritty*)
    command=(
      alacritty
      --class=org.ryoku.screensaver
      --config-file "$RYOKU_PATH/default/alacritty/screensaver.toml"
      -e "$screensaver_command"
    )
  ;;
  *ghostty*)
    command=(
      ghostty
      --class=org.ryoku.screensaver
      --config-file="$RYOKU_PATH/default/ghostty/screensaver"
      --font-size=18
      -e "$screensaver_command"
    )
  ;;
  *kitty*)
    command=(
      kitty
      --class=org.ryoku.screensaver
      --override font_size=18
      --override window_padding_width=0
      --override background=#000000
      --override cursor=#000000
      --override cursor_text_color=#000000
      -e "$screensaver_command"
    )
  ;;
  *)
    notify-send -u low "Screensaver only runs in Alacritty, Ghostty, or Kitty"
    exit 1
  ;;
  esac
}

spawn_screensaver() {
  setsid "${command[@]}" >/dev/null 2>&1 &
}

build_command
spawn_screensaver
