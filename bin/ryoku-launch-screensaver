#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

config_path_helper="$RYOKU_PATH/shell/scripts/lib/config-path.sh"
if [[ -f $config_path_helper ]]; then
  source "$config_path_helper"
fi

# Launch the Ryoku screensaver in the default terminal on the system with the correct font configuration.

# Exit early if we don't have the tte show
if ! command -v tte &>/dev/null; then
  exit 1
fi

# Exit early if screensave is already running
pgrep -f org.ryoku.screensaver && exit 0

# Allow screensaver to be turned off but also force started
if ryoku-toggle-enabled screensaver-off && [[ ${1:-} != "force" ]]; then
  exit 1
fi

screensaver_command="$RYOKU_PATH/bin/ryoku-cmd-screensaver"

configured_terminal_command() {
  local config_file

  if declare -F ryoku_shell_config_file >/dev/null; then
    config_file="$(ryoku_shell_config_file)"
  else
    config_file="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku-shell/config.json"
  fi

  [[ -f $config_file ]] || return 1
  ryoku-cmd-present jq || return 1

  jq -r '.apps.terminal // empty' "$config_file" 2>/dev/null
}

terminal_id_from_command() {
  local configured_command="$1"
  local terminal_bin

  read -r terminal_bin _ <<< "$configured_command"

  case "$(basename "$terminal_bin")" in
  alacritty)
    printf '%s\n' "Alacritty.desktop"
  ;;
  ghostty)
    printf '%s\n' "com.mitchellh.ghostty.desktop"
  ;;
  kitty)
    printf '%s\n' "kitty.desktop"
  ;;
  *)
    return 1
  ;;
  esac
}

terminal="$(terminal_id_from_command "$(configured_terminal_command)" || xdg-terminal-exec --print-id)"

build_command() {
  case $terminal in
  *Alacritty*)
    command=(
      alacritty
      --class=org.ryoku.screensaver
      --config-file "$RYOKU_PATH/default/alacritty/screensaver.toml"
      -e "$screensaver_command"
    )
  ;;
  *ghostty*)
    command=(
      ghostty
      --class=org.ryoku.screensaver
      --config-file=$RYOKU_PATH/default/ghostty/screensaver
      --font-size=18
      -e "$screensaver_command"
    )
  ;;
  *kitty*)
    command=(
      kitty
      --class=org.ryoku.screensaver
      --override font_size=18
      --override window_padding_width=0
      -e "$screensaver_command"
    )
  ;;
  *)
    notify-send -u low "Screensaver only runs in Alacritty, Ghostty, or Kitty"
    exit 1
  ;;
  esac
}

spawn_screensaver() {
  if ryoku-cmd-present niri; then
    niri msg action spawn -- "${command[@]}" >/dev/null 2>&1 && return 0
  fi

  setsid "${command[@]}" >/dev/null 2>&1 &
}

build_command

focused=""
if ryoku-cmd-present niri; then
  focused="$(niri msg -j focused-output 2>/dev/null | jq -r '.name // empty' 2>/dev/null || true)"
fi

mapfile -t monitors < <(niri msg -j outputs 2>/dev/null | jq -r 'if type == "array" then .[].name else keys[] end' 2>/dev/null || true)

if (( ${#monitors[@]} == 0 )); then
  spawn_screensaver
else
  for monitor in "${monitors[@]}"; do
    niri msg action focus-monitor "$monitor" >/dev/null 2>&1 || true
    spawn_screensaver
  done

  if [[ -n $focused ]]; then
    niri msg action focus-monitor "$focused" >/dev/null 2>&1 || true
  fi
fi
