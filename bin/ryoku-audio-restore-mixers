#!/bin/bash

# Unmute the hardware output switches that some Realtek / generic HD-Audio
# codecs ship muted by default (Speaker / Headphone / Bass Speaker, plus the
# Master / PCM switches). The symptom is "the slider works but the speakers
# stay silent" because the final ALSA mute switch is off.
#
# This only flips the mute switches - it never sets a level. WirePlumber owns
# the actual volume natively (slider -> hardware "Master"), so forcing a level
# here would fight WirePlumber and override the user's chosen volume.
#
# Idempotent: safe to run repeatedly. Silently skips controls that don't
# exist on a given card.
#
# Called at install time by install/config/hardware/fix-audio-mixer.sh AND by
# ryoku-audio-restore-mixers.service on every login (self-healing for the case
# where suspend / profile-switch / codec power transitions re-mute a switch).

set -euo pipefail

if ! command -v amixer >/dev/null 2>&1; then
  echo "ryoku-audio-restore-mixers: amixer not found (install alsa-utils)" >&2
  exit 1
fi

if ! command -v aplay >/dev/null 2>&1; then
  echo "ryoku-audio-restore-mixers: aplay not found (install alsa-utils)" >&2
  exit 1
fi

controls=(Master Speaker Headphone "Bass Speaker" PCM)

while read -r card; do
  for ctl in "${controls[@]}"; do
    amixer -c "$card" sget "$ctl" >/dev/null 2>&1 || continue
    amixer -c "$card" set "$ctl" unmute >/dev/null 2>&1 || true
  done
done < <(aplay -l 2>/dev/null | sed -n 's/^card \([0-9]\+\):.*/\1/p' | sort -u)
