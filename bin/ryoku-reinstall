#!/bin/bash
set -e

# Attempt to reinstall all default Ryoku packages and reset all the default configs.

echo -e "This will reinstall all the default Ryoku packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if ryoku-tui confirm "Are you sure you want to reinstall and lose all config changes?"; then
  ryoku-reinstall-git
  ryoku-reinstall-pkgs
  ryoku-reinstall-configs

  ryoku-tui confirm "System has been reinstalled. Reboot?" && ryoku-system-reboot
fi
