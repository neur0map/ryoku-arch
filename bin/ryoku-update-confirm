#!/bin/bash

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/ryoku-update-core.sh"

# Branded, clean update confirmation. Falls back to a plain prompt when gum is
# unavailable so the flow never stalls on a missing dependency.

version="$(cat "$RYOKU_PATH/version" 2>/dev/null || printf 'unknown')"
channel="$(ryoku_resolve_channel 2>/dev/null || printf 'main')"
releases_url="https://github.com/neur0map/ryoku-arch/releases"

notes=(
  "You cannot stop the update once it starts"
  "Sleep and shutdown are blocked while it runs"
  "Low-battery updates need AC power"
)

if command -v gum >/dev/null 2>&1; then
  gum style --border rounded --border-foreground 3 --padding "1 3" --align center \
    "力  Ryoku Update" \
    "" \
    "version $version    channel $channel"
  echo
  gum style --foreground 7 \
    "- ${notes[0]}" \
    "- ${notes[1]}" \
    "- ${notes[2]}" \
    "- What's new: $releases_url"
  echo
  if ! gum confirm "Continue with the update?"; then
    echo "Update cancelled"
    exit 1
  fi
  exit 0
fi

# Plain fallback (no gum).
echo "=============================================="
echo " Ryoku Update    version $version    channel $channel"
echo "=============================================="
for note in "${notes[@]}"; do
  echo "  - $note"
done
echo "  - What's new: $releases_url"
echo
read -r -p "Continue with the update? [y/N] " answer
if [[ $answer != [yY]* ]]; then
  echo "Update cancelled"
  exit 1
fi
