#!/usr/bin/env bash
# next Ryoku version from the repo-root VERSION file.
#
#   ryoku-release-bump <patch|minor|major> <alpha|beta|stable|keep>
#
# prints the bumped version, no leading "v". stable = bare semver; alpha/beta
# append "-<stage>.0"; keep preserves the current pre-release suffix, so an
# unstable patch bump keeps the hand-set beta line (0.1.2-beta.16 -> 0.1.3-beta.16).
set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
base=$(tr -d '[:space:]' < "$ROOT/VERSION")

bump=${1:?usage: ryoku-release-bump <patch|minor|major> <alpha|beta|stable|keep>}
stage=${2:?usage: ryoku-release-bump <patch|minor|major> <alpha|beta|stable|keep>}

IFS=. read -r major minor patch <<<"${base%%-*}"

case "$bump" in
  major) major=$((major + 1)); minor=0; patch=0 ;;
  minor) minor=$((minor + 1)); patch=0 ;;
  patch) patch=$((patch + 1)) ;;
  *) echo "ryoku-release-bump: unknown bump type: $bump" >&2; exit 2 ;;
esac

next="${major}.${minor}.${patch}"

case "$stage" in
  stable) printf '%s\n' "$next" ;;
  alpha|beta) printf '%s-%s.0\n' "$next" "$stage" ;;
  keep)
    suffix=""
    [[ $base == *-* ]] && suffix="-${base#*-}"
    printf '%s%s\n' "$next" "$suffix"
    ;;
  *) echo "ryoku-release-bump: unknown stage: $stage" >&2; exit 2 ;;
esac
