#!/bin/bash

set -euo pipefail

ROOT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

usage() {
  cat <<'USAGE'
Usage: ryoku-release-bump patch|minor|major alpha|beta|rc|stable [VERSION]

Prints the next tracked Ryoku release version. PATCH stays for stable hotfixes,
MINOR for feature batches, and MAJOR for breaking release eras.
USAGE
}

die() {
  echo "ryoku-release-bump: $1" >&2
  exit 1
}

(( $# >= 2 && $# <= 3 )) || {
  usage >&2
  exit 1
}

bump_type="$1"
release_stage="$2"
input_version="${3:-${RYOKU_RELEASE_VERSION:-}}"

read_current_version() {
  if [[ -n $input_version ]]; then
    printf '%s\n' "$input_version"
    return
  fi

  local version_file="$ROOT_DIR/VERSION"
  [[ -f $version_file ]] || die "missing VERSION file at $version_file"
  head -1 "$version_file" | tr -d '[:space:]'
}

raw_version="$(read_current_version)"
raw_version="${raw_version#v}"
raw_version="${raw_version%%+*}"
core_version="${raw_version%%-*}"

IFS=. read -r major minor patch extra <<<"$core_version"

[[ -z ${extra:-} ]] || die "VERSION core must have exactly three numeric fields"
[[ ${major:-} =~ ^[0-9]+$ ]] || die "VERSION major number is invalid"
[[ ${minor:-} =~ ^[0-9]+$ ]] || die "VERSION minor number is invalid"
[[ ${patch:-} =~ ^[0-9]+$ ]] || die "VERSION patch number is invalid"

case "$bump_type" in
  patch)
    (( patch += 1 ))
    ;;
  minor)
    (( minor += 1 ))
    patch=0
    ;;
  major)
    (( major += 1 ))
    minor=0
    patch=0
    ;;
  *)
    die "unsupported bump type: $bump_type"
    ;;
esac

case "$release_stage" in
  alpha|beta|rc)
    printf '%s.%s.%s-%s.0\n' "$major" "$minor" "$patch" "$release_stage"
    ;;
  stable|final|release)
    printf '%s.%s.%s\n' "$major" "$minor" "$patch"
    ;;
  *)
    die "unsupported release stage: $release_stage"
    ;;
esac
