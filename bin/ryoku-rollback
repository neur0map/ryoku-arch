#!/bin/bash
#
# Restore the pre-Ryoku snapshot recorded by boot.sh during an Omarchy
# to Ryoku migration. Uses snapper to roll back / and /home, then
# reboots so the rollback takes effect.
#
# Reads ~/.local/state/ryoku/migration-state.txt for snapshot ids.

set -eEo pipefail

STATE_FILE="$HOME/.local/state/ryoku/migration-state.txt"

if [[ ! -f $STATE_FILE ]]; then
  echo "No migration snapshot recorded at $STATE_FILE."
  echo "ryoku-rollback only works for Ryoku installs that were applied"
  echo "on top of an existing Omarchy install via boot.sh, where the"
  echo "snapshot was created before the migration."
  exit 1
fi

# shellcheck disable=SC1090
source "$STATE_FILE"

if ! command -v snapper >/dev/null; then
  echo "snapper is not installed; cannot roll back."
  exit 1
fi

echo "Rollback target:"
echo "  Created at:      ${created_at:-unknown}"
echo "  Root snapshot:   ${root_snapshot:-(none)}"
echo "  Home snapshot:   ${home_snapshot:-(none)}"
echo

if command -v gum >/dev/null; then
  gum confirm \
    --prompt.foreground 202 \
    --selected.background 202 --selected.foreground 0 \
    "Restore the pre-Ryoku state and reboot? Anything written to /home or / since the snapshot will be lost." \
    || { echo "Aborted."; exit 0; }
else
  read -rp "Restore the pre-Ryoku state and reboot? [y/N] " ans
  [[ ${ans,,} == y || ${ans,,} == yes ]] || { echo "Aborted."; exit 0; }
fi

if [[ -n ${root_snapshot:-} ]]; then
  echo "Rolling back / from snapshot $root_snapshot..."
  sudo snapper -c root rollback "$root_snapshot"
fi

if [[ -n ${home_snapshot:-} ]]; then
  echo "Rolling back /home from snapshot $home_snapshot..."
  sudo snapper -c home rollback "$home_snapshot"
fi

# Move the state file aside so a second rollback does not run again
# unintentionally; user can still find it under .completed.
mv "$STATE_FILE" "${STATE_FILE%.txt}.completed-$(date +%s).txt" || true

echo
echo "Rollback queued. The system will reboot in 5 seconds..."
sleep 5
sudo reboot
