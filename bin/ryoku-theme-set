#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

if [[ -z $1 ]]; then
  echo "Usage: ryoku-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$RYOKU_CONFIG_PATH/current/theme"
NEXT_THEME_PATH="$RYOKU_CONFIG_PATH/current/next-theme"
USER_THEMES_PATH="$RYOKU_CONFIG_PATH/themes"
RYOKU_THEMES_PATH="$RYOKU_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $RYOKU_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$RYOKU_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate dynamic configs
ryoku-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$RYOKU_CONFIG_PATH/current/theme.name"

# Change background with theme
ryoku-theme-bg-next

# Keep the Ryoku shell and compatibility-generated app color files aligned with
# the selected Ryoku theme instead of wallpaper-generated colors.
ryoku-theme-set-shell

# Restart components to apply new theme.
# RYOKU: the shell is NOT restarted — ryoku-theme-set-shell writes the live
# scheme.json atomically and Colours.qml hot-reloads it (no jarring restart).
ryoku-restart-terminal
ryoku-restart-btop

# Change app-specific themes
# RYOKU: gate GNOME/GTK theme sync on the shell setting (Settings > Color Scheme >
# "Sync system theme" = services.syncSystemTheme, default on). When the user turns
# it off, leave the system toolkit theme untouched.
# Note: read the raw value (no `// true` — jq's `//` treats false the same as
# null, which would ignore an explicit off). Missing key/file → "null"/"" → runs.
if [[ "$(jq -r '.services.syncSystemTheme' "$RYOKU_CONFIG_PATH/shell.json" 2>/dev/null)" != "false" ]]; then
  ryoku-theme-set-gnome
fi
# Recolor GTK/Qt apps to the new palette (self-gated on services.syncAppColors).
ryoku-theme-set-qtgtk
ryoku-theme-set-browser
ryoku-theme-set-vscode
ryoku-theme-set-obsidian
ryoku-theme-set-keyboard

# Call hook on theme set
ryoku-hook theme-set "$THEME_NAME"
