#!/bin/bash

set -euo pipefail

default_runtime_dir="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-rebirth-shell"
runtime_dir="${RYOKU_REBIRTH_SHELL_DIR:-$default_runtime_dir}"
qs_bin="${RYOKU_QS_BIN:-qs}"
qs_config_name="ryoku-rebirth-shell"
qs_args=()

usage() {
  cat <<'EOF'
Usage: ryoku-rebirth-shell [run|restart|stop|status|path]

Runs the rebirth Quickshell runtime copied from the rebirth branch.
EOF
}

require_runtime() {
  [[ -f $runtime_dir/shell.qml ]] || {
    echo "ryoku-rebirth-shell: missing runtime at $runtime_dir" >&2
    exit 1
  }
}

select_qs_config() {
  case "$runtime_dir" in
    "$default_runtime_dir")
      export QS_CONFIG_NAME="$qs_config_name"
      unset QS_CONFIG_PATH
      qs_args=(-c "$QS_CONFIG_NAME")
      ;;
    *)
      export QS_CONFIG_PATH="$RYOKU_REBIRTH_SHELL_DIR"
      unset QS_CONFIG_NAME
      qs_args=(-p "$QS_CONFIG_PATH")
      ;;
  esac
}

export RYOKU_REBIRTH_SHELL_DIR="$runtime_dir"
select_qs_config

command="${1:-run}"
(($# == 0)) || shift
case "$command" in
  run)
    require_runtime
    exec "$qs_bin" "${qs_args[@]}"
    ;;
  restart)
    require_runtime
    "$qs_bin" kill "${qs_args[@]}" --any-display >/dev/null 2>&1 || true
    exec "$qs_bin" "${qs_args[@]}"
    ;;
  stop)
    "$qs_bin" kill "${qs_args[@]}" --any-display
    ;;
  status)
    "$qs_bin" list --all
    ;;
  ipc)
    require_runtime
    exec "$qs_bin" "${qs_args[@]}" ipc "$@"
    ;;
  path)
    printf '%s\n' "$RYOKU_REBIRTH_SHELL_DIR"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "ryoku-rebirth-shell: unknown command: $command" >&2
    usage >&2
    exit 1
    ;;
esac
