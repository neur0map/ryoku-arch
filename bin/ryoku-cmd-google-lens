#!/bin/bash

set -euo pipefail

input_file=""
if [[ ${1:-} == "--file" ]]; then
  if [[ -z ${2:-} ]]; then
    notify-send -u critical "Google Lens" "Missing image path"
    exit 2
  fi
  input_file="$2"
  shift 2
fi

if (( $# > 0 )); then
  notify-send -u critical "Google Lens" "Usage: ryoku-cmd-google-lens [--file IMAGE]"
  exit 2
fi

for cmd in curl jq notify-send xdg-open; do
  if ryoku-cmd-missing "$cmd"; then
    notify-send -u normal "Google Lens" "$cmd is not installed"
    exit 1
  fi
done

tmp="$input_file"
cleanup_tmp=0

if [[ -z $tmp ]]; then
  for cmd in grim slurp; do
    if ryoku-cmd-missing "$cmd"; then
      notify-send -u normal "Google Lens" "$cmd is not installed"
      exit 1
    fi
  done

  tmp_dir="${XDG_RUNTIME_DIR:-/tmp}"
  tmp="$(mktemp "$tmp_dir/ryoku-google-lens.XXXXXX.png")"
  cleanup_tmp=1
fi

cleanup() {
  if (( cleanup_tmp )); then
    rm -f "$tmp"
  fi
}
trap cleanup EXIT

if [[ -n $input_file ]]; then
  if [[ ! -f $tmp ]]; then
    notify-send -u critical "Google Lens" "No image found at $tmp"
    exit 1
  fi

  if [[ ! -r $tmp ]]; then
    notify-send -u critical "Google Lens" "Cannot read image at $tmp"
    exit 1
  fi
else
  if ! geometry="$(slurp 2>/dev/null)"; then
    exit 130
  fi

  if [[ -z $geometry ]]; then
    exit 0
  fi

  grim -g "$geometry" "$tmp"
fi

notify-send -u normal "Google Lens" "Uploading selected screenshot and opening Google Lens"

if ! response="$(curl -fsS --connect-timeout 10 --max-time 45 -F "files[]=@$tmp" https://uguu.se/upload)"; then
  notify-send -u critical "Google Lens" "Image upload failed"
  exit 1
fi

if ! remote_url="$(printf '%s' "$response" | jq -r '.files[0].url // .files[0].src // empty')"; then
  notify-send -u critical "Google Lens" "Upload response did not include an image URL"
  exit 1
fi

if [[ -z $remote_url ]]; then
  notify-send -u critical "Google Lens" "Upload response did not include an image URL"
  exit 1
fi

encoded_url="$(jq -nr --arg url "$remote_url" '$url|@uri')"
xdg-open "https://www.google.com/searchbyimage?image_url=$encoded_url" >/dev/null 2>&1
