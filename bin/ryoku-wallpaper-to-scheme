#!/usr/bin/env python3
"""Generate a Material-3 scheme.json from a wallpaper image (ryoku "wallpaper colors").

Extracts vibrant accent colors from the wallpaper and pairs them with neutral,
mode-appropriate surfaces that are subtly tinted by the wallpaper — then reuses
ryoku-theme-to-scheme to derive the full M3 palette. Emits flavour="wallpaper" so the
dark/light toggle stays enabled (a wallpaper scheme supports both modes).

Usage: ryoku-wallpaper-to-scheme <image> [--mode dark|light]
"""
import argparse
import colorsys
import os
import subprocess
import sys
import tempfile

from PIL import Image


def rgb_hex(c):
    return "".join(f"{max(0, min(255, round(v))):02X}" for v in c)


def mix(a, b, t):
    return [a[i] + (b[i] - a[i]) * t for i in range(3)]


def extract(path):
    img = Image.open(path).convert("RGB")
    img.thumbnail((160, 160))
    q = img.quantize(colors=24, method=Image.MEDIANCUT).convert("RGB")
    counts = q.getcolors(160 * 160) or []
    counts.sort(key=lambda x: -x[0])
    cols = [list(c[1]) for c in counts] or [[120, 140, 200]]

    def hls(c):
        r, g, b = [v / 255 for v in c]
        return colorsys.rgb_to_hls(r, g, b)

    def vib(c):
        _h, l, s = hls(c)
        return s * (1 - abs(l - 0.55) * 1.1)

    ranked = sorted(cols, key=lambda c: -vib(c))
    primary = ranked[0]
    accents = [primary]
    for c in ranked[1:]:
        if all(abs(hls(c)[0] - hls(a)[0]) > 0.07 for a in accents) and vib(c) > 0.1:
            accents.append(c)
        if len(accents) >= 3:
            break
    while len(accents) < 3:
        accents.append(primary)
    return accents[0], accents[1], accents[2]


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("image")
    ap.add_argument("--mode", choices=["dark", "light"], default="dark")
    args = ap.parse_args()

    try:
        primary, secondary, tertiary = extract(args.image)
    except Exception as exc:
        print(f"ryoku-wallpaper-to-scheme: {exc}", file=sys.stderr)
        return 1

    light = args.mode == "light"

    def normalize(c):
        # Keep the wallpaper's hue but force a usable accent tone (Material-You style):
        # accents must read clearly against the surface, so set saturation + lightness.
        r, g, b = [v / 255 for v in c]
        h, l, s = colorsys.rgb_to_hls(r, g, b)
        s = 0.18 if s < 0.08 else min(max(s, 0.5), 0.85)
        l = 0.70 if not light else 0.40
        r, g, b = colorsys.hls_to_rgb(h, l, s)
        return [r * 255, g * 255, b * 255]

    primary = normalize(primary)
    secondary = normalize(secondary)
    tertiary = normalize(tertiary)

    base = [247, 245, 243] if light else [23, 23, 25]
    fg = [26, 25, 24] if light else [208, 210, 212]
    base = mix(base, primary, 0.06)  # subtle wallpaper tint on the neutral surface

    palette = {
        "background": rgb_hex(base),
        "foreground": rgb_hex(fg),
        "accent": rgb_hex(primary),
        "color0": rgb_hex(base),
        "color1": "BA1A1A" if light else "E0707A",   # error / red
        "color2": "3F6B49" if light else "8FBF8F",   # success / green
        "color5": rgb_hex(tertiary),
        "color6": rgb_hex(secondary),
        "color8": rgb_hex(mix(base, fg, 0.35)),
    }

    tmp = None
    try:
        with tempfile.NamedTemporaryFile("w", suffix=".toml", delete=False) as fh:
            for key, val in palette.items():
                fh.write(f'{key} = "#{val}"\n')
            tmp = fh.name
        out = subprocess.check_output([
            "ryoku-theme-to-scheme", tmp,
            "--name", "wallpaper", "--flavour", "wallpaper", "--mode", args.mode,
        ])
        sys.stdout.write(out.decode())
    finally:
        if tmp and os.path.exists(tmp):
            os.unlink(tmp)
    return 0


if __name__ == "__main__":
    sys.exit(main())
