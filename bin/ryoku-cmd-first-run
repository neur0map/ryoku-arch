#!/bin/bash

# Finish the installation of Ryoku with items that can only be done after logging in.

set -e

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

FIRST_RUN_MODE="$RYOKU_STATE_PATH/first-run.mode"

if [[ -f $FIRST_RUN_MODE ]]; then
  rm -f "$FIRST_RUN_MODE"

  bash "$RYOKU_PATH/install/first-run/battery-monitor.sh"
  bash "$RYOKU_PATH/install/first-run/cleanup-reboot-sudoers.sh"
  bash "$RYOKU_PATH/install/first-run/firewall.sh"
  bash "$RYOKU_PATH/install/first-run/dns-resolver.sh"
  bash "$RYOKU_PATH/install/first-run/gnome-theme.sh"
  sudo rm -f /etc/sudoers.d/first-run

  bash "$RYOKU_PATH/install/first-run/welcome.sh"
  bash "$RYOKU_PATH/install/first-run/wifi.sh"
fi
