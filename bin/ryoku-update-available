#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Never block on a credential prompt or send a leaked CI auth header: this check
# must fail cleanly when offline and never demand a GitHub account.
export GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true GCM_INTERACTIVE=never

# Get remote tag
latest_tag=$(git -c http.extraheader= -C "$RYOKU_PATH" ls-remote --tags origin 2>/dev/null | grep -v "{}" | awk '{print $2}' | sed 's#refs/tags/##' | sort -V | tail -n 1)
if [[ -z $latest_tag ]]; then
  echo "Error: Could not retrieve latest tag."
  exit 1
fi

# Get local tag
current_tag=$(git -C "$RYOKU_PATH" describe --tags "$(git -C "$RYOKU_PATH" rev-list --tags --max-count=1)")
if [[ -z $current_tag ]]; then
  echo "Error: Could not retrieve current tag."
  exit 1
fi

if [[ $current_tag != "$latest_tag" ]]; then
  echo "Ryoku update available ($latest_tag)"
  exit 0
else
  echo "Ryoku is up to date ($current_tag)"
  exit 1
fi
