#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Resolve the light/dark mode to mirror to GNOME/GTK.
# Optional $1 (dark|light) is passed by callers that flip the live mode — e.g. the
# shell's dark-mode toggle — so GNOME follows a live flip. The per-theme light.mode
# marker only tracks the theme's own default mode, not a live flip, so it is the
# fallback for the full theme-apply path (ryoku-theme-set, no arg).
mode="${1:-}"
if [[ -z $mode ]]; then
  if [[ -f $RYOKU_CONFIG_PATH/current/theme/light.mode ]]; then
    mode="light"
  else
    mode="dark"
  fi
fi

# Change gnome modes
if [[ $mode == "light" ]]; then
  gsettings set org.gnome.desktop.interface color-scheme "prefer-light"
  gsettings set org.gnome.desktop.interface gtk-theme "Adwaita"
else
  gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
  gsettings set org.gnome.desktop.interface gtk-theme "Adwaita-dark"
fi

# Change the GNOME/Qt icon theme. A per-theme icons.theme override is honoured
# only when that theme is actually installed; otherwise fall back to Ryoku's
# shipped Papirus. (Yaru is no longer packaged, so the old hardcoded fallback
# pointed at a missing theme and broke icon resolution for GNOME and Qt apps.)
icon_theme_installed() {
  [[ -n $1 && ( -d $HOME/.local/share/icons/$1 || -d /usr/share/icons/$1 ) ]]
}

GNOME_ICONS_THEME=$RYOKU_CONFIG_PATH/current/theme/icons.theme
requested_icons=""
[[ -f $GNOME_ICONS_THEME ]] && requested_icons="$(<"$GNOME_ICONS_THEME")"

for candidate in "$requested_icons" Papirus Adwaita hicolor; do
  if icon_theme_installed "$candidate"; then
    gsettings set org.gnome.desktop.interface icon-theme "$candidate"
    break
  fi
done
