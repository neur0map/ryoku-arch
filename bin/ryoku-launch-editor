#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Launch Ryoku's default editor, with RYOKU_EDITOR available as an explicit override.
# Starts suitable editors in a terminal window and otherwise as a regular application.

editor="${RYOKU_EDITOR:-nvim}"

if ryoku-cmd-missing "$editor"; then
  editor="${EDITOR:-nvim}"
fi

if ryoku-cmd-missing "$editor"; then
  echo "No supported editor found. Install neovim or set RYOKU_EDITOR." >&2
  exit 1
fi

case "$(basename "$editor")" in
nvim | vim | nano | micro | hx | helix | fresh)
  exec ryoku-launch-tui "$editor" "$@"
  ;;
*)
  exec setsid "$editor" "$@"
  ;;
esac
