#!/bin/bash

# Returns true if the AUR is up and available.
# Used by ryoku-update-system-pkgs to ensure the AUR is available before updating packages from it.

command -v yay >/dev/null || exit 1

curl -sf --connect-timeout 30 --retry 3 --retry-delay 3 -A "ryoku-update" \
  "https://aur.archlinux.org/rpc/?v=5&type=info&arg=base" >/dev/null
