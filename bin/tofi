#!/bin/bash

set -euo pipefail

find_external_command() {
  local name="$1"
  local source_path="${BASH_SOURCE[0]}"
  local self_dir path_dir absolute_dir candidate
  local -a path_dirs

  if [[ $source_path == */* ]]; then
    self_dir=${source_path%/*}
  else
    self_dir="."
  fi
  self_dir=$(cd -- "$self_dir" && pwd)

  IFS=':' read -ra path_dirs <<<"$PATH"
  for path_dir in "${path_dirs[@]}"; do
    [[ -n $path_dir ]] || path_dir="."
    absolute_dir=$(cd -- "$path_dir" 2>/dev/null && pwd) || continue
    [[ $absolute_dir == $self_dir ]] && continue

    candidate="$absolute_dir/$name"
    if [[ -x $candidate ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

if fuzzel_path=$(find_external_command fuzzel); then
  args=(--dmenu --namespace=tofi)

  while (($# > 0)); do
    case $1 in
      --dmenu)
        shift
        ;;
      --config)
        shift 2
        ;;
      --config=*)
        shift
        ;;
      --prompt-text)
        args+=("--prompt=${2:-}")
        shift 2
        ;;
      --prompt-text=*)
        args+=("--prompt=${1#*=}")
        shift
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  exec "$fuzzel_path" "${args[@]}"
fi

if tofi_path=$(find_external_command tofi); then
  exec "$tofi_path" "$@"
fi

echo "tofi wrapper: neither fuzzel nor system tofi is installed" >&2
exit 127
