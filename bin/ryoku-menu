#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

case "${1:-settings}" in
  overview|launcher)
    exec ryoku-shell overview toggle
    ;;
  actions)
    exec ryoku-shell globalActions open
    ;;
  keybindings|keys|cheatsheet)
    exec ryoku-shell cheatsheet toggle
    ;;
  settings|*)
    exec ryoku-shell settings
    ;;
esac
