#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

case "${1:-settings}" in
  overview|launcher)
    exec inir overview toggle
    ;;
  actions)
    exec inir globalActions open
    ;;
  keybindings|keys|cheatsheet)
    exec inir cheatsheet toggle
    ;;
  settings|*)
    exec inir settings
    ;;
esac
