#!/bin/bash

# Launch the Ryoku Menu or takes a parameter to jump straight to a submenu.

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

export PATH="$RYOKU_PATH/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -x tofi >/dev/null; then
    pkill -x tofi >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  # preselect is unused under tofi (no native support); kept in the
  # signature so existing callers do not need to change argument counts.

  read -r -a args <<<"$extra"

  echo -e "$options" | ryoku-launch-walker --dmenu --prompt-text "$prompt: " "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.ryoku.terminal "$@"
}

present_terminal() {
  ryoku-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  ryoku-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; ryoku-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; ryoku-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; ryoku-pkg-add $2 && sleep 2 && ryoku-font-set '$3'"
}

install_terminal() {
  present_terminal "ryoku-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; ryoku-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; ryoku-pkg-aur-add $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "  Keybindings\n  Omarchy Manual (upstream)\n  Hyprland\n󰣇  Arch\n  Helix\n󱆃  Bash") in
  *Keybindings*) ryoku-menu-keybindings ;;
  *Omarchy*) ryoku-launch-webapp "https://learn.omacom.io/2/the-omarchy-manual" ;;
  *Hyprland*) ryoku-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) ryoku-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) ryoku-launch-webapp "https://devhints.io/bash" ;;
  *Helix*) ryoku-launch-webapp "https://docs.helix-editor.com/" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "  Capture\n  Share\n󰔎  Toggle\n  Hardware") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "  Screenshot\n  Screenrecord\n󰃉  Color") in
  *Screenshot*) ryoku-cmd-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  ryoku-cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "  With no audio\n  With desktop audio\n  With desktop + microphone audio\n  With desktop + microphone audio + webcam") in
  *"With no audio") ryoku-cmd-screenrecord ;;
  *"With desktop audio") ryoku-cmd-screenrecord --with-desktop-audio ;;
  *"With desktop + microphone audio") ryoku-cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    ryoku-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "  Clipboard\n  File \n  Folder") in
  *Clipboard*) ryoku-cmd-share clipboard ;;
  *File*) terminal bash -c "ryoku-cmd-share file" ;;
  *Folder*) terminal bash -c "ryoku-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local options="󱄄  Screensaver\n󰔎  Nightlight\n󱫖  Idle Lock\n󰍜  Top Bar\n󱂬  Workspace Layout\n  Window Gaps\n  1-Window Ratio\n󰍹  Monitor Scaling\n"

  case $(menu "Toggle" "$options") in
  *Screensaver*) ryoku-toggle-screensaver ;;
  *Nightlight*) ryoku-toggle-nightlight ;;
  *Idle*) ryoku-toggle-idle ;;
  *Bar*) ryoku-toggle-waybar ;;
  *Layout*) ryoku-hyprland-workspace-layout-toggle ;;
  *Ratio*) ryoku-hyprland-window-single-square-aspect-toggle ;;
  *Gaps*) ryoku-hyprland-window-gaps-toggle ;;
  *Scaling*) ryoku-hyprland-monitor-scaling-cycle ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  local options="󰛧  Laptop Display"

  if ryoku-hw-hybrid-gpu; then
    options="$options\n  Hybrid GPU"
  fi

  if ryoku-hw-touchpad; then
    options="$options\n󰟸  Touchpad"
  fi

  case $(menu "Toggle" "$options") in
  *Laptop*) ryoku-hyprland-monitor-internal toggle ;;
  *Touchpad*) ryoku-toggle-touchpad ;;
  *"Hybrid GPU"*) present_terminal ryoku-toggle-hybrid-gpu ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "󰸌  Theme\n  Font\n  Background\n  Hyprland\n󱄄  Screensaver\n  About") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *Screensaver*) open_in_editor "$RYOKU_CONFIG_PATH/branding/screensaver.txt" ;;
  *About*) open_in_editor "$RYOKU_CONFIG_PATH/branding/about.txt" ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  exec bash "$RYOKU_PATH/default/tofi/pickers/themes.sh"
}

show_background_menu() {
  exec bash "$RYOKU_PATH/default/tofi/pickers/backgrounds.sh"
}

show_font_menu() {
  theme=$(menu "Font" "$(ryoku-font-list)" "--width 350" "$(ryoku-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    ryoku-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="  Audio\n  Wifi\n󰂯  Bluetooth\n󱐋  Power Profile\n  System Sleep\n󰍹  Monitors"
  [[ -f ~/.config/hypr/bindings.conf ]] && options="$options\n  Keybindings"
  [[ -f ~/.config/hypr/input.conf ]] && options="$options\n  Input"
  options="$options\n󰱔  DNS\n  Security\n  Config"

  case $(menu "Setup" "$options") in
  *Audio*) ryoku-launch-audio ;;
  *Wifi*) ryoku-launch-wifi ;;
  *Bluetooth*) ryoku-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Monitors*) open_in_editor ~/.config/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/hypr/bindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *DNS*) present_terminal ryoku-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(ryoku-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ $profile == "CNCLD" || -z $profile ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_security_menu() {
  case $(menu "Setup" "󰈷  Fingerprint\n  Fido2") in
  *Fingerprint*) present_terminal ryoku-setup-fingerprint ;;
  *Fido2*) present_terminal ryoku-setup-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "  Defaults\n  Hyprland\n  Hypridle\n  Hyprlock\n  Hyprsunset\n  Swayosd\n󰌧  Launcher\n󰍜  Waybar\n󰞅  XCompose") in
  *Defaults*) open_in_editor ~/.config/uwsm/default ;;
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && ryoku-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && ryoku-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && ryoku-restart-swayosd ;;
  *Launcher*) open_in_editor "$RYOKU_CONFIG_PATH/tofi/config" ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && ryoku-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && ryoku-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

  if ryoku-toggle-enabled suspend-off; then
    options="$options󰒲  Enable Suspend"
  else
    options="$options󰒲  Disable Suspend"
  fi

  if ryoku-hibernation-available; then
    options="$options\n󰤁  Disable Hibernate"
  else
    options="$options\n󰤁  Enable Hibernate"
  fi

  case $(menu "System" "$options") in
  *Suspend*) ryoku-toggle-suspend ;;
  *"Enable Hibernate"*) present_terminal ryoku-hibernation-setup ;;
  *"Disable Hibernate"*) present_terminal ryoku-hibernation-remove ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "󰣇  Package\n󰣇  AUR\n  Web App\n  TUI\n  Service\n  Style\n󰵮  Development\n  Editor\n  Terminal\n󱚤  AI\n󰍲  Windows\n  Gaming") in
  *Package*) terminal ryoku-pkg-install ;;
  *AUR*) terminal ryoku-pkg-aur-install ;;
  *Web*) present_terminal ryoku-webapp-install ;;
  *TUI*) present_terminal ryoku-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) present_terminal "ryoku-windows-vm install" ;;
  *Gaming*) show_install_gaming_menu ;;
  *) show_main_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "  Dropbox\n  Tailscale\n󱇱  NordVPN [AUR]\n󰏖  ONCE\n󰟵  Bitwarden\n  Chromium Account") in
  *Dropbox*) present_terminal ryoku-install-dropbox ;;
  *Tailscale*) present_terminal ryoku-install-tailscale ;;
  *NordVPN*) present_terminal ryoku-install-nordvpn ;;
  *ONCE*) present_terminal ryoku-install-once ;;
  *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
  *Chromium*) present_terminal ryoku-install-chromium-google-account ;;
  *) show_install_menu ;;
  esac
}

show_install_editor_menu() {
  case $(menu "Install" "  VSCode\n  Cursor\n  Zed\n  Sublime Text\n  Helix\n  Emacs") in
  *VSCode*) present_terminal ryoku-install-vscode ;;
  *Cursor*) install_and_launch "Cursor" "cursor-bin" "cursor" ;;
  *Zed*) install_and_launch "Zed" "zed" "dev.zed.Zed" ;;
  *Sublime*) install_and_launch "Sublime Text" "sublime-text-4" "sublime_text" ;;
  *Helix*) install "Helix" "helix" ;;
  *Emacs*) install "Emacs" "emacs-wayland" && systemctl --user enable --now emacs.service ;;
  *) show_install_menu ;;
  esac
}

show_install_terminal_menu() {
  case $(menu "Install" "  Alacritty\n  Ghostty\n  Kitty") in
  *Alacritty*) install_terminal "alacritty" ;;
  *Ghostty*) install_terminal "ghostty" ;;
  *Kitty*) install_terminal "kitty" ;;
  *) show_install_menu ;;
  esac
}

show_install_ai_menu() {
  ollama_pkg=$(
    (command -v nvidia-smi &>/dev/null && echo ollama-cuda) ||
      (command -v rocminfo &>/dev/null && echo ollama-rocm) ||
      echo ollama
  )

  case $(menu "Install" "  Dictation\n󱚤  LM Studio\n󱚤  Ollama\n󱚤  Crush") in
  *Dictation*) present_terminal ryoku-voxtype-install ;;
  *Studio*) install "LM Studio" "lmstudio-bin" ;;
  *Ollama*) install "Ollama" $ollama_pkg ;;
  *Crush*) install "Crush" "crush-bin" ;;
  *) show_install_menu ;;
  esac
}

show_install_gaming_menu() {
  case $(menu "Install" "  Steam\n󰢹  NVIDIA GeForce NOW\n  RetroArch [AUR]\n󰍳  Minecraft\n󰖺  Xbox Controller [AUR]") in
  *Steam*) present_terminal ryoku-install-steam ;;
  *GeForce*) present_terminal ryoku-install-geforce-now ;;
  *RetroArch*) aur_install_and_launch "RetroArch" "retroarch retroarch-assets libretro libretro-fbneo" "com.libretro.RetroArch.desktop" ;;
  *Minecraft*) install_and_launch "Minecraft" "minecraft-launcher" "minecraft-launcher" ;;
  *Xbox*) present_terminal ryoku-install-xbox-controllers ;;
  *) show_install_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "󰸌  Theme\n  Background\n  Font") in
  *Theme*) present_terminal ryoku-theme-install ;;
  *Background*) ryoku-theme-bg-install ;;
  *Font*) show_install_font_menu ;;
  *) show_install_menu ;;
  esac
}

