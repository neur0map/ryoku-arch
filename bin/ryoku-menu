  *Channel*) show_update_channel_menu ;;
  *Config*) show_update_config_menu ;;
  *Themes*) present_terminal ryoku-theme-update ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Firmware*) present_terminal ryoku-update-firmware ;;
  *Timezone*) present_terminal ryoku-tz-select ;;
  *Time*) present_terminal ryoku-update-time ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

show_update_channel_menu() {
  case $(menu "Update channel" "🟢 Stable\n🟡 RC\n🟠 Edge\n🔴 Dev") in
  *Stable*) present_terminal "ryoku-channel-set stable" ;;
  *RC*) present_terminal "ryoku-channel-set rc" ;;
  *Edge*) present_terminal "ryoku-channel-set edge" ;;
  *Dev*) present_terminal "ryoku-channel-set dev" ;;
  *) show_update_menu ;;
  esac
}
show_update_process_menu() {
  case $(menu "Restart" "  Hypridle\n  Hyprsunset\n󰎟  Mako\n  Swayosd\n󰌧  Launcher\n󰍜  Waybar") in
  *Hypridle*) ryoku-restart-hypridle ;;
  *Hyprsunset*) ryoku-restart-hyprsunset ;;
  *Mako*) ryoku-restart-mako ;;
  *Swayosd*) ryoku-restart-swayosd ;;
  *Launcher*) notify-send "Launcher" "Tofi has no daemon; nothing to restart." ;;
  *Waybar*) ryoku-restart-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "  Hyprland\n  Hypridle\n  Hyprlock\n  Hyprsunset\n󱣴  Plymouth\n  Swayosd\n  Tmux\n󰌧  Launcher\n󰍜  Waybar") in
  *Hyprland*) present_terminal ryoku-refresh-hyprland ;;
  *Hypridle*) present_terminal ryoku-refresh-hypridle ;;
  *Hyprlock*) present_terminal ryoku-refresh-hyprlock ;;
  *Hyprsunset*) present_terminal ryoku-refresh-hyprsunset ;;
  *Plymouth*) present_terminal ryoku-refresh-plymouth ;;
  *Swayosd*) present_terminal ryoku-refresh-swayosd ;;
  *Tmux*) present_terminal ryoku-refresh-tmux ;;
  *Launcher*) present_terminal "mkdir -p $RYOKU_CONFIG_PATH/tofi && cp $RYOKU_PATH/default/tofi/config $RYOKU_CONFIG_PATH/tofi/config" ;;
  *Waybar*) present_terminal ryoku-refresh-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "  Audio\n󱚾  Wi-Fi\n󰂯  Bluetooth\n󰟸  Trackpad") in
  *Audio*) present_terminal ryoku-restart-pipewire ;;
  *Wi-Fi*) present_terminal ryoku-restart-wifi ;;
  *Bluetooth*) present_terminal ryoku-restart-bluetooth ;;
  *Trackpad*) present_terminal ryoku-restart-trackpad ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "  Drive Encryption\n  User") in
  *Drive*) present_terminal ryoku-drive-set-password ;;
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  ryoku-launch-about
}

show_system_menu() {
  local options="󱄄  Screensaver\n  Lock"
  ! ryoku-toggle-enabled suspend-off && options="$options\n󰒲  Suspend"
  ryoku-hibernation-available && options="$options\n󰤁  Hibernate"
  options="$options\n󰍃  Logout\n󰜉  Restart\n󰐥  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) ryoku-launch-screensaver force ;;
  *Lock*) ryoku-lock-screen ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) ryoku-system-logout ;;
  *Restart*) ryoku-system-reboot ;;
  *Shutdown*) ryoku-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "󰀻  Apps\n󰧑  Learn\n󱓞  Trigger\n  Style\n  Setup\n󰉉  Install\n󰭌  Remove\n  Update\n  About\n  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) ryoku-launch-walker ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *hardware*) show_hardware_menu ;;
  *share*) show_share_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$RYOKU_CONFIG_PATH/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n $1 ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
