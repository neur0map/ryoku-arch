  *PHP*) show_install_php_menu ;;
  *Python*) present_terminal "ryoku-install-dev-env python" ;;
  *Elixir*) show_install_elixir_menu ;;
  *Zig*) present_terminal "ryoku-install-dev-env zig" ;;
  *Rust*) present_terminal "ryoku-install-dev-env rust" ;;
  *Java*) present_terminal "ryoku-install-dev-env java" ;;
