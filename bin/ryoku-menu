  *TUI*) present_terminal ryoku-tui-remove ;;
  *Development*) show_remove_development_menu ;;
  *Preinstalls*) present_terminal ryoku-remove-preinstalls ;;
  *Dictation*) present_terminal ryoku-voxtype-remove ;;
  *Theme*) present_terminal ryoku-theme-remove ;;
  *Windows*) present_terminal "ryoku-windows-vm remove" ;;
  *Fingerprint*) present_terminal "ryoku-setup-fingerprint --remove" ;;
  *Fido2*) present_terminal "ryoku-setup-fido2 --remove" ;;
  *) show_main_menu ;;
  esac
}

