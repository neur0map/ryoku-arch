#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Cycles through the background images available

USER_BACKGROUNDS_PATH="$RYOKU_WALLPAPER_DIR/"
CURRENT_BACKGROUND_LINK="$RYOKU_CONFIG_PATH/current/background"

apply_inir_background() {
  local background="$1"
  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/inir"
  local config_file="$config_dir/config.json"
  local temp_file

  if [[ ! -f $config_file ]] || ryoku-cmd-missing jq; then
    return 0
  fi

  temp_file=$(mktemp)
  jq --arg path "$background" \
    '.background.wallpaperPath = $path | .background.thumbnailPath = ""' \
    "$config_file" >"$temp_file" &&
    mv "$temp_file" "$config_file"
}

mapfile -d '' -t BACKGROUNDS < <(find -L "$USER_BACKGROUNDS_PATH" -maxdepth 1 -type f -print0 2>/dev/null | sort -z)
TOTAL=${#BACKGROUNDS[@]}

if (( TOTAL == 0 )); then
  notify-send "No background was found for theme" -t 2000
else
  # Get current background from symlink
  if [[ -L $CURRENT_BACKGROUND_LINK ]]; then
    CURRENT_BACKGROUND=$(readlink "$CURRENT_BACKGROUND_LINK")
  else
    # Default to first background if no symlink exists
    CURRENT_BACKGROUND=""
  fi

  # Find current background index
  INDEX=-1
  for i in "${!BACKGROUNDS[@]}"; do
    if [[ ${BACKGROUNDS[$i]} == $CURRENT_BACKGROUND ]]; then
      INDEX=$i
      break
    fi
  done

  # Get next background (wrap around)
  if (( INDEX == -1 )); then
    # Use the first background when no match was found
    NEW_BACKGROUND="${BACKGROUNDS[0]}"
  else
    NEXT_INDEX=$(((INDEX + 1) % TOTAL))
    NEW_BACKGROUND="${BACKGROUNDS[$NEXT_INDEX]}"
  fi

  # Set new background symlink
  ln -nsf "$NEW_BACKGROUND" "$CURRENT_BACKGROUND_LINK"
  apply_inir_background "$CURRENT_BACKGROUND_LINK"
fi
