#!/bin/bash

set -euo pipefail

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
source "$script_root/lib/runtime-env.sh"

case ":$PATH:" in
  *":$script_root/bin:"*) ;;
  *) export PATH="$script_root/bin:$PATH" ;;
esac

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
bin_dir="$HOME/.local/bin"
appimage_path="$data_home/ryoku-apps/helium/helium.AppImage"
bin_path="$bin_dir/helium"
helium_profile="$config_home/net.imput.helium"
helium_prefs="$config_home/net.imput.helium/Default/Preferences"
chromium_prefs="$config_home/chromium/Default/Preferences"

write_default_prefs() {
  local prefs="$1"

  mkdir -p "$(dirname -- "$prefs")"
  cat >"$prefs" <<'JSON'
{
  "browser": {
    "theme": {
      "color_scheme": 0,
      "color_scheme2": 0
    }
  },
  "extensions": {
    "theme": {
      "id": "",
      "use_system": false,
      "use_custom": false
    }
  }
}
JSON
}

refresh_prefs() {
  local prefs="$1"
  local tmp_file

  if [[ ! -s $prefs ]]; then
    write_default_prefs "$prefs"
    return
  fi

  if ryoku-cmd-missing jq; then
    return
  fi

  tmp_file="$(mktemp)"
  if jq '
    .browser.theme.color_scheme = 0
    | .browser.theme.color_scheme2 = 0
    | del(
        .browser.theme.user_color,
        .browser.theme.user_color2,
        .browser.theme.color_variant2,
        .browser.theme.is_grayscale2
      )
    | .extensions.theme.id = ""
    | .extensions.theme.use_system = false
    | .extensions.theme.use_custom = false
  ' "$prefs" >"$tmp_file"; then
    cat "$tmp_file" >"$prefs"
  fi
  rm -f "$tmp_file"
}

write_launcher_wrapper() {
  [[ -f $appimage_path ]] || return 0

  mkdir -p "$bin_dir"

  if [[ -L $bin_path ]]; then
    rm -f "$bin_path"
  fi

  cat >"$bin_path" <<'EOF'
#!/bin/bash

set -euo pipefail

data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
appimage="$data_home/ryoku-apps/helium/helium.AppImage"

if [[ ! -x $appimage ]]; then
  echo "Helium AppImage not found: $appimage" >&2
  exit 1
fi

# Helium runs under XWayland (avoids the Wayland black-omnibox bug). hyprland's
# force_zero_scaling makes XWayland apps render at 1x, so on a scaled panel they
# look tiny -- pass Chromium a device-scale-factor matching the focused monitor
# scale so Helium renders crisp and correctly sized. Override with HELIUM_SCALE
# or HELIUM_OZONE_PLATFORM.
scale="${HELIUM_SCALE:-}"
if [[ -z $scale ]] && command -v hyprctl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  scale="$(hyprctl monitors -j 2>/dev/null | jq -r '[.[] | select(.focused) | .scale][0] // (.[0].scale) // 1' 2>/dev/null)"
fi
[[ $scale =~ ^[0-9]+(\.[0-9]+)?$ ]] || scale=1

scale_args=()
case "$scale" in
  1 | 1.0 | 1.00 | 0 | "") ;;
  *) scale_args=("--force-device-scale-factor=$scale") ;;
esac

exec "$appimage" --ozone-platform="${HELIUM_OZONE_PLATFORM:-x11}" "${scale_args[@]}" "$@"
EOF
  chmod 0755 "$bin_path"
}

profile_running() {
  local profile_dir="$1"
  local lock_pid
  local lock_target

  [[ -L $profile_dir/SingletonLock ]] || return 1

  lock_target="$(readlink "$profile_dir/SingletonLock" 2>/dev/null || true)"
  lock_pid="${lock_target##*-}"

  if [[ ! $lock_pid =~ ^[0-9]+$ ]]; then
    return 0
  fi

  kill -0 "$lock_pid" 2>/dev/null
}

helium_status=0

write_launcher_wrapper

if profile_running "$helium_profile"; then
  echo "Helium is still running. Quit Helium completely, then run ryoku-refresh-helium-browser again." >&2
  helium_status=1
else
  refresh_prefs "$helium_prefs"
fi

if [[ -f $chromium_prefs ]]; then
  refresh_prefs "$chromium_prefs"
fi

if (( helium_status )); then
  exit "$helium_status"
fi

echo "Refreshed Helium browser theme defaults"
