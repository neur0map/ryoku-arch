#!/bin/bash
# Invoke fastfetch with the logo-type that matches the current terminal.
# Kitty graphics protocol: kitty, ghostty, wezterm.
# Chafa (libchafa-backed ANSI block render): every other terminal.

if [[ -n ${KITTY_WINDOW_ID:-} ]] \
   || [[ -n ${GHOSTTY_RESOURCES_DIR:-} ]] \
   || [[ -n ${WEZTERM_PANE:-} ]] \
   || [[ ${TERM:-} == "xterm-kitty" ]] \
   || [[ ${TERM:-} == "xterm-ghostty" ]] \
   || [[ ${TERM:-} == "wezterm" ]]; then
  exec fastfetch "$@"
else
  exec fastfetch --logo-type chafa "$@"
fi
