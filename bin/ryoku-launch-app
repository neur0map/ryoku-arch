#!/bin/bash

# Ryoku app-launcher dispatcher. The Super+Space / Super+R keybind ($menu) runs
# this so the launcher backend can be switched at runtime from Settings >
# Launcher without rewriting the Hyprland config. Backends:
#   vicinae    - the Vicinae launcher (default)
#   quickshell - the built-in Ryoku quickshell launcher
#
# The choice is GlobalConfig.system.useVicinaeLauncher, persisted by the ambxst
# shell to ~/.config/ambxst/config/system.json. Absent or true selects Vicinae.
#
# Modes:
#   (no args) | open   toggle the configured launcher window
#   apply              reconcile the Vicinae server with the configured backend:
#                      start it when Vicinae is selected, stop it otherwise. Run
#                      by the Hyprland exec-once at login and by the Settings
#                      toggle.

set -euo pipefail

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Echo the active backend: "vicinae" or "quickshell". Defaults to Vicinae unless
# the user turned it off in Settings or Vicinae is not installed.
launcher_backend() {
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/ambxst/config/system.json"
  local value=""

  if [[ -f $config_file ]] && command -v jq >/dev/null 2>&1; then
    # Strict boolean read: only an explicit `false` opts out. Absent, null, or
    # any other shape collapses to "true" -> the Vicinae default below. (jq's
    # `//` can't be used here: it treats a literal `false` the same as null.)
    value="$(jq -r 'if .useVicinaeLauncher == false then "false" else "true" end' "$config_file" 2>/dev/null)"
  fi

  if [[ $value == "false" ]] || ! command -v vicinae >/dev/null 2>&1; then
    printf 'quickshell\n'
  else
    printf 'vicinae\n'
  fi
}

case "${1:-open}" in
  apply)
    # The Settings toggle passes the freshly chosen backend explicitly ($2) to
    # avoid a read-after-write race with its asynchronous config save. With no
    # argument (the login exec-once) we read the persisted setting.
    backend="${2:-}"
    [[ $backend == "vicinae" || $backend == "quickshell" ]] || backend="$(launcher_backend)"
    if [[ $backend == "vicinae" ]] && command -v vicinae >/dev/null 2>&1; then
      systemctl --user reset-failed vicinae.service >/dev/null 2>&1 || true
      systemctl --user start vicinae.service >/dev/null 2>&1 || true
    else
      vicinae close >/dev/null 2>&1 || true
      systemctl --user stop vicinae.service >/dev/null 2>&1 || true
    fi
    ;;
  open | "")
    if [[ "$(launcher_backend)" == "vicinae" ]]; then
      exec vicinae toggle
    else
      exec ryoku-shell launcher
    fi
    ;;
  *)
    echo "usage: ryoku-launch-app [open | apply [vicinae|quickshell]]" >&2
    exit 2
    ;;
esac
