#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/hypr-config.sh"

set -euo pipefail

# ryoku-gpu — pin the strongest GPU as Hyprland's primary render device.
#
# On a multi-GPU desktop (a powerful discrete Radeon/GeForce alongside the CPU's
# integrated GPU), Hyprland and its Wayland clients render on whichever GPU drives
# the connected display. When the monitor is wired to the weak iGPU, the whole
# desktop renders there while the dGPU idles: a 1440p/4K high-refresh desktop
# then thrashes the iGPU's tiny VRAM and feels sub-60Hz no matter the refresh
# rate, getting worse the longer the session runs as buffers pile up.
#
# This makes the discrete GPU Hyprland's PRIMARY renderer via AQ_DRM_DEVICES.
# Leftmost device = primary renderer; every GPU with a connected monitor MUST
# stay in the list, so a monitor on the iGPU keeps working through render-offload
# (reverse PRIME). Mesa clients follow the compositor's primary device, so the
# shell and apps render on the dGPU too.
#
# Stable device names: AQ_DRM_DEVICES uses ':' as its separator, so the
# colon-laden /dev/dri/by-path/pci-*-card paths cannot be used, and bare
# /dev/dri/cardN can be reordered across boots. A udev rule symlinks each GPU by
# its PCI slot to a colon-free, boot-stable /dev/dri/ryoku-gpu-<slot> name and we
# reference those. When the rule is not installed yet, we fall back to the
# currently-resolved cardN nodes so the fix still applies (boot stability then
# depends on stable enumeration; install the udev rule for guarantees).

# Test / override seams: every device and config path can be redirected so the
# detector is unit-testable against a fake DRM tree with no real hardware.
DRM_ROOT="${RYOKU_GPU_DRM_ROOT:-/sys/class/drm}"
DRI_DIR="${RYOKU_GPU_DRI_DIR:-/dev/dri}"
HYPR_DIR="${RYOKU_GPU_HYPR_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/hypr}"
UWSM_ENV="${RYOKU_GPU_UWSM_ENV:-${XDG_CONFIG_HOME:-$HOME/.config}/uwsm/env-hyprland}"
UDEV_RULE="${RYOKU_GPU_UDEV_RULE:-/etc/udev/rules.d/90-ryoku-gpu.rules}"

HYPR_CONF="$HYPR_DIR/hyprland.conf"
HYPR_LUA="$HYPR_DIR/hyprland.lua"
SOURCE_LINE="source = ~/.config/hypr/gpu.conf"
# Hyprland loads hyprland.lua over hyprland.conf when present; write the matching
# format so the pin is actually read.
if [[ -f $HYPR_LUA ]]; then GPU_CONF="$HYPR_DIR/gpu.lua"; else GPU_CONF="$HYPR_DIR/gpu.conf"; fi
SYMLINK_PREFIX="ryoku-gpu-"

# APU integrated-graphics UMA carveouts stay under this; discrete cards report
# their full VRAM well above it. Used only as a fallback to split AMD/Intel
# integrated vs discrete when the UMA tell below is unavailable; NVIDIA is always
# treated as discrete (no in-scope NVIDIA iGPUs).
DISCRETE_VRAM_MIN=$((2 * 1024 * 1024 * 1024))
# AMD/Intel APUs carve their "VRAM" out of system RAM, so the whole carveout is
# CPU-visible (vis_vram == vram). Consumer BIOSes cap that carveout; treat a fully
# visible carveout at or below this as integrated even when it tops DISCRETE_VRAM_MIN
# (a 4 GiB-UMA Radeon 780M must not outrank a real dGPU). Real dGPUs are 8 GiB+.
APU_UMA_CEIL=$((8 * 1024 * 1024 * 1024))
# Bias so any discrete GPU outranks any integrated one regardless of reported VRAM
# (an NVIDIA card with no sysfs VRAM file still beats a 4 GiB-UMA APU), and an
# external GPU outranks an internal discrete one (it was hot-plugged for power).
DISCRETE_BIAS=$((1 << 60))
EGPU_BIAS=$((1 << 61))

# ── detection ───────────────────────────────────────────────────────────────

gpu_field() {
  # Read KEY=value from a card's device uevent (carries DRIVER + PCI_SLOT_NAME).
  sed -n "s/^$2=//p" "$1/device/uevent" 2>/dev/null | head -n1 || true
}

hw_probe_ok() {
  # Only probe real hardware tools (nvidia-smi/lspci) against the real DRM tree;
  # unit tests redirect DRM_ROOT to a synthesized tree and must stay hermetic.
  [[ $DRM_ROOT == "/sys/class/drm" ]]
}

gpu_uint() {
  # Read a non-negative integer sysfs field for a card, defaulting to 0.
  local v
  v="$(cat "$1/device/$2" 2>/dev/null || printf '0')"
  [[ $v =~ ^[0-9]+$ ]] && printf '%s' "$v" || printf '0'
}

gpu_removable() {
  # "removable" marks a hot-pluggable (Thunderbolt/USB4) GPU, i.e. an eGPU.
  cat "$1/device/removable" 2>/dev/null || true
}

nvidia_vram_bytes() {
  # NVIDIA cards expose no mem_info_vram_total (that is an amdgpu node), so ranking
  # and the UI see 0. Recover the real size from nvidia-smi, keyed by PCI slot.
  hw_probe_ok || { printf '0'; return; }
  command -v nvidia-smi >/dev/null 2>&1 || { printf '0'; return; }
  local bdf="${1#*:}" mib
  mib="$(nvidia-smi --query-gpu=pci.bus_id,memory.total --format=csv,noheader,nounits 2>/dev/null \
    | awk -F', *' -v s="$bdf" 'index(tolower($1), tolower(s)) {print $2; exit}')"
  [[ $mib =~ ^[0-9]+$ ]] && printf '%s' "$((mib * 1024 * 1024))" || printf '0'
}

gpu_model() {
  # Best-effort human label for the UI (empty when lspci is unavailable).
  hw_probe_ok || return 0
  command -v lspci >/dev/null 2>&1 || return 0
  lspci -s "$1" 2>/dev/null | head -n1 \
    | sed -E 's/^[0-9a-fA-F:.]+ [^:]+: //; s/ \(rev [0-9a-fA-F]+\)$//'
}

slot_token() {
  # PCI slot 0000:03:00.0 -> colon/dot-free 0000-03-00-0 for symlink names.
  local s="$1"
  printf '%s' "${s//[:.]/-}"
}

symlink_path() {
  printf '%s/%s%s' "$DRI_DIR" "$SYMLINK_PREFIX" "$(slot_token "$1")"
}

classify() {
  # Sets _class (egpu|discrete|integrated) and _weight (sortable strength).
  # Args: driver vram vis_vram removable
  local driver="$1" vram="$2" vis_vram="${3:-0}" removable="${4:-}"
  if [[ $removable == "removable" ]]; then
    _class="egpu"   # hot-pluggable external GPU: attached on purpose for power
  else
    case "$driver" in
      nvidia | nouveau)
        _class="discrete"   # no in-scope NVIDIA iGPUs
        ;;
      *)
        # An APU/iGPU's whole VRAM is a CPU-visible UMA carveout (vis == total) and
        # stays under APU_UMA_CEIL; a discrete card has dedicated VRAM (vis < total)
        # or far more of it. Fall back to the VRAM threshold when the tell is absent.
        if (( vis_vram > 0 )) && (( vis_vram == vram )) && (( vram <= APU_UMA_CEIL )); then
          _class="integrated"
        elif (( vram >= DISCRETE_VRAM_MIN )); then
          _class="discrete"
        else
          _class="integrated"
        fi
        ;;
    esac
  fi
  case "$_class" in
    egpu)     _weight=$((EGPU_BIAS + vram)) ;;
    discrete) _weight=$((DISCRETE_BIAS + vram)) ;;
    *)        _weight=$vram ;;
  esac
}

gpu_records() {
  # One TSV row per real DRM GPU, strongest first:
  #   weight <tab> class <tab> slot <tab> card <tab> driver <tab> vram <tab> connected <tab> model
  local path base slot driver vram vis removable connected conn st model
  for path in "$DRM_ROOT"/card[0-9]*; do
    [[ -d $path ]] || continue
    base="$(basename "$path")"
    [[ $base == *-* ]] && continue          # skip cardN-CONNECTOR subdevices
    [[ -e $path/device ]] || continue
    slot="$(gpu_field "$path" PCI_SLOT_NAME)"
    [[ -n $slot ]] || continue
    driver="$(gpu_field "$path" DRIVER)"
    [[ -n $driver ]] || driver="unknown"
    vram="$(gpu_uint "$path" mem_info_vram_total)"
    vis="$(gpu_uint "$path" mem_info_vis_vram_total)"
    # NVIDIA exposes no amdgpu VRAM node; recover the real size for ranking + the UI.
    if (( vram == 0 )) && [[ $driver == nvidia || $driver == nouveau ]]; then
      vram="$(nvidia_vram_bytes "$slot")"
    fi
    removable="$(gpu_removable "$path")"
    connected=0
    for conn in "$DRM_ROOT/$base"-*; do
      [[ -r $conn/status ]] || continue
      st="$(cat "$conn/status" 2>/dev/null || true)"
      if [[ $st == "connected" ]]; then
        connected=1
        break
      fi
    done
    model="$(gpu_model "$slot")"
    classify "$driver" "$vram" "$vis" "$removable"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$_weight" "$_class" "$slot" "$base" "$driver" "$vram" "$connected" "$model"
  done | sort -t$'\t' -k1,1nr -k3,3
}

analyze() {
  # Populate _slots / _classes (strongest first) and counts from gpu_records.
  local class slot
  _slots=()
  _classes=()
  _ngpu=0
  _ndiscrete=0
  _nintegrated=0
  while IFS=$'\t' read -r _ class slot _; do
    [[ -n $slot ]] || continue
    _slots+=("$slot")
    _classes+=("$class")
    _ngpu=$((_ngpu + 1))
    if [[ $class == "discrete" || $class == "egpu" ]]; then
      _ndiscrete=$((_ndiscrete + 1))
    else
      _nintegrated=$((_nintegrated + 1))
    fi
  done < <(gpu_records)
}

is_desktop() {
  # Auto-config only on desktops: on laptops Hyprland recommends iGPU-first for
  # battery life, so forcing the dGPU there would hurt. --force / env overrides.
  case "${RYOKU_GPU_ASSUME_DESKTOP:-}" in
    1) return 0 ;;
    0) return 1 ;;
  esac
  [[ ${RYOKU_GPU_FORCE:-0} == "1" ]] && return 0
  ! ryoku-battery-present
}

beneficial() {
  # True when auto-pinning the strongest GPU as primary is worth doing here.
  (( _ngpu >= 2 )) || return 1
  # An external GPU is hot-plugged on purpose for power, so pin it even on a laptop
  # (the iGPU-first battery default does not apply to a deliberately attached eGPU).
  [[ ${_classes[0]} == "egpu" ]] && return 0
  # Otherwise only auto-pin a discrete GPU on desktops; laptops keep iGPU-first for
  # battery (users can still force the dGPU from Settings > Display > GPU).
  is_desktop || return 1
  [[ ${_classes[0]} == "discrete" ]] || return 1
  return 0
}

aq_value_symlinks() {
  local out="" slot
  for slot in "${_slots[@]}"; do
    out+="${out:+:}$(symlink_path "$slot")"
  done
  printf '%s' "$out"
}

card_node_for_slot() {
  local want="$1" path base
  for path in "$DRM_ROOT"/card[0-9]*; do
    [[ -d $path ]] || continue
    base="$(basename "$path")"
    [[ $base == *-* ]] && continue
    if [[ "$(gpu_field "$path" PCI_SLOT_NAME)" == "$want" ]]; then
      printf '%s/%s' "$DRI_DIR" "$base"
      return 0
    fi
  done
  return 1
}

aq_value_cardn() {
  local out="" slot node
  for slot in "${_slots[@]}"; do
    node="$(card_node_for_slot "$slot")" || return 1
    out+="${out:+:}$node"
  done
  printf '%s' "$out"
}

symlinks_present() {
  local slot
  for slot in "${_slots[@]}"; do
    [[ -e "$(symlink_path "$slot")" ]] || return 1
  done
  return 0
}

slot_known() {
  local want="$1" s
  for s in "${_slots[@]}"; do
    [[ $s == "$want" ]] && return 0
  done
  return 1
}

reorder_primary_first() {
  # Move $1 to the front of _slots (the primary renderer). The rest stay in the
  # list so monitors wired to other GPUs keep working via reverse PRIME.
  local want="$1" s new=("$1")
  for s in "${_slots[@]}"; do
    [[ $s == "$want" ]] || new+=("$s")
  done
  _slots=("${new[@]}")
}

current_primary_slot() {
  # PCI slot recorded in the current pin, or empty when not configured.
  [[ -f $GPU_CONF ]] || return 0
  sed -n -E 's/^(#|--) ryoku-gpu-primary: //p' "$GPU_CONF" | head -n1 || true
}

is_configured() {
  [[ -f $GPU_CONF ]] && grep -qE '^(env = AQ_DRM_DEVICES,|hl\.env\("AQ_DRM_DEVICES")' "$GPU_CONF"
}

# ── config writers ──────────────────────────────────────────────────────────

write_gpu_conf() {
  local value="$1" primary="$2"
  if [[ $GPU_CONF == *.lua ]]; then
    cat >"$GPU_CONF" <<EOF
-- Managed by ryoku-gpu — do not edit by hand (reset with: ryoku-gpu disable).
-- Pins Hyprland's primary render device to the strongest GPU so the desktop
-- renders on the discrete GPU instead of a weak integrated one. The leftmost
-- device is the primary renderer; the others stay listed so monitors attached to
-- them keep working through render-offload (reverse PRIME). The env is read once
-- at compositor start, so changes take effect on the next Hyprland login.
-- ryoku-gpu-primary: $primary
hl.env("AQ_DRM_DEVICES", "$value")

-- Reverse PRIME renders the cursor on the primary GPU but scans it out on the GPU
-- the monitor is wired to. Hyprland's hardware cursor plane can't reliably import
-- that cross-GPU buffer, so cursor shape changes (text, resize, pointer) stick on
-- the last shape. Compositing the cursor in software keeps it correct. HyprMod
-- owns cursor theme/size; it does not manage this rendering setting.
hl.config({ cursor = { no_hardware_cursors = true } })
EOF
  else
    cat >"$GPU_CONF" <<EOF
# Managed by ryoku-gpu — do not edit by hand (reset with: ryoku-gpu disable).
# Pins Hyprland's primary render device to the strongest GPU so the desktop
# renders on the discrete GPU instead of a weak integrated one. The leftmost
# device is the primary renderer; the others stay listed so monitors attached to
# them keep working through render-offload (reverse PRIME). The env is read once
# at compositor start, so changes take effect on the next Hyprland login.
# ryoku-gpu-primary: $primary
env = AQ_DRM_DEVICES,$value

# Reverse PRIME renders the cursor on the primary GPU but scans it out on the GPU
# the monitor is wired to. Hyprland's hardware cursor plane can't reliably import
# that cross-GPU buffer, so cursor shape changes (text, resize, pointer) stick on
# the last shape. Compositing the cursor in software keeps it correct. HyprMod
# owns cursor theme/size; it does not manage this rendering setting.
cursor:no_hardware_cursors = true
EOF
  fi
}

ensure_source_line() {
  # Lua entrypoint: ensure require("gpu") is present (idempotent).
  if [[ -f $HYPR_LUA ]]; then
    hypr_ensure_require "$HYPR_LUA" gpu
    return 0
  fi
  [[ -f $HYPR_CONF ]] || return 0
  grep -qxF "$SOURCE_LINE" "$HYPR_CONF" && return 0
  local tmp
  tmp="$(mktemp)"
  # Insert right after the first top-of-file machine include so gpu.conf is
  # sourced before custom.conf (user overrides win on duplicate env).
  awk -v line="$SOURCE_LINE" '
    { print }
    !ins && substr($0, 1, 24) == "source = ~/.config/hypr/" { print line; ins = 1 }
    END { if (!ins) print line }
  ' "$HYPR_CONF" >"$tmp" && cat "$tmp" >"$HYPR_CONF"
  rm -f "$tmp"
}

write_uwsm_env() {
  local value="$1" dir
  dir="$(dirname "$UWSM_ENV")"
  # Only relevant when a uwsm-managed session is in play; under uwsm, AQ_* must
  # be exported here rather than via hyprland.conf.
  [[ -d $dir ]] || command -v uwsm >/dev/null 2>&1 || return 0
  mkdir -p "$dir" 2>/dev/null || return 0
  local tmp
  tmp="$(mktemp)"
  if [[ -f $UWSM_ENV ]]; then
    grep -v '^export AQ_DRM_DEVICES=' "$UWSM_ENV" >"$tmp" 2>/dev/null || true
  fi
  printf 'export AQ_DRM_DEVICES=%s\n' "$value" >>"$tmp"
  cat "$tmp" >"$UWSM_ENV"
  rm -f "$tmp"
}

# ── subcommands ─────────────────────────────────────────────────────────────

cmd_detect() {
  analyze
  printf '%-7s %-13s %-11s %-9s %9s %-10s %s\n' "CARD" "PCI" "CLASS" "DRIVER" "VRAM_MB" "DISPLAY" "MODEL"
  local class slot card driver vram connected model
  while IFS=$'\t' read -r _ class slot card driver vram connected model; do
    [[ -n $slot ]] || continue
    printf '%-7s %-13s %-11s %-9s %9s %-10s %s\n' \
      "$card" "$slot" "$class" "$driver" "$((vram / 1024 / 1024))" \
      "$([[ $connected == 1 ]] && printf 'connected' || printf '-')" "$model"
  done < <(gpu_records)
  echo
  if beneficial; then
    echo "Recommended primary render GPU: ${_slots[0]}"
    echo "AQ_DRM_DEVICES = $(aq_value_symlinks)"
    return 0
  fi
  echo "No GPU reorder needed here (single GPU, laptop, or no discrete GPU)."
  return 1
}

cmd_order() {
  analyze
  if ! beneficial; then
    echo "ryoku-gpu: no discrete-GPU reorder needed on this machine" >&2
    return 1
  fi
  aq_value_symlinks
  echo
}

cmd_check() {
  # Exit 0 = already pinned to the recommended primary; 1 = needs persist;
  # 2 = not applicable (nothing to do).
  analyze
  beneficial || return 2
  [[ -f $GPU_CONF ]] || return 1
  local pinned
  pinned="$(sed -n -E 's/^(#|--) ryoku-gpu-primary: //p' "$GPU_CONF" | head -n1 || true)"
  [[ $pinned == "${_slots[0]}" ]] && return 0
  return 1
}

cmd_install_udev() {
  analyze
  if ! beneficial; then
    echo "ryoku-gpu: no discrete-GPU reorder needed; not installing a udev rule" >&2
    return 0
  fi
  local content slot tok
  content="# Managed by ryoku-gpu: stable, colon-free DRM card names by PCI slot"$'\n'
  content+="# so Hyprland's AQ_DRM_DEVICES can pin the discrete GPU as primary."$'\n'
  for slot in "${_slots[@]}"; do
    tok="$(slot_token "$slot")"
    content+="SUBSYSTEM==\"drm\", KERNEL==\"card[0-9]*\", KERNELS==\"$slot\", SYMLINK+=\"dri/${SYMLINK_PREFIX}${tok}\""$'\n'
  done

  local rule_dir
  rule_dir="$(dirname "$UDEV_RULE")"
  if [[ -w $rule_dir || $EUID -eq 0 ]]; then
    mkdir -p "$rule_dir"
    printf '%s' "$content" >"$UDEV_RULE"
  else
    printf '%s' "$content" | sudo tee "$UDEV_RULE" >/dev/null
  fi

  # Load the rule so it applies on the next boot (rules.d is re-read at boot
  # regardless, so this is best-effort).
  if [[ ${RYOKU_GPU_SKIP_UDEVADM:-0} != "1" ]] && command -v udevadm >/dev/null 2>&1; then
    if [[ $EUID -eq 0 ]]; then
      udevadm control --reload-rules || true
    else
      sudo udevadm control --reload-rules || true
    fi
  fi

  # Materialise the symlinks for the current session by hand instead of
  # `udevadm trigger`: triggering would re-emit DRM connector hotplug events and
  # could perturb a live Hyprland session (the migration and doctor run this
  # while you are logged in). udev recreates these identically on the next boot.
  local node base
  for slot in "${_slots[@]}"; do
    node="$(card_node_for_slot "$slot")" || continue
    base="$(basename "$node")"
    tok="$(slot_token "$slot")"
    if [[ -w $DRI_DIR || $EUID -eq 0 ]]; then
      ln -sfn "$base" "$DRI_DIR/${SYMLINK_PREFIX}${tok}"
    else
      sudo ln -sfn "$base" "$DRI_DIR/${SYMLINK_PREFIX}${tok}"
    fi
  done
  echo "ryoku-gpu: installed stable GPU symlinks via $UDEV_RULE"
}

cmd_persist() {
  local want="${1:-}"
  analyze
  local primary
  if [[ -n $want ]]; then
    # Explicit choice (Settings > Display > GPU): pin this GPU even on a laptop,
    # overriding the iGPU-first battery default. Needs >=2 GPUs to mean anything.
    slot_known "$want" || {
      echo "ryoku-gpu: unknown GPU slot '$want'" >&2
      return 1
    }
    if (( _ngpu < 2 )); then
      echo "ryoku-gpu: only one GPU present; nothing to pin" >&2
      return 0
    fi
    reorder_primary_first "$want"
    primary="$want"
  else
    if ! beneficial; then
      echo "ryoku-gpu: no discrete-GPU reorder needed; leaving GPU config untouched" >&2
      return 0
    fi
    primary="${_slots[0]}"
  fi
  mkdir -p "$HYPR_DIR"

  local value style
  if symlinks_present; then
    value="$(aq_value_symlinks)"
    style="stable udev symlinks"
  elif value="$(aq_value_cardn)"; then
    style="card nodes (run 'ryoku-gpu install-udev' as root for boot-stable names)"
  else
    echo "ryoku-gpu: could not resolve GPU device nodes; aborting" >&2
    return 1
  fi

  write_gpu_conf "$value" "$primary"
  ensure_source_line
  write_uwsm_env "$value"

  echo "ryoku-gpu: pinned primary render GPU $primary via $style"
  echo "  AQ_DRM_DEVICES=$value"
  echo "  wrote $GPU_CONF (active on next Hyprland login)"
}

cmd_disable() {
  if [[ -f $GPU_CONF ]]; then
    if [[ $GPU_CONF == *.lua ]]; then
      cat >"$GPU_CONF" <<'EOF'
-- Managed by ryoku-gpu. Empty: Hyprland uses its default GPU selection.
-- Pin the discrete GPU as the primary renderer with: ryoku-gpu persist
EOF
    else
      cat >"$GPU_CONF" <<'EOF'
# Managed by ryoku-gpu. Empty: Hyprland uses its default GPU selection.
# Pin the discrete GPU as the primary renderer with: ryoku-gpu persist
EOF
    fi
  fi
  if [[ -f $UWSM_ENV ]]; then
    local tmp
    tmp="$(mktemp)"
    grep -v '^export AQ_DRM_DEVICES=' "$UWSM_ENV" >"$tmp" 2>/dev/null || true
    cat "$tmp" >"$UWSM_ENV"
    rm -f "$tmp"
  fi
  if [[ -f $UDEV_RULE ]]; then
    if [[ -w $UDEV_RULE || $EUID -eq 0 ]]; then
      rm -f "$UDEV_RULE"
    else
      sudo rm -f "$UDEV_RULE"
    fi
  fi
  echo "ryoku-gpu: reset to Hyprland's default GPU selection (active on next login)"
}

cmd_status() {
  cmd_detect || true
  echo
  if [[ -f $GPU_CONF ]] && grep -qE '^(env = AQ_DRM_DEVICES,|hl\.env\("AQ_DRM_DEVICES")' "$GPU_CONF"; then
    echo "Configured ($GPU_CONF):"
    grep -E 'ryoku-gpu-primary:|AQ_DRM_DEVICES' "$GPU_CONF" | sed 's/^/  /'
  else
    echo "Not configured: $GPU_CONF has no AQ_DRM_DEVICES pin."
  fi
}

cmd_auto() {
  # The automatic policy used by the "Automatic" choice in Settings > Display > GPU:
  # pin the strongest GPU where beneficial (desktop or eGPU), otherwise clear any
  # stale pin so the box falls back to Hyprland's default (iGPU-first on laptops).
  analyze
  if beneficial; then
    cmd_persist
  else
    cmd_disable
  fi
}

cmd_detect_json() {
  # Machine-readable detection for the settings UI: the GPU list plus the current
  # pin, the auto recommendation, and whether this is a laptop.
  ryoku-cmd-present jq || {
    echo "ryoku-gpu: jq required for detect-json" >&2
    return 1
  }
  analyze
  local pinned recommended is_laptop conf
  pinned="$(current_primary_slot)"
  recommended=""
  beneficial && recommended="${_slots[0]}"
  is_laptop=false
  is_desktop || is_laptop=true
  conf=false
  is_configured && conf=true
  {
    while IFS=$'\t' read -r _ class slot card driver vram connected model; do
      [[ -n $slot ]] || continue
      jq -n --arg slot "$slot" --arg card "$card" --arg driver "$driver" \
        --arg class "$class" --arg model "$model" \
        --argjson vramMb "$((vram / 1024 / 1024))" \
        --argjson connected "$([[ $connected == 1 ]] && echo true || echo false)" \
        '{slot:$slot, card:$card, driver:$driver, class:$class, model:$model, vramMb:$vramMb, connected:$connected}'
    done < <(gpu_records)
  } | jq -s --arg pinned "$pinned" --arg recommended "$recommended" \
    --argjson ngpu "$_ngpu" --argjson configured "$conf" --argjson isLaptop "$is_laptop" \
    '{ngpu:$ngpu, pinned:$pinned, recommended:$recommended, configured:$configured, isLaptop:$isLaptop, gpus:.}'
}

usage() {
  cat <<'USAGE'
Usage: ryoku-gpu <command>

Pin the strongest GPU as Hyprland's primary render device on multi-GPU machines
so the desktop renders on the discrete GPU instead of a weak integrated one.

Commands:
  detect         Show detected GPUs and the recommended primary (exit 1 if none).
  detect-json    Machine-readable GPU list + current pin (for Settings > Display).
  order          Print the recommended AQ_DRM_DEVICES value (exit 1 if none).
  status         Show detection plus the current gpu.lua/gpu.conf GPU pin.
  check          Exit 0 if already pinned, 1 if persist needed, 2 if N/A.
  auto           Apply the automatic policy (strongest on desktop/eGPU; iGPU on laptop).
  persist [SLOT] Pin the strongest GPU, or the given PCI slot (forces it even on a laptop).
  install-udev   Install the udev rule for boot-stable GPU symlinks (root).
  disable        Reset to Hyprland's default GPU selection.

Takes effect on the next Hyprland login (AQ_DRM_DEVICES is read at start).
USAGE
}

case "${1:-status}" in
  detect) cmd_detect ;;
  detect-json | --json) cmd_detect_json ;;
  order) cmd_order ;;
  status) cmd_status ;;
  check) cmd_check ;;
  auto) cmd_auto ;;
  persist) cmd_persist "${2:-}" ;;
  install-udev) cmd_install_udev ;;
  disable | clear) cmd_disable ;;
  -h | --help | help) usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
