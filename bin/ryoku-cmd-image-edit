#!/bin/bash

set -euo pipefail

target="${1:-}"

if [[ -z $target ]]; then
  notify-send -u normal "Image editor" "No image path provided"
  exit 1
fi

if [[ ! -f $target ]]; then
  notify-send -u critical "Image editor" "Image does not exist: $target"
  exit 1
fi

launch_detached() {
  setsid "$@" >/dev/null 2>&1 &
}

if ryoku-cmd-present gradia; then
  launch_detached gradia "$target"
elif ryoku-cmd-present flatpak; then
  launch_detached flatpak run be.alexandervanhee.gradia "$target"
elif ryoku-cmd-present pinta; then
  launch_detached pinta "$target"
else
  notify-send -u normal "Image editor" "Gradia is not installed; opening image instead"
  launch_detached xdg-open "$target"
fi
