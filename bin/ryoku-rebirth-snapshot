#!/bin/bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: ryoku-rebirth-snapshot [--dry-run]

Archives the current live compositor, shell, and service state before rebirth
Hyprland experiments.
EOF
}

fail() {
  echo "ryoku-rebirth-snapshot: $1" >&2
  exit 1
}

dry_run=false

while (($# > 0)); do
  case "$1" in
    --dry-run)
      dry_run=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "unknown argument: $1"
      ;;
  esac
  shift
done

[[ -n ${HOME:-} ]] || fail "HOME is empty"
[[ $HOME != "/" ]] || fail "refusing to snapshot with HOME=/"

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'unknown')"
xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
xdg_state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
snapshot_base="$xdg_state_home/ryoku/rebirth-snapshots"
timestamp="${RYOKU_REBIRTH_SNAPSHOT_TIMESTAMP:-$(date +%Y%m%d-%H%M%S)}"
snapshot_dir="$snapshot_base/$timestamp"

if [[ $dry_run == false ]]; then
  counter=1
  while [[ -e $snapshot_dir ]]; do
    snapshot_dir="$snapshot_base/$timestamp-$counter"
    ((counter += 1))
  done
fi

paths=(
  "niri/config.kdl"
  "hypr/hypridle.conf"
  "hypr/hyprlock.conf"
  "systemd/user/ryoku-shell.service"
  "systemd/user/niri.service.wants/ryoku-shell.service"
  "quickshell/ryoku-shell/shell.qml"
  "ryoku-shell/config.json"
)

print_plan() {
  local rel
  local src
  local state

  printf 'Snapshot: %s\n' "$snapshot_dir"
  printf 'dry_run=true\n'
  for rel in "${paths[@]}"; do
    src="$xdg_config_home/$rel"
    state="skipped"
    [[ -e $src || -L $src ]] && state="copy"
    printf '%s=config/%s\n' "$state" "$rel"
  done
}

write_manifest_header() {
  local manifest="$1"

  {
    printf 'branch=%s\n' "$branch"
    printf 'timestamp=%s\n' "$timestamp"
    printf 'home=%s\n' "$HOME"
    printf 'xdg_config_home=%s\n' "$xdg_config_home"
    printf 'xdg_state_home=%s\n' "$xdg_state_home"
  } > "$manifest"
}

copy_config_path() {
  local rel="$1"
  local manifest="$2"
  local src="$xdg_config_home/$rel"
  local dest="$snapshot_dir/config/$rel"

  if [[ -e $src || -L $src ]]; then
    mkdir -p "$(dirname "$dest")"
    cp -a "$src" "$dest"
    printf 'copied=config/%s\n' "$rel" >> "$manifest"
  else
    printf 'skipped=config/%s\n' "$rel" >> "$manifest"
  fi
}

if [[ $dry_run == true ]]; then
  print_plan
  exit 0
fi

mkdir -p "$snapshot_dir"
manifest="$snapshot_dir/manifest.txt"
write_manifest_header "$manifest"

for rel in "${paths[@]}"; do
  copy_config_path "$rel" "$manifest"
done

printf 'Snapshot: %s\n' "$snapshot_dir"
