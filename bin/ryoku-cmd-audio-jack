#!/bin/bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
helper_candidates=(
  "$repo_root/shell/scripts/ryoku-cmd-audio-jack"
  "${RYOKU_PATH:-$HOME/.local/share/ryoku}/shell/scripts/ryoku-cmd-audio-jack"
  "${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-shell/scripts/ryoku-cmd-audio-jack"
)

for helper in "${helper_candidates[@]}"; do
  if [[ -x $helper ]]; then
    exec "$helper" "$@"
  fi
done

echo "ryoku-cmd-audio-jack: unable to locate shell helper" >&2
exit 1
