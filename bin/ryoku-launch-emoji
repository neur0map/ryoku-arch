#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Emoji picker using bemoji with tofi as its dmenu front-end.

if ! command -v bemoji >/dev/null; then
  notify-send -u critical "Emoji" "bemoji is not installed"
  exit 1
fi

# bemoji uses BEMOJI_PICKER_CMD to drive the picker. Point it at tofi.
export BEMOJI_PICKER_CMD="tofi --config $RYOKU_PATH/default/tofi/config --prompt-text Emoji:"
exec bemoji --no-picker=false
