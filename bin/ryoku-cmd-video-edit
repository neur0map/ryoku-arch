#!/bin/bash

set -euo pipefail

target="${1:-}"

if [[ -z $target ]]; then
  notify-send -u normal "Video editor" "No video path provided"
  exit 1
fi

if [[ ! -f $target ]]; then
  notify-send -u critical "Video editor" "Video does not exist: $target"
  exit 1
fi

launch_detached() {
  setsid "$@" >/dev/null 2>&1 &
}

if ryoku-cmd-present kdenlive; then
  launch_detached kdenlive "$target"
elif ryoku-cmd-present mpv; then
  notify-send -u normal "Video editor" "Kdenlive is not installed; opening video instead"
  launch_detached mpv "$target"
else
  notify-send -u normal "Video editor" "Kdenlive is not installed; opening video instead"
  launch_detached xdg-open "$target"
fi
