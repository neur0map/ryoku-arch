#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Overwrite /etc/pacman with the Ryoku main pacman config and mirrorlist,
# then update all packages.

channel="${1:-$(ryoku-channel-current)}"

if [[ $channel != "main" ]]; then
  echo "Error: Invalid channel '$channel'. Must be: main"
  exit 1
fi

# Take backup of existing files
sudo cp -f /etc/pacman.conf /etc/pacman.conf.bak
sudo cp -f /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak

echo "Setting channel to $channel"
echo

sudo cp -f "$RYOKU_PATH/default/pacman/pacman-$channel.conf" /etc/pacman.conf
sudo cp -f "$RYOKU_PATH/default/pacman/mirrorlist-$channel" /etc/pacman.d/mirrorlist

# Reset all package DBs and then update
sudo pacman -Syyuu --noconfirm
