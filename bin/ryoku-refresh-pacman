#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Overwrite /etc/pacman with the Ryoku main pacman config and mirrorlist,
# then update all packages.

channel="${1:-$(ryoku-channel-current)}"
pacman_channel="main"

case "$channel" in
main)
  pacman_channel="main"
  ;;
unstable-dev)
  pacman_channel="main"
  ;;
*)
  echo "Error: Invalid channel '$channel'. Must be: main or unstable-dev"
  exit 1
  ;;
esac

# Take backup of existing files
sudo cp -f /etc/pacman.conf /etc/pacman.conf.bak
sudo cp -f /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak

echo "Refreshing Ryoku package mirror for update channel: $channel"
echo "Package mirror channel: $pacman_channel"
echo

sudo cp -f "$RYOKU_PATH/default/pacman/pacman-$pacman_channel.conf" /etc/pacman.conf
sudo cp -f "$RYOKU_PATH/default/pacman/mirrorlist-$pacman_channel" /etc/pacman.d/mirrorlist

# Reset all package DBs and then update
sudo pacman -Syyuu --noconfirm
