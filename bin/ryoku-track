#!/usr/bin/env bash
# ryoku track: point this Ryoku checkout at a channel branch (default
# unstable-dev) so `ryoku update` pulls from it and keeps pulling it. The branch
# is written to <repo>/.ryoku-channel (gitignored) and the deployed `ryoku`
# reads it. `ryoku recovery` git-cleans the checkout, dropping the file and
# restoring main. main is never touched by this.
#
#   curl -fsSL https://raw.githubusercontent.com/neur0map/ryoku-arch/unstable-dev/bin/ryoku-track | bash
#   ryoku-track [channel]        # default: unstable-dev; `ryoku-track main` clears it
set -euo pipefail

CHANNEL="${1:-unstable-dev}"

say()  { printf '==> %s\n' "$*"; }
warn() { printf '!!  %s\n' "$*" >&2; }
die()  { printf 'ryoku-track: %s\n' "$*" >&2; exit 1; }

command -v ryoku >/dev/null 2>&1 || die "the 'ryoku' CLI is not installed; this is for a Ryoku system"

# Find the checkout `ryoku update` tracks, the same way the CLI does: RYOKU_REPO,
# else the path the last deploy recorded in ~/.local/state/ryoku/repo.
repo="${RYOKU_REPO:-}"
if [[ -z $repo ]]; then
  state_repo="${XDG_STATE_HOME:-$HOME/.local/state}/ryoku/repo"
  [[ -f $state_repo ]] && repo="$(<"$state_repo")"
fi
if [[ -z $repo ]] || ! git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
  die "no Ryoku checkout found; this box updates from packages, not a git channel, so there is nothing to track"
fi

if [[ $CHANNEL == main ]]; then
  # main is the default, so tracking it just means removing the override.
  rm -f "$repo/.ryoku-channel"
  say "cleared the channel override in $repo; back on main"
else
  printf '%s\n' "$CHANNEL" >"$repo/.ryoku-channel"
  say "tracking channel '$CHANNEL' in $repo"
fi

# First switch runs under the currently deployed CLI, which is still main's and
# does not read the file yet, so hand it the channel by env for this one update.
# That pull deploys the CLI that reads .ryoku-channel from here on.
say "pulling and deploying '$CHANNEL' (ryoku update)"
RYOKU_CHANNEL="$CHANNEL" ryoku update \
  || die "ryoku update failed; nothing changed but the .ryoku-channel marker. Fix the error and re-run."

hash -r 2>/dev/null || true

say "status:"
ryoku status || true

if ryoku status 2>/dev/null | grep -qE "^channel:[[:space:]]+${CHANNEL}$"; then
  say "now tracking '$CHANNEL'. Run 'ryoku update' any time to pull it; 'ryoku recovery' restores main."
else
  warn "status does not show '$CHANNEL' yet. Reboot (or log out and back in) so the freshly deployed 'ryoku' picks up the channel, then check 'ryoku status'."
fi
