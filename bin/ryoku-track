#!/usr/bin/env bash
# ryoku track: turn a Ryoku box into an unstable-dev tracker. It installs the
# build tools, clones the repo, switches the desktop to the unstable-dev branch,
# and sets the update channel, so from then on `ryoku update` pulls unstable-dev.
# `ryoku recovery` force-resets you back to main, so keep NO local edits in
# ~/ryoku-arch. Use at your own risk.
#
#   curl -fsSL https://raw.githubusercontent.com/neur0map/ryoku-arch/unstable-dev/bin/ryoku-track | bash
set -euo pipefail

REPO="$HOME/ryoku-arch"
say() { printf '\n==> %s\n' "$*"; }

say "This turns your box into an unstable-dev tracker so you get unstable-dev changes. Use at your own risk."

say "Installing build tools"
sudo pacman -S --needed --noconfirm git go cmake ninja qt6-shadertools wayland base-devel

say "Fetching the Ryoku source on unstable-dev into $REPO"
if [[ -d $REPO/.git ]]; then
  git -C "$REPO" fetch origin unstable-dev
  git -C "$REPO" checkout unstable-dev
  git -C "$REPO" reset --hard origin/unstable-dev
else
  git clone https://github.com/neur0map/ryoku-arch "$REPO"
  git -C "$REPO" checkout unstable-dev
fi

say "Setting the update channel to unstable-dev"
mkdir -p "$HOME/.config/environment.d"
echo 'RYOKU_CHANNEL=unstable-dev' >"$HOME/.config/environment.d/ryoku.conf"

say "Building and deploying the desktop from the checkout"
bash "$REPO/ryoku/shell/deploy.sh"

# environment.d misses the graphical session on some display managers, so set the
# channel in the session too; user.lua survives updates.
ulua="$HOME/.config/hypr/user.lua"
line='hl.env("RYOKU_CHANNEL", "unstable-dev")'
grep -qF "$line" "$ulua" 2>/dev/null || printf '%s\n' "$line" >>"$ulua"

say "Done. Log out and back in, then:  ryoku status  (should say unstable-dev)."
cat <<'EOF'

Every update after: ryoku update. Back to main: ryoku recovery.
Keep no local edits in ~/ryoku-arch (ryoku update resets it to origin/unstable-dev).
If ryoku status still says main, reboot so the session picks up the channel.
EOF
