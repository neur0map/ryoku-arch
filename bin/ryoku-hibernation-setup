#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Creates a swap file in the btrfs subvolume, adds the swap file to /etc/fstab,
# adds a resume hook to mkinitcpio, and configures suspend-then-hibernate.

FORCE=false
NO_REBUILD=false
WRITE_STH_ONLY=false

for arg in "$@"; do
  case $arg in
    --force) FORCE=true ;;
    --no-rebuild) NO_REBUILD=true ;;
    --write-sth-config) WRITE_STH_ONLY=true ;;
    *)
      echo "Usage: ryoku-hibernation-setup [--force] [--no-rebuild] [--write-sth-config]" >&2
      exit 2
      ;;
  esac
done

if [[ ! -f /sys/power/image_size ]]; then
  echo -e "Hibernation is not supported on your system" >&2
  exit 0
fi

if ! $WRITE_STH_ONLY && ! $NO_REBUILD && ! command -v limine-mkinitcpio &>/dev/null; then
  echo "Skipping hibernation setup (requires Limine bootloader)"
  exit 0
fi

MKINITCPIO_CONF="/etc/mkinitcpio.conf.d/ryoku_resume.conf"
SWAP_FILE="/swap/swapfile"
RESUME_DROP_IN="/etc/limine-entry-tool.d/resume.conf"

# --- suspend-then-hibernate trigger -----------------------------------------
# The groundwork above (swap, resume=, RTC alarm) is inert without a request to
# actually suspend-then-hibernate: a plain lid suspend just rots in s2idle, and
# on s2idle-only AMD laptops a long overnight sleep intermittently never wakes.
# These drop-ins wire the trigger. Idempotent (Ryoku owns the 10-ryoku-* files).
# RYOKU_ETC_PREFIX lets tests target a scratch dir without sudo.
sth_etc_prefix="${RYOKU_ETC_PREFIX:-}"

write_root() { # write_root <dest> ; file content on stdin
  local dest="$1"
  if [[ -n $sth_etc_prefix ]]; then
    mkdir -p "$(dirname "$dest")"
    cat >"$dest"
  else
    sudo mkdir -p "$(dirname "$dest")"
    sudo tee "$dest" >/dev/null
  fi
}

hibernation_ready() {
  case "${RYOKU_ASSUME_HIBERNATION_READY:-}" in 1) return 0 ;; 0) return 1 ;; esac
  [[ -f $MKINITCPIO_CONF ]] && grep -q "^HOOKS+=(resume)$" "$MKINITCPIO_CONF" || return 1
  swapon --show 2>/dev/null | grep -q . || return 1
  return 0
}

configure_suspend_then_hibernate() {
  # No usable hibernate image -> requesting s-t-h would fail; skip quietly.
  hibernation_ready || return 0

  local logind_dir="$sth_etc_prefix/etc/systemd/logind.conf.d"
  local sleep_dir="$sth_etc_prefix/etc/systemd/sleep.conf.d"
  local delay="${RYOKU_HIBERNATE_DELAY_SEC:-50min}"

  # Universal: how long to sit in s2idle before hibernating to disk. Short
  # enough to dodge the s2idle long-sleep resume hang, long enough that a brief
  # lid-close (meeting, transit) still fast-resumes from s2idle.
  echo "Configuring suspend-then-hibernate (HibernateDelaySec=$delay)"
  write_root "$sleep_dir/10-ryoku-hibernate-delay.conf" <<EOF
# Managed by ryoku-hibernation-setup. Re-run the command to change.
[Sleep]
HibernateDelaySec=$delay
EOF

  # Laptop-only: route the lid + suspend key through suspend-then-hibernate.
  # Desktops have no lid; leave their logind handling untouched.
  if ryoku-hw-laptop; then
    echo "Laptop: lid + suspend key -> suspend-then-hibernate"
    write_root "$logind_dir/10-ryoku-lid.conf" <<'EOF'
# Managed by ryoku-hibernation-setup. Re-run the command to change.
[Login]
HandleLidSwitch=suspend-then-hibernate
HandleLidSwitchExternalPower=suspend-then-hibernate
HandleSuspendKey=suspend-then-hibernate
EOF
    if [[ -z $sth_etc_prefix ]] && command -v systemctl >/dev/null 2>&1; then
      sudo systemctl reload systemd-logind 2>/dev/null || true
    fi
  fi
}

if $WRITE_STH_ONLY; then
  configure_suspend_then_hibernate
  exit 0
fi

# Check if hibernation is already configured
if [[ -f $MKINITCPIO_CONF ]] && grep -q "^HOOKS+=(resume)$" "$MKINITCPIO_CONF"; then
  # Fix empty resume_offset if btrfs map-swapfile failed during initial setup
  if [[ -f $RESUME_DROP_IN ]] && grep -q 'resume_offset="$' "$RESUME_DROP_IN" && [[ -f $SWAP_FILE ]]; then
    RESUME_OFFSET=$(sudo btrfs inspect-internal map-swapfile -r "$SWAP_FILE" 2>/dev/null)
    if [[ -n $RESUME_OFFSET ]]; then
      echo "Fixing empty resume_offset ($RESUME_OFFSET)"
      sudo sed -i "s/resume_offset=\"$/resume_offset=$RESUME_OFFSET\"/" "$RESUME_DROP_IN"
      sudo sed -i "s/resume_offset=\"$/resume_offset=$RESUME_OFFSET\"/" /etc/default/limine
      $NO_REBUILD || sudo limine-mkinitcpio
    fi
  fi
  configure_suspend_then_hibernate
  echo "Hibernation is already set up"
  exit 0
fi

if ! $FORCE; then
  MEM_TOTAL_HUMAN=$(free --human | awk '/Mem/ {print $2}')
  if ! ryoku-tui confirm "Use $MEM_TOTAL_HUMAN on boot drive to make hibernation available?"; then
    exit 0
  fi
fi

SWAP_SUBVOLUME="/swap"

# Create btrfs subvolume for swap
if ! sudo btrfs subvolume show "$SWAP_SUBVOLUME" &>/dev/null; then
  echo "Creating Btrfs subvolume"
  sudo btrfs subvolume create "$SWAP_SUBVOLUME"
  sudo chattr +C "$SWAP_SUBVOLUME"
fi

# Create swapfile
if ! sudo swaplabel "$SWAP_FILE" &>/dev/null; then
  echo "Creating swapfile in Btrfs subvolume"
  MEM_TOTAL_KB="$(awk '/MemTotal/ {print $2}' /proc/meminfo)k"
  sudo btrfs filesystem mkswapfile -s "$MEM_TOTAL_KB" "$SWAP_FILE"
fi

# Add swapfile to fstab
if ! grep -Fq "$SWAP_FILE" /etc/fstab; then
  echo "Adding swapfile to /etc/fstab"
  sudo cp -a /etc/fstab "/etc/fstab.$(date +%Y%m%d%H%M%S).back"
  printf "\n# Btrfs swapfile for system hibernation\n%s none swap defaults,pri=0 0 0\n" "$SWAP_FILE" | sudo tee -a /etc/fstab >/dev/null
fi

# Enable swap
if ! swapon --show | grep -q "$SWAP_FILE"; then
  echo "Enabling swap on $SWAP_FILE"
  sudo swapon -p 0 "$SWAP_FILE"
fi

# Add resume hook to mkinitcpio
sudo mkdir -p /etc/mkinitcpio.conf.d
echo "Adding resume hook to $MKINITCPIO_CONF"
echo "HOOKS+=(resume)" | sudo tee "$MKINITCPIO_CONF" >/dev/null

# Ensure keyboard backlight doesn't prevent sleep
sudo cp -p "$RYOKU_PATH/default/systemd/system-sleep/keyboard-backlight" /usr/lib/systemd/system-sleep/

# Add resume= kernel parameters so the initramfs resume hook knows where to find the
# hibernation image. Without these, resume happens late (after GPU drivers load) and fails.
if [[ ! -f $RESUME_DROP_IN ]]; then
  echo "Adding resume kernel parameters"
  sudo swapon -p 0 "$SWAP_FILE" 2>/dev/null
  RESUME_DEVICE=$(findmnt -no SOURCE -T "$SWAP_FILE" | sed 's/\[.*\]//')
  RESUME_OFFSET=$(sudo btrfs inspect-internal map-swapfile -r "$SWAP_FILE")
  if [[ -n $RESUME_OFFSET ]]; then
    sudo mkdir -p /etc/limine-entry-tool.d
    echo "KERNEL_CMDLINE[default]+=\" resume=$RESUME_DEVICE resume_offset=$RESUME_OFFSET\"" | sudo tee "$RESUME_DROP_IN" >/dev/null
    sudo tee -a /etc/default/limine < "$RESUME_DROP_IN" >/dev/null
  else
    echo "Warning: Could not determine resume offset for $SWAP_FILE" >&2
  fi
fi

# Use ACPI alarm for RTC wakeup on s2idle systems (needed for suspend-then-hibernate)
if grep -q "\[s2idle\]" /sys/power/mem_sleep 2>/dev/null; then
  LIMINE_DROP_IN="/etc/limine-entry-tool.d/rtc-alarm.conf"
  if [[ ! -f $LIMINE_DROP_IN ]]; then
    echo "Enabling ACPI RTC alarm for s2idle suspend"
    sudo mkdir -p /etc/limine-entry-tool.d
    echo 'KERNEL_CMDLINE[default]+=" rtc_cmos.use_acpi_alarm=1"' | sudo tee "$LIMINE_DROP_IN" >/dev/null
    sudo tee -a /etc/default/limine < "$LIMINE_DROP_IN" >/dev/null
  fi
fi

configure_suspend_then_hibernate

if ! $NO_REBUILD; then
  # limine-mkinitcpio rebuilds initramfs/UKI and updates entries through
  # limine-entry-tool. The bootloader binary itself does not change here.
  echo "Regenerating initramfs..."
  sudo limine-mkinitcpio
  echo
fi

if ! $FORCE && ! $NO_REBUILD && ryoku-tui confirm "Reboot to enable hibernation?"; then
  ryoku-system-reboot
fi
