#!/bin/bash
set -e

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Reinstall all default Ryoku packages from the main channel and downgrade any packages that are too new.

# Set the package repository to the main mirrors
ryoku-refresh-pacman main

# Downgrade any packages to the main setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$RYOKU_PATH/install/ryoku-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
