#!/bin/bash
# ryoku-doctor-rice: report where the live shell config diverges from the Ryoku
# rice, so "yours" vs "how Ryoku ships" is always legible.
#
# shell/rice/config-overrides.json is force-merged into
# ~/.config/ryoku-shell/config.json on every install AND update, so any local
# change to a rice-managed key does NOT persist (it is reset on the next update).
# This surfaces exactly those keys. To change a managed default for everyone,
# edit the rice (shell/rice/) instead of the live config.

set -euo pipefail

script_path="$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]:-$0}")"
repo_root="$(cd -- "$(dirname -- "$script_path")/.." && pwd)"
RYOKU_PATH="${RYOKU_PATH:-$repo_root}"

RICE_OVERRIDES="$RYOKU_PATH/shell/rice/config-overrides.json"
USER_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku-shell/config.json"

if ! command -v jq >/dev/null 2>&1; then
  echo "ryoku-doctor-rice: jq is required" >&2
  exit 1
fi
if [[ ! -f $RICE_OVERRIDES ]]; then
  echo "ryoku-doctor-rice: rice overrides not found: $RICE_OVERRIDES" >&2
  exit 1
fi

echo "Ryoku rice divergence (rice: shell/rice/config-overrides.json)"
echo "Live config: $USER_CFG"
echo

if [[ ! -f $USER_CFG ]]; then
  echo "No live shell config yet; the rice applies in full on first run."
  exit 0
fi

report="$(jq -rn \
  --slurpfile o "$RICE_OVERRIDES" \
  --slurpfile u "$USER_CFG" '
    ($o[0]) as $ov | ($u[0]) as $us |
    [ ($ov | paths(scalars)) as $p
      | { p: ($p | join(".")), rice: ($ov | getpath($p)), live: ($us | getpath($p)) }
      | select(.rice != .live) ]
    | if length == 0 then
        "OK: every rice-managed key matches the rice."
      else
        ( "Diverged rice-managed keys (reset to the rice value on next update):",
          ( .[] | "  ~ \(.p)\n      rice: \(.rice | tojson)\n      live: \(.live | tojson)" ) )
      end
  ')"

printf '%s\n' "$report"

# Divergence is informational, not a failure.
exit 0
