#!/bin/bash

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
source "$repo_root/lib/runtime-env.sh"
source "$repo_root/lib/update-dashboard.sh"

# Run all pending migrations to bring the system in line with the installed version.

# Where we store an empty file for each migration that has already been performed.
STATE_ROOT="$RYOKU_STATE_PATH"
STATE_DIR="$STATE_ROOT/migrations"
LEGACY_STATE_DIR="$HOME/.local/state/omarchy/migrations"

repair_self_linked_state_root() {
  local target state_basename

  if [[ ! -L $STATE_ROOT ]]; then
    return
  fi

  target=$(readlink "$STATE_ROOT" || true)
  state_basename=$(basename "$STATE_ROOT")

  case "$target" in
    "$STATE_ROOT"|"$state_basename") rm -f "$STATE_ROOT" ;;
  esac
}

repair_self_linked_state_root

mkdir -p "$STATE_DIR" || exit 1

# Skipped migrations are tracked separately
mkdir -p "$STATE_DIR/skipped" || exit 1

# Bridge historical migration markers from the legacy omarchy state dir so
# migrations already applied under the old namespace do not re-run under
# the new one. Idempotent: cp -an never clobbers existing ryoku markers.
if [[ -d $LEGACY_STATE_DIR ]]; then
  cp -an "$LEGACY_STATE_DIR/." "$STATE_DIR/" 2>/dev/null || true
fi

# Run any pending migrations
for file in $RYOKU_PATH/migrations/*.sh; do
  filename=$(basename "$file")

  if [[ ! -f $STATE_DIR/$filename && ! -f $STATE_DIR/skipped/$filename ]]; then
    echo -e "\e[32m\nRunning migration (${filename%.sh})\e[0m"

    if bash $file; then
      touch "$STATE_DIR/$filename"
    else
      exit_code=$?
      if (( exit_code == 75 )); then
        echo "Migration ${filename%.sh} deferred; it will be retried later."
      elif ryoku_update_confirm "Migration ${filename%.sh} failed. Skip and continue?"; then
        touch "$STATE_DIR/skipped/$filename"
      else
        exit 1
      fi
    fi
  fi
done
