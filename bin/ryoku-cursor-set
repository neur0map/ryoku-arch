#!/bin/bash

set -e

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/hypr-config.sh"

cursor_theme="${1:-}"
cursor_size="${2:-24}"

if [[ -z $cursor_theme ]]; then
  echo "Usage: ryoku-cursor-set <cursor-theme> [size]" >&2
  exit 2
fi

if [[ ! -d /usr/share/icons/$cursor_theme/cursors && ! -d $HOME/.local/share/icons/$cursor_theme/cursors ]]; then
  echo "Cursor theme '$cursor_theme' is not installed." >&2
  exit 1
fi

mkdir -p "$RYOKU_STATE_PATH/toggles"
{
  printf 'XCURSOR_THEME=%s\n' "$cursor_theme"
  printf 'XCURSOR_SIZE=%s\n' "$cursor_size"
} >"$RYOKU_STATE_PATH/toggles/cursor.conf"

write_default_cursor_theme() {
  local index_file="$1"

  mkdir -p "$(dirname -- "$index_file")"
  cat >"$index_file" <<EOF
[Icon Theme]
Inherits=$cursor_theme
EOF
}

write_default_cursor_theme "${XDG_DATA_HOME:-$HOME/.local/share}/icons/default/index.theme"
write_default_cursor_theme "$HOME/.icons/default/index.theme"

export XCURSOR_THEME="$cursor_theme"
export XCURSOR_SIZE="$cursor_size"
export HYPRCURSOR_THEME="$cursor_theme"
export HYPRCURSOR_SIZE="$cursor_size"

if ryoku-cmd-present gsettings; then
  gsettings set org.gnome.desktop.interface cursor-theme "$cursor_theme" || true
  gsettings set org.gnome.desktop.interface cursor-size "$cursor_size" || true
fi

if ryoku-cmd-present hyprctl; then
  hyprctl setcursor "$cursor_theme" "$cursor_size" || true
fi

# Persist cursor env to whichever config Hyprland loads (hyprland.lua or .conf).
# Live apply already happened above via hyprctl/gsettings; this is for next login.
hypr_conf="$(hypr_entrypoint)"
hypr_set_env "$hypr_conf" XCURSOR_THEME "$cursor_theme"
hypr_set_env "$hypr_conf" XCURSOR_SIZE "$cursor_size"
hypr_set_env "$hypr_conf" HYPRCURSOR_THEME "$cursor_theme"
hypr_set_env "$hypr_conf" HYPRCURSOR_SIZE "$cursor_size"

if ryoku-cmd-present systemctl; then
  systemctl --user import-environment XCURSOR_THEME XCURSOR_SIZE HYPRCURSOR_THEME HYPRCURSOR_SIZE >/dev/null 2>&1 || true
fi

if ryoku-cmd-present dbus-update-activation-environment; then
  dbus-update-activation-environment --systemd XCURSOR_THEME XCURSOR_SIZE HYPRCURSOR_THEME HYPRCURSOR_SIZE >/dev/null 2>&1 || true
fi
