#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Apply a Ryoku-style color scheme (Material + terminal palette) system-wide
# through the SAME pipeline ryoku themes use, so the shell, GTK, Qt, terminals,
# GNOME, browser, etc. all recolor - not just the shell's colors.json, which the
# live shell does not even read (it reads ~/.local/state/ryoku-shell/scheme.json).

name="$1"
if [[ -z $name ]]; then
  echo "Usage: ryoku-scheme-set <scheme-name>" >&2
  exit 1
fi

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
state_home="${XDG_STATE_HOME:-$HOME/.local/state}"

# Locate the scheme JSON: downloaded schemes first, then shipped (preinstalled).
scheme_json=""
for cand in \
  "$config_home/ryoku/settings-gui/colorschemes/$name/$name.json" \
  "$config_home/quickshell/ryoku-shell/settingsgui/Assets/ColorScheme/$name/$name.json"; do
  if [[ -f $cand ]]; then
    scheme_json="$cand"
    break
  fi
done
if [[ -z $scheme_json ]]; then
  echo "Color scheme '$name' not found" >&2
  exit 1
fi

# Pick the variant matching the shell's current light/dark mode.
mode="$(jq -r '.mode // "dark"' "$state_home/ryoku-shell/scheme.json" 2>/dev/null || echo dark)"
[[ $mode == "light" ]] || mode="dark"
if ! jq -e --arg m "$mode" 'has($m)' "$scheme_json" >/dev/null 2>&1; then
  mode="dark"
fi

next_theme="$RYOKU_CONFIG_PATH/current/next-theme"
current_theme="$RYOKU_CONFIG_PATH/current/theme"
rm -rf "$next_theme"
mkdir -p "$next_theme"

# Build a ryoku colors.toml from the scheme: background/foreground/accent from the
# Material roles, color0-15 from the scheme's terminal palette (Material fallback).
jq -r --arg mode "$mode" '
  .[$mode] as $v | ($v.terminal // {}) as $t |
  "background = \"\($t.background // $v.mSurface)\"",
  "foreground = \"\($t.foreground // $v.mOnSurface)\"",
  "accent = \"\($v.mPrimary)\"",
  "color0 = \"\($t.normal.black // $v.mSurface)\"",
  "color1 = \"\($t.normal.red // $v.mError)\"",
  "color2 = \"\($t.normal.green // $v.mSecondary)\"",
  "color3 = \"\($t.normal.yellow // $v.mOutline)\"",
  "color4 = \"\($t.normal.blue // $v.mPrimary)\"",
  "color5 = \"\($t.normal.magenta // $v.mTertiary)\"",
  "color6 = \"\($t.normal.cyan // $v.mSecondary)\"",
  "color7 = \"\($t.normal.white // $v.mOnSurface)\"",
  "color8 = \"\($t.bright.black // $v.mSurfaceVariant)\"",
  "color9 = \"\($t.bright.red // $v.mError)\"",
  "color10 = \"\($t.bright.green // $v.mSecondary)\"",
  "color11 = \"\($t.bright.yellow // $v.mOutline)\"",
  "color12 = \"\($t.bright.blue // $v.mPrimary)\"",
  "color13 = \"\($t.bright.magenta // $v.mTertiary)\"",
  "color14 = \"\($t.bright.cyan // $v.mSecondary)\"",
  "color15 = \"\($t.bright.white // $v.mOnSurface)\"",
  "cursor = \"\($t.cursor // $v.mOnSurface)\"",
  "selection_background = \"\($t.selectionBg // $v.mPrimary)\"",
  "selection_foreground = \"\($t.selectionFg // $v.mOnPrimary)\""
' "$scheme_json" >"$next_theme/colors.toml"

if [[ ! -s $next_theme/colors.toml ]]; then
  echo "Failed to build a palette for '$name'" >&2
  rm -rf "$next_theme"
  exit 1
fi

# Generate the dynamic per-app configs (GTK/Qt/terminal/btop/...) from the palette.
ryoku-theme-set-templates

# Swap the generated palette in as the current theme + record the active name so
# Colours.qml (and the picker highlight) reflect it.
rm -rf "$current_theme"
mv "$next_theme" "$current_theme"
printf '%s\n' "$name" >"$RYOKU_CONFIG_PATH/current/theme.name"

# Apply across the shell and the system, mirroring ryoku-theme-set (a color scheme
# carries no wallpaper, so the wallpaper is intentionally left untouched).
ryoku-theme-set-shell
ryoku-restart-terminal
ryoku-restart-btop
if [[ "$(jq -r '.services.syncSystemTheme' "$RYOKU_CONFIG_PATH/shell.json" 2>/dev/null)" != "false" ]]; then
  ryoku-theme-set-gnome
fi
# Recolor GTK/Qt apps to the new palette (self-gated on services.syncAppColors).
ryoku-theme-set-qtgtk
ryoku-theme-set-browser
ryoku-theme-set-vscode
ryoku-theme-set-obsidian
ryoku-theme-set-keyboard
ryoku-hook theme-set "$name"
