#!/bin/bash

set -euo pipefail

# shellcheck source=lib/runtime-env.sh
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

usage() {
  cat <<'EOF'
Usage:
  ryoku-cmd-screenshot screen
  ryoku-cmd-screenshot region
  ryoku-cmd-screenshot choose
EOF
}

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a ryoku-cli "$@"
  fi
}

require_command() {
  local command_name="$1"
  local label="$2"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    notify -u critical "Screenshot failed" "$label is not installed"
    echo "ryoku-cmd-screenshot: missing command: $command_name" >&2
    exit 1
  fi
}

next_screenshot_path() {
  local dir="$1"
  local name_format="${RYOKU_SCREENSHOT_NAME_FORMAT:-ss-%Y%m%d-%H%M%S}"
  local name
  local path
  local suffix=1

  name="$(date +"$name_format")"
  path="$dir/$name.png"

  while [[ -e $path ]]; do
    path="$dir/$name-$suffix.png"
    ((suffix++))
  done

  printf '%s\n' "$path"
}

mode="${1:-}"
case "$mode" in
screen | region | choose) ;;
-h | --help)
  usage
  exit 0
  ;;
*)
  usage >&2
  exit 2
  ;;
esac

grim_cmd="${RYOKU_SCREENSHOT_GRIM:-grim}"
slurp_cmd="${RYOKU_SCREENSHOT_SLURP:-slurp}"
wl_copy_cmd="${RYOKU_SCREENSHOT_WL_COPY:-wl-copy}"
editor_cmd="${RYOKU_SCREENSHOT_EDITOR:-ryoku-cmd-image-edit}"
menu_cmd="${RYOKU_SCREENSHOT_MENU:-fuzzel}"
gradia_cmd="${RYOKU_SCREENSHOT_GRADIA:-gradia}"
systemctl_cmd="${RYOKU_SCREENSHOT_SYSTEMCTL:-systemctl}"
shell_cmd="${RYOKU_SCREENSHOT_SHELL:-ryoku-shell}"

start_screenshot_portal() {
  if command -v "$systemctl_cmd" >/dev/null 2>&1; then
    "$systemctl_cmd" --user start xdg-desktop-portal-hyprland.service xdg-desktop-portal.service >/dev/null 2>&1 || true
  fi
}

open_shell_picker() {
  if command -v "$shell_cmd" >/dev/null 2>&1; then
    "$shell_cmd" screenshot && exit 0
  fi
}

case "$mode" in
region | choose)
  open_shell_picker
  ;;
esac

if command -v "$gradia_cmd" >/dev/null 2>&1; then
  start_screenshot_portal

  case "$mode" in
  screen)
    exec "$gradia_cmd" --screenshot=FULL
    ;;
  region | choose)
    exec "$gradia_cmd" --screenshot
    ;;
  esac
fi

if [[ $mode == "choose" ]]; then
  require_command "$menu_cmd" "fuzzel"

  choice="$(printf 'Screen\nDrag region\n' | "$menu_cmd" --dmenu --prompt "Screenshot: " 2>/dev/null || true)"
  case "${choice,,}" in
  screen)
    mode="screen"
    ;;
  region | "drag region" | drag)
    mode="region"
    ;;
  "")
    exit 0
    ;;
  *)
    notify -u normal "Screenshot cancelled" "Unknown screenshot mode: $choice"
    exit 0
    ;;
  esac
fi

require_command "$grim_cmd" "grim"
require_command "$wl_copy_cmd" "wl-copy"
require_command "$editor_cmd" "Gradia"

if [[ $mode == "region" ]]; then
  require_command "$slurp_cmd" "slurp"
fi

screenshot_dir="${RYOKU_SCREENSHOT_DIR:-}"
if [[ -z $screenshot_dir ]]; then
  pictures_dir=""
  if command -v xdg-user-dir >/dev/null 2>&1; then
    pictures_dir="$(xdg-user-dir PICTURES 2>/dev/null || true)"
  fi
  pictures_dir="${pictures_dir:-$HOME/Pictures}"
  screenshot_dir="$pictures_dir/Screenshots"
fi

mkdir -p "$screenshot_dir"
screenshot_path="$(next_screenshot_path "$screenshot_dir")"

case "$mode" in
screen)
  "$grim_cmd" "$screenshot_path"
  ;;
region)
  geometry="$("$slurp_cmd" 2>/dev/null || true)"
  if [[ -z $geometry ]]; then
    exit 0
  fi
  "$grim_cmd" -g "$geometry" "$screenshot_path"
  ;;
esac

"$wl_copy_cmd" --type image/png <"$screenshot_path" || \
  notify -u normal "Screenshot taken" "Saved, but clipboard copy failed"

"$editor_cmd" "$screenshot_path" || true
notify -u normal -i "$screenshot_path" "Screenshot taken" "Copied to clipboard and opened in Gradia"
printf '%s\n' "$screenshot_path"
