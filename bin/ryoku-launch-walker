#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Historical name preserved so Hyprland bindings stay stable. Dispatches
# tofi for both dmenu and app-launcher modes.
#
#   --dmenu [...]   piped selection -> tofi --dmenu
#   otherwise       app launcher    -> tofi-drun
#
# Config resolution: prefer the current theme's rendered tofi.conf
# (generated by ryoku-theme-set-templates from default/themed/
# tofi.conf.tpl) so the launcher picks up the active theme's palette.
# Fall back to the repo default when a theme has not been set yet.

TOFI_CONFIG="$RYOKU_CONFIG_PATH/current/theme/tofi.conf"
[[ -f $TOFI_CONFIG ]] || TOFI_CONFIG="$RYOKU_PATH/default/tofi/config"

if [[ ${1:-} == "--dmenu" ]]; then
  shift
  exec tofi --config "$TOFI_CONFIG" "$@"
fi

# Force drun-launch on the CLI as well: tofi's system default is false,
# which would otherwise print the Exec line to stdout instead of running
# it. CLI value beats config; guarantees the launcher actually launches.
exec tofi-drun --drun-launch=true --config "$TOFI_CONFIG" "$@"
