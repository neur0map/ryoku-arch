#!/bin/bash

# Toggle microphone mute. Dell XPS and ThinkPad systems get special handling for the hardware LED.

if ryoku-hw-match "XPS"; then
  ryoku-cmd-mic-mute-xps
elif ryoku-hw-match "ThinkPad"; then
  ryoku-cmd-mic-mute-thinkpad
elif ryoku-cmd-present inir; then
  inir audio micMute
else
  wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
fi
