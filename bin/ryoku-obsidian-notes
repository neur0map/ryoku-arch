#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  ryoku-obsidian-notes path [--vault-dir DIR] [--daily-dir DIR] [--inbox-file FILE] [--date YYYY-MM-DD]
  ryoku-obsidian-notes save [--vault-dir DIR] [--daily-dir DIR] [--inbox-file FILE] [--vault-name NAME] [--date YYYY-MM-DD] [--entry-id ID] --content CONTENT [--print-path] [--print-entry-id]
  ryoku-obsidian-notes open [--vault-dir DIR] [--daily-dir DIR] [--inbox-file FILE] [--vault-name NAME] [--date YYYY-MM-DD] [--print-uri]
EOF
}

die() {
  echo "ryoku-obsidian-notes: $1" >&2
  usage
  exit 2
}

urlencode() {
  jq -rn --arg v "$1" '$v | @uri'
}

expand_path() {
  local path="$1"

  case "$path" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    \~/*)
      printf '%s\n' "$HOME/${path#"~/"}"
      ;;
    "\$HOME"*)
      printf '%s\n' "$HOME${path#"\$HOME"}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

safe_relative_path() {
  local value="$1"
  local label="$2"
  local part
  local -a parts

  [[ -n $value ]] || die "missing $label"
  [[ $value != /* ]] || die "unsafe relative path for $label: $value"

  while [[ $value == ./* ]]; do
    value="${value#./}"
  done

  IFS='/' read -r -a parts <<< "$value"
  for part in "${parts[@]}"; do
    [[ -n $part && $part != "." && $part != ".." ]] || die "unsafe relative path for $label: $value"
  done

  printf '%s\n' "$value"
}

safe_entry_id() {
  local value="$1"

  [[ -n $value ]] || die "missing --entry-id"
  [[ $value =~ ^[A-Za-z0-9._:-]+$ ]] || die "unsafe --entry-id: $value"
  printf '%s\n' "$value"
}

new_entry_id() {
  printf 'ryoku-%s-%04d\n' "$(date +%s%N)" "$RANDOM"
}

validate_date() {
  local note_date="$1"
  local normalized

  [[ $note_date =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || die "invalid --date: $note_date"
  normalized=$(date -d "$note_date" +%F 2>/dev/null) || die "invalid --date: $note_date"
  [[ $normalized == "$note_date" ]] || die "invalid --date: $note_date"
}

default_vault_dir() {
  local discovered

  if [[ -n ${RYOKU_OBSIDIAN_VAULT_DIR:-} ]]; then
    printf '%s\n' "$RYOKU_OBSIDIAN_VAULT_DIR"
    return
  fi

  if discovered=$(obsidian_registered_vault) && [[ -n $discovered ]]; then
    printf '%s\n' "$discovered"
    return
  fi

  printf '%s\n' "${XDG_DOCUMENTS_DIR:-$HOME/Documents}/Ryoku Notes"
}

obsidian_registered_vault() {
  local config

  config="${XDG_CONFIG_HOME:-$HOME/.config}/obsidian/obsidian.json"
  [[ -f $config ]] || return 1

  jq -er '
    (.vaults // {}) as $vaults
    | (
        $vaults
        | to_entries
        | map(select(.value.open == true))
        | sort_by(.value.ts // 0)
        | reverse
        | .[0].value.path
      ) // (
        $vaults
        | to_entries
        | sort_by(.value.ts // 0)
        | reverse
        | .[0].value.path
      ) // empty
  ' "$config" 2>/dev/null
}

target_relative_path() {
  local daily_dir="$1"
  local inbox_file="$2"
  local note_date="$3"

  if [[ -n $note_date ]]; then
    validate_date "$note_date"
    daily_dir=$(safe_relative_path "$daily_dir" "--daily-dir") || exit $?
    printf '%s/%s.md\n' "$daily_dir" "$note_date"
  else
    safe_relative_path "$inbox_file" "--inbox-file" || exit $?
  fi
}

target_path() {
  local vault_dir="$1"
  local daily_dir="$2"
  local inbox_file="$3"
  local note_date="$4"
  local relative

  [[ -n $vault_dir ]] || die "missing --vault-dir"
  vault_dir=$(expand_path "$vault_dir")
  relative=$(target_relative_path "$daily_dir" "$inbox_file" "$note_date") || exit $?
  printf '%s/%s\n' "${vault_dir%/}" "$relative"
}

heading_for_note() {
  local note_date="$1"

  if [[ -n $note_date ]]; then
    printf '# %s\n' "$note_date"
  else
    printf '# Inbox\n'
  fi
}

append_note() {
  local target="$1"
  local note_date="$2"
  local content="$3"
  local parent timestamp

  [[ -n $content ]] || die "missing --content"

  parent="$(dirname -- "$target")"
  mkdir -p "$parent"
  if [[ ! -f $target ]]; then
    heading_for_note "$note_date" > "$target"
  fi

  timestamp="$(date +%H:%M)"
  {
    printf '\n## %s\n\n' "$timestamp"
    printf '%s\n' "$content"
  } >> "$target"
}

write_widget_note() {
  local target="$1"
  local note_date="$2"
  local entry_id="$3"
  local content="$4"
  local parent timestamp tmp rc

  [[ -n $content ]] || die "missing --content"

  parent="$(dirname -- "$target")"
  mkdir -p "$parent"
  if [[ ! -f $target ]]; then
    heading_for_note "$note_date" > "$target"
  fi

  timestamp="$(date +%H:%M)"
  tmp="$(mktemp "$parent/.ryoku-obsidian-notes.XXXXXX")"

  set +e
  ENTRY_ID="$entry_id" TIMESTAMP="$timestamp" CONTENT="$content" perl -0we '
    my $id = $ENV{"ENTRY_ID"};
    my $timestamp = $ENV{"TIMESTAMP"};
    my $content = $ENV{"CONTENT"};
    my $text = do { local $/; <> };
    my $block = "\n## $timestamp\n\n<!-- ryoku-widget-note:id=$id -->\n$content\n<!-- /ryoku-widget-note:id=$id -->";
    if ($text =~ s/\n## [^\n]+\n\n<!-- ryoku-widget-note:id=\Q$id\E(?: [^>]*)? -->\n.*?\n<!-- \/ryoku-widget-note:id=\Q$id\E -->/$block/s) {
      print $text;
      exit 0;
    }
    print $text;
    exit 42;
  ' "$target" > "$tmp"
  rc=$?
  set -e

  case "$rc" in
    0)
      mv -- "$tmp" "$target"
      ;;
    42)
      rm -f -- "$tmp"
      {
        printf '\n## %s\n\n' "$timestamp"
        printf '<!-- ryoku-widget-note:id=%s -->\n' "$entry_id"
        printf '%s\n' "$content"
        printf '<!-- /ryoku-widget-note:id=%s -->\n' "$entry_id"
      } >> "$target"
      ;;
    *)
      rm -f -- "$tmp"
      return "$rc"
      ;;
  esac
}

build_obsidian_uri() {
  local vault_dir="$1"
  local vault_name="$2"
  local daily_dir="$3"
  local inbox_file="$4"
  local note_date="$5"
  local relative target

  vault_dir=$(expand_path "$vault_dir")
  relative=$(target_relative_path "$daily_dir" "$inbox_file" "$note_date") || exit $?
  if [[ -n $vault_name ]]; then
    printf 'obsidian://open?vault=%s&file=%s\n' "$(urlencode "$vault_name")" "$(urlencode "$relative")"
  else
    target="${vault_dir%/}/$relative"
    printf 'obsidian://open?path=%s\n' "$(urlencode "$target")"
  fi
}

run_path() {
  local vault_dir daily_dir inbox_file note_date

  vault_dir="$(default_vault_dir)"
  daily_dir="${RYOKU_OBSIDIAN_DAILY_DIR:-Daily}"
  inbox_file="${RYOKU_OBSIDIAN_INBOX_FILE:-Inbox.md}"
  note_date=""

  while (( $# )); do
    case "$1" in
      --vault-dir)
        (( $# >= 2 )) || die "missing value for --vault-dir"
        vault_dir="$2"
        shift 2
        ;;
      --daily-dir)
        (( $# >= 2 )) || die "missing value for --daily-dir"
        daily_dir="$2"
        shift 2
        ;;
      --inbox-file)
        (( $# >= 2 )) || die "missing value for --inbox-file"
        inbox_file="$2"
        shift 2
        ;;
      --date)
        (( $# >= 2 )) || die "missing value for --date"
        note_date="$2"
        shift 2
        ;;
      --*)
        die "unknown option: $1"
        ;;
      *)
        die "unexpected argument: $1"
        ;;
    esac
  done

  target_path "$vault_dir" "$daily_dir" "$inbox_file" "$note_date"
}

run_save() {
  local vault_dir daily_dir inbox_file vault_name note_date entry_id content print_path print_entry_id target

  vault_dir="$(default_vault_dir)"
  daily_dir="${RYOKU_OBSIDIAN_DAILY_DIR:-Daily}"
  inbox_file="${RYOKU_OBSIDIAN_INBOX_FILE:-Inbox.md}"
  vault_name="${RYOKU_OBSIDIAN_VAULT_NAME:-}"
  note_date=""
  entry_id=""
  content=""
  print_path=0
  print_entry_id=0

  while (( $# )); do
    case "$1" in
      --vault-dir)
        (( $# >= 2 )) || die "missing value for --vault-dir"
        vault_dir="$2"
        shift 2
        ;;
      --daily-dir)
        (( $# >= 2 )) || die "missing value for --daily-dir"
        daily_dir="$2"
        shift 2
        ;;
      --inbox-file)
        (( $# >= 2 )) || die "missing value for --inbox-file"
        inbox_file="$2"
        shift 2
        ;;
      --vault-name)
        (( $# >= 2 )) || die "missing value for --vault-name"
        vault_name="$2"
        shift 2
        ;;
      --date)
        (( $# >= 2 )) || die "missing value for --date"
        note_date="$2"
        shift 2
        ;;
      --entry-id)
        (( $# >= 2 )) || die "missing value for --entry-id"
        entry_id="$2"
        shift 2
        ;;
      --content)
        (( $# >= 2 )) || die "missing value for --content"
        content="$2"
        shift 2
        ;;
      --print-path)
        print_path=1
        shift
        ;;
      --print-entry-id)
        print_entry_id=1
        shift
        ;;
      --*)
        die "unknown option: $1"
        ;;
      *)
        die "unexpected argument: $1"
        ;;
    esac
  done

  target=$(target_path "$vault_dir" "$daily_dir" "$inbox_file" "$note_date")
  if (( print_entry_id )) || [[ -n $entry_id ]]; then
    if [[ -z $entry_id ]]; then
      entry_id=$(new_entry_id)
    fi
    entry_id=$(safe_entry_id "$entry_id")
    write_widget_note "$target" "$note_date" "$entry_id" "$content"
  else
    append_note "$target" "$note_date" "$content"
  fi
  if (( print_path )); then
    printf '%s\n' "$target"
  fi
  if (( print_entry_id )); then
    printf '%s\n' "$entry_id"
  fi
}

run_open() {
  local vault_dir daily_dir inbox_file vault_name note_date print_uri uri

  vault_dir="$(default_vault_dir)"
  daily_dir="${RYOKU_OBSIDIAN_DAILY_DIR:-Daily}"
  inbox_file="${RYOKU_OBSIDIAN_INBOX_FILE:-Inbox.md}"
  vault_name="${RYOKU_OBSIDIAN_VAULT_NAME:-}"
  note_date=""
  print_uri=0

  while (( $# )); do
    case "$1" in
      --vault-dir)
        (( $# >= 2 )) || die "missing value for --vault-dir"
        vault_dir="$2"
        shift 2
        ;;
      --daily-dir)
        (( $# >= 2 )) || die "missing value for --daily-dir"
        daily_dir="$2"
        shift 2
        ;;
      --inbox-file)
        (( $# >= 2 )) || die "missing value for --inbox-file"
        inbox_file="$2"
        shift 2
        ;;
      --vault-name)
        (( $# >= 2 )) || die "missing value for --vault-name"
        vault_name="$2"
        shift 2
        ;;
      --date)
        (( $# >= 2 )) || die "missing value for --date"
        note_date="$2"
        shift 2
        ;;
      --print-uri)
        print_uri=1
        shift
        ;;
      --*)
        die "unknown option: $1"
        ;;
      *)
        die "unexpected argument: $1"
        ;;
    esac
  done

  uri=$(build_obsidian_uri "$vault_dir" "$vault_name" "$daily_dir" "$inbox_file" "$note_date")
  if (( print_uri )); then
    printf '%s\n' "$uri"
  else
    xdg-open "$uri" >/dev/null 2>&1 &
  fi
}

case "${1:-}" in
  path)
    shift
    run_path "$@"
    ;;
  save)
    shift
    run_save "$@"
    ;;
  open)
    shift
    run_open "$@"
    ;;
  --help|-h)
    usage
    ;;
  "")
    die "missing command"
    ;;
  *)
    die "unknown command: $1"
    ;;
esac
