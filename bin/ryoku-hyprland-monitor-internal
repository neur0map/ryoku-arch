#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

TOGGLE="internal-monitor-disable"

enable() {
  if ryoku-hyprland-toggle-enabled "$TOGGLE"; then
    ryoku-hyprland-toggle --disabled-notification "󰍹    Laptop display enabled" "$TOGGLE"
  fi
}

disable() {
  if ryoku-hyprland-monitors-many; then
    if ryoku-hyprland-toggle-disabled "$TOGGLE"; then
      ryoku-hyprland-toggle --enabled-notification "󰍹    Laptop display disabled" "$TOGGLE"
    fi
  else
    notify-send -u low "󰍹    Can't disable the only active display"
    exit 1
  fi
}

recover() {
  if ryoku-hyprland-monitors-none && ryoku-hyprland-toggle-enabled "$TOGGLE"; then
    enable
  fi
}

case "$1" in
  on) enable ;;
  off) disable ;;
  toggle) if ryoku-hyprland-toggle-enabled "$TOGGLE"; then enable; else disable; fi ;;
  recover) recover ;;
  *)
    echo "Usage: $(basename "$0") {on|off|toggle|recover}" >&2
    exit 1
    ;;
esac
