#!/bin/bash

set -eE

script_path="${BASH_SOURCE[0]}"
script_path="$(readlink -f "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
source "$(cd -- "$(dirname -- "$script_path")/.." && pwd)/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "$script_path")/.." && pwd)/lib/ryoku-update-core.sh"

ryoku_update_default_log() {
  local state_home=""
  local log_dir=""

  if [[ -n ${XDG_STATE_HOME:-} ]]; then
    state_home="$XDG_STATE_HOME"
  elif [[ -n ${HOME:-} ]]; then
    state_home="$HOME/.local/state"
  else
    printf '%s\n' "/tmp/ryoku-update.log"
    return
  fi

  log_dir="$state_home/quickshell/user"
  if mkdir -p "$log_dir" 2>/dev/null; then
    printf '%s\n' "$log_dir/update.log"
  else
    printf '%s\n' "/tmp/ryoku-update.log"
  fi
}

export RYOKU_UPDATE_LOG="${RYOKU_UPDATE_LOG:-$(ryoku_update_default_log)}"

ryoku_update_sudo_has_terminal() {
  ((EUID == 0)) && return 0
  command -v sudo >/dev/null 2>&1 || return 0
  sudo -n true >/dev/null 2>&1 && return 0
  [[ -t 0 ]]
}

if [[ -z ${RYOKU_UPDATE_LOGGED:-} ]] && ! ryoku_update_sudo_has_terminal; then
  echo "Ryoku update needs sudo authentication, but stdin is not a terminal."
  echo "Run from a real terminal, or run sudo -v first and retry: ryoku-update -y"
  exit 1
fi

if [[ -z ${RYOKU_UPDATE_INHIBITED:-} ]] && command -v systemd-inhibit >/dev/null 2>&1; then
  exec env RYOKU_UPDATE_INHIBITED=1 systemd-inhibit \
    --what=idle \
    --who=ryoku-update \
    --why="Ryoku system update in progress" \
    --mode=block \
    "$0" "$@"
fi

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $RYOKU_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env RYOKU_UPDATE_LOGGED=1 RYOKU_UPDATE_LOG="$RYOKU_UPDATE_LOG" script -qefc "$script_command" "$RYOKU_UPDATE_LOG"
fi

update_failed() {
  local doctor_command="${RYOKU_UPDATE_DOCTOR_COMMAND:-}"

  if [[ -z $doctor_command && -n ${RYOKU_PATH:-} && -x $RYOKU_PATH/bin/ryoku-doctor ]]; then
    doctor_command="$RYOKU_PATH/bin/ryoku-doctor"
  fi

  [[ -n $doctor_command ]] || doctor_command="ryoku-doctor"

  echo ""
  echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nRun: $doctor_command\n\nIf you need assistance, open an issue at https://github.com/neur0map/ryoku-arch/issues\033[0m"
}

trap update_failed ERR

update_resume_after_git=0
update_assume_yes=0
switch_channel=""
update_args=()

# -sc/--switch-channel is intentionally undocumented in the headline usage so
# the channel is never changed by accident: it takes an explicit channel and is
# gated by a confirmation unless -y is passed.
while (($# > 0)); do
  case "$1" in
    --resume-after-git)
      update_resume_after_git=1
      ;;
    -y | --yes)
      update_assume_yes=1
      update_args+=("$1")
      ;;
    -sc | --switch-channel)
      switch_channel="${2:-}"
      if [[ -z $switch_channel ]]; then
        echo "Error: -sc requires a channel (one of: ${RYOKU_CHANNELS[*]})." >&2
        exit 1
      fi
      shift
      ;;
    -sc=* | --switch-channel=*)
      switch_channel="${1#*=}"
      ;;
    *)
      update_args+=("$1")
      ;;
  esac
  shift
done

if [[ -n $switch_channel ]] && ! ryoku_channel_is_valid "$switch_channel"; then
  echo "Error: unknown channel '$switch_channel'. Valid channels: ${RYOKU_CHANNELS[*]}." >&2
  exit 1
fi

command_bridge_backup_dir=""

command_bridge_target() {
  local source_path="$1"
  local target_path="$2"

  [[ -e $source_path ]] || return 0

  if [[ -e $target_path && ! -L $target_path ]]; then
    if [[ -z $command_bridge_backup_dir ]]; then
      command_bridge_backup_dir="$RYOKU_STATE_PATH/command-bridge-backups/$(date +%Y%m%d-%H%M%S)"
      mkdir -p "$command_bridge_backup_dir"
    fi

    mv -- "$target_path" "$command_bridge_backup_dir/$(basename "$target_path")"
    echo "Moved stale local command to: $command_bridge_backup_dir/$(basename "$target_path")"
  fi

  ln -sfn "$source_path" "$target_path"
}

repair_command_bridges() {
  local bin_home="${XDG_BIN_HOME:-$HOME/.local/bin}"
  local lib_home
  local command_path
  local lib_file

  mkdir -p "$bin_home"

  if [[ -d $RYOKU_PATH/lib ]]; then
    lib_home="$(dirname "$bin_home")/lib"
    mkdir -p "$lib_home"
    for lib_file in "$RYOKU_PATH"/lib/*.sh; do
      [[ -f $lib_file ]] || continue
      ln -sfn "$lib_file" "$lib_home/$(basename "$lib_file")"
    done
  fi

  if [[ -d $RYOKU_PATH/bin ]]; then
    for command_path in "$RYOKU_PATH"/bin/ryoku-*; do
      [[ -f $command_path && -x $command_path ]] || continue
      command_bridge_target "$command_path" "$bin_home/$(basename "$command_path")"
    done
  fi

  if [[ -x $RYOKU_PATH/shell/scripts/ryoku-shell ]]; then
    command_bridge_target "$RYOKU_PATH/shell/scripts/ryoku-shell" "$bin_home/ryoku-shell"
  fi

  if [[ -x $RYOKU_PATH/shell/scripts/ryoku ]]; then
    command_bridge_target "$RYOKU_PATH/shell/scripts/ryoku" "$bin_home/ryoku"
  fi

  repair_system_command_bridges
}

repair_system_command_bridges() {
  local command_path
  local system_bin="${RYOKU_SYSTEM_BIN_DIR:-/usr/local/bin}"
  local system_lib="${RYOKU_SYSTEM_LIB_DIR:-/usr/local/lib}"
  local lib_file

  command -v sudo >/dev/null 2>&1 || return 0
  if ! sudo -n true >/dev/null 2>&1; then
    [[ -t 0 ]] || return 0
    sudo -v || return 0
  fi

  if [[ -d $RYOKU_PATH/lib ]]; then
    sudo -n install -d "$system_lib" >/dev/null 2>&1 || return 0
    for lib_file in "$RYOKU_PATH"/lib/*.sh; do
      [[ -f $lib_file ]] || continue
      sudo -n ln -sfn "$lib_file" "$system_lib/$(basename "$lib_file")" || true
    done
  fi

  [[ -d $RYOKU_PATH/bin ]] || return 0
  sudo -n install -d "$system_bin" >/dev/null 2>&1 || return 0
  for command_path in "$RYOKU_PATH"/bin/ryoku-*; do
    [[ -f $command_path && -x $command_path ]] || continue
    sudo -n ln -sfn "$command_path" "$system_bin/$(basename "$command_path")" || true
  done

  if [[ -x $RYOKU_PATH/shell/scripts/ryoku ]]; then
    sudo -n ln -sfn "$RYOKU_PATH/shell/scripts/ryoku" "$system_bin/ryoku" || true
  fi
}

continue_with_refreshed_updater() {
  local refreshed_updater="$RYOKU_PATH/bin/ryoku-update"
  local doctor_command="${RYOKU_UPDATE_DOCTOR_COMMAND:-$RYOKU_PATH/bin/ryoku-doctor}"

  [[ -f $refreshed_updater ]] || return 1

  echo
  echo "Continuing through refreshed Ryoku updater:"
  echo "  $refreshed_updater --resume-after-git"

  if [[ -x $refreshed_updater ]]; then
    exec env RYOKU_UPDATE_BOOTSTRAP_RESUMED=1 RYOKU_UPDATE_DOCTOR_COMMAND="$doctor_command" "$refreshed_updater" --resume-after-git "${update_args[@]}"
  fi

  exec env RYOKU_UPDATE_BOOTSTRAP_RESUMED=1 RYOKU_UPDATE_DOCTOR_COMMAND="$doctor_command" bash "$refreshed_updater" --resume-after-git "${update_args[@]}"
}

run_post_git_update() {
  repair_command_bridges
  ryoku-snapshot create || (($? == 127))
  ryoku-update-perform
}

# The one pipeline both normal updates and channel switches run through, so a
# channel switch gets the same PTY logging, idle inhibit, battery guard,
# command-bridge repair, and ERR->doctor handling as a normal update.
run_full_update() {
  repair_command_bridges
  ryoku-update-git
  repair_command_bridges
  if ! continue_with_refreshed_updater; then
    run_post_git_update
  fi
}

# Deliberate gate for channel switching. Returns success only if the user
# confirms (or already on the target channel). Never triggered by accident:
# the caller only reaches here when -sc was passed explicitly.
confirm_channel_switch() {
  local from="$1" to="$2"
  local message reply

  if [[ $from == "$to" ]]; then
    echo "Already on the $to channel; updating it in place."
    return 0
  fi

  message="Switch Ryoku update channel: $from -> $to
This checks out the '$to' branch and updates the system from it."

  if command -v ryoku-tui >/dev/null 2>&1; then
    ryoku-tui style --border rounded --border-foreground 3 --padding "1 3" --align center \
      "力  Ryoku Channel Switch" \
      "" \
      "$from  ->  $to" \
      "" \
      "Checks out the '$to' branch and updates from it." >&2 2>/dev/null \
      || echo -e "\n$message" >&2
    ryoku-tui confirm "Switch channel to $to and update now?"
    return $?
  fi

  echo -e "\n$message" >&2
  read -r -p "Switch channel to $to and update now? [y/N] " reply
  [[ $reply == [yY]* ]]
}

if [[ -z ${RYOKU_UPDATE_POWER_CHECKED:-} ]]; then
  battery_level=""

  for battery in /sys/class/power_supply/BAT*; do
    [[ -r $battery/capacity ]] || continue
    battery_level=$(<"$battery/capacity")
    break
  done

  if [[ -n $battery_level ]]; then
    ac_online=0

    for supply in /sys/class/power_supply/*; do
      [[ -r $supply/type && -r $supply/online ]] || continue

      if [[ $(<"$supply/type") == "Mains" && $(<"$supply/online") == "1" ]]; then
        ac_online=1
        break
      fi
    done

    if ((ac_online == 0 && battery_level < 25)); then
      echo -e "\033[0;31mUpdate blocked: battery is at ${battery_level}% and AC power is not online.\033[0m"
      echo "Connect power or charge above 25%, then run the update again."
      exit 1
    fi
  fi

  export RYOKU_UPDATE_POWER_CHECKED=1
fi

if (( update_resume_after_git == 1 )); then
  run_post_git_update
  exit 0
fi

if [[ -n $switch_channel ]]; then
  current_channel="$(ryoku_resolve_channel)"
  if ((update_assume_yes == 1)) || confirm_channel_switch "$current_channel" "$switch_channel"; then
    export RYOKU_UPDATE_BRANCH="$switch_channel"
    # Keep the pacman channel config in step (best-effort: ryoku packages track
    # the main mirror, so a hiccup here must not block the git channel switch).
    if command -v ryoku-refresh-pacman >/dev/null 2>&1; then
      ryoku-refresh-pacman "$switch_channel" \
        || echo -e "\e[33mPacman channel refresh reported an issue; continuing with the git channel switch.\e[0m"
    fi
    run_full_update
  else
    echo "Channel switch cancelled."
  fi
  exit 0
fi

if (( update_assume_yes == 1 )) || ryoku-update-confirm; then
  run_full_update
fi
