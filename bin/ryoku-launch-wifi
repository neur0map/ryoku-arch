#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Launch Ryoku wifi controls. Prefer impala when installed, otherwise use
# NetworkManager's nmtui.
# Attempts to unblock the wifi service first in case it should be been blocked.

rfkill unblock wifi

if ryoku-cmd-present impala; then
  ryoku-launch-or-focus-tui impala
elif ryoku-cmd-present nmtui; then
  ryoku-launch-or-focus-tui nmtui
else
  ryoku-launch-or-focus-tui ryoku-network-status
fi
