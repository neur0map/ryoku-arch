#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

lock_file="${XDG_RUNTIME_DIR:-/tmp}/ryoku-caffeine.lock"
inhibit_pattern="[r]yoku-caffeine-inhibit"
legacy_inhibit_pattern="^/usr/bin/systemd-inhibit --what=idle --who=Ryoku .*Ryoku caffeine mode"

usage() {
  cat <<'EOF'
Usage:
  ryoku-cmd-caffeine status
  ryoku-cmd-caffeine start
  ryoku-cmd-caffeine stop
  ryoku-cmd-caffeine toggle
EOF
}

helper_inhibitor_active() {
  pgrep -f "$inhibit_pattern" >/dev/null
}

legacy_inhibitor_active() {
  pgrep -f "$legacy_inhibit_pattern" >/dev/null
}

caffeine_active() {
  helper_inhibitor_active || legacy_inhibitor_active
}

with_caffeine_lock() {
  mkdir -p "$(dirname "$lock_file")"

  (
    flock -x 9
    "$@"
  ) 9>"$lock_file"
}

start_inhibitor() {
  if helper_inhibitor_active; then
    return 0
  fi

  pkill -f "$legacy_inhibit_pattern" >/dev/null 2>&1 || true

  setsid systemd-inhibit \
    --what=idle \
    --who=Ryoku \
    --why="Ryoku caffeine mode" \
    bash -c 'exec -a ryoku-caffeine-inhibit sleep infinity' 9>&- >/dev/null 2>&1 &
}

stop_inhibitor() {
  pkill -f "$inhibit_pattern" >/dev/null 2>&1 || true
  pkill -f "$legacy_inhibit_pattern" >/dev/null 2>&1 || true
}

start_caffeine() {
  if caffeine_active; then
    return 0
  fi

  start_inhibitor

  for _ in {1..20}; do
    if caffeine_active; then
      return 0
    fi
    sleep 0.05
  done

  return 1
}

stop_caffeine() {
  stop_inhibitor
}

toggle_caffeine() {
  if caffeine_active; then
    stop_caffeine
  else
    start_caffeine
  fi
}

case "${1:-}" in
  status)
    caffeine_active
    ;;
  start)
    with_caffeine_lock start_caffeine
    ;;
  stop)
    with_caffeine_lock stop_caffeine
    ;;
  toggle)
    with_caffeine_lock toggle_caffeine
    ;;
  --help|-h|"")
    usage
    ;;
  *)
    echo "ryoku-cmd-caffeine: unknown action: $1" >&2
    usage >&2
    exit 2
    ;;
esac
