#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

state_dir="${XDG_RUNTIME_DIR:-/tmp}"
inhibit_pattern="[r]yoku-caffeine-inhibit"

usage() {
  cat <<'EOF'
Usage:
  ryoku-cmd-caffeine status
  ryoku-cmd-caffeine start
  ryoku-cmd-caffeine stop
  ryoku-cmd-caffeine toggle
EOF
}

caffeine_active() {
  pgrep -f "$inhibit_pattern" >/dev/null
}

start_inhibitor() {
  if caffeine_active; then
    return 0
  fi

  setsid systemd-inhibit \
    --what=idle:sleep \
    --who=Ryoku \
    --why="Ryoku Caffeine mode" \
    bash -c 'exec -a ryoku-caffeine-inhibit sleep infinity' >/dev/null 2>&1 &
}

stop_inhibitor() {
  pkill -f "$inhibit_pattern" >/dev/null 2>&1 || true
}

start_caffeine() {
  if caffeine_active; then
    return 0
  fi

  start_inhibitor

  for _ in {1..20}; do
    if caffeine_active; then
      return 0
    fi
    sleep 0.05
  done

  return 1
}

stop_caffeine() {
  stop_inhibitor
}

case "${1:-}" in
  status)
    caffeine_active
    ;;
  start)
    start_caffeine
    ;;
  stop)
    stop_caffeine
    ;;
  toggle)
    if caffeine_active; then
      stop_caffeine
    else
      start_caffeine
    fi
    ;;
  --help|-h|"")
    usage
    ;;
  *)
    echo "ryoku-cmd-caffeine: unknown action: $1" >&2
    usage >&2
    exit 2
    ;;
esac
