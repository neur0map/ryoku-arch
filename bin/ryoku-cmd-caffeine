#!/bin/bash

set -euo pipefail

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
runtime_env="$script_root/lib/runtime-env.sh"
fallback_runtime_env="${RYOKU_PATH:-$HOME/.local/share/ryoku}/lib/runtime-env.sh"

if [[ -f $runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$runtime_env"
elif [[ -f $fallback_runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$fallback_runtime_env"
else
  export RYOKU_STATE_PATH="${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}"
fi

lock_file="${RYOKU_CAFFEINE_LOCK_FILE:-${XDG_RUNTIME_DIR:-/tmp}/ryoku-caffeine.lock}"
state_file="${RYOKU_CAFFEINE_STATE_FILE:-${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}/caffeine.enabled}"
unit_name="${RYOKU_CAFFEINE_UNIT_NAME:-ryoku-caffeine-inhibit}"
inhibit_pattern="[r]yoku-caffeine-inhibit"
desired_inhibit_pattern="(^|/)systemd-inhibit --what=idle:sleep --who=Ryoku .*Ryoku caffeine mode"
legacy_inhibit_pattern="(^|/)systemd-inhibit --what=idle --who=Ryoku .*Ryoku caffeine mode"

usage() {
  cat <<'EOF'
Usage:
  ryoku-cmd-caffeine status
  ryoku-cmd-caffeine start
  ryoku-cmd-caffeine stop
  ryoku-cmd-caffeine restore
  ryoku-cmd-caffeine hold
  ryoku-cmd-caffeine release
  ryoku-cmd-caffeine toggle
EOF
}

helper_inhibitor_active() {
  pgrep -f "$inhibit_pattern" >/dev/null
}

desired_inhibitor_active() {
  pgrep -f "$desired_inhibit_pattern" >/dev/null
}

legacy_inhibitor_active() {
  pgrep -f "$legacy_inhibit_pattern" >/dev/null
}

caffeine_active() {
  desired_inhibitor_active || helper_inhibitor_active || legacy_inhibitor_active
}

caffeine_requested() {
  [[ -f $state_file ]] && grep -Fxq "enabled" "$state_file"
}

persist_caffeine_state() {
  mkdir -p "$(dirname "$state_file")"
  printf '%s\n' "enabled" >"$state_file"
}

clear_caffeine_state() {
  rm -f "$state_file"
}

with_caffeine_lock() {
  mkdir -p "$(dirname "$lock_file")"

  (
    flock -x 9
    "$@"
  ) 9>"$lock_file"
}

command_present() {
  ryoku-cmd-present "$@"
}

caffeine_unit_active() {
  command_present systemctl || return 1

  systemctl --user is-active --quiet "$unit_name.service" >/dev/null 2>&1
}

start_inhibitor_with_systemd() {
  command_present systemd-run || return 1

  systemd-run \
    --user \
    --quiet \
    --collect \
    --unit="$unit_name" \
    --description="Ryoku caffeine idle inhibitor" \
    systemd-inhibit \
    --what=idle:sleep \
    --who=Ryoku \
    --why="Ryoku caffeine mode" \
    bash -c 'exec -a ryoku-caffeine-inhibit sleep infinity' 9>&- >/dev/null 2>&1
}

start_inhibitor_with_setsid() {
  setsid systemd-inhibit \
    --what=idle:sleep \
    --who=Ryoku \
    --why="Ryoku caffeine mode" \
    bash -c 'exec -a ryoku-caffeine-inhibit sleep infinity' 9>&- >/dev/null 2>&1 &
}

start_inhibitor() {
  if desired_inhibitor_active; then
    if caffeine_unit_active || ! command_present systemd-run systemctl; then
      return 0
    fi
  fi

  pkill -f "$inhibit_pattern" >/dev/null 2>&1 || true
  pkill -f "$legacy_inhibit_pattern" >/dev/null 2>&1 || true

  start_inhibitor_with_systemd || start_inhibitor_with_setsid
}

wait_for_inhibitor() {
  for _ in {1..20}; do
    if desired_inhibitor_active; then
      return 0
    fi
    sleep 0.05
  done

  return 1
}

stop_inhibitor() {
  if command_present systemctl; then
    systemctl --user stop "$unit_name.service" >/dev/null 2>&1 || true
  fi

  pkill -f "$inhibit_pattern" >/dev/null 2>&1 || true
  pkill -f "$legacy_inhibit_pattern" >/dev/null 2>&1 || true
}

hold_caffeine() {
  if desired_inhibitor_active; then
    return 0
  fi

  start_inhibitor
  wait_for_inhibitor
}

release_caffeine() {
  if caffeine_requested; then
    restore_caffeine
    return
  fi

  stop_inhibitor
}

start_caffeine() {
  persist_caffeine_state
  hold_caffeine
}

stop_caffeine() {
  clear_caffeine_state
  stop_inhibitor
}

restore_caffeine() {
  if ! caffeine_requested; then
    return 0
  fi

  start_caffeine
}

toggle_caffeine() {
  if caffeine_requested || caffeine_active; then
    stop_caffeine
  else
    start_caffeine
  fi
}

case "${1:-}" in
  status)
    caffeine_active
    ;;
  start)
    with_caffeine_lock start_caffeine
    ;;
  stop)
    with_caffeine_lock stop_caffeine
    ;;
  restore)
    with_caffeine_lock restore_caffeine
    ;;
  hold)
    with_caffeine_lock hold_caffeine
    ;;
  release)
    with_caffeine_lock release_caffeine
    ;;
  toggle)
    with_caffeine_lock toggle_caffeine
    ;;
  --help|-h|"")
    usage
    ;;
  *)
    echo "ryoku-cmd-caffeine: unknown action: $1" >&2
    usage >&2
    exit 2
    ;;
esac
