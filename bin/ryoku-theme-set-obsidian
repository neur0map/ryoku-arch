#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Sync Ryoku theme to all Obsidian vaults

CURRENT_THEME_DIR="$RYOKU_CONFIG_PATH/current/theme"

[[ -f $CURRENT_THEME_DIR/obsidian.css ]] || exit 0

jq -r '.vaults | values[].path' ~/.config/obsidian/obsidian.json 2>/dev/null | while read -r vault_path; do
  [[ -d $vault_path/.obsidian ]] || continue

  theme_dir="$vault_path/.obsidian/themes/Ryoku"
  mkdir -p "$theme_dir"

  [[ -f $theme_dir/manifest.json ]] || cat >"$theme_dir/manifest.json" <<'EOF'
{
  "name": "Ryoku",
  "version": "1.0.0",
  "minAppVersion": "0.16.0",
  "description": "Automatically syncs with your current Ryoku system theme colors and fonts",
  "author": "Ryoku",
  "authorUrl": "https://github.com/neur0map/ryoku-arch"
}
EOF

  cp "$CURRENT_THEME_DIR/obsidian.css" "$theme_dir/theme.css"
done
