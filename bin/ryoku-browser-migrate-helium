#!/bin/bash

set -euo pipefail

mime_types=(
  x-scheme-handler/http
  x-scheme-handler/https
  x-scheme-handler/mailto
  text/html
  text/xml
  application/xhtml+xml
)

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
choice="${1:-${RYOKU_HELIUM_BROWSER_MIGRATION:-ask}}"
deferred_exit=75

old_browser_command() {
  local browser="$1"

  case $browser in
  "" | firefox | chromium | /usr/bin/firefox | /usr/bin/chromium)
    return 0
    ;;
  *)
    return 1
    ;;
  esac
}

old_browser_desktop() {
  local desktop="$1"

  case $desktop in
  firefox.desktop | chromium.desktop | org.mozilla.firefox.desktop | org.chromium.Chromium.desktop)
    return 0
    ;;
  *)
    return 1
    ;;
  esac
}

has_helium() {
  command -v helium >/dev/null 2>&1 || [[ -x $HOME/.local/bin/helium ]]
}

browser_for_desktop() {
  local desktop="$1"

  case $desktop in
  *chromium*)
    echo "chromium"
    ;;
  *firefox*)
    echo "firefox"
    ;;
  *)
    echo ""
    ;;
  esac
}

desktop_for_browser() {
  local browser="$1"

  case $browser in
  /usr/bin/chromium | chromium)
    echo "chromium.desktop"
    ;;
  /usr/bin/firefox | firefox)
    echo "firefox.desktop"
    ;;
  helium)
    echo "helium.desktop"
    ;;
  *)
    echo "$browser.desktop"
    ;;
  esac
}

config_files() {
  local file

  for file in "$config_home/ryoku-shell/config.json" "$config_home/illogical-impulse/config.json"; do
    [[ -f $file ]] && echo "$file"
  done
}

config_browser() {
  local config_file="$1"

  jq -r '.apps.browser? // ""' "$config_file" 2>/dev/null || true
}

fallback_browser() {
  local xdg_browser="$1"
  local config_file
  local browser

  browser="$(browser_for_desktop "$xdg_browser")"
  if [[ -n $browser ]]; then
    echo "$browser"
    return 0
  fi

  while IFS= read -r config_file; do
    browser="$(config_browser "$config_file")"
    case $browser in
    /usr/bin/chromium)
      echo "chromium"
      return 0
      ;;
    /usr/bin/firefox)
      echo "firefox"
      return 0
      ;;
    chromium | firefox)
      echo "$browser"
      return 0
      ;;
    esac
  done < <(config_files)

  if command -v chromium >/dev/null 2>&1; then
    echo "chromium"
  elif command -v firefox >/dev/null 2>&1; then
    echo "firefox"
  else
    echo "chromium"
  fi
}

set_default_browser_desktop() {
  local desktop_file="$1"
  local mime

  xdg-settings set default-web-browser "$desktop_file" 2>/dev/null || true
  for mime in "${mime_types[@]}"; do
    xdg-mime default "$desktop_file" "$mime" 2>/dev/null || true
  done
}

update_shell_config_to_helium() {
  local config_file="$1"
  local tmp_file

  [[ -f $config_file ]] || return 0
  ryoku-cmd-present jq || return 0

  tmp_file="$(mktemp)"
  if jq '
    def old_browser:
      . == "firefox"
      or . == "chromium"
      or . == "/usr/bin/firefox"
      or . == "/usr/bin/chromium";

    if ((.apps.browser? // "") | old_browser) or ((.apps.browser? // "") == "helium") then
      .apps.browser = "helium"
    else
      .
    end
    | if (.dock.pinnedApps? // []) == ["org.gnome.Nautilus", "firefox", "foot"]
        or (.dock.pinnedApps? // []) == ["org.gnome.Nautilus", "firefox", "kitty"]
        or (.dock.pinnedApps? // []) == ["org.gnome.Nautilus", "chromium", "kitty"]
        or ((.dock.pinnedApps? // []) | index("helium")) then
        .dock.pinnedApps = ["org.gnome.Nautilus", "helium", "kitty"]
      else
        .
      end
    | if (.sidebar.widgets.quickLaunch? | type) == "array" then
        .sidebar.widgets.quickLaunch |= map(
          if (.name == "Browser" and (((.cmd // "") | old_browser) or (.cmd // "") == "helium")) then
            .cmd = "helium"
          else
            .
          end
        )
      else
        .
      end
  ' "$config_file" > "$tmp_file"; then
    mv "$tmp_file" "$config_file"
  else
    rm -f "$tmp_file"
    return 1
  fi
}

restore_missing_helium_config() {
  local config_file="$1"
  local browser="$2"
  local tmp_file

  [[ -f $config_file ]] || return 0
  ryoku-cmd-present jq || return 0

  tmp_file="$(mktemp)"
  if jq --arg browser "$browser" '
    if (.apps.browser? // "") == "helium" then
      .apps.browser = $browser
    else
      .
    end
    | if ((.dock.pinnedApps? // []) | index("helium")) then
        .dock.pinnedApps |= map(if . == "helium" then $browser else . end)
      else
        .
      end
    | if (.sidebar.widgets.quickLaunch? | type) == "array" then
        .sidebar.widgets.quickLaunch |= map(
          if (.name == "Browser" and (.cmd // "") == "helium") then
            .cmd = $browser
          else
            .
          end
        )
      else
        .
      end
  ' "$config_file" > "$tmp_file"; then
    mv "$tmp_file" "$config_file"
  else
    rm -f "$tmp_file"
    return 1
  fi
}

config_needs_helium_offer() {
  local config_file="$1"

  jq -e '
    def old_browser:
      . == "firefox"
      or . == "chromium"
      or . == "/usr/bin/firefox"
      or . == "/usr/bin/chromium"
      or . == "";

    ((.apps.browser? // "") | old_browser)
    or (.dock.pinnedApps? // []) == ["org.gnome.Nautilus", "firefox", "foot"]
    or (.dock.pinnedApps? // []) == ["org.gnome.Nautilus", "firefox", "kitty"]
    or (.dock.pinnedApps? // []) == ["org.gnome.Nautilus", "chromium", "kitty"]
    or (
      (.sidebar.widgets.quickLaunch? | type) == "array"
      and any(.sidebar.widgets.quickLaunch[]; .name == "Browser" and ((.cmd // "") | old_browser))
    )
  ' "$config_file" >/dev/null 2>&1
}

config_has_missing_helium_reference() {
  local config_file="$1"

  jq -e '
    (.apps.browser? // "") == "helium"
    or ((.dock.pinnedApps? // []) | index("helium"))
    or (
      (.sidebar.widgets.quickLaunch? | type) == "array"
      and any(.sidebar.widgets.quickLaunch[]; .name == "Browser" and (.cmd // "") == "helium")
    )
  ' "$config_file" >/dev/null 2>&1
}

ask_to_install_helium() {
  case $choice in
  yes | true | 1)
    return 0
    ;;
  no | false | 0 | skip)
    return 1
    ;;
  ask | "")
    ;;
  *)
    echo "Unknown RYOKU_HELIUM_BROWSER_MIGRATION value: $choice" >&2
    echo "Use yes, no, or ask." >&2
    return 1
    ;;
  esac

  if [[ -t 0 && -t 1 ]] && ryoku-cmd-present gum; then
    gum confirm "Ryoku fresh installs now use Helium. Install Helium and switch this existing install?"
    return $?
  fi

  echo "Ryoku fresh installs now use Helium, but existing installs are not changed without confirmation."
  echo "Run one of these to choose:"
  echo "  ryoku-browser-migrate-helium yes"
  echo "  ryoku-browser-migrate-helium no"
  return "$deferred_exit"
}

main() {
  local xdg_browser
  local fallback
  local fallback_desktop
  local config_file
  local needs_offer=false
  local missing_helium_reference=false
  local ask_status=0

  xdg_browser="$(xdg-settings get default-web-browser 2>/dev/null || true)"

  if old_browser_desktop "$xdg_browser"; then
    needs_offer=true
  fi

  if [[ $xdg_browser == "helium.desktop" ]] && ! has_helium; then
    missing_helium_reference=true
  fi

  while IFS= read -r config_file; do
    if config_needs_helium_offer "$config_file"; then
      needs_offer=true
    fi

    if ! has_helium && config_has_missing_helium_reference "$config_file"; then
      missing_helium_reference=true
    fi
  done < <(config_files)

  if [[ $needs_offer == false && $missing_helium_reference == false ]]; then
    echo "Custom browser settings detected; leaving browser settings unchanged."
    return 0
  fi

  set +e
  ask_to_install_helium
  ask_status=$?
  set -e

  if (( ask_status == deferred_exit )); then
    if [[ $missing_helium_reference == true ]]; then
      fallback="$(fallback_browser "$xdg_browser")"
      fallback_desktop="$(desktop_for_browser "$fallback")"
      while IFS= read -r config_file; do
        restore_missing_helium_config "$config_file" "$fallback"
      done < <(config_files)
      set_default_browser_desktop "$fallback_desktop"
      echo "Helium is not installed yet; restored browser references to $fallback."
    fi
    return "$deferred_exit"
  fi

  if (( ask_status != 0 )); then
    fallback="$(fallback_browser "$xdg_browser")"
    fallback_desktop="$(desktop_for_browser "$fallback")"
    while IFS= read -r config_file; do
      restore_missing_helium_config "$config_file" "$fallback"
    done < <(config_files)
    set_default_browser_desktop "$fallback_desktop"
    echo "Keeping existing browser settings."
    return 0
  fi

  if ! has_helium; then
    if ! ryoku-install-helium-browser; then
      echo "Helium could not be installed. The browser migration will be retried later." >&2
      return "$deferred_exit"
    fi
  fi

  set_default_browser_desktop helium.desktop
  while IFS= read -r config_file; do
    update_shell_config_to_helium "$config_file"
  done < <(config_files)

  echo "Helium is installed and set as the Ryoku browser."
}

main "$@"
