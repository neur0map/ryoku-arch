#!/bin/bash

set -euo pipefail

dry_run=false
allow_auth_prompt=false
script_path="${BASH_SOURCE[0]}"
script_path="$(readlink -f "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
repo_root="$(cd -- "$(dirname -- "$script_path")/.." && pwd)"

if [[ -f $repo_root/lib/runtime-env.sh ]]; then
  # shellcheck disable=SC1091
  source "$repo_root/lib/runtime-env.sh"
else
  export RYOKU_PATH="${RYOKU_PATH:-$HOME/.local/share/ryoku}"
  export RYOKU_INSTALL="${RYOKU_INSTALL:-$RYOKU_PATH/install}"
  case ":$PATH:" in
    *":$RYOKU_PATH/bin:"*) ;;
    *) export PATH="$RYOKU_PATH/bin:$PATH" ;;
  esac
fi

packages=(
)

aur_packages=(
)

usage() {
  cat <<'EOF'
Usage: ryoku-rebirth-prepare-live [--dry-run] [--allow-auth-prompt]

Installs the package set needed to enter the rebirth Hyprland session and
build/run the current Ryoku shell.
It never removes Niri or user applications.
EOF
}

load_manifest() {
  local file="$1"

  [[ -f $file ]] || return 0
  grep -v '^#' "$file" | awk 'NF { print }'
}

while (($# > 0)); do
  case "$1" in
    --dry-run)
      dry_run=true
      ;;
    --allow-auth-prompt)
      allow_auth_prompt=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ryoku-rebirth-prepare-live: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

command_present() {
  command -v "$1" >/dev/null 2>&1
}

package_present() {
  local package="$1"

  if command_present ryoku-pkg-present; then
    ryoku-pkg-present "$package" >/dev/null 2>&1
    return
  fi

  pacman -Q "$package" >/dev/null 2>&1
}

can_install_without_prompt() {
  ((EUID == 0)) && return 0
  command_present sudo && sudo -n true >/dev/null 2>&1
}

refresh_package_metadata() {
  if command_present ryoku-update-keyring; then
    ryoku-update-keyring || true
  elif command_present sudo; then
    sudo pacman -Sy --noconfirm --needed archlinux-keyring >/dev/null 2>&1 || true
  fi

  if command_present sudo; then
    sudo pacman -Sy --noconfirm
  else
    pacman -Sy --noconfirm
  fi
}

print_sessions() {
  local session_dir="/usr/share/wayland-sessions"
  local found=false
  local session

  printf 'Detected Hyprland sessions:\n'
  for session in "$session_dir"/*hypr*.desktop "$session_dir"/*Hypr*.desktop; do
    [[ -f $session ]] || continue
    found=true
    printf '  %s\n' "$session"
  done

  if [[ $found == false ]]; then
    printf '  none\n'
  fi
}

mapfile -t packages < <(load_manifest "$RYOKU_INSTALL/ryoku-base.packages")
mapfile -t aur_packages < <(load_manifest "$RYOKU_INSTALL/ryoku-aur.packages")

missing=()
missing_aur=()
for package in "${packages[@]}"; do
  if package_present "$package"; then
    printf 'present: %s\n' "$package"
  else
    printf 'missing: %s\n' "$package"
    missing+=("$package")
  fi
done

for package in "${aur_packages[@]}"; do
  if package_present "$package"; then
    printf 'present: %s\n' "$package"
  else
    printf 'missing: %s\n' "$package"
    missing_aur+=("$package")
  fi
done

print_sessions

if [[ $dry_run == true ]]; then
  exit 0
fi

if ((${#missing[@]} == 0 && ${#missing_aur[@]} == 0)); then
  printf 'Rebirth Hyprland packages are already present.\n'
  exit 0
fi

if [[ $allow_auth_prompt == false ]] && ! can_install_without_prompt; then
  cat >&2 <<'EOF'
ryoku-rebirth-prepare-live: root authorization is required and no cached sudo session is available.
Re-run while present with:
  ryoku-rebirth-prepare-live --allow-auth-prompt
EOF
  exit 77
fi

refresh_package_metadata

if command_present ryoku-pkg-add; then
  ryoku-pkg-add "${missing[@]}"
else
  if ((${#missing[@]} > 0)); then
    sudo pacman -S --needed --noconfirm "${missing[@]}"
  fi
fi

if ((${#missing_aur[@]} > 0)); then
  if command_present ryoku-pkg-aur-add; then
    ryoku-pkg-aur-add "${missing_aur[@]}"
  elif command_present yay; then
    yay -S --needed --noconfirm "${missing_aur[@]}"
  else
    cat >&2 <<'EOF'
ryoku-rebirth-prepare-live: AUR packages are required for the current Ryoku shell.
Install yay or restore ryoku-pkg-aur-add, then re-run this command.
EOF
    exit 77
  fi
fi

print_sessions
