#!/bin/bash
set -euo pipefail

QYLOCK_DIR="${1:-$HOME/.local/share/qylock}"
THEMES_DIR="$QYLOCK_DIR/themes"
ASSETS_DIR="$QYLOCK_DIR/Assets"

if [[ ! -d $THEMES_DIR ]]; then
  echo "ryoku-refresh-qylock-previews: qylock themes dir not found: $THEMES_DIR" >&2
  exit 1
fi

valid_image() {
  local path="$1" mime

  [[ -s $path ]] || return 1
  mime=$(file -b --mime-type "$path" 2>/dev/null || true)
  [[ $mime == "image/png" || $mime == "image/jpeg" || $mime == "image/gif" || $mime == "image/webp" ]]
}

# Generic name variants for a theme's shared preview asset in Assets/ (qylock
# names them in snake_case, kebab-case, or lowercase; no per-theme hardcoding).
asset_base_names() {
  local theme="$1"
  local lower="${theme,,}"
  local snake="${lower//-/_}"
  local kebab="${lower//_/-}"
  local -A seen=()
  local value

  for value in "$snake" "$lower" "$kebab" "$theme"; do
    [[ -n $value && -z ${seen[$value]+x} ]] || continue
    seen[$value]=1
    printf '%s\n' "$value"
  done
}

render_image_preview() {
  local source="$1" target="$2" tmp

  tmp="${target}.tmp.$$.png"

  rm -f "$tmp"
  if command -v magick >/dev/null 2>&1; then
    if magick "${source}[0]" -auto-orient -resize '480x270^' -gravity center -extent 480x270 "$tmp" >/dev/null 2>&1; then
      mv "$tmp" "$target"
      return 0
    fi
  fi

  rm -f "$tmp"
  if valid_image "$source"; then
    cp -f "$source" "$target"
    return 0
  fi

  return 1
}

render_video_preview() {
  local source="$1" target="$2" tmp

  tmp="${target}.tmp.$$.png"

  command -v ffmpeg >/dev/null 2>&1 || return 1
  [[ -s $source ]] || return 1

  rm -f "$tmp"
  if ffmpeg -hide_banner -loglevel error -y -ss 1 -i "$source" -frames:v 1 \
    -vf "scale=480:270:force_original_aspect_ratio=increase,crop=480:270" \
    "$tmp" >/dev/null 2>&1; then
    mv "$tmp" "$target"
    return 0
  fi

  rm -f "$tmp"
  return 1
}

image_candidates() {
  local theme="$1" theme_dir="$2" base ext parent
  parent="$(basename "$(dirname "$theme_dir")")"
  # Generic background conventions only (no theme-specific filenames).
  local paths=(
    "$theme_dir/bg.png" "$theme_dir/bg.jpg" "$theme_dir/bg.jpeg"
    "$theme_dir/bg.gif" "$theme_dir/bg.webp"
    "$theme_dir/background.png" "$theme_dir/background.jpg" "$theme_dir/background.jpeg"
    "$theme_dir/background.gif" "$theme_dir/background.webp"
  )

  printf '%s\n' "${paths[@]}"
  # Shared Assets/ preview matched by the theme's name variants, then (for nested
  # variants like clockwork/orbital) its parent dir name, so they use the shared
  # Assets/clockwork.gif instead of a flat swatch.
  while IFS= read -r base; do
    for ext in gif png jpg jpeg webp; do
      printf '%s\n' "$ASSETS_DIR/$base.$ext"
    done
  done < <(asset_base_names "$theme"; [ "$parent" != "themes" ] && asset_base_names "$parent")

  find "$theme_dir" -maxdepth 3 -type f \
    \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.gif' -o -iname '*.webp' \) \
    ! -iname 'preview.png' ! -iname 'logo.*' ! -iname 'title.*' \
    -print 2>/dev/null | sort
}

video_candidates() {
  local theme_dir="$1"

  printf '%s\n' \
    "$theme_dir/bg.mp4" \
    "$theme_dir/background.mp4"
  find "$theme_dir" -maxdepth 3 -type f \
    \( -iname '*.mp4' -o -iname '*.mov' -o -iname '*.mkv' -o -iname '*.webm' \) \
    -print 2>/dev/null | sort
}

candidate_newer_than_preview() {
  local preview="$1" source

  while IFS= read -r source; do
    [[ -f $source ]] || continue
    if [[ $source -nt $preview ]]; then
      return 0
    fi
  done

  return 1
}

# Solid-colour preview for themes whose theme.conf declares a colour background
# (e.g. the bundled clockwork variants: type=color). They have no image/video
# source, so without this they render the "No preview" placeholder forever.
render_color_preview() {
  local theme_dir="$1" target="$2" conf color tmp

  conf="$theme_dir/theme.conf"
  [[ -f $conf ]] || return 1
  grep -qiE '^[[:space:]]*type[[:space:]]*=[[:space:]]*color([[:space:]]|$)' "$conf" || return 1
  color=$(sed -nE 's/^[[:space:]]*color[[:space:]]*=[[:space:]]*([^[:space:]]+).*/\1/Ip' "$conf" | head -n1)
  [[ -n $color ]] || color="#000000"
  command -v magick >/dev/null 2>&1 || return 1

  tmp="${target}.tmp.$$.png"
  rm -f "$tmp"
  if magick -size 480x270 "xc:${color}" "$tmp" >/dev/null 2>&1; then
    mv "$tmp" "$target"
    return 0
  fi
  rm -f "$tmp"
  return 1
}

refresh_theme_preview() {
  local theme_dir="$1"
  local theme preview source

  theme="$(basename "$theme_dir")"
  preview="$theme_dir/preview.png"

  if valid_image "$preview" && ! candidate_newer_than_preview "$preview" < <(
    image_candidates "$theme" "$theme_dir"
    video_candidates "$theme_dir"
  ); then
    return 0
  fi

  while IFS= read -r source; do
    [[ -f $source ]] || continue
    valid_image "$source" || continue
    if render_image_preview "$source" "$preview"; then
      echo "  preview ready: $theme"
      return 0
    fi
  done < <(image_candidates "$theme" "$theme_dir")

  while IFS= read -r source; do
    [[ -f $source ]] || continue
    if render_video_preview "$source" "$preview"; then
      echo "  preview ready: $theme"
      return 0
    fi
  done < <(video_candidates "$theme_dir")

  if render_color_preview "$theme_dir" "$preview"; then
    echo "  preview ready (color): $theme"
    return 0
  fi

  echo "  preview unavailable: $theme" >&2
  return 0
}

main() {
  local main_qml theme_dir

  # Process every theme variant (a dir containing Main.qml), including nested
  # ones like clockwork/orbital and clockwork/tape, matching how LockThemes.qml
  # scans. The old depth-1 loop skipped nested variants so they never got a
  # preview.png.
  while IFS= read -r main_qml; do
    theme_dir="$(dirname "$main_qml")"
    refresh_theme_preview "$theme_dir"
  done < <(find "$THEMES_DIR" -mindepth 1 -maxdepth 3 -name Main.qml -print 2>/dev/null | sort)
}

main "$@"
