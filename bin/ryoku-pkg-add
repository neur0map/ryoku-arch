#!/bin/bash

# Add the named packages to the system if they're missing. Returns false if it couldn't be done.

if (( $# == 0 )); then
  exit 0
fi

mapfile -t missing_packages < <(pacman -T "$@")

if (( ${#missing_packages[@]} > 0 )); then
  sudo pacman -S --noconfirm --needed "${missing_packages[@]}" || exit 1
fi

mapfile -t missing_packages < <(pacman -T "$@")

if (( ${#missing_packages[@]} > 0 )); then
  printf '\033[31mError: Package dependencies did not install: %s\033[0m\n' "${missing_packages[*]}" >&2
  exit 1
fi

exit 0
