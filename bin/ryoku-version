#!/bin/bash

# Prints Ryoku Arch version on a single line.
# Public preview: version is derived from the git tip until tagged releases.

RYOKU_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
export RYOKU_PATH
source "$RYOKU_PATH/lib/runtime-env.sh"

version="preview"
if [[ -d $RYOKU_PATH/.git ]]; then
  tip=$(git -C "$RYOKU_PATH" rev-parse --short HEAD 2>/dev/null)
  [[ -n $tip ]] && version="$version (g$tip)"
fi

echo "$version"
