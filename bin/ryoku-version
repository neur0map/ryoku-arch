#!/bin/bash

# Prints Ryoku Arch version and current HEAD.
# Pre-alpha: version is derived from the git tip, not a tagged release.

OMARCHY_PATH="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"

echo "Ryoku Arch (pre-alpha)"
if [[ -d $OMARCHY_PATH/.git ]]; then
  tip=$(git -C "$OMARCHY_PATH" rev-parse --short HEAD 2>/dev/null)
  [[ -n $tip ]] && echo "HEAD: $tip"
fi
