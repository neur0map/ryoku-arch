#!/bin/bash

# Prints Ryoku Arch version and current HEAD.
# Pre-alpha: version is derived from the git tip, not a tagged release.

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

echo "Ryoku Arch (pre-alpha)"
if [[ -d $RYOKU_PATH/.git ]]; then
  tip=$(git -C "$RYOKU_PATH" rev-parse --short HEAD 2>/dev/null)
  [[ -n $tip ]] && echo "HEAD: $tip"
fi
