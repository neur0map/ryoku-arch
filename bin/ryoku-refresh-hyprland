#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Overwrite all the user configs in ~/.config/hypr with the Ryoku defaults.

ryoku-refresh-config hypr/autostart.conf
ryoku-refresh-config hypr/bindings.conf
ryoku-refresh-config hypr/input.conf
ryoku-refresh-config hypr/looknfeel.conf
ryoku-refresh-config hypr/hyprland.conf
bash "$RYOKU_PATH/install/config/detect-keyboard-layout.sh"
