#!/usr/bin/env bash
# print the Ryoku version string for a release channel. base semver comes from
# the repo root VERSION file (X.Y.Z).
#
#   --channel main
#       -> v<VERSION>                       (e.g. v0.1.0)
#   --channel unstable-dev --build-number <N> --sha <SHA>
#       -> v<VERSION>.dev.<N>+g<short-sha>  (e.g. v0.1.0.dev.42+gabc1234)
set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
version_file="$ROOT/VERSION"
[[ -f $version_file ]] || { echo "ryoku-release-version: missing $version_file" >&2; exit 1; }
base=$(tr -d '[:space:]' < "$version_file")

channel=main
build_number=0
sha=""
pkgver_mode=0
while (($#)); do
  case "$1" in
    --channel) channel=${2:?}; shift 2 ;;
    --build-number) build_number=${2:?}; shift 2 ;;
    --sha) sha=${2:-}; shift 2 ;;
    --pkgver) pkgver_mode=1; shift ;;
    *) echo "ryoku-release-version: unknown argument: $1" >&2; exit 2 ;;
  esac
done

# --pkgver = a pacman-valid, strictly increasing, commit-identifiable version
# for the monorepo packages. core semver (any -alpha/-beta suffix stripped, a
# pacman pkgver can't contain '-') + commit count + short sha. every commit
# yields a higher version pacman upgrades to, and the gNNNN token lets the Hub
# and `ryoku status` show the exact commit a machine runs.
if (( pkgver_mode )); then
  core=${base%%-*}
  if [[ -n $sha ]]; then
    short=${sha:0:7}
  else
    short=$(git -C "$ROOT" rev-parse --short=7 HEAD 2>/dev/null || echo 0000000)
  fi
  count=$(git -C "$ROOT" rev-list --count HEAD 2>/dev/null || echo 0)
  printf '%s.r%s.g%s\n' "$core" "$count" "$short"
  exit 0
fi

case "$channel" in
  main)
    printf 'v%s\n' "$base"
    ;;
  unstable-dev)
    short=${sha:0:7}
    [[ -n $short ]] || short=0000000
    printf 'v%s.dev.%s+g%s\n' "$base" "$build_number" "$short"
    ;;
  *)
    echo "ryoku-release-version: unknown channel: $channel" >&2
    exit 2
    ;;
esac
