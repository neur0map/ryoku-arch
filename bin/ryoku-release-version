#!/bin/bash

set -euo pipefail

ROOT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

usage() {
  cat <<'USAGE'
Usage: ryoku-release-version [--channel main|unstable-dev] [--build-number N] [--sha SHA] [--version VERSION]

Prints the public Ryoku version for a release channel.

main prints the tracked release version.
unstable-dev prints the tracked release target plus a dev build and commit.
USAGE
}

die() {
  echo "ryoku-release-version: $1" >&2
  exit 1
}

channel="${RYOKU_RELEASE_CHANNEL:-}"
build_number="${RYOKU_RELEASE_BUILD:-${GITHUB_RUN_NUMBER:-}}"
commit_sha="${RYOKU_RELEASE_SHA:-${GITHUB_SHA:-}}"
explicit_version="${RYOKU_RELEASE_VERSION:-}"
version_file="$ROOT_DIR/VERSION"

while (( $# > 0 )); do
  case "$1" in
    --channel)
      (( $# >= 2 )) || die "--channel requires a value"
      channel="$2"
      shift 2
      ;;
    --build-number)
      (( $# >= 2 )) || die "--build-number requires a value"
      build_number="$2"
      shift 2
      ;;
    --sha)
      (( $# >= 2 )) || die "--sha requires a value"
      commit_sha="$2"
      shift 2
      ;;
    --version)
      (( $# >= 2 )) || die "--version requires a value"
      explicit_version="$2"
      shift 2
      ;;
    --version-file)
      (( $# >= 2 )) || die "--version-file requires a path"
      version_file="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

read_tracked_version() {
  if [[ -n $explicit_version ]]; then
    printf '%s\n' "$explicit_version"
    return
  fi

  [[ -f $version_file ]] || die "missing VERSION file at $version_file"
  head -1 "$version_file" | tr -d '[:space:]'
}

current_branch() {
  if [[ -n ${GITHUB_REF_NAME:-} ]]; then
    printf '%s\n' "$GITHUB_REF_NAME"
    return
  fi

  git -C "$ROOT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || printf '%s\n' "main"
}

commit_short() {
  local sha="$commit_sha"

  if [[ -z $sha ]]; then
    sha="$(git -C "$ROOT_DIR" rev-parse --short=7 HEAD 2>/dev/null || true)"
  fi

  sha="${sha#g}"
  sha="${sha:0:7}"
  [[ -n $sha ]] || sha="unknown"
  printf '%s\n' "$sha"
}

commit_count() {
  if [[ -n $build_number ]]; then
    printf '%s\n' "$build_number"
    return
  fi

  git -C "$ROOT_DIR" rev-list --count HEAD 2>/dev/null || printf '%s\n' "0"
}

normalize_version() {
  local raw="$1"
  local metadata=""
  local prerelease=""
  local core=""

  raw="${raw#v}"
  [[ -n $raw ]] || die "empty version"

  if [[ $raw == *+* ]]; then
    metadata="+${raw#*+}"
    raw="${raw%%+*}"
  fi

  if [[ $raw == *-* ]]; then
    core="${raw%%-*}"
    prerelease="${raw#*-}"
  else
    core="$raw"
  fi

  [[ $core =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "VERSION must start with MAJOR.MINOR.PATCH"

  if [[ -n $prerelease ]]; then
    if [[ $prerelease =~ ^(alpha|beta|rc)-([0-9]+)$ ]]; then
      prerelease="${BASH_REMATCH[1]}.${BASH_REMATCH[2]}"
    fi
    printf '%s-%s%s\n' "$core" "$prerelease" "$metadata"
  else
    printf '%s%s\n' "$core" "$metadata"
  fi
}

if [[ -z $channel ]]; then
  channel="$(current_branch)"
fi

tracked_version="$(normalize_version "$(read_tracked_version)")"

case "$channel" in
  unstable-dev)
    build="$(commit_count)"
    [[ $build =~ ^[0-9]+$ ]] || die "unstable-dev build number must be numeric"
    stable_target="${tracked_version%%+*}"
    if [[ $stable_target == *-* ]]; then
      printf 'v%s.dev.%s+g%s\n' "$stable_target" "$build" "$(commit_short)"
    else
      printf 'v%s-dev.%s+g%s\n' "$stable_target" "$build" "$(commit_short)"
    fi
    ;;
  main|stable)
    printf 'v%s\n' "$tracked_version"
    ;;
  *)
    die "unsupported release channel: $channel"
    ;;
esac
