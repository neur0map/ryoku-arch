#!/bin/bash
# Audit Ryoku shell IPC <-> keybind parity.
#
# Catches the regression class where a keybind dispatches to a shell IPC target
# or function that the shell does not actually register: the key silently does
# nothing (e.g. a handler is renamed/removed but its `ryoku-shell ipc ...` bind
# is left behind).
#
# Source of truth for the IPC surface is the LIVE registry (`ryoku-shell ipc
# show`). When no shell is running (CI), it falls back to the committed manifest
# at shell/ipc-surface.txt. Run with --refresh to regenerate that manifest from
# the live shell after adding or renaming IPC handlers.
#
# Usage:
#   ryoku-dev-audit-shell-binds            # check (default); nonzero on dangling binds
#   ryoku-dev-audit-shell-binds --check
#   ryoku-dev-audit-shell-binds --refresh  # regenerate shell/ipc-surface.txt
#   ryoku-dev-audit-shell-binds --report   # also print unbound handlers (informational)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RYOKU_PATH="${RYOKU_PATH:-$(cd "$SCRIPT_DIR/.." && pwd)}"
MANIFEST="$RYOKU_PATH/shell/ipc-surface.txt"

ipc_show() {
  # CI / tests force the committed-manifest path (no running shell).
  [[ -n ${RYOKU_AUDIT_FORCE_MANIFEST:-} ]] && return 0
  env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST ryoku-shell ipc show 2>/dev/null || true
}

# Emit "target function" pairs from `ryoku-shell ipc show` text on stdin.
parse_pairs() {
  awk '
    /^target / { t = $2; next }
    /^[[:space:]]+function / {
      f = $2; sub(/\(.*/, "", f)
      if (t != "" && f != "") print t " " f
    }
  '
}

load_surface() {
  local live
  live="$(ipc_show)"
  if [[ -n $live ]]; then
    printf '%s\n' "$live" | parse_pairs | sort -u
  elif [[ -f $MANIFEST ]]; then
    parse_pairs <"$MANIFEST" | sort -u
  else
    echo "audit: no live shell (ryoku-shell ipc show) and no manifest at $MANIFEST" >&2
    return 1
  fi
}

# "target function" invocations from every `ryoku-shell ipc <t> <f>` callsite.
invocations() {
  grep -rhoE 'ryoku-shell ipc [a-zA-Z_]+ [a-zA-Z_]+' \
    "$RYOKU_PATH/config/hypr" "$RYOKU_PATH/bin" "$RYOKU_PATH/shell/scripts" 2>/dev/null \
    | sed -E 's/^ryoku-shell ipc //' | sort -u || true
}

cmd_refresh() {
  local live
  live="$(ipc_show)"
  [[ -n $live ]] || {
    echo "refresh: 'ryoku-shell ipc show' produced nothing; is the shell running?" >&2
    return 1
  }
  {
    echo "# Ryoku shell IPC surface (target + functions)."
    echo "# Generated by: ryoku-dev-audit-shell-binds --refresh. Do not hand-edit."
    printf '%s\n' "$live"
  } >"$MANIFEST"
  echo "Wrote $MANIFEST ($(printf '%s\n' "$live" | parse_pairs | wc -l) functions across $(printf '%s\n' "$live" | grep -c '^target ') targets)."
}

cmd_check() {
  local report="${1:-}"
  local pairs fail=0
  pairs="$(load_surface)" || return 2

  local inv
  while IFS= read -r inv; do
    [[ -z $inv ]] && continue
    if ! grep -qxF "$inv" <<<"$pairs"; then
      echo "DANGLING BIND: 'ryoku-shell ipc $inv' has no matching IPC handler" >&2
      fail=1
    fi
  done < <(invocations)

  if [[ $report == "--report" ]]; then
    echo "# IPC handlers with no keybind (informational, not a failure):"
    local p
    while IFS= read -r p; do
      [[ -z $p ]] && continue
      grep -qxF "$p" < <(invocations) || echo "  $p"
    done <<<"$pairs"
  fi

  if (( fail )); then
    echo "audit: dangling keybind(s) found. Fix the bind or run --refresh if the handler is new." >&2
    return 1
  fi
  echo "audit: shell IPC <-> keybind parity OK ($(wc -l <<<"$pairs") handler functions, $(invocations | wc -l) bound)."
}

case "${1:---check}" in
  --refresh) cmd_refresh ;;
  --report) cmd_check --report ;;
  --check | "") cmd_check ;;
  *) echo "usage: ryoku-dev-audit-shell-binds [--check|--refresh|--report]" >&2; exit 2 ;;
esac
