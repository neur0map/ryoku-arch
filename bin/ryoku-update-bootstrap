#!/bin/bash

set -euo pipefail

script_path="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s\n' "${BASH_SOURCE[0]}")"
repo_root="$(cd -- "$(dirname -- "$script_path")/.." 2>/dev/null && pwd || true)"
local_medevac="$repo_root/bin/ryoku-call911now"
requested_medevac_branch="${RYOKU_UPDATE_BRANCH:-}"
medevac_branch="${requested_medevac_branch:-unstable-dev}"
medevac_env=(RYOKU_MEDEVAC_COMPAT_BOOTSTRAP=1)

case "$medevac_branch" in
  main | unstable-dev) ;;
  *)
    printf '%s\n' "WARN: ignoring invalid Ryoku MedEvac branch '$medevac_branch'; using main" >&2
    medevac_branch="main"
    requested_medevac_branch="$medevac_branch"
    ;;
esac

if [[ -n $requested_medevac_branch ]]; then
  medevac_env+=(RYOKU_UPDATE_BRANCH="$medevac_branch")
fi

raw_medevac_url="${RYOKU_MEDEVAC_URL:-https://raw.githubusercontent.com/neur0map/ryoku-arch/$medevac_branch/bin/ryoku-call911now}"

if [[ -x $local_medevac ]]; then
  exec env "${medevac_env[@]}" "$local_medevac" "$@"
fi

set -o pipefail

if command -v curl >/dev/null 2>&1; then
  curl -fsSL "$raw_medevac_url" | env "${medevac_env[@]}" bash -s -- "$@"
  exit $?
fi

if command -v wget >/dev/null 2>&1; then
  wget -qO- "$raw_medevac_url" | env "${medevac_env[@]}" bash -s -- "$@"
  exit $?
fi

printf '%s\n' "ERROR: ryoku-update-bootstrap now routes through ryoku-call911now, but curl/wget is missing" >&2
exit 1
