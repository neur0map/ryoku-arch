#!/bin/bash

# Recover Ryoku session UI after suspend, lid resume, or DRM wake delays.

set -euo pipefail

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

QUIET=false
RESUME=false

usage() {
  cat <<'USAGE'
Usage:
  ryoku-session-recover [--quiet] [--resume]

Refreshes the compositor-facing session state, powers compositor outputs back on,
cleans stale Ryoku helpers, and restarts Ryoku UI components.
USAGE
}

for arg in "$@"; do
  case "$arg" in
  --quiet)
    QUIET=true
    ;;
  --resume)
    RESUME=true
    ;;
  --help)
    usage
    exit 0
    ;;
  *)
    echo "ryoku-session-recover: unknown option: $arg" >&2
    usage >&2
    exit 2
    ;;
  esac
done

log() {
  if [[ $QUIET == "false" ]]; then
    printf '%s\n' "$1"
  fi
}

command_present() {
  ryoku-cmd-present "$1"
}

refresh_activation_environment() {
  if command_present systemctl; then
    systemctl --user import-environment \
      DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE HYPRLAND_INSTANCE_SIGNATURE XCURSOR_THEME XCURSOR_SIZE HYPRCURSOR_THEME HYPRCURSOR_SIZE \
      >/dev/null 2>&1 || true
  fi

  if command_present dbus-update-activation-environment; then
    dbus-update-activation-environment --systemd --all >/dev/null 2>&1 || true
  fi
}

hyprland_active() {
  [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] && return 0
  [[ ${XDG_CURRENT_DESKTOP:-} == *"Hyprland"* ]] && return 0
  command_present pgrep && pgrep -x Hyprland >/dev/null 2>&1
}

power_on_hyprland_monitors() {
  command_present hyprctl || return 1

  log "power on Hyprland monitors"
  hyprctl dispatch dpms on >/dev/null 2>&1 || true
}

cleanup_shell_helpers() {
  if command_present ryoku-shell-cleanup-orphans; then
    ryoku-shell-cleanup-orphans --quiet
  fi
}

restart_session_ui() {
  if command_present ryoku-restart-ui; then
    ryoku-restart-ui --quiet
  fi
}

restore_audio_mixers() {
  [[ $RESUME == "true" ]] || return 0

  if command_present ryoku-audio-restore-mixers; then
    ryoku-audio-restore-mixers >/dev/null 2>&1 || true
  fi
}

# Serialize concurrent recoveries. On resume this can fire more than once (the
# user-bus resume listener plus the root system-sleep hook); without a guard the runs race in
# ryoku-restart-shell (status-then-try-restart TOCTOU) and can leave the shell stopped
# with no restart. Hold a non-blocking lock so a second concurrent run skips cleanly;
# flock releases it automatically when this process exits.
recover_lock="${XDG_RUNTIME_DIR:-/tmp}/ryoku-session-recover.lock"
if command_present flock && exec 9>"$recover_lock" 2>/dev/null; then
  if ! flock -n 9; then
    log "another session recovery is already running; skipping"
    exit 0
  fi
fi

if [[ $RESUME == "true" ]]; then
  sleep 1
fi

log "Ryoku session recovery"
refresh_activation_environment
restore_audio_mixers
if hyprland_active; then
  power_on_hyprland_monitors || true
fi
cleanup_shell_helpers
restart_session_ui
