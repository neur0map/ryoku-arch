#!/bin/bash
set -euo pipefail

script_path="$(readlink -f "${BASH_SOURCE[0]}")"
script_dir="${script_path%/*}"

if [[ $script_dir == "$script_path" ]]; then
  script_dir=.
fi

script_dir="$(cd "$script_dir" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

cd "$repo_root"

chunk="${1:?chunk name required}"

doc_globs=(
  "--glob" "!docs/specs/*"
  "--glob" "!docs/plans/*"
  "--glob" "!docs/superpowers/specs/*"
)

existing_paths=()

collect_existing_paths() {
  local path

  for path in "$@"; do
    if [[ -e $path ]]; then
      existing_paths+=("$path")
    fi
  done
}

run_rg() {
  local status

  set +e
  rg -n "${doc_globs[@]}" "$@"
  status=$?
  set -e

  case $status in
    0)
      exit 1
      ;;
    1)
      return 0
      ;;
    *)
      echo "rg failed for chunk: $chunk" >&2
      exit "$status"
      ;;
  esac
}

case "$chunk" in
  foundation)
    collect_existing_paths install.sh default/bash/envs config/uwsm/env

    if (( ${#existing_paths[@]} == 0 )); then
      echo "no target paths exist for chunk: $chunk" >&2
      exit 1
    fi

    command -v rg >/dev/null || { echo "missing command: rg" >&2; exit 1; }
    run_rg 'OMARCHY_PATH|~/.local/share/omarchy' "${existing_paths[@]}"
    ;;
  hypr)
    collect_existing_paths config/hypr default/hypr

    if (( ${#existing_paths[@]} == 0 )); then
      echo "no target paths exist for chunk: $chunk" >&2
      exit 1
    fi

    command -v rg >/dev/null || { echo "missing command: rg" >&2; exit 1; }
    run_rg 'omarchy-|/omarchy|\.config/omarchy|\.local/state/omarchy' "${existing_paths[@]}"
    ;;
  waybar)
    collect_existing_paths config/waybar config/walker default/mako config/fastfetch

    if (( ${#existing_paths[@]} == 0 )); then
      echo "no target paths exist for chunk: $chunk" >&2
      exit 1
    fi

    command -v rg >/dev/null || { echo "missing command: rg" >&2; exit 1; }
    run_rg 'omarchy-|OMARCHY_PATH|/omarchy|\.config/omarchy' "${existing_paths[@]}"
    ;;
  *)
    echo "unknown chunk: $chunk" >&2
    exit 1
    ;;
esac
