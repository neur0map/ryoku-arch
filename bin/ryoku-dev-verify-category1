#!/bin/bash
set -euo pipefail

resolve_script_path() {
  local path="$1"
  local link_target link_dir

  while [[ -L $path ]]; do
    if ! command -v readlink >/dev/null; then
      echo "missing command: readlink" >&2
      return 1
    fi

    if ! link_target="$(readlink "$path")"; then
      echo "failed to resolve script path: $path" >&2
      return 1
    fi

    if [[ $link_target == /* ]]; then
      path="$link_target"
    else
      link_dir="${path%/*}"
      if [[ $link_dir == "$path" ]]; then
        link_dir=.
      fi
      path="$link_dir/$link_target"
    fi
  done

  printf '%s\n' "$path"
}

script_path="$(resolve_script_path "${BASH_SOURCE[0]}")"
script_dir="${script_path%/*}"

if [[ $script_dir == "$script_path" ]]; then
  script_dir=.
fi

script_dir="$(cd -P "$script_dir" && pwd -P)"
repo_root="$(cd -P "$script_dir/.." && pwd -P)"

cd "$repo_root"

chunk="${1:?chunk name required}"

doc_globs=(
  "--glob" "!docs/specs/*"
  "--glob" "!docs/plans/*"
)

existing_paths=()

collect_existing_paths() {
  local path

  for path in "$@"; do
    if [[ -e $path ]]; then
      existing_paths+=("$path")
    fi
  done
}

run_rg() {
  local status

  set +e
  rg -n "${doc_globs[@]}" "$@"
  status=$?
  set -e

  case $status in
    0)
      exit 1
      ;;
    1)
      return 0
      ;;
    *)
      echo "rg failed for chunk: $chunk" >&2
      exit "$status"
      ;;
  esac
}

case "$chunk" in
  foundation)
    collect_existing_paths install.sh default/bash/envs config/niri/config.d/40-environment.kdl

    if (( ${#existing_paths[@]} == 0 )); then
      echo "no target paths exist for chunk: $chunk" >&2
      exit 1
    fi

    command -v rg >/dev/null || { echo "missing command: rg" >&2; exit 1; }
    run_rg 'OMARCHY_PATH|~/.local/share/omarchy' "${existing_paths[@]}"
    ;;
  niri)
    collect_existing_paths config/niri config/fuzzel config/systemd/user/inir.service

    if (( ${#existing_paths[@]} == 0 )); then
      echo "no target paths exist for chunk: $chunk" >&2
      exit 1
    fi

    command -v rg >/dev/null || { echo "missing command: rg" >&2; exit 1; }
    run_rg 'omarchy-|/omarchy|\.config/omarchy|\.local/state/omarchy' "${existing_paths[@]}"
    ;;
  shell)
    collect_existing_paths config/niri config/fuzzel config/fastfetch

    if (( ${#existing_paths[@]} == 0 )); then
      echo "no target paths exist for chunk: $chunk" >&2
      exit 1
    fi

    command -v rg >/dev/null || { echo "missing command: rg" >&2; exit 1; }
    run_rg 'omarchy-|OMARCHY_PATH|/omarchy|\.config/omarchy' "${existing_paths[@]}"
    ;;
  *)
    echo "unknown chunk: $chunk" >&2
    exit 1
    ;;
esac
