#!/bin/bash

# Repair invalid bare multimedia keysyms in HyprMod's generated Hyprland config.
#
# HyprMod (the AUR Hyprland settings GUI) can write a multimedia key by its bare
# name, e.g. "Tools", into ~/.config/hypr/hyprland-gui.{lua,conf}. Hyprland's
# keysym parser only accepts the XF86-prefixed form ("XF86Tools"); a bare name
# fails the WHOLE config load, so Hyprland reverts to defaults: keybinds stop
# working and the monitor comes up unscaled. This rewrites the known bare
# multimedia keynames to their XF86 keysyms so the config parses again.
#
# This is a defensive repair around an upstream HyprMod serialization gap; it is
# idempotent and only ever touches HyprMod-owned files.
#
# Usage:
#   ryoku-hypr-fix-keysyms          repair in place (reloads Hyprland if live)
#   ryoku-hypr-fix-keysyms --check  report only; exit 1 if a bad keysym is present

set -uo pipefail

mode="${1:-repair}"
cfg="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"

# Bare device/multimedia keynames that are invalid in Hyprland but valid as XF86*.
# Ambiguous English words (Back, Forward, Stop, Search, Reload, ...) are excluded
# so a dispatcher name or command argument is never rewritten.
keynames=(
  Tools Calculator Mail WWW Explorer HomePage Favorites Documents
  MyComputer Computer Eject ScreenSaver AudioMedia AudioMicMute
  MonBrightnessUp MonBrightnessDown KbdBrightnessUp KbdBrightnessDown
  KbdLightOnOff Battery Bluetooth WLAN Sleep WakeUp Suspend Hibernate
)

found=0
changed=0

for f in "$cfg/hyprland-gui.lua" "$cfg/hyprland-gui.conf"; do
  [[ -f $f ]] || continue
  for name in "${keynames[@]}"; do
    # The keysym must stand alone as a token bounded by a quote, comma or space on
    # both sides (covers "Name", ", Name," and "MODS, Name"); embedded text and an
    # already-correct XF86Name are left untouched, which keeps the pass idempotent.
    if grep -qE "[\",[:space:]]${name}[\",[:space:]]" "$f"; then
      found=1
      if [[ $mode == "--check" ]]; then
        echo "ryoku-hypr-fix-keysyms: invalid bare keysym \"$name\" in $f"
        continue
      fi
      sed -i -E "s|([\",[:space:]])${name}([\",[:space:]])|\1XF86${name}\2|g" "$f"
      echo "ryoku-hypr-fix-keysyms: $f: $name -> XF86$name"
      changed=1
    fi
  done
done

if [[ $mode == "--check" ]]; then
  if (( found )); then
    exit 1
  fi
  exit 0
fi

if (( changed )) && command -v hyprctl >/dev/null 2>&1 && [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
  hyprctl reload >/dev/null 2>&1 || true
fi
exit 0
