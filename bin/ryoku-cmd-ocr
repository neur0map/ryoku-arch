#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Select a screen region, run OCR on it, and copy the recognized text to the
# clipboard. Self-contained (grim + slurp + tesseract + wl-copy) — the previous
# "ryoku-shell region ocr" delegation pointed at a shell IPC target that no longer
# exists, so OCR silently did nothing.

for cmd in grim slurp tesseract wl-copy notify-send; do
  if ryoku-cmd-missing "$cmd"; then
    notify-send -u normal "OCR" "$cmd is not installed"
    exit 1
  fi
done

tmp_dir="${XDG_RUNTIME_DIR:-/tmp}"
tmp="$(mktemp "$tmp_dir/ryoku-ocr.XXXXXX.png")"
trap 'rm -f "$tmp"' EXIT

# Region select (Esc/cancel → exit quietly)
if ! geometry="$(slurp 2>/dev/null)"; then
  exit 130
fi
[[ -z $geometry ]] && exit 0

grim -g "$geometry" "$tmp"

# Recognize text (command substitution trims trailing newlines)
text="$(tesseract "$tmp" - 2>/dev/null || true)"

if [[ -z ${text//[[:space:]]/} ]]; then
  notify-send -u normal "OCR" "No text recognized in the selected region"
  exit 0
fi

printf '%s' "$text" | wl-copy
notify-send -u low "OCR" "Recognized text copied to clipboard"
