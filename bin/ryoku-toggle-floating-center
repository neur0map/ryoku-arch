#!/bin/bash

set -euo pipefail

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
runtime_env="$script_root/lib/runtime-env.sh"
fallback_runtime_env="${RYOKU_PATH:-$HOME/.local/share/ryoku}/lib/runtime-env.sh"

floating_width="${RYOKU_FLOATING_WINDOW_WIDTH:-1280}"
floating_height="${RYOKU_FLOATING_WINDOW_HEIGHT:-720}"

if [[ -f $runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$runtime_env"
elif [[ -f $fallback_runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$fallback_runtime_env"
fi

if ! declare -F ryoku-cmd-missing >/dev/null; then
  ryoku-cmd-missing() {
    ! command -v "$1" >/dev/null 2>&1
  }
fi

if ! declare -F ryoku-cmd-present >/dev/null; then
  ryoku-cmd-present() {
    command -v "$1" >/dev/null 2>&1
  }
fi

if ryoku-cmd-missing hyprctl || ryoku-cmd-missing jq; then
  echo "hyprctl/jq not available for floating center helper"
  exit 1
fi

# HyprMod 0.3+ runs Hyprland in Lua config mode, where `hyprctl dispatch` is
# evaluated as Lua and legacy string dispatchers (togglefloating, ...) fail.
# Probe once and translate to the hl.dsp.* forms when in that mode.
lua_dispatch=false
if [[ "$(hyprctl dispatch 'hl.dsp.no_op()' 2>/dev/null)" == ok* ]]; then
  lua_dispatch=true
fi

hypr_toggle_floating() {
  if [[ $lua_dispatch == true ]]; then
    hyprctl dispatch 'hl.dsp.window.float({ action = "toggle" })' >/dev/null 2>&1 || true
  else
    hyprctl dispatch togglefloating >/dev/null 2>&1 || true
  fi
}

hypr_resize_exact() { # width height address
  if [[ $lua_dispatch == true ]]; then
    hyprctl dispatch "hl.dsp.window.resize({ exact = true, x = $1, y = $2, window = \"address:$3\" })" >/dev/null 2>&1 || true
  else
    hyprctl dispatch resizewindowpixel exact "$1" "$2,address:$3" >/dev/null 2>&1 || true
  fi
}

hypr_center() { # address
  if [[ $lua_dispatch == true ]]; then
    hyprctl dispatch "hl.dsp.window.center({ window = \"address:$1\" })" >/dev/null 2>&1 || true
  else
    hyprctl dispatch centerwindow "address:$1" >/dev/null 2>&1 || true
  fi
}

read -r address _ < <(hyprctl activewindow -j 2>/dev/null | jq -r '"\(.address // empty) \(.floating // false)"')

if [[ -z $address ]]; then
  exit 0
fi

hypr_toggle_floating
sleep 0.05

new_floating="$(hyprctl activewindow -j 2>/dev/null | jq -r '.floating // false')"
if [[ $new_floating == "true" ]]; then
  hypr_resize_exact "$floating_width" "$floating_height" "$address"
  hypr_center "$address"
fi
