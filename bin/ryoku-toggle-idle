#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Toggle whether the computer idles (screensaver / lock / sleep). Idle is owned by
# the Ryoku shell (IdleMonitors), gated by the shared keep-awake inhibitor, so flip
# that inhibitor through the shell IPC; fall back to the caffeine helper directly if
# the shell IPC is unreachable. (swayidle is retired; it used to be toggled here.)
ipc() { env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST ryoku-shell ipc "$@" 2>/dev/null; }

if ipc idleInhibitor toggle >/dev/null; then
  enabled="$(ipc idleInhibitor isEnabled)"
else
  ryoku-cmd-caffeine toggle >/dev/null 2>&1 || true
  if ryoku-cmd-caffeine status >/dev/null 2>&1; then enabled=true; else enabled=false; fi
fi

if [[ $enabled == *true* ]]; then
  notify-send -u low "Keep awake" "Won't lock or sleep when idle"
else
  notify-send -u low "Idle locking on" "Will lock and sleep when idle"
fi
