#!/bin/bash
set -e

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Reinstall the Ryoku configuration directory from the git source.

TARGET="$RYOKU_PATH"
BACKUP="${RYOKU_PATH}-old"
STAGING="${RYOKU_PATH}-new"

git clone --depth=1 --branch main "https://github.com/neur0map/ryoku-arch.git" "$STAGING" >/dev/null
rm -rf "$BACKUP"
mv "$TARGET" "$BACKUP"
mv "$STAGING" "$TARGET"
