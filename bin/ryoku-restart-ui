#!/bin/bash

# Hard-refresh Ryoku desktop UI components without touching user apps.

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

QUIET=false

usage() {
  cat <<'USAGE'
Usage:
  ryoku-restart-ui [--quiet]

Restarts Ryoku shell/session UI components that commonly get stuck:
Quickshell, Hyprland config state, notifications, OSD, portals, clipboard
watchers, and already-running legacy bars/idle helpers.
USAGE
}

for arg in "$@"; do
  case "$arg" in
  --quiet)
    QUIET=true
    ;;
  --help)
    usage
    exit 0
    ;;
  *)
    echo "ryoku-restart-ui: unknown option: $arg" >&2
    usage >&2
    exit 2
    ;;
  esac
done

log() {
  if [[ $QUIET == "false" ]]; then
    printf '%s\n' "$1"
  fi
}

command_present() {
  ryoku-cmd-present "$1"
}

launch_background() {
  if command_present uwsm-app; then
    setsid uwsm-app -- "$@" >/dev/null 2>&1 &
  else
    setsid "$@" >/dev/null 2>&1 &
  fi
}

process_running() {
  pgrep -x "$1" >/dev/null 2>&1
}

restart_always() {
  local process="$1"
  shift

  if ! command_present "$1"; then
    log "skip $process: $1 missing"
    return
  fi

  log "restart $process"
  pkill -x "$process" >/dev/null 2>&1 || true
  launch_background "$@"
}

restart_if_running() {
  local process="$1"
  shift

  if process_running "$process"; then
    restart_always "$process" "$@"
  else
    log "skip $process: not running"
  fi
}

try_restart_user_service() {
  local unit="$1"

  if ! command_present systemctl; then
    return
  fi

  if systemctl --user list-unit-files "$unit" >/dev/null 2>&1 ||
    systemctl --user status "$unit" >/dev/null 2>&1; then
    log "try-restart $unit"
    systemctl --user try-restart "$unit" >/dev/null 2>&1 || true
  fi
}

refresh_activation_environment() {
  if command_present systemctl; then
    systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XCURSOR_THEME XCURSOR_SIZE >/dev/null 2>&1 || true
  fi

  if command_present dbus-update-activation-environment; then
    dbus-update-activation-environment --systemd --all >/dev/null 2>&1 || true
  fi
}

restart_clipboard_watchers() {
  if ! command_present wl-paste || ! command_present cliphist; then
    log "skip clipboard watchers: wl-paste or cliphist missing"
    return
  fi

  log "restart clipboard watchers"
  pkill -f '(^|/)wl-paste --type text --watch cliphist store$' >/dev/null 2>&1 || true
  pkill -f '(^|/)wl-paste --type image --watch cliphist store$' >/dev/null 2>&1 || true
  launch_background wl-paste --type text --watch cliphist store
  launch_background wl-paste --type image --watch cliphist store
}

reset_hyprland() {
  if ! command_present hyprctl; then
    log "skip Hyprland reload: hyprctl missing"
    return
  fi

  log "reset Hyprland submap"
  hyprctl dispatch submap reset >/dev/null 2>&1 || true

  log "reload Hyprland"
  hyprctl reload >/dev/null 2>&1 || true
}

restart_portals() {
  try_restart_user_service xdg-desktop-portal.service
  try_restart_user_service xdg-desktop-portal-hyprland.service
  try_restart_user_service xdg-desktop-portal-gtk.service
}

notify_finished() {
  if command_present notify-send; then
    notify-send -u low "Ryoku hard refresh" "Desktop UI components refreshed" -t 2500 >/dev/null 2>&1 || true
  fi
}

log "Ryoku hard refresh"
refresh_activation_environment
reset_hyprland
ryoku-restart-shell >/dev/null 2>&1 || true
restart_always "mako" mako
restart_always "swayosd-server" swayosd-server
restart_if_running "waybar" waybar
restart_if_running "hypridle" hypridle
restart_clipboard_watchers
restart_portals
notify_finished
