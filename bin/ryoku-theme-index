#!/usr/bin/env python3
"""Generate themes/index.json — the catalog the Settings download list reads.

Scans a themes directory (each theme = <dir>/<name>/colors.toml + optional
preview.png) and emits a JSON catalog with the swatch colors used for the tiles.
Run this whenever a theme folder is added/removed so the catalog stays in sync:

    ryoku-theme-index themes -o themes/index.json
"""
import argparse
import json
import os
import re
import sys


def grab(text, key, fallback=""):
    m = re.search(rf'^\s*{key}\s*=\s*["\']?(#?[0-9A-Fa-f]{{6}})', text, re.MULTILINE)
    if not m:
        return fallback
    v = m.group(1)
    return v if v.startswith("#") else f"#{v}"


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("themes_dir")
    ap.add_argument("-o", "--out", default=None, help="write to file (default: stdout)")
    args = ap.parse_args()

    if not os.path.isdir(args.themes_dir):
        print(f"ryoku-theme-index: not a directory: {args.themes_dir}", file=sys.stderr)
        return 1

    entries = []
    for name in sorted(os.listdir(args.themes_dir)):
        d = os.path.join(args.themes_dir, name)
        toml = os.path.join(d, "colors.toml")
        if not os.path.isdir(d) or not os.path.isfile(toml):
            continue
        text = open(toml, encoding="utf-8", errors="replace").read()
        accent = grab(text, "accent", grab(text, "color4", "#888888"))
        entries.append({
            "name": name,
            "display": name.replace("-", " "),
            "background": grab(text, "background", "#222222"),
            "foreground": grab(text, "foreground", "#cccccc"),
            "accent": accent,
            "secondary": grab(text, "color6", accent),
            "tertiary": grab(text, "color5", accent),
            "preview": os.path.isfile(os.path.join(d, "preview.png")),
        })

    out = json.dumps({"version": 1, "themes": entries}, indent=2)
    if args.out:
        with open(args.out, "w", encoding="utf-8") as fh:
            fh.write(out + "\n")
        print(f"ryoku-theme-index: wrote {args.out} ({len(entries)} themes)")
    else:
        print(out)
    return 0


if __name__ == "__main__":
    sys.exit(main())
