#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Offline ISO installs intentionally skip yay bootstrap during install
# (preflight/yay-bootstrap.sh exits when RYOKU_ONLINE_INSTALL is unset).
# Once the user is on the network and runs ryoku-update, bootstrap yay
# now so subsequent AUR-dependent work can proceed. Bootstrap failures
# are non-fatal: ryoku-update keeps running through the rest of the
# update flow rather than aborting the whole thing.
if ! command -v yay >/dev/null 2>&1; then
  if ping -c1 -W2 1.1.1.1 >/dev/null 2>&1; then
    echo -e "\e[32m\nBootstrap yay (deferred from offline install)\e[0m"
    RYOKU_ONLINE_INSTALL=1 bash "$RYOKU_PATH/install/preflight/yay-bootstrap.sh" || true
  fi
fi

skip_aur_update=0

transition_localsend_to_bin() {
  if ! pacman -Q localsend >/dev/null 2>&1 || pacman -Q localsend-bin >/dev/null 2>&1; then
    return 0
  fi

  command -v yay >/dev/null 2>&1 || return 0
  ryoku-pkg-aur-accessible || return 0

  echo -e "\e[32m\nSwitch LocalSend to binary package\e[0m"
  echo "The source AUR package pulls rustup as a build dependency, which conflicts with Arch rust."

  if ! sudo pacman -Rdd --noconfirm localsend; then
    echo -e "\e[31mCould not remove source LocalSend; skipping AUR package upgrades to avoid rustup conflicts.\e[0m"
    skip_aur_update=1
    return 0
  fi

  if ! yay -S --noconfirm --needed localsend-bin; then
    echo -e "\e[31mCould not install localsend-bin; skipping AUR package upgrades for this run.\e[0m"
    skip_aur_update=1
    return 0
  fi

  echo
}

transition_localsend_to_bin

if (( skip_aur_update == 1 )); then
  exit 0
fi

# Update AUR packages only if at least one is actually installed.
# `pacman -Qem` exits 0 even when its output is empty, so the previous
# guard fired the "AUR unavailable" warning even on systems that had
# no AUR packages and nothing to update.
if [[ -n $(pacman -Qem 2>/dev/null) ]]; then
  if ryoku-pkg-aur-accessible; then
    echo -e "\e[32m\nUpdate AUR packages\e[0m"
    yay -Sua --noconfirm --cleanafter --ignore gcc14,gcc14-libs
    echo
  else
    echo -e "\e[31m\nAUR is unavailable (so skipping updates)\e[0m"
    echo
  fi
fi
