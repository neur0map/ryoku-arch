#!/bin/bash

# Install / uninstall extras bundles and items from the ryoku-extras catalogue.
#
# Detection, install, uninstall and reporting are per-item so the Settings ->
# Extras UI can show a loader, a success check and a precise "what failed" per
# tool. Packages are routed to the right backend (official repos via
# ryoku-pkg-add, AUR via ryoku-pkg-aur-add, removal via ryoku-pkg-remove);
# scripts run installers/<name>.sh; plugins are deferred to the shell
# (Settings -> Plugins / PluginService), never (un)installed here.
#
# Privileged work (pacman/yay) needs a real terminal for the sudo prompt, so the
# shell launches this through ryoku-launch-floating-terminal-with-presentation.
# Pass --report FILE to also emit a machine-readable per-item report the UI
# watches via FileView.

set -uo pipefail

CATALOGUE="${RYOKU_EXTRAS_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/ryoku-extras}"

usage() {
  cat >&2 <<'EOF'
Usage:
  ryoku-extras-install list
  ryoku-extras-install status bundle <id>
  ryoku-extras-install status item <type> <name>
  ryoku-extras-install bundle <id> [--dry-run] [--report FILE]
  ryoku-extras-install item <type> <name> [--dry-run] [--report FILE]
  ryoku-extras-install uninstall bundle <id> [--dry-run] [--report FILE]
  ryoku-extras-install uninstall item <type> <name> [--dry-run] [--report FILE]

Commands:
  list                        List available bundles (id and name).
  status ...                  Print JSON presence for each item; changes nothing.
  bundle <id>                 Install every item in bundles/<id>/bundle.json.
  item <type> <name>          Install a single item (type: package|script|plugin).
  uninstall bundle <id>       Remove the installed package items of a bundle.
  uninstall item <type> <name>  Remove a single package item.

Options:
  --dry-run            Print the plan and exit without changing anything.
  --report FILE        Write per-item JSON results to FILE after running.
  -h, --help           Show this help.

Item types:
  package   Installed from the official repos (ryoku-pkg-add) or, if it is not
            there, the AUR (ryoku-pkg-aur-add); removed with ryoku-pkg-remove.
  script    Installed by running installers/<name>.sh; not auto-uninstallable.
  plugin    Not handled here - add/remove it from Settings -> Plugins.
EOF
}

die() {
  echo "ryoku-extras-install: $1" >&2
  exit 2
}

# --- item model (parallel arrays, filled by load_*) ----------------------------
declare -a IT_TYPE=() IT_NAME=() IT_DETECT=()
# Per-item outcome, keyed by name.
declare -A RES=() ERR=()
REPORT_SCOPE=""

load_bundle_items() {
  local id="$1"
  local bundle="$CATALOGUE/bundles/$id/bundle.json"
  [[ -f $bundle ]] || die "no such bundle: $id"
  REPORT_SCOPE="bundle:$id"
  local type name detect
  while IFS=$'\t' read -r type name detect; do
    [[ -n $type ]] || continue
    IT_TYPE+=("$type")
    IT_NAME+=("$name")
    IT_DETECT+=("$detect")
  done < <(jq -r '.items[] | "\(.type)\t\(.name)\t\(.detect // "")"' "$bundle")
  (( ${#IT_NAME[@]} )) || die "bundle has no items: $id"
}

load_single_item() {
  local type="$1" name="$2"
  case "$type" in
    package | script | plugin) ;;
    *) die "unknown item type: $type" ;;
  esac
  REPORT_SCOPE="item:$type/$name"
  IT_TYPE+=("$type")
  IT_NAME+=("$name")
  IT_DETECT+=("")
}

# item_present TYPE NAME DETECT -> 0 when the tool is already available.
item_present() {
  local type="$1" name="$2" detect="${3:-}"
  [[ -n $detect ]] || detect="$name"
  case "$type" in
    package) ryoku-pkg-present "$name" || ryoku-cmd-present "$detect" ;;
    script) ryoku-cmd-present "$detect" ;;
    plugin) return 1 ;; # plugins are resolved by the shell, not detectable here
    *) return 1 ;;
  esac
}

# --- detection (status) --------------------------------------------------------
emit_status() {
  local i present
  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    present=false
    item_present "${IT_TYPE[i]}" "${IT_NAME[i]}" "${IT_DETECT[i]}" && present=true
    printf '%s\t%s\t%s\n' "${IT_TYPE[i]}" "${IT_NAME[i]}" "$present"
  done | jq -R -s --arg scope "$REPORT_SCOPE" '
    {scope: $scope,
     items: (split("\n") | map(select(length > 0)) | map(split("\t")) |
             map({type: .[0], name: .[1], present: (.[2] == "true")}))}'
}

# --- plan ----------------------------------------------------------------------
print_plan() {
  local action="$1" i type name detect any=0
  echo "Plan:"
  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    type="${IT_TYPE[i]}"
    name="${IT_NAME[i]}"
    detect="${IT_DETECT[i]}"
    if [[ $type == plugin ]]; then
      echo "  plugin $name -> use Settings -> Plugins"
    elif [[ $action == uninstall ]]; then
      if [[ $type == script ]]; then
        echo "  manual    $name (scripts are not auto-removed)"
      elif item_present "$type" "$name" "$detect"; then
        echo "  remove    $type $name"
        any=1
      else
        echo "  absent    $name"
      fi
    else
      if item_present "$type" "$name" "$detect"; then
        echo "  present   $name"
      else
        echo "  install   $type $name"
        any=1
      fi
    fi
  done
  if (( any == 0 )); then
    [[ $action == uninstall ]] && echo "  Nothing to remove." || echo "  Nothing to install."
  fi
}

# --- install -------------------------------------------------------------------
run_script() {
  local name="$1"
  local script="$CATALOGUE/installers/$name.sh"
  if [[ ! -f $script ]]; then
    RES[$name]="failed"
    ERR[$name]="installer not found: installers/$name.sh"
    return 1
  fi
  if ! bash "$script"; then
    ERR[$name]="installer exited with an error"
  fi
}

install_items() {
  local -a repo_pkgs=() aur_pkgs=()
  local i type name detect

  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    type="${IT_TYPE[i]}"
    name="${IT_NAME[i]}"
    detect="${IT_DETECT[i]}"
    if [[ $type == plugin ]]; then
      RES[$name]="deferred"
      continue
    fi
    if item_present "$type" "$name" "$detect"; then
      RES[$name]="present"
      continue
    fi
    case "$type" in
      package)
        if pacman -Si "$name" >/dev/null 2>&1; then
          repo_pkgs+=("$name")
        else
          aur_pkgs+=("$name")
        fi
        ;;
      script) run_script "$name" ;;
    esac
  done

  if (( ${#repo_pkgs[@]} )); then
    echo "==> Installing from official repos: ${repo_pkgs[*]}"
    ryoku-pkg-add "${repo_pkgs[@]}" || true
  fi
  if (( ${#aur_pkgs[@]} )); then
    echo "==> Installing from the AUR: ${aur_pkgs[*]}"
    ryoku-pkg-aur-add "${aur_pkgs[@]}" || true
  fi

  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    type="${IT_TYPE[i]}"
    name="${IT_NAME[i]}"
    detect="${IT_DETECT[i]}"
    [[ -n ${RES[$name]:-} ]] && continue
    if item_present "$type" "$name" "$detect"; then
      RES[$name]="installed"
    else
      RES[$name]="failed"
      [[ -n ${ERR[$name]:-} ]] || ERR[$name]="install failed"
    fi
  done
}

# --- uninstall -----------------------------------------------------------------
uninstall_items() {
  local -a rm_pkgs=()
  local i type name detect

  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    type="${IT_TYPE[i]}"
    name="${IT_NAME[i]}"
    detect="${IT_DETECT[i]}"
    if [[ $type == plugin ]]; then
      RES[$name]="deferred"
      continue
    fi
    if ! item_present "$type" "$name" "$detect"; then
      RES[$name]="absent"
      continue
    fi
    case "$type" in
      package) rm_pkgs+=("$name") ;;
      script)
        RES[$name]="skipped"
        ERR[$name]="script-installed tool; remove it manually"
        ;;
    esac
  done

  if (( ${#rm_pkgs[@]} )); then
    echo "==> Removing: ${rm_pkgs[*]}"
    ryoku-pkg-remove "${rm_pkgs[@]}" || true
  fi

  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    type="${IT_TYPE[i]}"
    name="${IT_NAME[i]}"
    detect="${IT_DETECT[i]}"
    [[ -n ${RES[$name]:-} ]] && continue
    if item_present "$type" "$name" "$detect"; then
      RES[$name]="failed"
      ERR[$name]="removal failed"
    else
      RES[$name]="removed"
    fi
  done
}

print_summary() {
  local i name s
  local -a installed_=() present_=() removed_=() absent_=() failed_=() deferred_=() skipped_=()
  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    name="${IT_NAME[i]}"
    s="${RES[$name]:-unknown}"
    case "$s" in
      installed) installed_+=("$name") ;;
      present) present_+=("$name") ;;
      removed) removed_+=("$name") ;;
      absent) absent_+=("$name") ;;
      deferred) deferred_+=("$name") ;;
      skipped) skipped_+=("$name") ;;
      failed) failed_+=("$name (${ERR[$name]:-error})") ;;
    esac
  done
  echo
  echo "Summary:"
  (( ${#installed_[@]} )) && echo "  Installed:       ${installed_[*]}"
  (( ${#removed_[@]} )) && echo "  Removed:         ${removed_[*]}"
  (( ${#present_[@]} )) && echo "  Already present: ${present_[*]}"
  (( ${#absent_[@]} )) && echo "  Not installed:   ${absent_[*]}"
  (( ${#deferred_[@]} )) && echo "  Plugins (Settings -> Plugins): ${deferred_[*]}"
  (( ${#skipped_[@]} )) && echo "  Skipped:         ${skipped_[*]}"
  if (( ${#failed_[@]} )); then
    local f
    echo "  Failed:"
    for f in "${failed_[@]}"; do echo "    - $f"; done
  fi
}

write_report() {
  local file="$1"
  [[ -n $file ]] || return 0
  mkdir -p "$(dirname "$file")" 2>/dev/null || true
  local tmp i
  tmp="$(mktemp "${file}.XXXXXX")" || return 0
  {
    for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
      printf '%s\t%s\t%s\t%s\n' \
        "${IT_TYPE[i]}" "${IT_NAME[i]}" "${RES[${IT_NAME[i]}]:-unknown}" "${ERR[${IT_NAME[i]}]:-}"
    done
  } | jq -R -s --arg scope "$REPORT_SCOPE" '
    {ts: (now | floor), scope: $scope,
     items: (split("\n") | map(select(length > 0)) | map(split("\t")) |
             map({type: .[0], name: .[1], status: .[2], error: .[3]}))}' >"$tmp" \
    && mv "$tmp" "$file"
}

run_op() {
  local action="$1" dry_run="$2" report="$3"
  if (( dry_run )); then
    print_plan "$action"
    exit 0
  fi
  if [[ $action == uninstall ]]; then
    uninstall_items
  else
    install_items
  fi
  print_summary
  write_report "$report"
  local i fail=0
  for ((i = 0; i < ${#IT_NAME[@]}; i++)); do
    [[ ${RES[${IT_NAME[i]}]:-} == failed ]] && fail=1
  done
  (( fail == 0 )) || exit 1
}

cmd_list() {
  local registry="$CATALOGUE/bundles/registry.json"
  [[ -f $registry ]] || die "no bundle registry at $registry"
  jq -r '.bundles[] | "\(.id)\t\(.name)"' "$registry"
}

cmd_status() {
  case "${1:-}" in
    all)
      local registry="$CATALOGUE/bundles/registry.json"
      [[ -f $registry ]] || { echo '{}'; return 0; }
      {
        local id bpath type name detect present
        while IFS= read -r id; do
          [[ -n $id ]] || continue
          bpath="$CATALOGUE/bundles/$id/bundle.json"
          [[ -f $bpath ]] || continue
          while IFS=$'\t' read -r type name detect; do
            [[ -n $type ]] || continue
            present=false
            item_present "$type" "$name" "$detect" && present=true
            printf '%s\t%s\n' "$name" "$present"
          done < <(jq -r '.items[] | "\(.type)\t\(.name)\t\(.detect // "")"' "$bpath")
        done < <(jq -r '.bundles[].id' "$registry")
      } | jq -R -s 'split("\n") | map(select(length > 0)) | map(split("\t")) |
        reduce .[] as $x ({}; .[$x[0]] = ($x[1] == "true"))'
      return 0
      ;;
    bundle)
      [[ -n ${2:-} ]] || die "status bundle requires an id"
      load_bundle_items "$2"
      ;;
    item)
      [[ -n ${2:-} && -n ${3:-} ]] || die "status item requires a type and a name"
      load_single_item "$2" "$3"
      ;;
    *) die "status takes 'all', 'bundle <id>' or 'item <type> <name>'" ;;
  esac
  emit_status
}

# cmd_run ACTION KIND [args] -- shared parser for (un)install of a bundle/item.
cmd_run() {
  local action="$1" kind="$2"
  shift 2
  local dry_run=0 report=""
  local -a pos=()
  while (( $# )); do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --report)
        shift
        [[ -n ${1:-} ]] || die "--report requires a path"
        report="$1"
        ;;
      --*) die "unknown option: $1" ;;
      *) pos+=("$1") ;;
    esac
    shift
  done
  case "$kind" in
    bundle)
      [[ -n ${pos[0]:-} ]] || die "$action bundle requires an id"
      load_bundle_items "${pos[0]}"
      ;;
    item)
      [[ -n ${pos[0]:-} && -n ${pos[1]:-} ]] || die "$action item requires a type and a name"
      load_single_item "${pos[0]}" "${pos[1]}"
      ;;
    *) die "expected 'bundle' or 'item'" ;;
  esac
  run_op "$action" "$dry_run" "$report"
}

case "${1:-}" in
  -h | --help | "")
    usage
    [[ -n ${1:-} ]] || exit 1
    ;;
  *)
    [[ -d $CATALOGUE ]] || die "extras catalogue not found at $CATALOGUE - refresh extras first (Settings -> Extras -> Refresh)"
    case "$1" in
      list) shift; cmd_list "$@" ;;
      status) shift; cmd_status "$@" ;;
      bundle) shift; cmd_run install bundle "$@" ;;
      item) shift; cmd_run install item "$@" ;;
      uninstall)
        shift
        kind="${1:-}"
        shift || true
        cmd_run uninstall "$kind" "$@"
        ;;
      *) die "unknown command: $1" ;;
    esac
    ;;
esac
