#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

STATE_CONF="$RYOKU_STATE_PATH/toggles/touchpad-disabled"

device="$(ryoku-hw-touchpad)"

if [[ -z $device ]]; then
  echo "No touchpad device found" >&2
  exit 1
fi

enable() {
  rm -f "$STATE_CONF"
  notify-send -u low "Touchpad toggle is managed in Niri settings" >/dev/null 2>&1 || true
}

disable() {
  mkdir -p "$(dirname "$STATE_CONF")"
  : >"$STATE_CONF"
  notify-send -u low "Touchpad toggle is managed in Niri settings" >/dev/null 2>&1 || true
}

case "${1:-toggle}" in
  on) enable ;;
  off) disable ;;
  toggle) if [[ -f $STATE_CONF ]]; then enable; else disable; fi ;;
esac
