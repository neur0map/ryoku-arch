#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

if [[ -n ${RYOKU_SHELL_PATH:-} ]]; then
  SHELL_PATH="$RYOKU_SHELL_PATH"
elif [[ -x $RYOKU_PATH/shell/scripts/sddm/install-pixel-sddm.sh ]]; then
  SHELL_PATH="$RYOKU_PATH/shell"
else
  SHELL_PATH="$HOME/.local/share/ryoku-shell"
fi
SDDM_SCRIPT="$SHELL_PATH/scripts/sddm/install-pixel-sddm.sh"

if [[ ! -x $SDDM_SCRIPT ]]; then
  echo "ryoku-refresh-sddm: missing Ryoku SDDM installer at $SDDM_SCRIPT" >&2
  exit 1
fi

RYOKU_SHELL_SDDM_AUTO_APPLY="${RYOKU_SHELL_SDDM_AUTO_APPLY:-preserve}" REPO_ROOT="$SHELL_PATH" exec "$SDDM_SCRIPT"
