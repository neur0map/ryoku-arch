#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Ensure all default .desktop, web apps, and TUIs are installed.

# Copy and sync icon files
mkdir -p ~/.local/share/icons/hicolor/48x48/apps/
cp "$RYOKU_PATH"/applications/icons/*.png ~/.local/share/icons/hicolor/48x48/apps/
gtk-update-icon-cache ~/.local/share/icons/hicolor &>/dev/null

# Copy .desktop declarations
mkdir -p ~/.local/share/applications
cp "$RYOKU_PATH"/applications/*.desktop ~/.local/share/applications/
cp "$RYOKU_PATH"/applications/hidden/*.desktop ~/.local/share/applications/
ryoku-refresh-editor-desktop

# Refresh the webapps and TUIs
bash "$RYOKU_PATH"/install/packaging/icons.sh
bash "$RYOKU_PATH"/install/packaging/webapps.sh
bash "$RYOKU_PATH"/install/packaging/tuis.sh

update-desktop-database ~/.local/share/applications
