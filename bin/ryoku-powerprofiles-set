#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Set the power profile to the requested level, falling back to balanced
# if the requested profile isn't available on this machine.
#
# Usage: ryoku-powerprofiles-set [autodetect|ac|battery]

action="${1:-autodetect}"
power_supply_dir="${RYOKU_POWER_SUPPLY_DIR:-/sys/class/power_supply}"

detect_power_source() {
  local online ps type

  for ps in "$power_supply_dir"/*; do
    [[ -r $ps/type && -r $ps/online ]] || continue
    type=$(<"$ps/type")
    [[ $type == "Mains" || $type == "USB" ]] || continue
    online=$(<"$ps/online")
    if [[ $online == "1" ]]; then
      printf 'ac\n'
      return 0
    fi
  done

  printf 'battery\n'
}

if [[ -z $action || $action == "autodetect" ]]; then
  # On plug/unplug, udev fires the power_supply rule before sysfs `online`
  # is updated on some laptops (notably USB-C charging). A short settle
  # delay lets the kernel catch up before we read state. Explicit ac/battery
  # invocations skip this and stay instant.
  sleep 0.3
  action=$(detect_power_source)
fi

mapfile -t profiles < <(powerprofilesctl list | awk '/^\s*[* ]\s*[a-zA-Z0-9\-]+:$/ { gsub(/^[*[:space:]]+|:$/,""); print }')
profiles_text=" ${profiles[*]} "

case "$action" in
  ac)
    # Prefer performance, fall back to balanced
    if [[ $profiles_text == *" performance "* ]]; then
      powerprofilesctl set performance
    else
      powerprofilesctl set balanced
    fi
    ;;
  battery)
    powerprofilesctl set balanced
    ;;
esac
