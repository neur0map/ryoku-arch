#!/bin/bash

# Run the Ryoku screensaver using random effects from TTE.

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

screensaver_in_focus() {
  niri msg -j focused-window 2>/dev/null |
    jq -e '.app_id == "org.ryoku.screensaver"' >/dev/null 2>&1 ||
    return 0
}

exit_screensaver() {
  pkill -x tte 2>/dev/null
  pkill -f org.ryoku.screensaver 2>/dev/null
  exit 0
}

# Exit the screensaver on signals and input from keyboard and mouse
trap exit_screensaver SIGINT SIGTERM SIGHUP SIGQUIT

printf '\033]11;rgb:00/00/00\007'  # Set background color to black

tty=$(tty 2>/dev/null)

while true; do
  tte -i "$RYOKU_CONFIG_PATH/branding/screensaver.txt" \
    --frame-rate 120 --canvas-width 0 --canvas-height 0 --reuse-canvas --anchor-canvas c --anchor-text c\
    --random-effect --exclude-effects dev_worm \
    --no-eol --no-restore-cursor &

  while pgrep -t "${tty#/dev/}" -x tte >/dev/null; do
    if read -n1 -t 1 || ! screensaver_in_focus; then
      exit_screensaver
    fi
  done
done
