#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

chromium_theme="$RYOKU_CONFIG_PATH/current/theme/chromium.theme"
theme_rgb_color="28,32,39"

if [[ -f $chromium_theme ]]; then
  theme_rgb_color="$(<$chromium_theme)"
fi

theme_hex_color="$(printf '#%02x%02x%02x' ${theme_rgb_color//,/ })"
theme_script="$RYOKU_PATH/shell/scripts/colors/apply-chrome-theme.sh"

if [[ -x $theme_script ]]; then
  "$theme_script" "$theme_hex_color"
elif [[ -f $theme_script ]]; then
  bash "$theme_script" "$theme_hex_color"
fi
