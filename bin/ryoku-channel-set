#!/bin/bash

set -e

# Channel switching now lives inside the single Ryoku update command. This shim
# stays for backward compatibility and forwards to `ryoku-update -sc`, which
# routes the switch through the full hardened update pipeline (confirmation,
# logging, idle inhibit, command-bridge repair, ERR->doctor).
#
#   ryoku-channel-set main|unstable-dev [-y]   ==   ryoku-update -sc <channel> [-y]

script_path="${BASH_SOURCE[0]}"
script_path="$(readlink -f "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
bin_dir="$(cd -- "$(dirname -- "$script_path")" && pwd)"

if (($# == 0)); then
  echo "Usage: ryoku-channel-set main|unstable-dev [-y]"
  exit 1
fi

exec "$bin_dir/ryoku-update" -sc "$@"
