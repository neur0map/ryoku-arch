#!/bin/bash

set -e

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Set the Ryoku update channel. Pacman packages still use the main mirror.

if (($# == 0)); then
  echo "Usage: ryoku-channel-set main|unstable-dev"
  exit 1
fi

channel="$1"

case "$channel" in
main | unstable-dev) ;;
*)
  echo "Unknown channel: $channel"
  exit 1
  ;;
esac

echo "Setting Ryoku update channel to $channel"
echo

ryoku-refresh-pacman "$channel"
ryoku-update-branch "$channel"
