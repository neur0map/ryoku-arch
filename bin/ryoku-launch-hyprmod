#!/bin/bash

set -euo pipefail

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
runtime_env="$script_root/lib/runtime-env.sh"
fallback_runtime_env="${RYOKU_PATH:-$HOME/.local/share/ryoku}/lib/runtime-env.sh"

if [[ -f $runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$runtime_env"
elif [[ -f $fallback_runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$fallback_runtime_env"
fi

if ! declare -F ryoku-cmd-missing >/dev/null; then
  ryoku-cmd-missing() {
    ! command -v "$1" >/dev/null 2>&1
  }
fi

if ! declare -F ryoku-cmd-present >/dev/null; then
  ryoku-cmd-present() {
    command -v "$1" >/dev/null 2>&1
  }
fi

hyprmod_class="io.github.bluemancz.hyprmod"
launch_attempts=120
launch_interval="0.1"

hyprmod_address() {
  hyprctl clients -j | jq -r --arg class "$hyprmod_class" '
    [.[] | select(.class == $class)][-1].address // empty
  '
}

settings_geometry() {
  hyprctl monitors -j | jq -r '
    ([.[] | select(.focused)][0] // .[0]) as $monitor
    | ($monitor.width / $monitor.scale) as $width
    | ($monitor.height / $monitor.scale) as $height
    | [($width * 0.8 | floor), ([$height * 0.78, 1180] | min | floor)]
    | @tsv
  '
}

shape_hyprmod() {
  local address="$1"
  local width height

  read -r width height < <(settings_geometry)
  [[ -n $width && -n $height ]] || return 1

  hyprctl dispatch resizewindowpixel exact "$width" "$height,address:$address" >/dev/null 2>&1 || true
  hyprctl dispatch centerwindow "address:$address" >/dev/null 2>&1 || true
  hyprctl dispatch focuswindow "address:$address" >/dev/null 2>&1 || true
}

if ryoku-cmd-missing hyprmod; then
  echo "HyprMod is not installed."
  exit 1
fi

if ryoku-cmd-missing hyprctl || ryoku-cmd-missing jq; then
  exec hyprmod
fi

address="$(hyprmod_address || true)"
if [[ -n $address ]]; then
  shape_hyprmod "$address"
  exit 0
fi

if ryoku-cmd-present setsid; then
  setsid -f hyprmod >/dev/null 2>&1
else
  hyprmod >/dev/null 2>&1 &
fi

for ((attempt = 0; attempt < launch_attempts; attempt++)); do
  sleep "$launch_interval"
  address="$(hyprmod_address || true)"

  if [[ -n $address ]]; then
    shape_hyprmod "$address"
    exit 0
  fi
done

exit 0
