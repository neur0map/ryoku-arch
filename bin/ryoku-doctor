#!/bin/bash

set -euo pipefail

script_path="${BASH_SOURCE[0]:-}"
repo_root=""
if [[ -n $script_path ]]; then
  script_path="$(readlink -f "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
  repo_root="$(cd -- "$(dirname -- "$script_path")/.." && pwd)"
fi

if [[ -n $repo_root && -f $repo_root/lib/runtime-env.sh ]]; then
  # shellcheck disable=SC1091
  source "$repo_root/lib/runtime-env.sh"
else
  export RYOKU_PATH_DEFAULT="$HOME/.local/share/ryoku"
  export RYOKU_LEGACY_PATH="$HOME/.local/share/omarchy"
  export RYOKU_STATE_PATH="${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}"
  export RYOKU_CONFIG_PATH="${RYOKU_CONFIG_PATH:-$HOME/.config/ryoku}"

  if [[ -n ${RYOKU_PATH:-} ]]; then
    export RYOKU_PATH
  elif [[ -e $RYOKU_PATH_DEFAULT ]]; then
    export RYOKU_PATH="$RYOKU_PATH_DEFAULT"
  else
    export RYOKU_PATH="$RYOKU_LEGACY_PATH"
  fi

  export RYOKU_INSTALL="$RYOKU_PATH/install"
  case ":$PATH:" in
    *":$RYOKU_PATH/bin:"*) ;;
    *) export PATH="$RYOKU_PATH/bin:$PATH" ;;
  esac
fi

if [[ -n $repo_root && -f $repo_root/lib/pacman-conflicts.sh ]]; then
  # shellcheck disable=SC1091
  source "$repo_root/lib/pacman-conflicts.sh"
else
  ryoku_pacman_latest_update_log() {
    local env_log="${RYOKU_UPDATE_LOG:-}"
    local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
    local candidate newest=""
    local mtime newest_mtime=0
    local candidates=(
      "$state_home/quickshell/user/update.log"
      "$state_home/ryoku/update.log"
      "/tmp/ryoku-update.log"
      "/tmp/omarchy-update.log"
    )

    if [[ -n $env_log && -r $env_log ]]; then
      printf '%s\n' "$env_log"
      return 0
    fi

    for candidate in "${candidates[@]}"; do
      [[ -r $candidate ]] || continue
      mtime="$(stat -c %Y "$candidate" 2>/dev/null || printf '0')"
      if [[ -z $newest ]] || (( mtime > newest_mtime )); then
        newest="$candidate"
        newest_mtime="$mtime"
      fi
    done

    [[ -n $newest ]] || return 1
    printf '%s\n' "$newest"
  }

  ryoku_pacman_conflicts_from_log() {
    return 1
  }

  ryoku_pacman_repair_conflicts_from_log() {
    return 1
  }
fi

usage() {
  cat <<'USAGE'
Usage: ryoku-doctor [-h]

Runs the right Ryoku doctor automatically:
  - update repair when the last update needs attention
  - desktop shell health and automatic repair otherwise

Advanced compatibility aliases:
  ryoku-doctor update
  ryoku-doctor shell
USAGE
}

state_home() {
  printf '%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

update_status_file() {
  printf '%s\n' "${RYOKU_UPDATE_STATUS:-$(state_home)/quickshell/user/update-status}"
}

print_update_status() {
  local status_file status

  status_file="$(update_status_file)"
  [[ -r $status_file ]] || return 0

  status="$(<"$status_file")"
  [[ -n $status ]] || return 0

  echo "Status: $status"
}

doctor_report_dir=""
doctor_report_file=""

doctor_pretty() {
  [[ ${RYOKU_DOCTOR_PLAIN:-0} == "1" ]] && return 1
  if [[ ${RYOKU_DOCTOR_PRETTY:-0} == "1" ]]; then
    command -v gum >/dev/null 2>&1
    return
  fi

  [[ -t 1 ]] && command -v gum >/dev/null 2>&1
}

doctor_repair_gum() {
  local gum_installer="${RYOKU_DOCTOR_GUM_INSTALLER:-ryoku-pkg-add}"

  [[ ${RYOKU_DOCTOR_PLAIN:-0} == "1" ]] && return 0
  if [[ ${RYOKU_DOCTOR_FORCE_GUM_REPAIR:-0} != "1" ]]; then
    command -v gum >/dev/null 2>&1 && return 0
  fi
  command -v "$gum_installer" >/dev/null 2>&1 || return 0

  echo "Ryoku Doctor: installing missing UI dependency: gum"
  if "$gum_installer" gum >/dev/null 2>&1; then
    doctor_report_issue "FIX Installed missing gum package for doctor UI."
  else
    doctor_report_issue "WARN Could not install missing gum package for doctor UI."
  fi
}

doctor_style() {
  if doctor_pretty; then
    gum style "$@"
  else
    printf '%s\n' "${@: -1}"
  fi
}

doctor_banner() {
  local mode="$1"

  if doctor_pretty; then
    gum style \
      --border double \
      --border-foreground 6 \
      --foreground 15 \
      --padding "1 3" \
      --margin "1 0" \
      "Ryoku Doctor" \
      "$mode"
  else
    printf '%s\n' "========================================"
    printf '%s\n' "Ryoku Doctor"
    printf '%s\n' "$mode"
    printf '%s\n' "========================================"
  fi
}

doctor_note() {
  local kind="$1"
  local message="$2"
  local color="7"

  case "$kind" in
    OK) color="2" ;;
    WARN) color="3" ;;
    FIX) color="6" ;;
    FAIL) color="1" ;;
    INFO) color="4" ;;
  esac

  if doctor_pretty; then
    gum style --foreground "$color" "${kind}: ${message}"
  else
    echo "${kind}: ${message}"
  fi
}

doctor_checkout_summary() {
  local branch="unknown"
  local commit="unknown"

  if [[ -d $RYOKU_PATH/.git ]] && command -v git >/dev/null 2>&1; then
    branch="$(GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" rev-parse --abbrev-ref HEAD 2>/dev/null || printf '%s\n' "unknown")"
    commit="$(GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" rev-parse --short HEAD 2>/dev/null || printf '%s\n' "unknown")"
  fi

  printf '%s@%s\n' "$branch" "$commit"
}

doctor_last_update_summary() {
  local state_file="$RYOKU_STATE_PATH/last-update"
  local updated_at="unknown"
  local checkout="unknown"
  local active_doctor="unknown"
  local gum_path="unknown"
  local key value

  [[ -r $state_file ]] || return 1

  while IFS='=' read -r key value; do
    case "$key" in
      updated_at) updated_at="$value" ;;
      checkout) checkout="$value" ;;
      active_doctor) active_doctor="$value" ;;
      gum) gum_path="$value" ;;
    esac
  done < "$state_file"

  printf '%s %s doctor=%s gum=%s\n' "$updated_at" "$checkout" "$active_doctor" "$gum_path"
}

doctor_context_panel() {
  local command_path="${script_path:-ryoku-doctor}"
  local expected_path="$RYOKU_PATH/bin/ryoku-doctor"
  local context
  local last_update=""

  context=$(
    printf 'Command: %s\n' "$command_path"
    printf 'Expected: %s\n' "$expected_path"
    printf 'Ryoku path: %s\n' "$RYOKU_PATH"
    printf 'Channel: %s\n' "$(doctor_release_branch)"
    printf 'Checkout: %s\n' "$(doctor_checkout_summary)"
    if last_update="$(doctor_last_update_summary 2>/dev/null)"; then
      printf 'Last update: %s\n' "$last_update"
    fi
  )

  if doctor_pretty; then
    gum style \
      --border rounded \
      --border-foreground 8 \
      --foreground 7 \
      --padding "1 2" \
      "$context"
  else
    printf '%s\n' "$context"
  fi
}

doctor_command_realpath() {
  local command_name="$1"
  local command_path=""

  command_path="$(command -v "$command_name" 2>/dev/null || true)"
  [[ -n $command_path ]] || return 1
  readlink -f "$command_path" 2>/dev/null || printf '%s\n' "$command_path"
}

doctor_environment_warnings() {
  local active_doctor=""
  local expected_doctor="$RYOKU_PATH/bin/ryoku-doctor"

  if ! command -v gum >/dev/null 2>&1; then
    doctor_note "WARN" "gum is missing or not on PATH; doctor UI is using the built-in fallback"
    doctor_report_issue "WARN gum is missing or not on PATH."
  fi

  active_doctor="$(doctor_command_realpath ryoku-doctor || true)"
  if [[ -n $active_doctor && -x $expected_doctor && $active_doctor != "$expected_doctor" ]]; then
    doctor_note "WARN" "ryoku-doctor resolves to $active_doctor instead of installed $expected_doctor"
    doctor_report_issue "WARN ryoku-doctor resolves to a different path than the installed checkout."
  fi
}

doctor_anonymize_report_line() {
  local line="$*"
  local home_path="${HOME:-}"
  local user_name=""
  local host_name=""

  user_name="$(id -un 2>/dev/null || true)"
  host_name="$(hostname 2>/dev/null || true)"

  if [[ -n $home_path ]]; then
    line="${line//$home_path/~}"
  fi

  line="$(printf '%s\n' "$line" | sed -E 's#/home/[^/[:space:]]+#~#g; s#/run/user/[0-9]+#/run/user/<uid>#g')"

  if [[ -n $user_name ]]; then
    line="${line//$user_name/<user>}"
  fi

  if [[ -n $host_name ]]; then
    line="${line//$host_name/<host>}"
  fi

  printf '%s\n' "$line"
}

doctor_report_line() {
  [[ -n $doctor_report_file ]] || return 0
  doctor_anonymize_report_line "$*" >> "$doctor_report_file"
}

doctor_report_value() {
  local label="$1"
  local value="${2:-unknown}"

  doctor_report_line "${label}: ${value:-unknown}"
}

doctor_report_issue() {
  [[ -n $doctor_report_file ]] || return 0
  doctor_report_line "- $*"
}

doctor_report_init() {
  local report_base="${TMPDIR:-/tmp}"
  local status_file status="unknown"

  doctor_report_dir="$(mktemp -d "${report_base}/ryoku-doctor-report.XXXXXXXX" 2>/dev/null || true)"
  if [[ -z $doctor_report_dir ]]; then
    return 0
  fi

  doctor_report_file="${doctor_report_dir}/report.txt"
  : > "$doctor_report_file" || {
    doctor_report_dir=""
    doctor_report_file=""
    return 0
  }
  chmod 600 "$doctor_report_file" 2>/dev/null || true

  status_file="$(update_status_file)"
  if [[ -r $status_file ]]; then
    status="$(<"$status_file")"
    [[ -n $status ]] || status="empty"
  fi

  doctor_report_line "Ryoku Update Doctor Report"
  doctor_report_line "Generated: $(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date 2>/dev/null || printf 'unknown')"
  doctor_report_line "Privacy: home path, username, hostname, and runtime UID are anonymized."
  doctor_report_line ""
  doctor_report_line "Context"
  doctor_report_value "Ryoku Path" "$RYOKU_PATH"
  doctor_report_value "Release Branch" "$(doctor_release_branch)"
  doctor_report_value "Remote" "$(doctor_remote_url)"
  doctor_report_value "Update Status" "$status"
  doctor_report_line ""
  doctor_report_line "Issues"
}

doctor_report_log_excerpt() {
  local log="$1"

  [[ -n $doctor_report_file && -r $log ]] || return 0

  doctor_report_line ""
  doctor_report_line "Update Log Excerpt"
  tail -n 120 "$log" 2>/dev/null | while IFS= read -r line; do
    doctor_report_line "$line"
  done
}

doctor_report_finish() {
  local log="${1:-}"
  local fixes="${2:-0}"
  local safe_to_retry="${3:-0}"
  local unresolved="${4:-0}"
  local warnings="${5:-0}"

  [[ -n $doctor_report_file && -f $doctor_report_file ]] || return 0

  if ! grep -q '^- ' "$doctor_report_file" 2>/dev/null; then
    doctor_report_issue "NONE No known update issue was matched before exit."
  fi

  doctor_report_line ""
  doctor_report_value "Fixes" "$fixes"
  doctor_report_value "Safe To Retry" "$safe_to_retry"
  doctor_report_value "Unresolved" "$unresolved"
  doctor_report_value "Warnings" "$warnings"

  if [[ -n $log ]]; then
    doctor_report_value "Log Path" "$log"
    doctor_report_log_excerpt "$log"
  fi
}

doctor_report_print_path() {
  [[ -n $doctor_report_file ]] || return 0
  echo
  echo "Doctor report: $doctor_report_file"
}

latest_update_log() {
  ryoku_pacman_latest_update_log
}

doctor_update_needs_attention() {
  local log status status_file

  status_file="$(update_status_file)"
  if [[ -r $status_file ]]; then
    status="$(<"$status_file")"
    if [[ $status == failed:* || $status == updating || $status == progress:* ]]; then
      return 0
    fi
  fi

  log="$(latest_update_log 2>/dev/null || true)"
  [[ -n $log && -r $log ]] || return 1

  grep -Eqi 'failed to commit transaction|Errors occurred, no packages were upgraded|unable to lock database|/var/lib/pacman/db\.lck|invalid or corrupted package|signature.*(unknown trust|invalid|marginal trust)|keyring.*(error|fail|missing)|required key missing|unknown trust|Migration [0-9]+ failed|Not possible to fast-forward|could not fast-forward to origin/|\[sudo\] password for |sudo: a password is required|sudo: a terminal is required' "$log"
}

doctor_git() {
  GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" "$@"
}

doctor_release_branch() {
  local config_file=""
  local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  local configured=""
  local state_file="$RYOKU_STATE_PATH/channel"
  local state_channel=""

  if [[ -n ${RYOKU_UPDATE_BRANCH:-} ]]; then
    configured="$RYOKU_UPDATE_BRANCH"
  else
    if [[ -r $state_file ]]; then
      state_channel="$(<"$state_file")"
      case "$state_channel" in
        main | unstable-dev)
          configured="$state_channel"
          ;;
      esac
    fi

    if [[ -z $configured ]]; then
      if [[ -n ${RYOKU_SHELL_CONFIG_DIR:-} ]]; then
        config_file="$RYOKU_SHELL_CONFIG_DIR/config.json"
      elif [[ -f $config_home/ryoku-shell/config.json ]]; then
        config_file="$config_home/ryoku-shell/config.json"
      else
        config_file="$config_home/illogical-impulse/config.json"
      fi

      if [[ -f $config_file ]] && command -v jq >/dev/null 2>&1; then
        configured="$(jq -r '.shellUpdates.channel // empty' "$config_file" 2>/dev/null || true)"
      fi
    fi
  fi

  case "$configured" in
    "" | main) printf '%s\n' "main" ;;
    unstable-dev) printf '%s\n' "unstable-dev" ;;
    *) printf '%s\n' "main" ;;
  esac
}

doctor_remote_url() {
  printf '%s\n' "${RYOKU_UPDATE_REMOTE_URL:-https://github.com/neur0map/ryoku-arch.git}"
}

doctor_remote_ref() {
  printf 'origin/%s\n' "$(doctor_release_branch)"
}

doctor_prepare_remote() {
  local remote_url

  [[ -d $RYOKU_PATH/.git ]] || return 1

  remote_url="$(doctor_remote_url)"
  if doctor_git remote get-url origin >/dev/null 2>&1; then
    doctor_git remote set-url origin "$remote_url"
  else
    doctor_git remote add origin "$remote_url"
  fi
}

doctor_fetch_release() {
  local release_branch

  release_branch="$(doctor_release_branch)"
  doctor_prepare_remote || return 1
  doctor_git fetch --prune origin "+refs/heads/${release_branch}:refs/remotes/origin/${release_branch}" >/dev/null 2>&1
}

doctor_fetch_branch() {
  local branch="$1"

  doctor_prepare_remote || return 1
  doctor_git fetch --prune origin "+refs/heads/${branch}:refs/remotes/origin/${branch}" >/dev/null 2>&1
}

doctor_fetch_official_refs() {
  local release_branch

  release_branch="$(doctor_release_branch)"
  doctor_fetch_branch "$release_branch" || return 1
  doctor_fetch_branch main || true
  doctor_fetch_branch unstable-dev || true
}

doctor_official_remote_contains_head() {
  local head ref reflog_head

  head="$(doctor_git rev-parse HEAD 2>/dev/null || true)"
  [[ -n $head ]] || return 1

  for ref in origin/main origin/unstable-dev; do
    doctor_git rev-parse --verify --quiet "$ref" >/dev/null || continue

    if doctor_git merge-base --is-ancestor HEAD "$ref"; then
      return 0
    fi

    while IFS= read -r reflog_head; do
      [[ $reflog_head == "$head" ]] && return 0
    done < <(doctor_git reflog show --format=%H "$ref" 2>/dev/null || true)
  done

  return 1
}

doctor_repair_stale_official_branch() {
  local branch remote_ref stash_ref=""

  [[ -d $RYOKU_PATH/.git ]] || {
    echo "Ryoku checkout is not a git repository: $RYOKU_PATH"
    return 2
  }

  branch="$(doctor_release_branch)"
  remote_ref="origin/$branch"

  doctor_fetch_official_refs || {
    echo "Unable to fetch Ryoku $branch from $(doctor_remote_url)."
    return 2
  }

  doctor_git rev-parse --verify "$remote_ref" >/dev/null || {
    echo "Unable to verify $remote_ref."
    return 2
  }

  if [[ $(doctor_git rev-parse HEAD) == "$(doctor_git rev-parse "$remote_ref")" ]]; then
    echo "Ryoku $branch is already aligned to $remote_ref."
    return 0
  fi

  if ! doctor_official_remote_contains_head; then
    echo "Current HEAD does not look like old official Ryoku history."
    echo "Leaving the installed checkout untouched."
    echo "Run: git -C \"$RYOKU_PATH\" log --oneline --decorate -8"
    return 2
  fi

  if [[ -n $(doctor_git status --porcelain --untracked-files=normal) ]]; then
    doctor_git stash push --include-untracked -m "ryoku-doctor branch repair $(date -Iseconds)"
    stash_ref="stash@{0}"
  fi

  doctor_git switch -C "$branch" "$remote_ref"

  echo "Repaired Ryoku checkout branch: $branch -> $remote_ref"
  if [[ -n $stash_ref ]]; then
    echo "Local checkout file changes were preserved in git stash: $stash_ref"
  fi
  doctor_report_issue "FIX Realigned installed checkout branch $branch to $remote_ref."
  return 0
}

doctor_fast_forward_available() {
  local remote_ref

  doctor_fetch_release || return 1
  remote_ref="$(doctor_remote_ref)"
  doctor_git rev-parse --verify "$remote_ref" >/dev/null 2>&1 || return 1
  doctor_git merge-base --is-ancestor HEAD "$remote_ref" || return 1
  [[ $(doctor_git rev-parse HEAD) != "$(doctor_git rev-parse "$remote_ref")" ]]
}

doctor_confirm_fast_forward() {
  local answer

  if [[ ${RYOKU_DOCTOR_ASSUME_YES:-} == "1" ]]; then
    echo "Fast-forward Ryoku now? [Y/n] y"
    return 0
  fi

  if [[ ${RYOKU_DOCTOR_ASSUME_NO:-} == "1" ]]; then
    echo "Fast-forward Ryoku now? [Y/n] n"
    return 1
  fi

  printf 'Fast-forward Ryoku now? [Y/n] '
  read -r answer || return 1
  [[ -z $answer || $answer =~ ^[Yy]$ ]]
}

run_fast_forward_doctor() {
  local updater="$RYOKU_PATH/bin/ryoku-update-git"
  local remote_ref

  if ! doctor_fast_forward_available; then
    echo "Ryoku is already on the latest fast-forwardable release."
    return 0
  fi

  remote_ref="$(doctor_remote_ref)"
  echo "Fast-forwarding Ryoku to $remote_ref..."

  if [[ -x $updater ]]; then
    "$updater"
  else
    doctor_git merge --ff-only "$remote_ref"
  fi
}

offer_fast_forward_update() {
  local remote_ref local_commit remote_commit

  doctor_fast_forward_available || return 1

  remote_ref="$(doctor_remote_ref)"
  local_commit="$(doctor_git rev-parse --short HEAD)"
  remote_commit="$(doctor_git rev-parse --short "$remote_ref")"

  echo "A newer Ryoku recovery update is available: $local_commit -> $remote_commit"
  if doctor_confirm_fast_forward; then
    run_fast_forward_doctor
    echo
    echo "Ryoku recovery update applied."
    return 0
  fi

  echo "Skipped Ryoku fast-forward."
  echo
  return 1
}

report_log_warnings() {
  local log="$1"
  local warnings=0

  if grep -q "Updating linux initcpios" "$log" \
    && ! grep -q "Initcpio image generation successful" "$log"; then
    echo "Warning: initramfs generation may have failed. Review the log before restart."
    ((warnings++)) || true
  fi

  if grep -Eq 'unable to lock database|/var/lib/pacman/db\.lck' "$log"; then
    echo "Warning: pacman database lock detected. Retry after package managers stop."
    ((warnings++)) || true
  fi

  if grep -Eqi 'invalid or corrupted package|signature.*(unknown trust|invalid|marginal trust)|keyring.*(error|fail|missing)|required key missing|unknown trust' "$log"; then
    echo "Warning: package signature or keyring issue detected. Try: ryoku-update-keyring"
    ((warnings++)) || true
  fi

  return "$warnings"
}

report_resolved_migration_failures() {
  local log="$1"
  local migration state_dir marker_name
  local resolved=0
  local unresolved=0
  local migrations=()

  state_dir="$RYOKU_STATE_PATH/migrations"

  mapfile -t migrations < <(
    sed -nE \
      -e 's/.*Migration ([0-9]+) failed.*/\1/p' \
      "$log" | sort -u
  )

  ((${#migrations[@]} > 0)) || return 1

  for migration in "${migrations[@]}"; do
    marker_name="${migration}.sh"

    if [[ -f $state_dir/$marker_name || -f $state_dir/skipped/$marker_name ]]; then
      echo "Migration $migration is already recorded; retry the update to continue."
      doctor_report_issue "SAFE Migration $migration is already recorded after the failed update."
      ((resolved++)) || true
    else
      echo "Migration $migration is still pending. Retry after fixing this migration."
      doctor_report_issue "FAIL Migration $migration is still pending after the failed update."
      ((unresolved++)) || true
    fi
  done

  ((unresolved == 0 && resolved > 0)) && return 0
  return 2
}

report_sudo_auth_stall() {
  local log="$1"

  grep -Eq '\[sudo\] password for |sudo: a password is required|sudo: a terminal is required' "$log" || return 1

  echo "Update stopped while waiting for sudo authentication."
  echo "Run: sudo -v"
  echo "Then retry: ryoku-update -y"
  doctor_report_issue "FAIL Update stopped while waiting for sudo authentication."
  return 0
}

report_git_fast_forward_stall() {
  local log="$1"
  local branch

  grep -Eq 'Not possible to fast-forward|could not fast-forward to origin/' "$log" || return 1

  branch="$(doctor_release_branch)"
  echo "Ryoku could not fast-forward its installed checkout."
  if doctor_repair_stale_official_branch; then
    echo "Run: ryoku-update -y"
    return 0
  fi

  doctor_report_issue "FAIL Installed checkout could not fast-forward to origin/$branch."
  return 2
}

report_local_runtime_env_bridge_failure() {
  local log="$1"
  local bin_home="${XDG_BIN_HOME:-$HOME/.local/bin}"
  local bridge_dir bridge_path source_path

  grep -Eq '\.local/lib/runtime-env\.sh: No such file' "$log" || return 1

  source_path="$RYOKU_PATH/lib/runtime-env.sh"
  bridge_dir="$(dirname "$bin_home")/lib"
  bridge_path="$bridge_dir/runtime-env.sh"

  if [[ ! -f $source_path ]]; then
    echo "Ryoku runtime environment source is missing: $source_path"
    doctor_report_issue "FAIL Missing runtime-env source for the local command bridge."
    return 2
  fi

  if ! mkdir -p "$bridge_dir" || ! ln -sfn "$source_path" "$bridge_path"; then
    echo "Could not repair local command runtime bridge: $bridge_path"
    doctor_report_issue "FAIL Could not repair local command runtime-env bridge."
    return 2
  fi

  echo "Repaired local command runtime bridge:"
  echo "  $bridge_path -> $source_path"
  doctor_report_issue "FIX Repaired local command runtime-env bridge."
  return 0
}

run_update_doctor() {
  local log repair_status migration_status ff_status runtime_env_status
  local fixes=0
  local safe_to_retry=0
  local unresolved=0
  local warnings=0

  doctor_report_init

  doctor_repair_gum
  doctor_banner "Update repair"
  doctor_context_panel
  doctor_environment_warnings
  echo
  echo "Ryoku Doctor: update"
  echo
  print_update_status
  if offer_fast_forward_update; then
    ((fixes++)) || true
    doctor_report_issue "FIX Fast-forwarded Ryoku recovery update."
    echo "Next:"
    echo "  Run: ryoku-update -y"
    doctor_report_finish "" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
    doctor_report_print_path
    return 0
  fi

  if ! log="$(latest_update_log)"; then
    echo "No readable Ryoku update log was found."
    echo "Run: ryoku-doctor"
    doctor_report_issue "FAIL No readable Ryoku update log was found."
    doctor_report_finish "" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
    doctor_report_print_path
    return 1
  fi

  echo "Log: $log"
  echo
  doctor_report_value "Log" "$log"

  if ryoku_pacman_conflicts_from_log "$log" | read -r _; then
    echo "Detected pacman file conflicts."
    doctor_report_issue "Detected pacman file conflicts."
    if ryoku_pacman_repair_conflicts_from_log "$log"; then
      ((fixes++)) || true
      doctor_report_issue "FIX Moved unowned package-manager conflict files."
    else
      repair_status=$?
      if (( repair_status == 2 )); then
        ((safe_to_retry++)) || true
        doctor_report_issue "SAFE Conflict paths are already clear or owned by pacman."
      else
        ((unresolved++)) || true
        doctor_report_issue "FAIL Pacman file conflicts need manual attention."
      fi
    fi
    echo
  fi

  if report_log_warnings "$log"; then
    :
  else
    warnings=$?
    doctor_report_issue "WARN Package/update warnings detected."
  fi

  if report_local_runtime_env_bridge_failure "$log"; then
    ((fixes++)) || true
    echo
  else
    runtime_env_status=$?
    if (( runtime_env_status == 2 )); then
      ((unresolved++)) || true
      echo
    fi
  fi

  if report_resolved_migration_failures "$log"; then
    ((safe_to_retry++)) || true
    echo
  else
    migration_status=$?
    if (( migration_status == 2 )); then
      ((unresolved++)) || true
      echo
    fi
  fi

  if report_sudo_auth_stall "$log"; then
    ((unresolved++)) || true
    echo
  fi

  if report_git_fast_forward_stall "$log"; then
    ((fixes++)) || true
    echo
  else
    ff_status=$?
    if (( ff_status == 2 )); then
      ((unresolved++)) || true
      echo
    fi
  fi

  if (( fixes > 0 || safe_to_retry > 0 )); then
    echo "Next:"
    echo "  Run: ryoku-update -y"
    doctor_report_finish "$log" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
    doctor_report_print_path
    return 0
  fi

  if (( unresolved > 0 || warnings > 0 )); then
    echo
    echo "No automatic safe fix was applied."
    echo "Review the note above, then run: ryoku-update -y"
    doctor_report_finish "$log" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
    doctor_report_print_path
    return 1
  fi

  echo "No known auto-fix matched this log."
  echo "If the update still fails, open an issue with this log: $log"
  doctor_report_finish "$log" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
  doctor_report_print_path
  return 1
}

doctor_command_present() {
  command -v "$1" >/dev/null 2>&1
}

doctor_hyprland_session_active() {
  [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] && return 0
  [[ ${XDG_CURRENT_DESKTOP:-} == *"Hyprland"* ]] && return 0

  if doctor_command_present hyprctl && hyprctl monitors -j >/dev/null 2>&1; then
    return 0
  fi

  return 1
}

doctor_converge_rebirth_session_services() {
  doctor_command_present systemctl || return 0
  doctor_hyprland_session_active || return 0

  systemctl --user import-environment \
    DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE HYPRLAND_INSTANCE_SIGNATURE \
    XCURSOR_THEME XCURSOR_SIZE HYPRCURSOR_THEME HYPRCURSOR_SIZE PATH \
    >/dev/null 2>&1 || true

  systemctl --user stop \
    niri.service \
    xdg-desktop-portal-gnome.service \
    >/dev/null 2>&1 || true

  systemctl --user reset-failed \
    niri.service \
    xdg-desktop-portal-gnome.service \
    xdg-desktop-portal-hyprland.service \
    xdg-desktop-portal.service \
    >/dev/null 2>&1 || true

  systemctl --user start \
    xdg-desktop-portal-hyprland.service \
    xdg-desktop-portal.service \
    >/dev/null 2>&1 || true

  doctor_note "OK" "Checked rebirth Hyprland user service state"
}

doctor_audio_restore_service_ready() {
  local unit="ryoku-audio-restore-mixers.service"
  local state=""

  systemctl --user list-unit-files "$unit" >/dev/null 2>&1 || return 1

  state="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
  case "$state" in
    enabled | static | enabled-runtime)
      return 0
      ;;
  esac

  return 1
}

doctor_repair_rebirth_audio_restore_service() {
  local installer="$RYOKU_PATH/install/config/ryoku-audio-restore-mixers.sh"

  doctor_command_present systemctl || return 0
  doctor_hyprland_session_active || return 0
  doctor_audio_restore_service_ready && return 0
  [[ -f $installer ]] || return 0

  if env RYOKU_PATH="$RYOKU_PATH" PATH="$RYOKU_PATH/bin:$PATH" bash "$installer" >/dev/null 2>&1; then
    doctor_note "FIX" "Repaired rebirth audio mixer self-heal service"
  else
    doctor_note "WARN" "Could not repair rebirth audio mixer self-heal service; shell doctor will report details" >&2
  fi
}

run_shell_doctor() {
  local setup
  local runtime_dir="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-shell"
  local candidates=(
    "$RYOKU_PATH/shell/setup"
    "$RYOKU_PATH/setup"
    "$runtime_dir/setup"
  )

  doctor_repair_gum
  doctor_banner "Shell health + automatic repair"
  doctor_context_panel
  doctor_environment_warnings
  echo

  doctor_converge_rebirth_session_services
  doctor_repair_rebirth_audio_restore_service

  for setup in "${candidates[@]}"; do
    [[ -x $setup ]] || continue
    env \
      -u RYOKU_SHELL_RUNTIME_DIR \
      -u QS_CONFIG_NAME \
      -u QS_CONFIG_PATH \
      -u QS_MANIFEST \
      RYOKU_DOCTOR_INTERNAL=1 \
      "$setup" doctor -y
    return $?
  done

  echo "Ryoku shell doctor is unavailable."
  echo "Checked the installed repo and quickshell config paths."
  return 1
}

run_smart_doctor() {
  if doctor_update_needs_attention; then
    run_update_doctor
  else
    run_shell_doctor
  fi
}

case "${1:-}" in
  "")
    run_smart_doctor
    ;;
  update)
    run_update_doctor
    ;;
  shell)
    run_shell_doctor
    ;;
  -h|help)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
