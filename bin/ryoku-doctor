#!/bin/bash

set -euo pipefail

script_path="${BASH_SOURCE[0]}"
script_path="$(readlink -f "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
repo_root="$(cd -- "$(dirname -- "$script_path")/.." && pwd)"
# shellcheck disable=SC1091
source "$repo_root/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$repo_root/lib/pacman-conflicts.sh"

usage() {
  cat <<'USAGE'
Usage: ryoku-doctor [shell|update|-h]

Diagnoses the latest failed Ryoku update when update state needs attention.
Otherwise runs the desktop shell doctor.
USAGE
}

state_home() {
  printf '%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

update_status_file() {
  printf '%s\n' "${RYOKU_UPDATE_STATUS:-$(state_home)/quickshell/user/update-status}"
}

print_update_status() {
  local status_file status

  status_file="$(update_status_file)"
  [[ -r $status_file ]] || return 0

  status="$(<"$status_file")"
  [[ -n $status ]] || return 0

  echo "Status: $status"
}

doctor_report_dir=""
doctor_report_file=""

doctor_anonymize_report_line() {
  local line="$*"
  local home_path="${HOME:-}"
  local user_name=""
  local host_name=""

  user_name="$(id -un 2>/dev/null || true)"
  host_name="$(hostname 2>/dev/null || true)"

  if [[ -n $home_path ]]; then
    line="${line//$home_path/~}"
  fi

  line="$(printf '%s\n' "$line" | sed -E 's#/home/[^/[:space:]]+#~#g; s#/run/user/[0-9]+#/run/user/<uid>#g')"

  if [[ -n $user_name ]]; then
    line="${line//$user_name/<user>}"
  fi

  if [[ -n $host_name ]]; then
    line="${line//$host_name/<host>}"
  fi

  printf '%s\n' "$line"
}

doctor_report_line() {
  [[ -n $doctor_report_file ]] || return 0
  doctor_anonymize_report_line "$*" >> "$doctor_report_file"
}

doctor_report_value() {
  local label="$1"
  local value="${2:-unknown}"

  doctor_report_line "${label}: ${value:-unknown}"
}

doctor_report_issue() {
  [[ -n $doctor_report_file ]] || return 0
  doctor_report_line "- $*"
}

doctor_report_init() {
  local report_base="${TMPDIR:-/tmp}"
  local status_file status="unknown"

  doctor_report_dir="$(mktemp -d "${report_base}/ryoku-doctor-report.XXXXXXXX" 2>/dev/null || true)"
  if [[ -z $doctor_report_dir ]]; then
    return 0
  fi

  doctor_report_file="${doctor_report_dir}/report.txt"
  : > "$doctor_report_file" || {
    doctor_report_dir=""
    doctor_report_file=""
    return 0
  }
  chmod 600 "$doctor_report_file" 2>/dev/null || true

  status_file="$(update_status_file)"
  if [[ -r $status_file ]]; then
    status="$(<"$status_file")"
    [[ -n $status ]] || status="empty"
  fi

  doctor_report_line "Ryoku Update Doctor Report"
  doctor_report_line "Generated: $(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date 2>/dev/null || printf 'unknown')"
  doctor_report_line "Privacy: home path, username, hostname, and runtime UID are anonymized."
  doctor_report_line ""
  doctor_report_line "Context"
  doctor_report_value "Ryoku Path" "$RYOKU_PATH"
  doctor_report_value "Release Branch" "$(doctor_release_branch)"
  doctor_report_value "Remote" "$(doctor_remote_url)"
  doctor_report_value "Update Status" "$status"
  doctor_report_line ""
  doctor_report_line "Issues"
}

doctor_report_log_excerpt() {
  local log="$1"

  [[ -n $doctor_report_file && -r $log ]] || return 0

  doctor_report_line ""
  doctor_report_line "Update Log Excerpt"
  tail -n 120 "$log" 2>/dev/null | while IFS= read -r line; do
    doctor_report_line "$line"
  done
}

doctor_report_finish() {
  local log="${1:-}"
  local fixes="${2:-0}"
  local safe_to_retry="${3:-0}"
  local unresolved="${4:-0}"
  local warnings="${5:-0}"

  [[ -n $doctor_report_file && -f $doctor_report_file ]] || return 0

  if ! grep -q '^- ' "$doctor_report_file" 2>/dev/null; then
    doctor_report_issue "NONE No known update issue was matched before exit."
  fi

  doctor_report_line ""
  doctor_report_value "Fixes" "$fixes"
  doctor_report_value "Safe To Retry" "$safe_to_retry"
  doctor_report_value "Unresolved" "$unresolved"
  doctor_report_value "Warnings" "$warnings"

  if [[ -n $log ]]; then
    doctor_report_value "Log Path" "$log"
    doctor_report_log_excerpt "$log"
  fi
}

doctor_report_print_path() {
  [[ -n $doctor_report_file ]] || return 0
  echo
  echo "Doctor report: $doctor_report_file"
}

latest_update_log() {
  ryoku_pacman_latest_update_log
}

doctor_update_needs_attention() {
  local log status status_file

  status_file="$(update_status_file)"
  if [[ -r $status_file ]]; then
    status="$(<"$status_file")"
    if [[ $status == failed:* || $status == updating || $status == progress:* ]]; then
      return 0
    fi
  fi

  log="$(latest_update_log 2>/dev/null || true)"
  [[ -n $log && -r $log ]] || return 1

  grep -Eqi 'failed to commit transaction|Errors occurred, no packages were upgraded|unable to lock database|/var/lib/pacman/db\.lck|invalid or corrupted package|signature.*(unknown trust|invalid|marginal trust)|keyring.*(error|fail|missing)|required key missing|unknown trust' "$log"
}

doctor_git() {
  GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" "$@"
}

doctor_release_branch() {
  local config_file=""
  local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  local configured=""
  local state_file="$RYOKU_STATE_PATH/channel"
  local state_channel=""

  if [[ -n ${RYOKU_UPDATE_BRANCH:-} ]]; then
    configured="$RYOKU_UPDATE_BRANCH"
  else
    if [[ -r $state_file ]]; then
      state_channel="$(<"$state_file")"
      case "$state_channel" in
        main | unstable-dev)
          configured="$state_channel"
          ;;
      esac
    fi

    if [[ -z $configured ]]; then
      if [[ -n ${RYOKU_SHELL_CONFIG_DIR:-} ]]; then
        config_file="$RYOKU_SHELL_CONFIG_DIR/config.json"
      elif [[ -f $config_home/ryoku-shell/config.json ]]; then
        config_file="$config_home/ryoku-shell/config.json"
      else
        config_file="$config_home/illogical-impulse/config.json"
      fi

      if [[ -f $config_file ]] && command -v jq >/dev/null 2>&1; then
        configured="$(jq -r '.shellUpdates.channel // empty' "$config_file" 2>/dev/null || true)"
      fi
    fi
  fi

  case "$configured" in
    "" | main) printf '%s\n' "main" ;;
    unstable-dev) printf '%s\n' "unstable-dev" ;;
    *) printf '%s\n' "main" ;;
  esac
}

doctor_remote_url() {
  printf '%s\n' "${RYOKU_UPDATE_REMOTE_URL:-https://github.com/neur0map/ryoku-arch.git}"
}

doctor_remote_ref() {
  printf 'origin/%s\n' "$(doctor_release_branch)"
}

doctor_prepare_remote() {
  local remote_url

  [[ -d $RYOKU_PATH/.git ]] || return 1

  remote_url="$(doctor_remote_url)"
  if doctor_git remote get-url origin >/dev/null 2>&1; then
    doctor_git remote set-url origin "$remote_url"
  else
    doctor_git remote add origin "$remote_url"
  fi
}

doctor_fetch_release() {
  local release_branch

  release_branch="$(doctor_release_branch)"
  doctor_prepare_remote || return 1
  doctor_git fetch --prune origin "+refs/heads/${release_branch}:refs/remotes/origin/${release_branch}" >/dev/null 2>&1
}

doctor_fast_forward_available() {
  local remote_ref

  doctor_fetch_release || return 1
  remote_ref="$(doctor_remote_ref)"
  doctor_git rev-parse --verify "$remote_ref" >/dev/null 2>&1 || return 1
  doctor_git merge-base --is-ancestor HEAD "$remote_ref" || return 1
  [[ $(doctor_git rev-parse HEAD) != "$(doctor_git rev-parse "$remote_ref")" ]]
}

doctor_confirm_fast_forward() {
  local answer

  if [[ ${RYOKU_DOCTOR_ASSUME_YES:-} == "1" ]]; then
    echo "Fast-forward Ryoku now? [Y/n] y"
    return 0
  fi

  if [[ ${RYOKU_DOCTOR_ASSUME_NO:-} == "1" ]]; then
    echo "Fast-forward Ryoku now? [Y/n] n"
    return 1
  fi

  printf 'Fast-forward Ryoku now? [Y/n] '
  read -r answer || return 1
  [[ -z $answer || $answer =~ ^[Yy]$ ]]
}

run_fast_forward_doctor() {
  local updater="$RYOKU_PATH/bin/ryoku-update-git"
  local remote_ref

  if ! doctor_fast_forward_available; then
    echo "Ryoku is already on the latest fast-forwardable release."
    return 0
  fi

  remote_ref="$(doctor_remote_ref)"
  echo "Fast-forwarding Ryoku to $remote_ref..."

  if [[ -x $updater ]]; then
    "$updater"
  else
    doctor_git merge --ff-only "$remote_ref"
  fi
}

offer_fast_forward_update() {
  local remote_ref local_commit remote_commit

  doctor_fast_forward_available || return 1

  remote_ref="$(doctor_remote_ref)"
  local_commit="$(doctor_git rev-parse --short HEAD)"
  remote_commit="$(doctor_git rev-parse --short "$remote_ref")"

  echo "A newer Ryoku recovery update is available: $local_commit -> $remote_commit"
  if doctor_confirm_fast_forward; then
    run_fast_forward_doctor
    echo
    exec "$script_path"
  fi

  echo "Skipped Ryoku fast-forward."
  echo
  return 1
}

report_log_warnings() {
  local log="$1"
  local warnings=0

  if grep -q "Updating linux initcpios" "$log" \
    && ! grep -q "Initcpio image generation successful" "$log"; then
    echo "Warning: initramfs generation may have failed. Review the log before restart."
    ((warnings++)) || true
  fi

  if grep -Eq 'unable to lock database|/var/lib/pacman/db\.lck' "$log"; then
    echo "Warning: pacman database lock detected. Retry after package managers stop."
    ((warnings++)) || true
  fi

  if grep -Eqi 'invalid or corrupted package|signature.*(unknown trust|invalid|marginal trust)|keyring.*(error|fail|missing)|required key missing|unknown trust' "$log"; then
    echo "Warning: package signature or keyring issue detected. Try: ryoku-update-keyring"
    ((warnings++)) || true
  fi

  return "$warnings"
}

report_resolved_migration_failures() {
  local log="$1"
  local migration state_dir marker_name
  local resolved=0
  local unresolved=0
  local migrations=()

  state_dir="$RYOKU_STATE_PATH/migrations"

  mapfile -t migrations < <(
    sed -nE \
      -e 's/.*Migration ([0-9]+) failed.*/\1/p' \
      "$log" | sort -u
  )

  ((${#migrations[@]} > 0)) || return 1

  for migration in "${migrations[@]}"; do
    marker_name="${migration}.sh"

    if [[ -f $state_dir/$marker_name || -f $state_dir/skipped/$marker_name ]]; then
      echo "Migration $migration is already recorded; retry the update to continue."
      doctor_report_issue "SAFE Migration $migration is already recorded after the failed update."
      ((resolved++)) || true
    else
      echo "Migration $migration is still pending. Retry after fixing this migration."
      doctor_report_issue "FAIL Migration $migration is still pending after the failed update."
      ((unresolved++)) || true
    fi
  done

  ((unresolved == 0 && resolved > 0)) && return 0
  return 2
}

report_sudo_auth_stall() {
  local log="$1"

  grep -Eq '\[sudo\] password for |sudo: a password is required|sudo: a terminal is required' "$log" || return 1

  echo "Update stopped while waiting for sudo authentication."
  echo "Run: sudo -v"
  echo "Then retry: ryoku-update -y"
  doctor_report_issue "FAIL Update stopped while waiting for sudo authentication."
  return 0
}

report_git_fast_forward_stall() {
  local log="$1"
  local branch

  grep -Eq 'Not possible to fast-forward|could not fast-forward to origin/' "$log" || return 1

  branch="$(doctor_release_branch)"
  echo "Ryoku could not fast-forward its installed checkout."
  echo "Run: ryoku-update-repair-branch $branch"
  echo "Then retry: ryoku-update -y"
  doctor_report_issue "FAIL Installed checkout could not fast-forward to origin/$branch."
  return 0
}

run_update_doctor() {
  local log repair_status migration_status
  local fixes=0
  local safe_to_retry=0
  local unresolved=0
  local warnings=0

  doctor_report_init

  echo "Ryoku Doctor: update"
  echo
  print_update_status
  offer_fast_forward_update || true

  if ! log="$(latest_update_log)"; then
    echo "No readable Ryoku update log was found."
    echo "Run: ryoku-doctor"
    doctor_report_issue "FAIL No readable Ryoku update log was found."
    doctor_report_finish "" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
    doctor_report_print_path
    return 1
  fi

  echo "Log: $log"
  echo
  doctor_report_value "Log" "$log"

  if ryoku_pacman_conflicts_from_log "$log" | read -r _; then
    echo "Detected pacman file conflicts."
    doctor_report_issue "Detected pacman file conflicts."
    if ryoku_pacman_repair_conflicts_from_log "$log"; then
      ((fixes++)) || true
      doctor_report_issue "FIX Moved unowned package-manager conflict files."
    else
      repair_status=$?
      if (( repair_status == 2 )); then
        ((safe_to_retry++)) || true
        doctor_report_issue "SAFE Conflict paths are already clear or owned by pacman."
      else
        ((unresolved++)) || true
        doctor_report_issue "FAIL Pacman file conflicts need manual attention."
      fi
    fi
    echo
  fi

  if report_log_warnings "$log"; then
    :
  else
    warnings=$?
    doctor_report_issue "WARN Package/update warnings detected."
  fi

  if report_resolved_migration_failures "$log"; then
    ((safe_to_retry++)) || true
    echo
  else
    migration_status=$?
    if (( migration_status == 2 )); then
      ((unresolved++)) || true
      echo
    fi
  fi

  if report_sudo_auth_stall "$log"; then
    ((unresolved++)) || true
    echo
  fi

  if report_git_fast_forward_stall "$log"; then
    ((unresolved++)) || true
    echo
  fi

  if (( fixes > 0 || safe_to_retry > 0 )); then
    echo "Next:"
    echo "  Run: ryoku-update -y"
    doctor_report_finish "$log" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
    doctor_report_print_path
    return 0
  fi

  if (( unresolved > 0 || warnings > 0 )); then
    echo
    echo "No automatic safe fix was applied."
    echo "Review the note above, then run: ryoku-update -y"
    doctor_report_finish "$log" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
    doctor_report_print_path
    return 1
  fi

  echo "No known auto-fix matched this log."
  echo "If the update still fails, open an issue with this log: $log"
  doctor_report_finish "$log" "$fixes" "$safe_to_retry" "$unresolved" "$warnings"
  doctor_report_print_path
  return 1
}

run_shell_doctor() {
  local setup
  local runtime_dir="${RYOKU_SHELL_RUNTIME_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-shell}"
  local candidates=(
    "$runtime_dir/setup"
    "$RYOKU_PATH/shell/setup"
    "$RYOKU_PATH/setup"
  )

  for setup in "${candidates[@]}"; do
    [[ -x $setup ]] || continue
    RYOKU_DOCTOR_INTERNAL=1 "$setup" doctor -y
    return $?
  done

  echo "Ryoku shell doctor is unavailable."
  echo "Checked the installed repo and quickshell config paths."
  return 1
}

run_smart_doctor() {
  if doctor_update_needs_attention; then
    run_update_doctor
  else
    run_shell_doctor
  fi
}

case "${1:-}" in
  "")
    run_smart_doctor
    ;;
  update)
    run_update_doctor
    ;;
  shell)
    run_shell_doctor
    ;;
  -h|help)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
