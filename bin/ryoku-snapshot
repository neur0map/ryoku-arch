#!/bin/bash

set -e
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

COMMAND="$1"

if [[ -z $COMMAND ]]; then
  echo "Usage: ryoku-snapshot <create|restore>" >&2
  exit 1
fi

if ! command -v snapper &>/dev/null; then
  exit 127 # ryoku-update can use this to just ignore if snapper is not available
fi

case "$COMMAND" in
create)
  DESC="$(ryoku-version)"

  echo -e "\e[32mCreate system snapshot\e[0m"

  # Get existing snapper config names from CSV output
  mapfile -t CONFIGS < <(sudo snapper --csvout list-configs | awk -F, 'NR>1 {print $1}')

  for config in "${CONFIGS[@]}"; do
    sudo snapper -c "$config" create -c number -d "$DESC"
    sudo snapper -c "$config" cleanup number || \
      echo -e "\e[33mWarning: could not prune old $config snapshots; run: sudo snapper -c $config cleanup number\e[0m" >&2
  done
  echo
  ;;
restore)
  sudo limine-snapper-restore
  ;;
esac
