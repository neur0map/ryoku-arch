#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

with_sound=false

for arg in "$@"; do
  case "$arg" in
  --with-desktop-audio|--with-microphone-audio)
    with_sound=true
    ;;
  --help)
    cat <<'USAGE'
Usage:
  ryoku-cmd-screenrecord [--with-desktop-audio] [--with-microphone-audio]

Starts Ryoku's region recorder. Audio flags select Ryoku's sound-capable
recording route.
USAGE
    exit 0
    ;;
  esac
done

if [[ $with_sound == "true" ]]; then
  exec ryoku-shell region recordWithSound
fi

exec ryoku-shell region record
