#!/bin/bash
set -euo pipefail

resolve_script_path() {
  local path="$1"
  local link_target link_dir

  while [[ -L $path ]]; do
    if ! command -v readlink >/dev/null; then
      echo "missing command: readlink" >&2
      return 1
    fi

    if ! link_target="$(readlink "$path")"; then
      echo "failed to resolve script path: $path" >&2
      return 1
    fi

    if [[ $link_target == /* ]]; then
      path="$link_target"
    else
      link_dir="${path%/*}"
      if [[ $link_dir == "$path" ]]; then
        link_dir=.
      fi
      path="$link_dir/$link_target"
    fi
  done

  printf '%s\n' "$path"
}

script_path="$(resolve_script_path "${BASH_SOURCE[0]}")"
script_dir="${script_path%/*}"

if [[ $script_dir == "$script_path" ]]; then
  script_dir=.
fi

script_dir="$(cd -P "$script_dir" && pwd -P)"
repo_root="$(cd -P "$script_dir/.." && pwd -P)"

cd "$repo_root"

required_commands=(
  xdg-terminal-exec
  walker
  waybar
  hyprctl
)

require_command() {
  local cmd="$1"

  if ! command -v "$cmd" >/dev/null; then
    echo "missing command: $cmd" >&2
    exit 1
  fi
}

require_file() {
  local path="$1"

  if [[ ! -f $path ]]; then
    echo "missing file: $path" >&2
    exit 1
  fi
}

for cmd in "${required_commands[@]}"; do
  require_command "$cmd"
done

require_file config/hypr/hyprland.conf
require_file config/waybar/config.jsonc
require_file config/waybar/style.css
