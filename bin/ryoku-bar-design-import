#!/bin/bash

# Import a third-party / user bar design into Ryoku.
#
# A bar design is DECLARATIVE DATA ONLY: it picks an in-repo Ryoku template +
# edge + bar entries (+ optional credits). It can NEVER carry runtime — no IPC,
# daemons, systemd units, helper binaries, commands, or embedded code. The shell
# only ever reads known declarative fields from a design and never execs, fetches
# or evaluates anything it contains.
#
# This importer enforces that boundary before a design is ever installed:
#   - a strict top-level ALLOWLIST (any unknown key is rejected),
#   - a runtime-token DENYLIST applied to every key at any depth,
#   - a value scan that rejects strings looking like embedded code/commands,
#   - shape checks (known template, known edge, known widget ids).
# A design that passes is re-emitted canonically (allowlisted keys only).

set -euo pipefail

PROG="${0##*/}"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/bar-designs"

# In-repo Ryoku templates a design may target.
KNOWN_TEMPLATES=(sidebar-left top-notch)
# Bar widget ids a design's entries may reference.
KNOWN_WIDGETS=(logo workspaces spacer activeWindow tray clock statusIcons power island)
KNOWN_EDGES=(left top right bottom)
# Top-level keys a design may contain. Anything else is rejected.
ALLOWED_ROOT=(id name description version templateId edge entries credits)
# Keys that imply runtime/code/IPC. Rejected anywhere in the document.
DENY_KEYS=(exec execdetached command cmd run shell sh bash script spawn process proc
  daemon service systemd unit ipc socket sock dbus eval function require plugin plugins
  binary entrypoint entrypoints onload handler hook fetch download curl wget)

usage() {
  cat <<EOF
Usage: $PROG <design.json> [--force]

Validate a declarative bar design and install it to:
  $config_dir/<id>.json

Rejects any design carrying runtime (IPC, daemons, commands, embedded code).
EOF
}

die() {
  echo "$PROG: $1" >&2
  exit 1
}

in_list() {
  local needle="$1"
  shift
  local x
  for x in "$@"; do
    [[ $x == "$needle" ]] && return 0
  done
  return 1
}

force=false
file=""
while (($# > 0)); do
  case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    --force) force=true ;;
    -*) die "unknown option: $1" ;;
    *)
      [[ -z $file ]] || die "only one design file may be given"
      file="$1"
      ;;
  esac
  shift
done

[[ -n $file ]] || {
  usage >&2
  exit 2
}
[[ -f $file ]] || die "no such file: $file"
command -v jq >/dev/null 2>&1 || die "jq is required"

# 1. Must be a JSON object.
jq -e 'type == "object"' "$file" >/dev/null 2>&1 || die "not a JSON object: $file"

# 2. Runtime/code denylist — reject any matching key at any depth.
mapfile -t all_keys < <(jq -r '[.. | objects | keys[]] | unique[]' "$file")
for k in "${all_keys[@]}"; do
  if in_list "${k,,}" "${DENY_KEYS[@]}"; then
    die "rejected: design contains a runtime field '$k'. Bar designs are declarative only — no IPC, daemons, commands or code."
  fi
done

# 3. Top-level allowlist — reject any unknown key.
mapfile -t root_keys < <(jq -r 'keys[]' "$file")
for k in "${root_keys[@]}"; do
  in_list "$k" "${ALLOWED_ROOT[@]}" || die "rejected: unknown top-level key '$k' (allowed: ${ALLOWED_ROOT[*]})"
done

# 4. Required fields + shapes.
id="$(jq -r '.id // empty' "$file")"
name="$(jq -r '.name // empty' "$file")"
template="$(jq -r '.templateId // empty' "$file")"
edge="$(jq -r '.edge // "left"' "$file")"

[[ -n $id ]] || die "rejected: missing required 'id'"
[[ $id =~ ^[a-z0-9][a-z0-9-]*$ ]] || die "rejected: 'id' must be a slug (lowercase letters, digits, hyphens): got '$id'"
[[ -n $name ]] || die "rejected: missing required 'name'"
[[ -n $template ]] || die "rejected: missing required 'templateId'"
in_list "$template" "${KNOWN_TEMPLATES[@]}" || die "rejected: unknown templateId '$template' (known: ${KNOWN_TEMPLATES[*]})"
in_list "$edge" "${KNOWN_EDGES[@]}" || die "rejected: invalid edge '$edge' (allowed: ${KNOWN_EDGES[*]})"

# 5. entries: array of {id, enabled?}; id in known widgets; enabled boolean.
if jq -e 'has("entries")' "$file" >/dev/null; then
  jq -e '.entries | type == "array"' "$file" >/dev/null || die "rejected: 'entries' must be an array"
  bad_entry_keys="$(jq -r '[.entries[] | keys[]] | unique | map(select(. != "id" and . != "enabled")) | join(",")' "$file")"
  [[ -z $bad_entry_keys ]] || die "rejected: entries may only contain id/enabled (saw: $bad_entry_keys)"
  jq -e '[.entries[] | select(has("enabled")) | .enabled | type] | all(. == "boolean")' "$file" >/dev/null \
    || die "rejected: entry 'enabled' must be boolean"
  mapfile -t entry_ids < <(jq -r '.entries[].id // empty' "$file")
  for wid in "${entry_ids[@]}"; do
    in_list "$wid" "${KNOWN_WIDGETS[@]}" || die "rejected: unknown widget id '$wid' in entries (known: ${KNOWN_WIDGETS[*]})"
  done
fi

# 6. credits (optional): only source/license/url.
if jq -e 'has("credits")' "$file" >/dev/null; then
  bad_credit_keys="$(jq -r '.credits | keys[] | select(. != "source" and . != "license" and . != "url")' "$file" | paste -sd, -)"
  [[ -z $bad_credit_keys ]] || die "rejected: credits may only contain source/license/url (saw: $bad_credit_keys)"
fi

# 7. Value scan — reject strings that look like embedded code/commands.
if jq -r '[.. | strings] | .[]' "$file" \
  | grep -qiE 'import[[:space:]]+Quickshell|Quickshell\.Io|Process[[:space:]]*\{|execDetached|\bexec\(|\bspawn\(|\bcurl\b|\bwget\b|;[[:space:]]*rm[[:space:]]'; then
  die "rejected: a string value looks like embedded code/commands. Bar designs are declarative only."
fi

# 8. Install canonical (allowlisted) form — refuse overwrite unless --force.
dest="$config_dir/$id.json"
if [[ -e $dest && $force != true ]]; then
  die "design '$id' already exists at $dest (use --force to overwrite)"
fi
mkdir -p "$config_dir"
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
jq '{id, name, description, version, templateId, edge: (.edge // "left"), entries, credits}
    | with_entries(select(.value != null))' "$file" >"$tmp"
mv "$tmp" "$dest"
echo "$PROG: installed bar design '$id' -> $dest"
