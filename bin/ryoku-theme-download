#!/bin/bash
# ryoku-theme-download: install a ryoku theme from the ryoku-arch repo.
#
# Fetches themes/<name>/ files (colors.toml + optional assets) from GitHub raw into
# ~/.config/ryoku/themes/<name>/ so it shows up in the Settings theme tiles. Skips
# themes that are already installed (user dir or the shipped install).
#
# Usage: ryoku-theme-download <theme-name>
# Env:   RYOKU_THEMES_REPO (default neur0map/ryoku-arch), RYOKU_THEMES_BRANCH (default main)

set -euo pipefail

name="${1:-}"
[[ -n $name ]] || {
  echo "usage: ryoku-theme-download <theme-name>" >&2
  exit 2
}

repo="${RYOKU_THEMES_REPO:-neur0map/ryoku-arch}"
branch="${RYOKU_THEMES_BRANCH:-main}"
base="https://raw.githubusercontent.com/$repo/$branch/themes/$name"
config_themes="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/themes"
dest="$config_themes/$name"

# already installed? (user dir or shipped install)
if [[ -d $dest ]] || { [[ -n ${RYOKU_PATH:-} ]] && [[ -d "$RYOKU_PATH/themes/$name" ]]; }; then
  echo "already installed: $name"
  exit 0
fi

command -v curl >/dev/null 2>&1 || {
  echo "ryoku-theme-download: curl is required" >&2
  exit 1
}

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

# colors.toml is required — abort if the theme isn't in the repo
if ! curl -fsSL "$base/colors.toml" -o "$tmp/colors.toml"; then
  echo "ryoku-theme-download: theme '$name' not found at $base" >&2
  exit 1
fi

# optional assets (best-effort)
for f in preview.png kitty.conf alacritty.toml btop.theme vscode.json icons.theme keyboard.rgb light.mode; do
  curl -fsSL "$base/$f" -o "$tmp/$f" 2>/dev/null || true
done

mkdir -p "$dest"
cp -r "$tmp/." "$dest/"
echo "installed: $name -> $dest"
