#!/bin/bash

# ryoku-verify-hypr-config — safety net against a missing/empty/stub Hyprland config.
#
# A failed config rewrite during an update (or any tool that moves the config aside
# without writing a valid replacement) leaves it absent. Hyprland then generates its
# built-in STUB hyprland.conf on next start, which strips every Ryoku keybind and the
# exec-once that launches the shell — the system looks "reset".
#
# Hyprland 0.55+ loads hyprland.lua (Lua) over hyprland.conf when present; Ryoku ships
# the Lua config. This guard treats EITHER a valid hyprland.lua OR a valid (non-stub)
# hyprland.conf as healthy, so it never forces a format on a not-yet-migrated box. It
# only acts when neither entrypoint is usable, restoring the canonical Lua tree from
# the installed repo default (and seeding any required sub-module that is missing, so
# the entrypoint's require()s resolve). It never overwrites a valid customized config.

set -euo pipefail

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

hypr_dir="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"
lua_entry="$hypr_dir/hyprland.lua"
conf_entry="$hypr_dir/hyprland.conf"
default_lua="$RYOKU_PATH/config/hypr/hyprland.lua"
stub_signature="This config is a STUB"
# Sub-modules hyprland.lua require()s; a missing one is a config error, so seed it.
modules=(colors monitors keyboard gpu hyprland-gui custom)

entry_is_valid() {
  local f="$1"
  [[ -f $f && -s $f ]] || return 1
  grep -Eq '[^[:space:]]' "$f" || return 1
  # Hyprland's auto-generated stub (written only when the real file was absent).
  grep -qF "$stub_signature" "$f" && return 1
  return 0
}

# Healthy when either entrypoint is usable.
if entry_is_valid "$lua_entry" || entry_is_valid "$conf_entry"; then
  exit 0
fi

if [[ ! -f $default_lua ]]; then
  echo "ryoku-verify-hypr-config: Hyprland config is broken but no Lua default to restore from ($default_lua)" >&2
  exit 1
fi

mkdir -p "$hypr_dir"

# Preserve a broken entrypoint for forensics before overwriting.
for broken in "$lua_entry" "$conf_entry"; do
  if [[ -f $broken ]]; then
    cp -a "$broken" "$broken.broken.$(date +%s)" 2>/dev/null \
      && echo "ryoku-verify-hypr-config: saved broken config to $broken.broken.*"
  fi
done

cp -a "$default_lua" "$lua_entry"
echo "ryoku-verify-hypr-config: restored hyprland.lua from $default_lua"

# Seed any required sub-module that is missing so every require() resolves; never
# overwrite an existing (possibly customized) module.
for m in "${modules[@]}"; do
  if [[ ! -f $hypr_dir/$m.lua && -f $RYOKU_PATH/config/hypr/$m.lua ]]; then
    cp -a "$RYOKU_PATH/config/hypr/$m.lua" "$hypr_dir/$m.lua"
    echo "ryoku-verify-hypr-config: seeded missing $m.lua"
  fi
done

# Apply live if a Hyprland instance is reachable (best-effort).
if command -v hyprctl >/dev/null 2>&1 && hyprctl reload >/dev/null 2>&1; then
  echo "ryoku-verify-hypr-config: reloaded Hyprland"
fi
