#!/bin/bash

# ryoku-verify-hypr-config — safety net against a missing/empty/stub hyprland.conf.
#
# A failed config rewrite during an update (or any tool that moves hyprland.conf
# aside without writing a valid replacement) leaves the file absent. Hyprland
# then generates its built-in STUB on next start, which strips every Ryoku
# keybind and the exec-once that launches the shell — the system looks "reset".
#
# This guard detects exactly that catastrophic state and restores the canonical
# config from the installed repo default, preserving whatever broken file was
# there. It never touches a valid (customized) config: it only acts when the
# file is missing, empty, or carries Hyprland's own stub signature.

set -euo pipefail

# shellcheck disable=SC1091
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

hypr_conf="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprland.conf"
default_conf="$RYOKU_PATH/config/hypr/hyprland.conf"
stub_signature="This config is a STUB"

config_is_broken() {
  # Missing or unreadable.
  [[ -f $hypr_conf ]] || return 0
  # Empty (no non-whitespace content).
  [[ -s $hypr_conf ]] || return 0
  grep -Eq '[^[:space:]]' "$hypr_conf" || return 0
  # Hyprland's auto-generated stub (written only when the real file was absent).
  grep -qF "$stub_signature" "$hypr_conf" && return 0
  return 1
}

if ! config_is_broken; then
  exit 0
fi

if [[ ! -f $default_conf ]]; then
  echo "ryoku-verify-hypr-config: hyprland.conf is broken but no default to restore from ($default_conf)" >&2
  exit 1
fi

mkdir -p "$(dirname "$hypr_conf")"

# Preserve the broken file for forensics before overwriting.
if [[ -f $hypr_conf ]]; then
  broken_copy="$hypr_conf.broken.$(date +%s)"
  cp -a "$hypr_conf" "$broken_copy" 2>/dev/null \
    && echo "ryoku-verify-hypr-config: saved broken config to $broken_copy"
fi

cp -a "$default_conf" "$hypr_conf"
echo "ryoku-verify-hypr-config: restored hyprland.conf from $default_conf"

# Apply live if a Hyprland instance is reachable (best-effort).
if command -v hyprctl >/dev/null 2>&1 && hyprctl reload >/dev/null 2>&1; then
  echo "ryoku-verify-hypr-config: reloaded Hyprland"
fi
