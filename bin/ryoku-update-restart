#!/bin/bash

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
source "$repo_root/lib/runtime-env.sh"
source "$repo_root/lib/update-dashboard.sh"

echo

if [[ ! -d /usr/lib/modules/$(uname -r) ]]; then
  ryoku_update_confirm "Linux kernel has been updated. Reboot?" && ryoku-system-reboot
elif [[ -f $RYOKU_STATE_PATH/reboot-required ]]; then
  ryoku_update_confirm "Updates require reboot. Ready?" && ryoku-system-reboot
fi

for file in "$RYOKU_STATE_PATH"/restart-*-required; do
  if [[ -f $file ]]; then
    filename=$(basename "$file")
    service=$(echo "$filename" | sed 's/restart-\(.*\)-required/\1/')
    echo "Restarting $service"
    ryoku-state clear "$filename"
    ryoku-restart-"$service"
  fi
done

# Mark the update finished for the bar's update-overlay watchdog and bounce
# the user's quickshell so the freshly-deployed payload loads, the stale
# localCommit clears on the next startup check, and the false "stuck"
# banner cannot fire. Both steps are best-effort: tty-only sessions and
# unmanaged shell instances skip silently.
quickshell_state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/quickshell/user"
if [[ -d $quickshell_state_dir ]]; then
  printf 'success\n' >"$quickshell_state_dir/update-status" 2>/dev/null || true
fi
if systemctl --user is-active ryoku-shell.service >/dev/null 2>&1; then
  systemctl --user restart ryoku-shell.service >/dev/null 2>&1 || true
elif systemctl --user is-enabled ryoku-shell.service >/dev/null 2>&1; then
  systemctl --user start ryoku-shell.service >/dev/null 2>&1 || true
fi
