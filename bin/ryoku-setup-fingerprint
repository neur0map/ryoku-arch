#!/bin/bash

set -e

PAM_SUDO_FILE="${RYOKU_PAM_SUDO_FILE:-/etc/pam.d/sudo}"
PAM_POLKIT_FILE="${RYOKU_PAM_POLKIT_FILE:-/etc/pam.d/polkit-1}"

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

print_success() {
  echo -e "${GREEN}$1${NC}"
}

print_error() {
  echo -e "${RED}$1${NC}"
}

print_info() {
  echo -e "${YELLOW}$1${NC}"
}

check_fingerprint_hardware() {
  # Get fingerprint devices for the user
  devices=$(fprintd-list "$USER" 2>/dev/null)

  # Exit if no devices found
  if [[ -z $devices ]]; then
    print_error "\nNo fingerprint sensor detected."
    return 1
  fi
  return 0
}

setup_pam_config() {
  # Configure sudo
  if ! grep -q pam_fprintd.so "$PAM_SUDO_FILE"; then
    print_info "Configuring sudo for fingerprint authentication..."
    sudo sed -i '1i auth    sufficient pam_fprintd.so' "$PAM_SUDO_FILE"
  fi

  # Configure polkit
  if [[ -f $PAM_POLKIT_FILE ]] && ! grep -q 'pam_fprintd.so' "$PAM_POLKIT_FILE"; then
    print_info "Configuring polkit for fingerprint authentication..."
    sudo sed -i '1i auth      sufficient pam_fprintd.so' "$PAM_POLKIT_FILE"
  elif [[ ! -f $PAM_POLKIT_FILE ]]; then
    print_info "Creating polkit configuration with fingerprint authentication..."
    sudo tee "$PAM_POLKIT_FILE" >/dev/null <<'EOF'
auth      sufficient pam_fprintd.so
auth      required pam_unix.so

account   required pam_unix.so
password  required pam_unix.so
session   required pam_unix.so
EOF
  fi
}

add_lockscreen_fingerprint_hint() {
  print_info "Fingerprint authentication is enabled for PAM-backed prompts."
}

remove_lockscreen_fingerprint_hint() {
  print_info "Fingerprint authentication removed from PAM-backed prompts."
}

remove_pam_config() {
  # Remove from sudo
  if grep -q pam_fprintd.so "$PAM_SUDO_FILE"; then
    print_info "Removing fingerprint authentication from sudo..."
    sudo sed -i '/pam_fprintd\.so/d' "$PAM_SUDO_FILE"
  fi

  # Remove from polkit
  if [[ -f $PAM_POLKIT_FILE ]] && grep -Fq 'pam_fprintd.so' "$PAM_POLKIT_FILE"; then
    print_info "Removing fingerprint authentication from polkit..."
    sudo sed -i '/pam_fprintd\.so/d' "$PAM_POLKIT_FILE"
  fi
}

install_fingerprint_packages() {
  # libfprint-git provides and conflicts with libfprint. Remove libfprint
  # without dependency checks first so noninteractive AUR installs cannot
  # abort on the conflict prompt.
  if ryoku-pkg-present libfprint; then
    sudo pacman -Rdd --noconfirm libfprint
  fi

  if ! ryoku-pkg-aur-add libfprint-git; then
    print_error "Could not install libfprint-git; restoring stock fingerprint packages."
    ryoku-pkg-add libfprint fprintd usbutils || true
    exit 1
  fi

  ryoku-pkg-add fprintd usbutils
}

mode="${1:-}"

if [[ $mode == "--remove" ]]; then
  print_success "Removing fingerprint scanner from authentication.\n"

  # Remove PAM configuration
  remove_pam_config

  remove_lockscreen_fingerprint_hint

  # Uninstall packages
  print_info "Removing fingerprint packages..."
  ryoku-pkg-drop fprintd libfprint-git

  print_success "Fingerprint authentication has been completely removed."
else
  print_success "Setting up fingerprint scanner for authentication.\n"

  # Install required packages
  print_info "Installing required packages..."
  install_fingerprint_packages

  if ! check_fingerprint_hardware; then
    exit 1
  fi

  # Configure PAM
  setup_pam_config

  add_lockscreen_fingerprint_hint

  # Enroll first fingerprint
  print_success "\nLet's setup your right index finger as the first fingerprint."
  print_info "Keep moving the finger around on sensor until the process completes.\n"

  if sudo fprintd-enroll "$USER"; then
    print_success "\nFingerprint enrolled successfully!"

    # Verify
    print_info "\nNow let's verify that it's working correctly.\n"
    if fprintd-verify; then
      print_success "\nPerfect! Fingerprint authentication is now configured."
      print_info "You can use your fingerprint for sudo, polkit, and lock screen (Super + Escape)."
    else
      print_error "\nVerification failed. You may want to try enrolling again."
    fi
  else
    print_error "\nEnrollment failed. Please try again."
    exit 1
  fi
fi
