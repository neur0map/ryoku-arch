#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Set the system-wide monospace font that should be used by terminals and fontconfig.
# The font name must be one of the ones returned by ryoku-font-list.

font_name="$1"

if [[ -n $font_name ]]; then
  if fc-list | grep -iq "$font_name"; then
    if [[ -f ~/.config/alacritty/alacritty.toml ]]; then
      sed -i "s/family = \".*\"/family = \"$font_name\"/g" ~/.config/alacritty/alacritty.toml
    fi

    if [[ -f ~/.config/kitty/kitty.conf ]]; then
      sed -i "s/^font_family .*/font_family $font_name/g" ~/.config/kitty/kitty.conf
      pkill -USR1 kitty
    fi

    if [[ -f ~/.config/ghostty/config ]]; then
      sed -i "s/font-family = \".*\"/font-family = \"$font_name\"/g" ~/.config/ghostty/config
      pkill -SIGUSR2 ghostty
    fi

    fontconfig_dir="$HOME/.config/fontconfig/conf.d"
    font_xml=$(printf '%s' "$font_name" | sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g')
    mkdir -p "$fontconfig_dir"

    cat >"$fontconfig_dir/50-ryoku-monospace.conf" <<EOF
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "urn:fontconfig:fonts.dtd">
<fontconfig>
  <match target="pattern">
    <test name="family">
      <string>monospace</string>
    </test>
    <edit name="family" mode="assign" binding="same">
      <string>$font_xml</string>
    </edit>
  </match>
</fontconfig>
EOF

    ryoku-restart-shell >/dev/null 2>&1 || true

    if pgrep -x ghostty; then
      notify-send -u low "    You must restart Ghostty to see font change"
    fi

    ryoku-hook font-set "$font_name"
  else
    echo "Font '$font_name' not found."
    exit 1
  fi
else
  echo "Usage: ryoku-font-set <font-name>"
fi
