#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  ryoku-wallpaper-apply --type image PATH
  ryoku-wallpaper-apply --type video PATH
EOF
}

json_error() {
  jq -cn --arg error "$1" '{ok:false,error:$error}'
}

json_ok() {
  jq -cn --arg type "$1" --arg path "$2" '{ok:true,type:$type,path:$path}'
}

apply_image() {
  local path="$1"

  if [[ ! -f $path ]]; then
    json_error "image file not found"
    return 1
  fi

  pkill -x mpvpaper 2>/dev/null || true
  if ! "$RYOKU_PATH/bin/ryoku-theme-bg-set" "$path" >/dev/null; then
    json_error "failed to apply image wallpaper"
    return 4
  fi
  json_ok "image" "$path"
}

apply_video() {
  local path="$1"
  local poster="$RYOKU_STATE_PATH/wallpaper/current-video-poster.jpg"

  if [[ ! -f $path ]]; then
    json_error "video file not found"
    return 1
  fi

  mkdir -p "$(dirname "$poster")"
  rm -f "$poster"
  if ryoku-cmd-present ffmpegthumbnailer; then
    ffmpegthumbnailer -i "$path" -o "$poster" -s 1280 -q 9 >/dev/null 2>&1 || true
  fi

  if [[ -f $poster ]]; then
    if ! mkdir -p "$RYOKU_CONFIG_PATH/current" 2>/dev/null; then
      json_error "failed to update video wallpaper poster"
      return 4
    fi
    if ! ln -nsf "$poster" "$RYOKU_CONFIG_PATH/current/background" 2>/dev/null; then
      json_error "failed to update video wallpaper poster"
      return 4
    fi
  fi

  if ! "$RYOKU_PATH/bin/ryoku-theme-bg-set" "$path" >/dev/null; then
    json_error "failed to apply video wallpaper"
    return 4
  fi

  json_ok "video" "$path"
}

main() {
  local type
  local path

  if (( $# != 3 )) || [[ ${1:-} != "--type" ]]; then
    json_error "expected --type image|video PATH"
    return 2
  fi

  type="$2"
  path="$3"

  case "$type" in
    image)
      apply_image "$path"
      ;;
    video)
      apply_video "$path"
      ;;
    *)
      json_error "unknown wallpaper type"
      return 2
      ;;
  esac
}

main "$@"
