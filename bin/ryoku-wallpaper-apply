#!/bin/bash

set -euo pipefail

_RYOKU_SELF="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
source "$_RYOKU_SELF/lib/runtime-env.sh"
source "$_RYOKU_SELF/lib/wallpaper-backends.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  ryoku-wallpaper-apply --type image|animated|video PATH
EOF
}

json_error() {
  jq -cn --arg error "$1" '{ok:false,error:$error}'
}

json_ok() {
  jq -cn --arg type "$1" --arg path "$2" '{ok:true,type:$type,path:$path}'
}

_settings_gui_settings="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/settings-gui/settings.json"

_settings_get() {
  local key="$1" default="$2"
  if [[ -f $_settings_gui_settings ]]; then
    local val
    val="$(jq -r --arg d "$default" "$key | if . == null then \$d else tostring end" "$_settings_gui_settings" 2>/dev/null)" || val="$default"
    printf '%s' "$val"
  else
    printf '%s' "$default"
  fi
}

set_shell_wallpaper_config() {
  local path="$1"
  local thumbnail="${2:-}"
  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku-shell"
  local config_file="$config_dir/config.json"
  local temp_file

  [[ -f $config_file ]] || return 0

  if ryoku-cmd-missing jq; then
    echo "ryoku-wallpaper-apply: jq is required to update Ryoku wallpaper config" >&2
    return 1
  fi

  temp_file=$(mktemp)
  jq --arg path "$path" --arg thumbnail "$thumbnail" \
    '.background.wallpaperPath = $path | .background.thumbnailPath = $thumbnail' \
    "$config_file" >"$temp_file" &&
    mv "$temp_file" "$config_file"
}

apply_image() {
  local path="$1"

  [[ -f $path ]] || { json_error "image file not found"; return 1; }
  ryoku_wp_stop_live_backends
  if ! "$RYOKU_PATH/bin/ryoku-theme-bg-set" "$path" >/dev/null; then
    json_error "failed to apply image wallpaper"
    return 4
  fi
  ryoku_wp_write_type image
  json_ok "image" "$path"
}

apply_animated() {
  local path="$1" poster="$RYOKU_STATE_PATH/wallpaper/current-poster.jpg" thumbnail=""
  [[ -f $path ]] || { json_error "animated file not found"; return 1; }
  local live_enabled transition
  live_enabled="$(_settings_get '.wallpaper.liveWallpaperEnabled' "true")"
  transition="$(_settings_get '.wallpaper.swwwTransition' "any")"
  ryoku_wp_stop_live_backends
  if [[ $live_enabled == "true" ]]; then
    if ! awww query >/dev/null 2>&1; then awww-daemon >/dev/null 2>&1 & fi
    for _ in 1 2 3 4 5; do awww query >/dev/null 2>&1 && break; sleep 0.1; done
    awww img "$path" --transition-type "$transition" >/dev/null 2>&1 || { json_error "awww failed"; return 4; }
  else
    if ryoku_wp_make_poster "$path" "$poster" && [[ -f $poster ]]; then
      apply_image "$poster"
      return
    fi
  fi
  if ryoku_wp_make_poster "$path" "$poster"; then
    thumbnail="$poster"
    mkdir -p "$RYOKU_CONFIG_PATH/current"
    ln -nsf "$poster" "$RYOKU_CONFIG_PATH/current/background"
  fi
  ryoku_wp_write_type animated
  set_shell_wallpaper_config "$path" "$thumbnail"
  json_ok "animated" "$path"
}

apply_video() {
  local path="$1" poster="$RYOKU_STATE_PATH/wallpaper/current-poster.jpg" thumbnail=""
  [[ -f $path ]] || { json_error "video file not found"; return 1; }
  local live_enabled muted
  live_enabled="$(_settings_get '.wallpaper.liveWallpaperEnabled' "true")"
  muted="$(_settings_get '.wallpaper.videoMuted' "true")"
  ryoku_wp_stop_live_backends
  if ryoku_wp_make_poster "$path" "$poster"; then
    thumbnail="$poster"
    mkdir -p "$RYOKU_CONFIG_PATH/current"
    ln -nsf "$poster" "$RYOKU_CONFIG_PATH/current/background"
  fi
  if [[ $live_enabled == "true" ]]; then
    local opts="loop hwdec=auto scale=ewa_lanczossharp cscale=ewa_lanczossharp video-sync=display-resample panscan=1.0 load-scripts=no"
    [[ $muted == "true" ]] && opts="no-audio $opts"
    nohup mpvpaper --auto-pause -o "$opts" ALL "$path" >/tmp/ryoku-mpvpaper.log 2>&1 &
  fi
  ryoku_wp_write_type video
  set_shell_wallpaper_config "$path" "$thumbnail"
  json_ok "video" "$path"
}

main() {
  local type
  local path

  if (( $# != 3 )) || [[ ${1:-} != "--type" ]]; then
    json_error "expected --type image|animated|video PATH"
    return 2
  fi

  type="$2"
  path="$3"

  case "$type" in
    image)
      apply_image "$path"
      ;;
    animated)
      apply_animated "$path"
      ;;
    video)
      apply_video "$path"
      ;;
    *)
      json_error "unknown wallpaper type"
      return 2
      ;;
  esac
}

main "$@"
