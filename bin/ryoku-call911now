#!/bin/bash

set -euo pipefail

medevac_version="1"
remote_url="${RYOKU_UPDATE_REMOTE_URL:-https://github.com/neur0map/ryoku-arch.git}"
archive_base_url="${RYOKU_MEDEVAC_ARCHIVE_BASE_URL:-https://github.com/neur0map/ryoku-arch/archive/refs/heads}"
compat_bootstrap="${RYOKU_MEDEVAC_COMPAT_BOOTSTRAP:-0}"
system_shim_status="not checked"
archive_mode="0"
update_status="not started"
doctor_status="not started"
release_branch=""
ryoku_path=""
lock_dir=""
backup_paths=()

state_home() {
  printf '%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

ryoku_state_path() {
  printf '%s\n' "${RYOKU_STATE_PATH:-$(state_home)/ryoku}"
}

release_lock() {
  [[ -n $lock_dir ]] || return 0
  rm -f "$lock_dir/pid" 2>/dev/null || true
  rmdir "$lock_dir" 2>/dev/null || true
}

acquire_lock() {
  local state_path
  local lock_pid

  state_path="$(ryoku_state_path)"
  mkdir -p "$state_path" 2>/dev/null || return 0
  lock_dir="$state_path/medevac.lock"

  if mkdir "$lock_dir" 2>/dev/null; then
    printf '%s\n' "$$" >"$lock_dir/pid" 2>/dev/null || true
    trap release_lock EXIT
    return 0
  fi

  if [[ -r $lock_dir/pid ]]; then
    lock_pid="$(<"$lock_dir/pid")"
    if [[ $lock_pid =~ ^[0-9]+$ ]] && ! kill -0 "$lock_pid" 2>/dev/null; then
      rm -f "$lock_dir/pid" 2>/dev/null || true
      rmdir "$lock_dir" 2>/dev/null || true
      if mkdir "$lock_dir" 2>/dev/null; then
        printf '%s\n' "$$" >"$lock_dir/pid" 2>/dev/null || true
        trap release_lock EXIT
        return 0
      fi
    fi
  fi

  die "another Ryoku MedEvac recovery is already running; wait for it to finish before starting a second one"
}

command_present() {
  command -v "$1" >/dev/null 2>&1
}

medevac_label() {
  if [[ $compat_bootstrap == "1" ]]; then
    printf '%s\n' "bootstrap"
  else
    printf '%s\n' "MedEvac"
  fi
}

medevac_run_label() {
  if [[ $compat_bootstrap == "1" ]]; then
    printf '%s\n' "Ryoku bootstrap"
  else
    printf '%s\n' "Ryoku MedEvac"
  fi
}

color_enabled() {
  [[ -t 1 && ${NO_COLOR:-} == "" ]]
}

ansi() {
  local code="$1"

  color_enabled || return 0
  printf '\033[%sm' "$code"
}

reset_ansi() {
  color_enabled || return 0
  printf '\033[0m'
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf '%sWARN:%s %s\n' "$(ansi 33)" "$(reset_ansi)" "$*" >&2
}

die() {
  printf '%sERROR:%s %s\n' "$(ansi 31)" "$(reset_ansi)" "$*" >&2
  exit 1
}

pretty_available() {
  [[ ${RYOKU_MEDEVAC_PLAIN:-0} != "1" ]] && command_present ryoku-tui && [[ -t 1 ]]
}

pretty_style() {
  if pretty_available; then
    ryoku-tui style "$@"
  else
    printf '%s\n' "${@: -1}"
  fi
}

banner() {
  local title subtitle

  title="RYOKU MEDEVAC // CALL SIGN: ryoku-call911now"
  subtitle="Last-resort extraction: recover checkout, repair bridges, pull latest doctor, run updater."

  if [[ $compat_bootstrap == "1" ]]; then
    title="RYOKU BOOTSTRAP // routed through ryoku-call911now"
    subtitle="Compatibility bridge: this old entrypoint now hands off to MedEvac."
  fi

  if pretty_available; then
    ryoku-tui style \
      --border double \
      --border-foreground 6 \
      --foreground 15 \
      --padding "1 3" \
      --margin "1 0" \
      "$title" \
      "$subtitle"
    return
  fi

  printf '%s\n' "$(ansi 36)============================================================$(reset_ansi)"
  printf '%s\n' "$(ansi 1)$(ansi 37)$title$(reset_ansi)"
  printf '%s\n' "$(ansi 36)$subtitle$(reset_ansi)"
  printf '%s\n' "$(ansi 36)============================================================$(reset_ansi)"
}

mission_panel() {
  local lines

  lines=$(
    printf '%s\n' "MISSION PROFILE"
    printf '%s\n' "1. Stabilize rescue tools without trusting stale Ryoku paths."
    printf '%s\n' "2. Recover the official checkout by git or archive fallback."
    printf '%s\n' "3. Repair local and authorized system command bridges."
    printf '%s\n' "4. Run the latest doctor, then hand off to normal update."
  )

  if pretty_available; then
    ryoku-tui style \
      --border rounded \
      --border-foreground 4 \
      --foreground 7 \
      --padding "1 2" \
      "$lines"
    return
  fi

  printf '%s\n' "$(ansi 34)+----------------------------------------------------------+$(reset_ansi)"
  while IFS= read -r line; do
    printf '%s|%s %-56s %s|%s\n' "$(ansi 34)" "$(reset_ansi)" "$line" "$(ansi 34)" "$(reset_ansi)"
  done <<<"$lines"
  printf '%s\n' "$(ansi 34)+----------------------------------------------------------+$(reset_ansi)"
}

preflight_summary() {
  local summary

  summary=$(
    printf 'Target path: %s\n' "$ryoku_path"
    printf 'Target channel: %s\n' "$release_branch"
    printf 'Remote: %s\n' "$remote_url"
    printf 'State: %s\n' "$(ryoku_state_path)"
    printf 'Mode: last-resort recovery, may preserve and replace stale checkouts\n'
  )

  if pretty_available; then
    ryoku-tui style \
      --border rounded \
      --border-foreground 3 \
      --foreground 7 \
      --padding "1 2" \
      "$summary"
    return
  fi

  printf '%s\n' "$(ansi 33)Preflight$(reset_ansi)"
  printf '%s\n' "$summary"
}

step() {
  local message="$1"

  if pretty_available; then
    ryoku-tui style --foreground 6 "==> $message"
  else
    printf '%s==>%s %s\n' "$(ansi 36)" "$(reset_ansi)" "$message"
  fi
}

ok() {
  printf '%sOK:%s %s\n' "$(ansi 32)" "$(reset_ansi)" "$*"
}

ryoku_config_file() {
  local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"

  if [[ -n ${RYOKU_SHELL_CONFIG_DIR:-} ]]; then
    printf '%s\n' "$RYOKU_SHELL_CONFIG_DIR/config.json"
    return
  fi

  if [[ -r $config_home/ryoku-shell/config.json ]]; then
    printf '%s\n' "$config_home/ryoku-shell/config.json"
    return
  fi

  printf '%s\n' "$config_home/illogical-impulse/config.json"
}

configured_release_branch() {
  local configured="${RYOKU_UPDATE_BRANCH:-}"
  local fallback="${RYOKU_MEDEVAC_DEFAULT_BRANCH:-unstable-dev}"
  local state_file config_file config_content label

  label="$(medevac_label)"
  state_file="$(ryoku_state_path)/channel"

  if [[ -z $configured ]]; then
    config_file="$(ryoku_config_file)"
    if [[ -r $config_file ]]; then
      config_content="$(<"$config_file")"
      if [[ $config_content == *'"unstable-dev"'* ]]; then
        configured="unstable-dev"
      elif [[ $config_content == *'"main"'* ]]; then
        configured="main"
      fi
    fi
  fi

  if [[ -z $configured && -r $state_file ]]; then
    configured="$(<"$state_file")"
  fi

  if [[ -z $configured ]]; then
    configured="$fallback"
    warn "no Ryoku update channel configured; $label is using $configured for rebirth recovery"
  fi

  case "$configured" in
    main)
      printf '%s\n' "main"
      ;;
    unstable-dev)
      printf '%s\n' "unstable-dev"
      ;;
    *)
      warn "ignoring invalid Ryoku update channel '$configured'; using main"
      printf '%s\n' "main"
      ;;
  esac
}

persist_release_branch() {
  local state_path

  state_path="$(ryoku_state_path)"
  mkdir -p "$state_path" 2>/dev/null || return 0
  printf '%s\n' "$release_branch" >"$state_path/channel" 2>/dev/null || true
}

default_ryoku_path() {
  local ryoku_default="$HOME/.local/share/ryoku"
  local legacy_path="$HOME/.local/share/omarchy"

  if [[ -n ${RYOKU_PATH:-} ]]; then
    printf '%s\n' "$RYOKU_PATH"
  elif [[ -e $ryoku_default ]]; then
    printf '%s\n' "$ryoku_default"
  elif [[ -e $legacy_path ]]; then
    printf '%s\n' "$legacy_path"
  else
    printf '%s\n' "$ryoku_default"
  fi
}

ensure_canonical_ryoku_path() {
  local canonical_path="$HOME/.local/share/ryoku"

  [[ -e $canonical_path ]] && return 0
  [[ -e $ryoku_path ]] || return 0

  mkdir -p "$(dirname "$canonical_path")"
  ln -sfn "$ryoku_path" "$canonical_path"
  log "Linked installed checkout into canonical Ryoku path: $canonical_path -> $ryoku_path"
}

command_realpath() {
  local command_name="$1"
  local command_path=""

  command_path="$(command -v "$command_name" 2>/dev/null || true)"
  [[ -n $command_path ]] || return 1
  readlink -f "$command_path" 2>/dev/null || printf '%s\n' "$command_path"
}

git_in_ryoku() {
  GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$ryoku_path" "$@"
}

sudo_authorized() {
  command_present sudo || return 1

  if sudo -n true 2>/dev/null; then
    return 0
  fi

  if [[ -t 0 && ${RYOKU_MEDEVAC_NO_SUDO_PROMPT:-0} != "1" ]]; then
    warn "MedEvac may ask for sudo once to repair /usr/local Ryoku shims and install missing rescue tools."
    sudo -v && return 0
  fi

  return 1
}

sudo_needs_terminal_input() {
  ((EUID == 0)) && return 1
  command_present sudo || return 1
  sudo -n true >/dev/null 2>&1 && return 1
  [[ ! -t 0 ]]
}

install_packages() {
  local packages=("$@")

  ((${#packages[@]} > 0)) || return 0

  if command_present ryoku-pkg-add; then
    ryoku-pkg-add "${packages[@]}" >/dev/null 2>&1 && return 0
  fi

  if command_present pacman && sudo_authorized; then
    sudo pacman -Sy --needed --noconfirm "${packages[@]}" >/dev/null 2>&1 && return 0
  fi

  if command_present paru; then
    paru -Sy --needed --noconfirm "${packages[@]}" >/dev/null 2>&1 && return 0
  fi

  if command_present yay; then
    yay -Sy --needed --noconfirm "${packages[@]}" >/dev/null 2>&1 && return 0
  fi

  return 1
}

try_install_rescue_tools() {
  local missing=()

  command_present git || missing+=(git)
  command_present curl || command_present wget || missing+=(curl)
  command_present tar || missing+=(tar)
  command_present gzip || missing+=(gzip)
  command_present find || missing+=(findutils)

  if ((${#missing[@]} == 0)); then
    ok "Rescue tools are present"
    return 0
  fi

  step "Installing missing rescue tools: ${missing[*]}"
  if install_packages "${missing[@]}"; then
    hash -r 2>/dev/null || true
    ok "Installed missing rescue tools"
  else
    warn "could not install all rescue tools; MedEvac will continue with available fallback paths"
  fi
}

# The shell command users can curl when the local install is too broken to run
# MedEvac at all.
recover_command() {
  printf 'curl -fsSL https://raw.githubusercontent.com/neur0map/ryoku-arch/%s/recover.sh | bash' "${release_branch:-main}"
}

# Fetch both channel refs. Returns 0 if origin/$release_branch is available
# (fetched now or already cached from a prior run), 1 if the remote is
# unreachable and there is no cached ref to fall back on (offline).
fetch_release_refs() {
  local branch

  git_in_ryoku remote set-url origin "$remote_url" 2>/dev/null || \
    git_in_ryoku remote add origin "$remote_url"

  for branch in main unstable-dev; do
    git_in_ryoku fetch --prune origin "+refs/heads/${branch}:refs/remotes/origin/${branch}" >/dev/null 2>&1 || true
  done

  git_in_ryoku rev-parse --verify --quiet "origin/$release_branch" >/dev/null
}

# Read-only diagnosis: tell the user exactly what state the installed checkout
# is in (detached HEAD, wrong channel, dirty tree, behind/ahead/diverged) before
# MedEvac acts on it. Requires origin/$release_branch to be present.
classify_and_report() {
  local head counts ahead behind

  head="$(git_in_ryoku rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'HEAD')"
  if [[ $head == "HEAD" ]]; then
    warn "checkout is in DETACHED HEAD state"
  elif [[ $head != "$release_branch" ]]; then
    warn "checkout is on '$head', not the '$release_branch' channel"
  fi
  checkout_has_local_file_changes && warn "checkout has uncommitted local file changes"

  if counts="$(git_in_ryoku rev-list --left-right --count "HEAD...origin/$release_branch" 2>/dev/null)"; then
    read -r ahead behind <<<"$counts"
    if ((ahead == 0 && behind == 0)); then
      ok "checkout is already at the latest $release_branch commit"
    elif ((ahead == 0)); then
      log "checkout is $behind commit(s) behind origin/$release_branch (fast-forward)"
    elif ((behind == 0)); then
      warn "checkout has $ahead local commit(s) not on origin/$release_branch"
    else
      warn "checkout has DIVERGED: $ahead local / $behind remote commit(s)"
    fi
  fi
}

checkout_release_branch() {
  local current_branch=""

  current_branch="$(git_in_ryoku rev-parse --abbrev-ref HEAD 2>/dev/null || printf '%s\n' "HEAD")"

  if [[ $current_branch != "$release_branch" ]]; then
    if git_in_ryoku show-ref --verify --quiet "refs/heads/$release_branch"; then
      git_in_ryoku switch "$release_branch"
    else
      git_in_ryoku switch --track -c "$release_branch" "origin/$release_branch"
    fi
  fi
}

head_is_official_history() {
  local ref

  for ref in origin/main origin/unstable-dev; do
    git_in_ryoku rev-parse --verify --quiet "$ref" >/dev/null || continue
    git_in_ryoku merge-base --is-ancestor HEAD "$ref" && return 0
  done

  return 1
}

checkout_has_local_file_changes() {
  [[ -n $(git_in_ryoku status --porcelain --untracked-files=normal 2>/dev/null || true) ]]
}

backup_existing_path() {
  local reason="$1"
  local backup_dir backup_path

  [[ -e $ryoku_path || -L $ryoku_path ]] || return 0

  backup_dir="$(ryoku_state_path)/medevac-backups/$(date +%Y%m%d-%H%M%S)"
  backup_path="$backup_dir/$(basename "$ryoku_path")"
  mkdir -p "$backup_dir"
  mv -- "$ryoku_path" "$backup_path"
  backup_paths+=("$backup_path")
  warn "moved $reason Ryoku checkout to $backup_path"
}

# Clone a clean official checkout BESIDE the live path, then atomically swap it
# in (preserving whatever was there). The live checkout is moved aside only
# after the fresh clone fully succeeds, so a failed/partial clone never strands
# the user without a checkout.
backup_and_clone_fresh() {
  local reason="$1"
  local tmp_clone
  tmp_clone="$(dirname "$ryoku_path")/.ryoku-medevac-clone.$$"

  rm -rf "$tmp_clone"
  step "Fetching a clean official $release_branch checkout"
  if ! git clone --branch "$release_branch" "$remote_url" "$tmp_clone"; then
    rm -rf "$tmp_clone"
    die "could not clone $remote_url (offline?). When back online, run:
  $(recover_command)"
  fi
  backup_existing_path "$reason"
  mkdir -p "$(dirname "$ryoku_path")"
  mv -- "$tmp_clone" "$ryoku_path"
  fetch_release_refs || true
}

fast_forward_or_realign() {
  local remote_ref="origin/$release_branch"

  if git_in_ryoku merge-base --is-ancestor HEAD "$remote_ref"; then
    git_in_ryoku merge --ff-only "$remote_ref"
    return
  fi

  if head_is_official_history; then
    warn "realigning stale Ryoku $release_branch checkout to $remote_ref"
    git_in_ryoku switch -C "$release_branch" "$remote_ref"
    return
  fi

  warn "checkout has local commits; preserving it and installing a clean official checkout"
  backup_and_clone_fresh "local-commit"
}

ensure_git_checkout() {
  if [[ -d $ryoku_path/.git ]]; then
    if ! fetch_release_refs; then
      # Remote unreachable and no cached ref. Degrade gracefully: keep the
      # local checkout if it is already on the channel and clean; otherwise we
      # cannot safely recover offline.
      local head
      head="$(git_in_ryoku rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'HEAD')"
      if [[ $head == "$release_branch" ]] && ! checkout_has_local_file_changes; then
        warn "offline: cannot reach $remote_url; keeping the existing clean $release_branch checkout"
        return 0
      fi
      die "offline and the local checkout is not in a safe state. Connect to the internet, then run:
  $(recover_command)"
    fi

    classify_and_report

    if checkout_has_local_file_changes; then
      warn "checkout has local file changes; preserving it and installing a clean official checkout"
      backup_and_clone_fresh "dirty"
      return
    fi
    checkout_release_branch
    fast_forward_or_realign
    return
  fi

  # No git checkout present at all: install a fresh one (backup_and_clone_fresh
  # preserves any non-git leftover sitting at the path first).
  backup_and_clone_fresh "non-git"
}

download_to_file() {
  local url="$1"
  local output="$2"

  if command_present curl; then
    curl -fsSL "$url" -o "$output"
    return
  fi

  if command_present wget; then
    wget -qO "$output" "$url"
    return
  fi

  return 1
}

ensure_archive_checkout() {
  local tmp_dir archive extracted archive_url

  command_present tar || die "git is missing and tar is unavailable, so MedEvac cannot unpack an archive fallback"

  tmp_dir="$(mktemp -d)"
  archive="$tmp_dir/ryoku-${release_branch}.tar.gz"
  archive_url="$archive_base_url/$release_branch.tar.gz"

  step "Git is unavailable; downloading latest $release_branch archive"
  download_to_file "$archive_url" "$archive" || die "could not download $archive_url with curl or wget"
  tar -xzf "$archive" -C "$tmp_dir"
  extracted="$(find "$tmp_dir" -mindepth 1 -maxdepth 1 -type d -name 'ryoku-arch-*' | head -n 1)"
  [[ -n $extracted ]] || die "downloaded archive did not contain a Ryoku checkout"

  if [[ -e $ryoku_path || -L $ryoku_path ]]; then
    backup_existing_path "archive-fallback"
  fi

  mkdir -p "$(dirname "$ryoku_path")"
  mv -- "$extracted" "$ryoku_path"
  rm -rf "$tmp_dir"
  archive_mode="1"
  warn "installed archive fallback because git is unavailable; normal update may install or require git afterward"
}

ensure_checkout() {
  if command_present git; then
    ensure_git_checkout
  else
    ensure_archive_checkout
  fi
}

command_bridge_target() {
  local source_path="$1"
  local target_path="$2"
  local backup_dir

  [[ -e $source_path ]] || return 0

  if [[ -e $target_path && ! -L $target_path ]]; then
    backup_dir="$(ryoku_state_path)/command-bridge-backups/$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$backup_dir"
    mv -- "$target_path" "$backup_dir/$(basename "$target_path")"
    warn "moved stale local command to $backup_dir/$(basename "$target_path")"
  fi

  ln -sfn "$source_path" "$target_path"
}

repair_system_command_bridges() {
  local system_bin="${RYOKU_SYSTEM_BIN_DIR:-/usr/local/bin}"
  local system_lib="${RYOKU_SYSTEM_LIB_DIR:-/usr/local/lib}"
  local command_path

  if ! sudo_authorized; then
    system_shim_status="skipped: sudo is not authorized"
    warn "skipped /usr/local Ryoku command shim repair because sudo is not authorized"
    return 0
  fi

  sudo mkdir -p "$system_bin" "$system_lib"

  if [[ -f $ryoku_path/lib/runtime-env.sh ]]; then
    sudo ln -sfn "$ryoku_path/lib/runtime-env.sh" "$system_lib/runtime-env.sh" || true
  fi

  if [[ -d $ryoku_path/bin ]]; then
    for command_path in "$ryoku_path"/bin/ryoku-*; do
      [[ -f $command_path && -x $command_path ]] || continue
      sudo ln -sfn "$command_path" "$system_bin/$(basename "$command_path")" || true
    done
  fi

  if [[ -x $ryoku_path/shell/scripts/ryoku ]]; then
    sudo ln -sfn "$ryoku_path/shell/scripts/ryoku" "$system_bin/ryoku" || true
  fi

  if [[ -x $ryoku_path/shell/scripts/ryoku-shell ]]; then
    sudo ln -sfn "$ryoku_path/shell/scripts/ryoku-shell" "$system_bin/ryoku-shell" || true
  fi

  system_shim_status="repaired: $system_bin"
}

repair_command_bridges() {
  local bin_home="${XDG_BIN_HOME:-$HOME/.local/bin}"
  local lib_home command_path

  mkdir -p "$bin_home"
  export PATH="$ryoku_path/bin:$bin_home:$PATH"

  if [[ -f $ryoku_path/lib/runtime-env.sh ]]; then
    lib_home="$(dirname "$bin_home")/lib"
    mkdir -p "$lib_home"
    ln -sfn "$ryoku_path/lib/runtime-env.sh" "$lib_home/runtime-env.sh"
  fi

  if [[ -d $ryoku_path/bin ]]; then
    for command_path in "$ryoku_path"/bin/ryoku-*; do
      [[ -f $command_path && -x $command_path ]] || continue
      command_bridge_target "$command_path" "$bin_home/$(basename "$command_path")"
    done
  fi

  if [[ -x $ryoku_path/shell/scripts/ryoku-shell ]]; then
    command_bridge_target "$ryoku_path/shell/scripts/ryoku-shell" "$bin_home/ryoku-shell"
  fi

  if [[ -x $ryoku_path/shell/scripts/ryoku ]]; then
    command_bridge_target "$ryoku_path/shell/scripts/ryoku" "$bin_home/ryoku"
  fi

  repair_system_command_bridges
}

remote_tip_summary() {
  if [[ $archive_mode == "1" ]]; then
    printf '%s\n' "archive/$release_branch"
    return
  fi

  if command_present git && [[ -d $ryoku_path/.git ]]; then
    local tip=""
    tip="$(git_in_ryoku rev-parse --short "origin/$release_branch" 2>/dev/null || true)"
    [[ -n $tip ]] && printf 'origin/%s@%s\n' "$release_branch" "$tip" && return
  fi

  printf '%s\n' "unknown"
}

runtime_bridge_summary() {
  local bridge="$HOME/.local/lib/runtime-env.sh"
  local target=""

  if [[ -L $bridge ]]; then
    target="$(readlink "$bridge" 2>/dev/null || true)"
    printf '%s -> %s\n' "$bridge" "$target"
  elif [[ -e $bridge ]]; then
    printf '%s exists but is not a symlink\n' "$bridge"
  else
    printf '%s missing\n' "$bridge"
  fi
}

write_medevac_state() {
  local state_path state_file
  local backup_summary=""

  state_path="$(ryoku_state_path)"
  mkdir -p "$state_path" 2>/dev/null || return 0
  state_file="$state_path/last-medevac"
  if ((${#backup_paths[@]} > 0)); then
    backup_summary="${backup_paths[*]}"
  fi

  {
    printf 'recovered_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'version=%s\n' "$medevac_version"
    printf 'path=%s\n' "$ryoku_path"
    printf 'channel=%s\n' "$release_branch"
    printf 'remote_tip=%s\n' "$(remote_tip_summary)"
    printf 'doctor_status=%s\n' "$doctor_status"
    printf 'update_status=%s\n' "$update_status"
    printf 'archive_mode=%s\n' "$archive_mode"
    printf 'system_shims=%s\n' "$system_shim_status"
    printf 'runtime_bridge=%s\n' "$(runtime_bridge_summary)"
    printf 'preserved_backups=%s\n' "$backup_summary"
  } >"$state_file" 2>/dev/null || true
}

print_result() {
  local expected_doctor="$ryoku_path/bin/ryoku-doctor"
  local active_doctor="missing"
  local run_label

  run_label="$(medevac_run_label)"
  active_doctor="$(command_realpath ryoku-doctor || true)"
  [[ -n $active_doctor ]] || active_doctor="missing"

  log ""
  log "$run_label result:"
  log "  Version: $medevac_version"
  log "  Path: $ryoku_path"
  log "  Channel: $release_branch"
  log "  Remote tip: $(remote_tip_summary)"
  log "  Updater: $ryoku_path/bin/ryoku-update"
  log "  Expected doctor: $expected_doctor"
  log "  Active doctor: $active_doctor"
  log "  Doctor command: $expected_doctor"
  log "  Runtime bridge: $(runtime_bridge_summary)"
  log "  System shims: $system_shim_status"

  if [[ $system_shim_status == skipped:* ]]; then
    if [[ $compat_bootstrap == "1" ]]; then
      log "  System shim next step: run sudo -v and this bootstrap again"
    else
      log "  System shim next step: run sudo -v and ryoku-call911now again"
    fi
  fi

  if [[ $archive_mode == "1" ]]; then
    log "  Archive fallback: used because git was unavailable"
  fi

  if ((${#backup_paths[@]} > 0)); then
    log "  Preserved previous checkout: ${backup_paths[*]}"
  fi
}

print_final_summary() {
  local run_label

  run_label="$(medevac_run_label)"
  log ""

  if [[ $update_status == "0" ]]; then
    if pretty_available; then
      ryoku-tui style \
        --border double \
        --border-foreground 2 \
        --foreground 15 \
        --padding "1 3" \
        "$run_label complete" \
        "System extracted to latest reachable Ryoku path." \
        "Run ryoku-doctor for normal health checks from here."
    else
      printf '%s\n' "$(ansi 32)${run_label} complete$(reset_ansi)"
      printf '%s\n' "System extracted to latest reachable Ryoku path."
      printf '%s\n' "Run ryoku-doctor for normal health checks from here."
    fi
  else
    if pretty_available; then
      ryoku-tui style \
        --border double \
        --border-foreground 1 \
        --foreground 15 \
        --padding "1 3" \
        "$run_label stopped" \
        "Checkout and command bridges were repaired as far as possible." \
        "Doctor status: $doctor_status" \
        "Updater status: $update_status" \
        "Next: run $ryoku_path/bin/ryoku-doctor" \
        "Still broken? Re-extract online with:" \
        "$(recover_command)"
    else
      printf '%s\n' "$(ansi 31)${run_label} stopped$(reset_ansi)"
      printf '%s\n' "Checkout and command bridges were repaired as far as possible."
      printf '%s\n' "Doctor status: $doctor_status"
      printf '%s\n' "Updater status: $update_status"
      printf '%s\n' "Next: run $ryoku_path/bin/ryoku-doctor"
      printf '%s\n' "Still broken? Re-extract online with:"
      printf '%s\n' "  $(recover_command)"
    fi
  fi
}

run_latest_doctor() {
  local doctor_cmd="$ryoku_path/bin/ryoku-doctor"

  if [[ ! -f $doctor_cmd ]]; then
    doctor_status="missing"
    warn "updated checkout does not contain bin/ryoku-doctor"
    return 0
  fi

  step "Running latest Ryoku doctor from the recovered checkout"
  set +e
  if [[ -x $doctor_cmd ]]; then
    RYOKU_DOCTOR_ASSUME_NO=1 RYOKU_PATH="$ryoku_path" "$doctor_cmd"
  else
    RYOKU_DOCTOR_ASSUME_NO=1 RYOKU_PATH="$ryoku_path" bash "$doctor_cmd"
  fi
  doctor_status="$?"
  set -e

  if [[ $doctor_status == "0" ]]; then
    ok "Latest doctor completed"
  else
    warn "latest doctor exited with status $doctor_status; MedEvac will still try the normal updater"
  fi
}

run_normal_update() {
  local update_cmd="$ryoku_path/bin/ryoku-update"

  if [[ ! -f $update_cmd ]]; then
    update_status="127"
    warn "updated checkout does not contain bin/ryoku-update"
    return 127
  fi

  if sudo_needs_terminal_input; then
    update_status="skipped-no-tty"
    warn "MedEvac repaired the checkout and command bridges, but skipped the updater because sudo needs a real terminal."
    warn "Run ryoku-call911now from an interactive terminal, or run sudo -v first and retry ryoku-update -y."
    return 0
  fi

  step "Running normal Ryoku updater from the recovered checkout"
  set +e
  if [[ -x $update_cmd ]]; then
    env RYOKU_UPDATE_DOCTOR_COMMAND="$ryoku_path/bin/ryoku-doctor" RYOKU_PATH="$ryoku_path" "$update_cmd" -y
  else
    env RYOKU_UPDATE_DOCTOR_COMMAND="$ryoku_path/bin/ryoku-doctor" RYOKU_PATH="$ryoku_path" bash "$update_cmd" -y
  fi
  update_status="$?"
  set -e

  if [[ $update_status == "0" ]]; then
    ok "Normal updater completed"
  else
    warn "normal updater exited with status $update_status"
  fi

  return "$update_status"
}

usage() {
  cat <<'USAGE'
Usage: ryoku-call911now [--help]

Last-resort Ryoku MedEvac recovery.

Installed emergency command:
  ryoku-call911now
  RYOKU_UPDATE_BRANCH=unstable-dev ryoku-call911now

Doctor versus MedEvac:
  ryoku-doctor checks and repairs a coherent Ryoku install.
  ryoku-call911now is the portable extraction path for broken checkouts,
  missing command bridges, stale runtime-env links, missing rescue tools,
  and update paths that cannot reach the latest doctor on their own.

Environment overrides:
  RYOKU_UPDATE_BRANCH=main|unstable-dev
  RYOKU_UPDATE_REMOTE_URL=https://github.com/neur0map/ryoku-arch.git
  RYOKU_PATH=$HOME/.local/share/ryoku
  RYOKU_MEDEVAC_NO_SUDO_PROMPT=1
USAGE
}

main() {
  case "${1:-}" in
    -h | --help | help)
      usage
      return 0
      ;;
  esac

  banner
  mission_panel
  acquire_lock
  release_branch="$(configured_release_branch)"
  ryoku_path="$(default_ryoku_path)"
  persist_release_branch
  preflight_summary

  step "Preparing rescue environment"
  try_install_rescue_tools

  step "Recovering official Ryoku checkout"
  ensure_checkout
  ensure_canonical_ryoku_path

  step "Repairing command and runtime bridges"
  repair_command_bridges

  step "Verifying Hyprland config (restore if missing/empty/stub)"
  if [[ -x $ryoku_path/bin/ryoku-verify-hypr-config ]]; then
    RYOKU_PATH="$ryoku_path" "$ryoku_path/bin/ryoku-verify-hypr-config" || true
  elif [[ -f $ryoku_path/bin/ryoku-verify-hypr-config ]]; then
    RYOKU_PATH="$ryoku_path" bash "$ryoku_path/bin/ryoku-verify-hypr-config" || true
  fi

  step "Repairing graphical-login keymap (so a TTY-valid password also works at the greeter)"
  if [[ -x $ryoku_path/bin/ryoku-keymap-sync ]]; then
    RYOKU_PATH="$ryoku_path" "$ryoku_path/bin/ryoku-keymap-sync" || true
  elif [[ -f $ryoku_path/bin/ryoku-keymap-sync ]]; then
    RYOKU_PATH="$ryoku_path" bash "$ryoku_path/bin/ryoku-keymap-sync" || true
  fi

  print_result
  run_latest_doctor
  run_normal_update || true
  write_medevac_state
  print_final_summary

  [[ $update_status == "0" ]] && return 0
  return 1
}

main "$@"
