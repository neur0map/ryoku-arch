#!/bin/bash
set -e

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
export RYOKU_PATH="$script_root"
source "$RYOKU_PATH/lib/runtime-env.sh"

# Install qylock (Darkkal44/qylock) as the Ryoku SDDM theme bundle.
#
# Usage:
#   ryoku-install-qylock                  interactive picker (qylock's sddm.sh)
#   ryoku-install-qylock --theme <name>   non-interactive; installs <name>
#   ryoku-install-qylock --default        non-interactive; installs clockwork
#                                         if no qylock theme is installed yet
#
# Safe to run via pkexec: when EUID=0, the helper drops privileges to
# $SUDO_USER for git operations so the clone at ~/.local/share/qylock
# stays user-owned. Privileged operations (cp into /usr/share/sddm/...
# and writing /etc/sddm.conf.d/99-ryoku-shell-theme.conf) use the _priv wrapper, which
# is empty when already root and "sudo" otherwise.

if (( EUID == 0 )); then
  # pkexec sets PKEXEC_UID (numeric UID of invoker), not SUDO_USER.
  # Resolve a username from either source so this helper works under
  # both `sudo` and `pkexec` invocation paths.
  if [[ -z ${SUDO_USER:-} && -n ${PKEXEC_UID:-} ]]; then
    SUDO_USER=$(getent passwd "$PKEXEC_UID" | cut -d: -f1)
  fi
  if [[ -z ${SUDO_USER:-} ]]; then
    echo "ryoku-install-qylock: cannot resolve invoking user (need SUDO_USER or PKEXEC_UID)" >&2
    exit 1
  fi
  TARGET_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
  if [[ -z $TARGET_HOME ]]; then
    echo "ryoku-install-qylock: failed to resolve home dir for $SUDO_USER" >&2
    exit 1
  fi
  _priv() { "$@"; }
  _user() { sudo -u "$SUDO_USER" "$@"; }
else
  TARGET_HOME="$HOME"
  _priv() { sudo "$@"; }
  _user() { "$@"; }
fi

QYLOCK_DIR="$TARGET_HOME/.local/share/qylock"
QYLOCK_LOCK_DIR="$TARGET_HOME/.local/share/quickshell-lockscreen"
QYLOCK_REPO="https://github.com/Darkkal44/qylock.git"
DEFAULT_THEME="clockwork/orbital"

mode="${1:-interactive}"

case "$mode" in
  --theme)
    theme="${2:?theme name required after --theme}"
    ;;
  --default)
    theme="$DEFAULT_THEME"
    ;;
  interactive)
    theme=""
    ;;
  *)
    echo "Usage: ryoku-install-qylock [--theme <name> | --default]" >&2
    exit 1
    ;;
esac

echo -e "\033[38;2;143;29;33m\nInstalling qylock SDDM theme bundle\033[0m"

ryoku-pkg-add \
  qt6-declarative \
  qt6-5compat \
  qt6-svg \
  qt6-multimedia \
  qt6-multimedia-ffmpeg \
  gst-plugins-base \
  gst-plugins-good \
  gst-plugins-bad \
  gst-plugins-ugly

# Vendored, trimmed qylock (clockwork greeter + lockscreen) shipped in the repo
# so the greeter installs with zero network. The full upstream repo is ~1.2G of
# themes Ryoku does not use; only the clockwork theme + quickshell-lockscreen
# are bundled here.
BUNDLED_QYLOCK="${RYOKU_QYLOCK_BUNDLE:-$RYOKU_PATH/vendor/qylock}"

clone_qylock_repo() {
  _user rm -rf "$QYLOCK_DIR"
  _user git clone --depth=1 "$QYLOCK_REPO" "$QYLOCK_DIR" >/dev/null
}

install_bundled_qylock() {
  # Copy the bundled clockwork greeter into the user's qylock dir instead of
  # cloning. This is the default path on a fresh install, so a no-network
  # machine still gets the qylock greeter rather than the bare SDDM fallback.
  [[ -f $BUNDLED_QYLOCK/themes/clockwork/orbital/Main.qml ]] || return 1
  _user rm -rf "$QYLOCK_DIR"
  _user mkdir -p "$QYLOCK_DIR"
  _user cp -a "$BUNDLED_QYLOCK/." "$QYLOCK_DIR/"
}

refresh_qylock_clone() {
  # If the user already has a real git clone (e.g. they pulled the full upstream
  # theme set), keep it and just try to update.
  if [[ -d $QYLOCK_DIR/.git ]]; then
    _user git -C "$QYLOCK_DIR" pull --ff-only >/dev/null 2>&1 || true
    return 0
  fi

  # Otherwise ship the bundled clockwork greeter offline. Fall back to a network
  # clone only if the bundle is somehow missing.
  if install_bundled_qylock; then
    return 0
  fi

  echo "  qylock bundle missing; cloning from network"
  clone_qylock_repo
}

refresh_qylock_clone

refresh_qylock_previews() {
  local preview_helper="$RYOKU_PATH/bin/ryoku-refresh-qylock-previews"

  [[ -x $preview_helper ]] || return 0
  _user "$preview_helper" "$QYLOCK_DIR" || true
}

read_active_sddm_theme() {
  local current="" file value
  local sddm_conf_dir="${RYOKU_SDDM_CONF_DIR:-/etc/sddm.conf.d}"
  local sddm_conf_file="${RYOKU_SDDM_CONF_FILE:-/etc/sddm.conf}"

  shopt -s nullglob
  for file in "$sddm_conf_file" "$sddm_conf_dir"/*.conf; do
    [[ -f $file ]] || continue
    value=$(awk -F= '
      /^[[:space:]]*Current[[:space:]]*=/ {
        v = $2
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
        print v
      }
    ' "$file" | tail -n1)
    [[ -n $value ]] && current="$value"
  done

  printf '%s\n' "$current"
}

normalize_qylock_theme() {
  local selected_theme="$1"

  case "$selected_theme" in
    clockwork)
      printf '%s\n' "$DEFAULT_THEME"
      ;;
    orbital|tape)
      printf 'clockwork/%s\n' "$selected_theme"
      ;;
    *)
      printf '%s\n' "$selected_theme"
      ;;
  esac
}

theme_install_name() {
  local selected_theme="$1"

  basename "$selected_theme"
}

valid_qylock_theme() {
  local selected_theme

  selected_theme=$(normalize_qylock_theme "$1")
  [[ $selected_theme =~ ^[A-Za-z0-9][A-Za-z0-9._-]*(/[A-Za-z0-9][A-Za-z0-9._-]*)?$ ]] || return 1
  [[ -f $QYLOCK_DIR/themes/$selected_theme/Main.qml ]]
}

list_valid_qylock_themes() {
  local candidate candidate_dir nested nested_dir

  shopt -s nullglob
  for candidate_dir in "$QYLOCK_DIR"/themes/*/; do
    [[ -d $candidate_dir ]] || continue
    candidate=$(basename "$candidate_dir")
    if [[ -f $candidate_dir/Main.qml ]] && valid_qylock_theme "$candidate"; then
      printf '%s\n' "$candidate"
      continue
    fi

    for nested_dir in "$candidate_dir"*/; do
      [[ -d $nested_dir ]] || continue
      nested="$candidate/$(basename "$nested_dir")"
      valid_qylock_theme "$nested" || continue
      printf '%s\n' "$nested"
    done
  done
}

install_system_theme() {
  local selected_theme="$1"
  local system_theme
  local src="$QYLOCK_DIR/themes/$selected_theme"

  if ! valid_qylock_theme "$selected_theme"; then
    echo "  theme '$selected_theme' is not a usable qylock theme under $QYLOCK_DIR/themes" >&2
    echo "  qylock themes must be directories containing Main.qml" >&2
    echo "  available:" >&2
    list_valid_qylock_themes | sed 's/^/    /' >&2
    exit 1
  fi

  system_theme=$(theme_install_name "$selected_theme")

  echo "  installing theme: $selected_theme"
  _priv rm -rf "/usr/share/sddm/themes/$system_theme"
  _priv cp -r "$src" "/usr/share/sddm/themes/$system_theme"
}

refresh_qylock_previews

theme=$(normalize_qylock_theme "$theme")

if [[ -z $theme ]]; then
  if (( EUID == 0 )); then
    echo "ryoku-install-qylock: interactive mode is not supported under pkexec" >&2
    exit 1
  fi
  cd "$QYLOCK_DIR"
  exec bash sddm.sh
fi

if [[ $mode == "--default" ]]; then
  current_theme=$(read_active_sddm_theme)
  if [[ -n $current_theme ]] && valid_qylock_theme "$current_theme"; then
    ensure_current=$(normalize_qylock_theme "$current_theme")
    echo "  qylock theme already active: $ensure_current (keeping)"
    install_system_theme "$ensure_current"
  else
    for candidate_dir in /usr/share/sddm/themes/*/; do
      candidate=$(basename "$candidate_dir")
      if valid_qylock_theme "$candidate"; then
        ensure_current=$(normalize_qylock_theme "$candidate")
        echo "  qylock theme already installed: $ensure_current (keeping)"
        install_system_theme "$ensure_current"
        break
      fi
    done
  fi
fi

if [[ -z ${ensure_current:-} ]]; then
  install_system_theme "$theme"
  ensure_current="$theme"
fi

write_sddm_current_theme() {
  local selected_theme="$1"
  local theme_conf="/etc/sddm.conf.d/99-ryoku-shell-theme.conf"
  local stale_theme_conf="/etc/sddm.conf.d/i""nir-theme.conf"

  _priv mkdir -p /etc/sddm.conf.d
  _priv rm -f "$stale_theme_conf" \
              /etc/sddm.conf.d/ryoku-shell-theme.conf
  _priv tee "$theme_conf" >/dev/null <<EOF
[Theme]
Current=$selected_theme
EOF
}

install_quickshell_lockscreen() {
  local lock_src="$QYLOCK_DIR/quickshell-lockscreen"

  if [[ ! -d $lock_src ]]; then
    echo "ryoku-install-qylock: missing qylock Quickshell lockscreen at $lock_src" >&2
    exit 1
  fi

  _user mkdir -p "$TARGET_HOME/.local/share"
  _user rm -rf "$QYLOCK_LOCK_DIR"
  _user cp -R "$lock_src" "$QYLOCK_LOCK_DIR"
  _user ln -sfn "$QYLOCK_DIR/themes" "$QYLOCK_LOCK_DIR/themes_link"
  _user chmod +x "$QYLOCK_LOCK_DIR/lock.sh"
}

write_quickshell_lockscreen_theme() {
  local selected_theme="$1"

  _user mkdir -p "$TARGET_HOME/.config/qylock"
  printf '%s\n' "$selected_theme" | _user tee "$TARGET_HOME/.config/qylock/theme" >/dev/null
}

_priv mkdir -p /etc/sddm.conf.d
write_sddm_current_theme "$(theme_install_name "$ensure_current")"
install_quickshell_lockscreen
write_quickshell_lockscreen_theme "$ensure_current"

echo "  qylock theme active: $ensure_current"
echo "  qylock lockscreen active: $ensure_current"
