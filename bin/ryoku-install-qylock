#!/bin/bash
set -e

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
export RYOKU_PATH="$script_root"
source "$RYOKU_PATH/lib/runtime-env.sh"

# Install qylock (Darkkal44/qylock) as the Ryoku SDDM theme bundle.
#
# Usage:
#   ryoku-install-qylock                  interactive picker (qylock's sddm.sh)
#   ryoku-install-qylock --theme <name>   non-interactive; installs <name>
#   ryoku-install-qylock --default        non-interactive; installs dog-samurai
#                                         if no qylock theme is installed yet
#
# Safe to run via pkexec: when EUID=0, the helper drops privileges to
# $SUDO_USER for git operations so the clone at ~/.local/share/qylock
# stays user-owned. Privileged operations (cp into /usr/share/sddm/...
# and writing /etc/sddm.conf.d/theme.conf) use the _priv wrapper, which
# is empty when already root and "sudo" otherwise.

if (( EUID == 0 )); then
  # pkexec sets PKEXEC_UID (numeric UID of invoker), not SUDO_USER.
  # Resolve a username from either source so this helper works under
  # both `sudo` and `pkexec` invocation paths.
  if [[ -z ${SUDO_USER:-} && -n ${PKEXEC_UID:-} ]]; then
    SUDO_USER=$(getent passwd "$PKEXEC_UID" | cut -d: -f1)
  fi
  if [[ -z ${SUDO_USER:-} ]]; then
    echo "ryoku-install-qylock: cannot resolve invoking user (need SUDO_USER or PKEXEC_UID)" >&2
    exit 1
  fi
  TARGET_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
  if [[ -z $TARGET_HOME ]]; then
    echo "ryoku-install-qylock: failed to resolve home dir for $SUDO_USER" >&2
    exit 1
  fi
  _priv() { "$@"; }
  _user() { sudo -u "$SUDO_USER" "$@"; }
else
  TARGET_HOME="$HOME"
  _priv() { sudo "$@"; }
  _user() { "$@"; }
fi

QYLOCK_DIR="$TARGET_HOME/.local/share/qylock"
QYLOCK_LOCK_DIR="$TARGET_HOME/.local/share/quickshell-lockscreen"
QYLOCK_REPO="https://github.com/Darkkal44/qylock.git"
DEFAULT_THEME="dog-samurai"

mode="${1:-interactive}"

case "$mode" in
  --theme)
    theme="${2:?theme name required after --theme}"
    ;;
  --default)
    theme="$DEFAULT_THEME"
    ;;
  interactive)
    theme=""
    ;;
  *)
    echo "Usage: ryoku-install-qylock [--theme <name> | --default]" >&2
    exit 1
    ;;
esac

echo -e "\033[38;2;143;29;33m\nInstalling qylock SDDM theme bundle\033[0m"

ryoku-pkg-add \
  qt6-declarative \
  qt6-5compat \
  qt6-svg \
  qt6-multimedia \
  qt6-multimedia-ffmpeg \
  gst-plugins-base \
  gst-plugins-good \
  gst-plugins-bad \
  gst-plugins-ugly

clone_qylock_repo() {
  _user rm -rf "$QYLOCK_DIR"
  _user git clone --depth=1 "$QYLOCK_REPO" "$QYLOCK_DIR" >/dev/null
}

refresh_qylock_clone() {
  if [[ -d $QYLOCK_DIR/.git ]]; then
    if _user git -C "$QYLOCK_DIR" pull --ff-only >/dev/null; then
      return 0
    fi
    echo "  refreshing qylock clone after pull failed"
  fi

  clone_qylock_repo
}

refresh_qylock_clone

refresh_qylock_previews() {
  local preview_helper="$RYOKU_PATH/bin/ryoku-refresh-qylock-previews"

  [[ -x $preview_helper ]] || return 0
  _user "$preview_helper" "$QYLOCK_DIR" || true
}

read_active_sddm_theme() {
  local current="" file value
  local sddm_conf_dir="${RYOKU_SDDM_CONF_DIR:-/etc/sddm.conf.d}"
  local sddm_conf_file="${RYOKU_SDDM_CONF_FILE:-/etc/sddm.conf}"

  shopt -s nullglob
  for file in "$sddm_conf_file" "$sddm_conf_dir"/*.conf; do
    [[ -f $file ]] || continue
    value=$(awk -F= '
      /^[[:space:]]*Current[[:space:]]*=/ {
        v = $2
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
        print v
      }
    ' "$file" | tail -n1)
    [[ -n $value ]] && current="$value"
  done

  printf '%s\n' "$current"
}

valid_qylock_theme() {
  local selected_theme="$1"

  [[ $selected_theme =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || return 1
  [[ -f $QYLOCK_DIR/themes/$selected_theme/Main.qml ]]
}

list_valid_qylock_themes() {
  local candidate_dir candidate

  shopt -s nullglob
  for candidate_dir in "$QYLOCK_DIR"/themes/*/; do
    [[ -d $candidate_dir ]] || continue
    candidate=$(basename "$candidate_dir")
    valid_qylock_theme "$candidate" || continue
    printf '%s\n' "$candidate"
  done
}

install_system_theme() {
  local selected_theme="$1"
  local src="$QYLOCK_DIR/themes/$selected_theme"

  if ! valid_qylock_theme "$selected_theme"; then
    echo "  theme '$selected_theme' is not a usable qylock theme under $QYLOCK_DIR/themes" >&2
    echo "  qylock themes must be top-level directories containing Main.qml" >&2
    echo "  available:" >&2
    list_valid_qylock_themes | sed 's/^/    /' >&2
    exit 1
  fi

  echo "  installing theme: $selected_theme"
  _priv rm -rf "/usr/share/sddm/themes/$selected_theme"
  _priv cp -r "$src" "/usr/share/sddm/themes/$selected_theme"
}

refresh_qylock_previews

if [[ -z $theme ]]; then
  if (( EUID == 0 )); then
    echo "ryoku-install-qylock: interactive mode is not supported under pkexec" >&2
    exit 1
  fi
  cd "$QYLOCK_DIR"
  exec bash sddm.sh
fi

if [[ $mode == "--default" ]]; then
  current_theme=$(read_active_sddm_theme)
  if [[ -n $current_theme ]] && valid_qylock_theme "$current_theme"; then
    echo "  qylock theme already active: $current_theme (keeping)"
    ensure_current="$current_theme"
    install_system_theme "$current_theme"
  else
    for candidate_dir in /usr/share/sddm/themes/*/; do
      candidate=$(basename "$candidate_dir")
      if valid_qylock_theme "$candidate"; then
        echo "  qylock theme already installed: $candidate (keeping)"
        ensure_current="$candidate"
        install_system_theme "$candidate"
        break
      fi
    done
  fi
fi

if [[ -z ${ensure_current:-} ]]; then
  install_system_theme "$theme"
  ensure_current="$theme"
fi

write_sddm_current_theme() {
  local selected_theme="$1"
  local stale_theme_conf="/etc/sddm.conf.d/i""nir-theme.conf"

  _priv mkdir -p /etc/sddm.conf.d
  _priv rm -f "$stale_theme_conf" \
              /etc/sddm.conf.d/ryoku-shell-theme.conf
  if _priv test -f /etc/sddm.conf; then
    _priv sed -i '/^[[:space:]]*Current[[:space:]]*=/d' /etc/sddm.conf
  fi
  _priv tee /etc/sddm.conf.d/theme.conf >/dev/null <<EOF
[Theme]
Current=$selected_theme
EOF
}

install_quickshell_lockscreen() {
  local lock_src="$QYLOCK_DIR/quickshell-lockscreen"

  if [[ ! -d $lock_src ]]; then
    echo "ryoku-install-qylock: missing qylock Quickshell lockscreen at $lock_src" >&2
    exit 1
  fi

  _user mkdir -p "$TARGET_HOME/.local/share"
  _user rm -rf "$QYLOCK_LOCK_DIR"
  _user cp -R "$lock_src" "$QYLOCK_LOCK_DIR"
  _user ln -sfn "$QYLOCK_DIR/themes" "$QYLOCK_LOCK_DIR/themes_link"
  _user chmod +x "$QYLOCK_LOCK_DIR/lock.sh"
}

_priv mkdir -p /etc/sddm.conf.d
write_sddm_current_theme "$ensure_current"
install_quickshell_lockscreen

echo "  qylock theme active: $ensure_current"
echo "  qylock lockscreen active: $ensure_current"
