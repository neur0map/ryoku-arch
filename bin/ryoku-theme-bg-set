#!/bin/bash

set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Sets the specified image as the current background

if (( $# != 1 )); then
  echo "Usage: ryoku-theme-bg-set <path-to-image>" >&2
  exit 2
fi

BACKGROUND="$1"
CURRENT_BACKGROUND_DIR="$RYOKU_CONFIG_PATH/current"
CURRENT_BACKGROUND_LINK="$RYOKU_CONFIG_PATH/current/background"

if [[ ! -f $BACKGROUND ]]; then
  echo "ryoku-theme-bg-set: image file not found: $BACKGROUND" >&2
  exit 1
fi

if ! mkdir -p "$CURRENT_BACKGROUND_DIR"; then
  echo "ryoku-theme-bg-set: failed to create current config directory: $CURRENT_BACKGROUND_DIR" >&2
  exit 1
fi

if [[ ! -d $CURRENT_BACKGROUND_DIR ]]; then
  echo "ryoku-theme-bg-set: current config path is not a directory: $CURRENT_BACKGROUND_DIR" >&2
  exit 1
fi

# Create symlink to the new background
if ! ln -nsf "$BACKGROUND" "$CURRENT_BACKGROUND_LINK"; then
  echo "ryoku-theme-bg-set: failed to update current background: $CURRENT_BACKGROUND_LINK" >&2
  exit 1
fi

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku-shell"
config_file="$config_dir/config.json"

if [[ -f $config_file ]]; then
  if ryoku-cmd-missing jq; then
    echo "ryoku-theme-bg-set: jq is required to update Ryoku wallpaper config" >&2
    exit 1
  fi

  temp_file=$(mktemp)
  jq --arg path "$CURRENT_BACKGROUND_LINK" \
    '.background.wallpaperPath = $path | .background.thumbnailPath = ""' \
    "$config_file" >"$temp_file" &&
    mv "$temp_file" "$config_file"
fi
