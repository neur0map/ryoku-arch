#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Clipboard picker: list history via cliphist, show only the content
# (strip the numeric ID + tab prefix) so tofi does not render a wide
# column of dead space on the left, then map the selection back to the
# original cliphist line for decoding.

if ! command -v cliphist >/dev/null; then
  notify-send -u critical "Clipboard" "cliphist is not installed"
  exit 1
fi

history=$(cliphist list)
[[ -z $history ]] && exit 0

pick=$(printf '%s\n' "$history" | sed $'s/^[0-9]\\+\t//' | tofi --config "$RYOKU_PATH/default/tofi/config" --prompt-text "Clipboard: ")
[[ -z $pick ]] && exit 0

printf '%s\n' "$history" | grep -F -m1 $'\t'"$pick" | cliphist decode | wl-copy
