#!/bin/bash

set -e

# Backward-compatible shim. Branch switching is now part of the single update
# command; forward to `ryoku-update -sc <channel> -y` so the switch runs through
# the same hardened pipeline (snapshot, git realign, perform, restart) instead
# of a separate, less-guarded code path.
#
#   ryoku-update-branch main|unstable-dev   ==   ryoku-update -sc <channel> -y

script_path="${BASH_SOURCE[0]}"
script_path="$(readlink -f "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
bin_dir="$(cd -- "$(dirname -- "$script_path")" && pwd)"

branch="${1:-}"
if [[ -z $branch ]]; then
  echo "Usage: ryoku-update-branch main|unstable-dev"
  exit 1
fi

exec "$bin_dir/ryoku-update" -sc "$branch" -y
