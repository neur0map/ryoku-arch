#!/bin/bash

set -e

if (($# == 0)); then
  echo "Usage: ryoku-update-branch main"
  exit 1
fi

branch="$1"

if [[ $branch != "main" ]]; then
  echo "Error: Invalid branch '$branch'. Must be: main"
  exit 1
fi

# Snapshot before switching branch
ryoku-snapshot create || (( $? == 127 ))

if ! git -C "$RYOKU_PATH" diff --quiet || ! git -C "$RYOKU_PATH" diff --cached --quiet; then
  stashed=true
  git -C "$RYOKU_PATH" stash push -u -m "Autostash before switching to $branch"
else
  stashed=false
fi

# Switch branches
git -C "$RYOKU_PATH" switch "$branch"

# Reapply stash if we made one
if [[ $stashed == "true" ]]; then
  if ! git -C "$RYOKU_PATH" stash pop; then
    echo "⚠️ Conflicts when applying stash - stash kept"
  fi
fi

# Update the system from the new branch
ryoku-update-perform
