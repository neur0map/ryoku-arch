#!/bin/bash

set -euo pipefail

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
runtime_env="$script_root/lib/runtime-env.sh"
fallback_runtime_env="${RYOKU_PATH:-$HOME/.local/share/ryoku}/lib/runtime-env.sh"

if [[ -f $runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$runtime_env"
elif [[ -f $fallback_runtime_env ]]; then
  # shellcheck disable=SC1090,SC1091
  source "$fallback_runtime_env"
fi

if ! declare -F ryoku-cmd-missing >/dev/null; then
  ryoku-cmd-missing() {
    ! command -v "$1" >/dev/null 2>&1
  }
fi

usage() {
  echo "Usage: ryoku-cmd-hypr-workspace-scroll next|prev" >&2
}

direction="${1:-}"
if [[ $direction != "next" && $direction != "prev" ]]; then
  usage
  exit 64
fi

if ryoku-cmd-missing hyprctl || ryoku-cmd-missing jq; then
  echo "hyprctl/jq not available for workspace scroll helper" >&2
  exit 1
fi

interval_ms="${RYOKU_WORKSPACE_SCROLL_INTERVAL_MS:-420}"
state_dir="${RYOKU_WORKSPACE_SCROLL_STATE_DIR:-${XDG_RUNTIME_DIR:-/tmp}/ryoku}"
state_file="$state_dir/workspace-scroll.last"
lock_dir="$state_dir/workspace-scroll.lock"

if [[ ! $interval_ms =~ ^[0-9]+$ ]]; then
  interval_ms=420
fi

mkdir -p "$state_dir"
if ! mkdir "$lock_dir" 2>/dev/null; then
  exit 0
fi
trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT

active_id="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id // empty' 2>/dev/null || true)"
if [[ ! $active_id =~ ^[0-9]+$ ]]; then
  exit 0
fi

target="$(
  hyprctl workspaces -j 2>/dev/null |
    jq -r --argjson active "$active_id" --arg direction "$direction" '
      [.[] | select((.id // 0) > 0 and ((.name // "") | startswith("special:") | not)) | .id]
      | unique
      | sort
      | if $direction == "next" then
          map(select(. > $active)) | first // empty
        else
          map(select(. < $active)) | last // empty
        end
    ' 2>/dev/null || true
)"

if [[ ! $target =~ ^[0-9]+$ ]]; then
  exit 0
fi

now_ms="${RYOKU_WORKSPACE_SCROLL_NOW_MS:-$(date +%s%3N)}"
last_ms=0

if [[ -f $state_file ]]; then
  read -r last_ms < "$state_file" || last_ms=0
fi

if [[ ! $now_ms =~ ^[0-9]+$ ]]; then
  now_ms=0
fi

if [[ ! $last_ms =~ ^[0-9]+$ ]]; then
  last_ms=0
fi

if (( last_ms > 0 && now_ms > last_ms && now_ms - last_ms < interval_ms )); then
  exit 0
fi

printf '%s\n' "$now_ms" > "$state_file"
hyprctl dispatch workspace "$target" >/dev/null 2>&1 || true
