#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

# Match Dell XPS systems with LG OLED panel on Intel Panther Lake (Xe3) GPU.

ryoku-hw-match "XPS" \
  && ryoku-hw-intel-ptl \
  && test "$(od -An -tx1 -j8 -N2 /sys/class/drm/card*-eDP-*/edid 2>/dev/null | tr -d ' \n')" = "30e4"
