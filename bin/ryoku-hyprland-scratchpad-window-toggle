#!/bin/bash

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/runtime-env.sh"

STATE_DIR="$RYOKU_STATE_PATH/hypr"
STATE_FILE="$STATE_DIR/scratchpad-workspaces.tsv"

mkdir -p "$STATE_DIR"
touch "$STATE_FILE"

remove_saved_workspace() {
  local address="$1"
  local tmp

  tmp="$(mktemp "$STATE_FILE.XXXXXX")"
  awk -F '\t' -v address="$address" '$1 != address' "$STATE_FILE" >"$tmp"
  mv "$tmp" "$STATE_FILE"
}

save_workspace() {
  local address="$1"
  local workspace="$2"
  local tmp

  tmp="$(mktemp "$STATE_FILE.XXXXXX")"
  awk -F '\t' -v address="$address" '$1 != address' "$STATE_FILE" >"$tmp"
  printf '%s\t%s\n' "$address" "$workspace" >>"$tmp"
  mv "$tmp" "$STATE_FILE"
}

saved_workspace() {
  local address="$1"

  awk -F '\t' -v address="$address" '$1 == address { print $2; exit }' "$STATE_FILE"
}

window_workspace_target() {
  local window_json="$1"
  local workspace_id
  local workspace_name

  workspace_id="$(printf '%s\n' "$window_json" | jq -r '.workspace.id // 0' 2>/dev/null)"
  workspace_name="$(printf '%s\n' "$window_json" | jq -r '.workspace.name // ""' 2>/dev/null)"

  if [[ $workspace_id =~ ^-?[0-9]+$ ]] && (( workspace_id > 0 )); then
    printf '%s\n' "$workspace_id"
  elif [[ -n $workspace_name ]]; then
    printf 'name:%s\n' "$workspace_name"
  else
    printf '1\n'
  fi
}

focused_monitor_workspace_target() {
  local monitors_json
  local workspace

  monitors_json="$(hyprctl monitors -j 2>/dev/null)"
  workspace="$(printf '%s\n' "$monitors_json" | jq -r '
    map(select(.focused))[0].activeWorkspace // {} |
    if (.id // 0) > 0 then
      (.id | tostring)
    elif ((.name // "") | length) > 0 then
      "name:" + .name
    else
      "1"
    end
  ' 2>/dev/null)"

  if [[ -z $workspace || $workspace == "null" || $workspace == "name:" ]]; then
    workspace="1"
  fi

  printf '%s\n' "$workspace"
}

scratchpad_visible() {
  hyprctl monitors -j | jq -e 'any(.[]; .specialWorkspace.name == "special:scratchpad")' >/dev/null 2>&1
}

active_window="$(hyprctl activewindow -j 2>/dev/null)"
address="$(printf '%s\n' "$active_window" | jq -r '.address // ""' 2>/dev/null)"
workspace_name="$(printf '%s\n' "$active_window" | jq -r '.workspace.name // ""' 2>/dev/null)"

[[ -n $address && $address != "null" ]] || exit 0

if [[ $workspace_name == "special:scratchpad" ]]; then
  destination="$(saved_workspace "$address")"
  if [[ -z $destination ]]; then
    destination="$(focused_monitor_workspace_target)"
  fi

  hyprctl dispatch movetoworkspacesilent "$destination,address:$address"
  remove_saved_workspace "$address"

  if scratchpad_visible; then
    hyprctl dispatch togglespecialworkspace scratchpad
  fi

  hyprctl dispatch workspace "$destination"
  exit 0
fi

destination="$(window_workspace_target "$active_window")"
save_workspace "$address" "$destination"
hyprctl dispatch movetoworkspacesilent "special:scratchpad,address:$address"
