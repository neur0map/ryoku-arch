#!/bin/bash

set -e
script_path="${BASH_SOURCE[0]}"
script_path="$(readlink -f "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
repo_root="$(cd -- "$(dirname -- "$script_path")/.." && pwd)"
# shellcheck disable=SC1091
source "$repo_root/lib/runtime-env.sh"
# shellcheck disable=SC1091
source "$repo_root/lib/ryoku-update-core.sh"
# shellcheck disable=SC1091
source "$repo_root/lib/update-dashboard.sh"

ryoku-cmd-caffeine hold >/dev/null 2>&1 || true

# Channel resolution lives in lib/ryoku-update-core.sh now; keep this wrapper
# name so the call sites below stay unchanged while using the single source.
update_release_branch() {
  ryoku_resolve_channel
}

update_command_realpath() {
  local command_name="$1"
  local command_path=""

  command_path="$(command -v "$command_name" 2>/dev/null || true)"
  [[ -n $command_path ]] || return 1
  readlink -f "$command_path" 2>/dev/null || printf '%s\n' "$command_path"
}

update_checkout_summary() {
  local checkout_branch="unknown"
  local checkout_commit="unknown"

  if [[ -d $RYOKU_PATH/.git ]] && command -v git >/dev/null 2>&1; then
    checkout_branch="$(GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" rev-parse --abbrev-ref HEAD 2>/dev/null || printf '%s\n' "unknown")"
    checkout_commit="$(GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" rev-parse --short HEAD 2>/dev/null || printf '%s\n' "unknown")"
  fi

  printf '%s@%s\n' "$checkout_branch" "$checkout_commit"
}

update_runtime_bridge_summary() {
  local bridge="$HOME/.local/lib/runtime-env.sh"
  local target=""

  if [[ -L $bridge ]]; then
    target="$(readlink "$bridge" 2>/dev/null || true)"
    printf '%s -> %s\n' "$bridge" "${target:-unknown}"
  elif [[ -e $bridge ]]; then
    printf '%s (present, not symlink)\n' "$bridge"
  else
    printf '%s (missing)\n' "$bridge"
  fi
}

update_remote_tip_summary() {
  local release_branch
  local remote_ref
  local remote_commit="unknown"

  release_branch="$(update_release_branch)"
  remote_ref="origin/$release_branch"

  if [[ -d $RYOKU_PATH/.git ]] && command -v git >/dev/null 2>&1 \
    && GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" rev-parse --verify --quiet "$remote_ref" >/dev/null; then
    remote_commit="$(GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/true git -C "$RYOKU_PATH" rev-parse --short "$remote_ref" 2>/dev/null || printf '%s\n' "unknown")"
  fi

  printf '%s@%s\n' "$remote_ref" "$remote_commit"
}

update_summary_commit() {
  local summary="$1"

  case "$summary" in
    *@*)
      printf '%s\n' "${summary##*@}"
      ;;
    *)
      printf '%s\n' "unknown"
      ;;
  esac
}

update_warn_remote_mismatch() {
  local checkout="$1"
  local remote_tip="$2"
  local checkout_commit
  local remote_commit

  checkout_commit="$(update_summary_commit "$checkout")"
  remote_commit="$(update_summary_commit "$remote_tip")"

  [[ $checkout_commit != "unknown" && $remote_commit != "unknown" ]] || return 0
  [[ $checkout_commit == "$remote_commit" ]] && return 0

  echo -e "\e[33mWarning: checkout does not match the selected remote tip; rerun ryoku-update before trusting this install state.\e[0m"
}

write_final_update_result_state() {
  local checkout="$1"
  local remote_tip="$2"
  local active_doctor="$3"
  local tui_path="$4"
  local runtime_bridge="$5"

  mkdir -p "$RYOKU_STATE_PATH" 2>/dev/null || return 0
  {
    printf 'updated_at=%s\n' "$(date -Iseconds 2>/dev/null || date)"
    printf 'path=%s\n' "$RYOKU_PATH"
    printf 'channel=%s\n' "$(update_release_branch)"
    printf 'checkout=%s\n' "$checkout"
    printf 'remote_tip=%s\n' "$remote_tip"
    printf 'expected_doctor=%s\n' "$RYOKU_PATH/bin/ryoku-doctor"
    printf 'active_doctor=%s\n' "$active_doctor"
    printf 'tui=%s\n' "$tui_path"
    printf 'runtime_bridge=%s\n' "$runtime_bridge"
  } >"$RYOKU_STATE_PATH/last-update" || true
}

print_final_update_result() {
  local checkout="unknown@unknown"
  local remote_tip=""
  local expected_doctor="$RYOKU_PATH/bin/ryoku-doctor"
  local active_doctor=""
  local tui_path=""
  local runtime_bridge=""

  checkout="$(update_checkout_summary)"
  remote_tip="$(update_remote_tip_summary)"
  active_doctor="$(update_command_realpath ryoku-doctor || true)"
  tui_path="$(update_command_realpath ryoku-tui || true)"
  runtime_bridge="$(update_runtime_bridge_summary)"

  [[ -n $active_doctor ]] || active_doctor="missing"
  [[ -n $tui_path ]] || tui_path="missing"

  write_final_update_result_state "$checkout" "$remote_tip" "$active_doctor" "$tui_path" "$runtime_bridge"

  echo
  echo "Ryoku update result:"
  echo "  Path: $RYOKU_PATH"
  echo "  Channel: $(update_release_branch)"
  echo "  Checkout: $checkout"
  echo "  Remote tip: $remote_tip"
  echo "  Expected doctor: $expected_doctor"
  echo "  Active doctor: $active_doctor"
  echo "  TUI: $tui_path"
  echo "  Runtime bridge: $runtime_bridge"
  update_warn_remote_mismatch "$checkout" "$remote_tip"

  if [[ -x $expected_doctor && $active_doctor != "$expected_doctor" ]]; then
    echo -e "\e[33mWarning: ryoku-doctor resolves outside the installed checkout; PATH or legacy wrappers may be stale.\e[0m"
  fi

  if [[ $tui_path == "missing" ]]; then
    echo -e "\e[33mWarning: ryoku-tui is still missing after package stages; ryoku-doctor will use fallback UI.\e[0m"
  fi
}

update_migration_safety_stage() {
  ryoku-migrate --repair-baseline
}

update_arch_keys_stage() {
  ryoku-update-keyring
  ryoku-update-available-reset
}

update_base_packages_stage() {
  bash "$RYOKU_INSTALL/packaging/base.sh"
}

update_aur_packages_stage() {
  ryoku-update-aur-pkgs
  bash "$RYOKU_INSTALL/packaging/aur-core.sh"
}

update_distro_packages_stage() {
  bash "$RYOKU_INSTALL/packaging/distro-arch.sh"
}

canonical_shell_runtime_dir() {
  printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-shell"
}

update_shell_stage() {
  env \
    -u QS_CONFIG_NAME \
    -u QS_CONFIG_PATH \
    -u QS_MANIFEST \
    RYOKU_SHELL_RUNTIME_DIR="$(canonical_shell_runtime_dir)" \
    bash "$RYOKU_INSTALL/config/shell.sh"
}

update_cleanup_stage() {
  # Safety net: if any earlier stage (a migration, a config rewrite) left
  # hyprland.conf missing/empty/stubbed, restore it before the session restarts
  # so the update can never leave the machine without keybinds or a shell.
  ryoku-verify-hypr-config || true
  ryoku-update-orphan-pkgs
  ryoku-hook post-update
  ryoku-update-analyze-logs
  ryoku-update-restart
}

finish_update_perform() {
  local exit_code=$?

  ryoku-cmd-caffeine release >/dev/null 2>&1 || true

  if (( exit_code == 0 )); then
    ryoku_update_dashboard_finish "success"
  else
    ryoku_update_dashboard_finish "failed" "$exit_code"
  fi

  exit "$exit_code"
}

trap finish_update_perform EXIT

update_stages=(
  "Migration safety"
  "Arch signing keys"
  "System packages"
  "Ryoku base packages"
  "AUR packages"
  "Ryoku distro packages"
  "Ryoku shell"
  "Migrations"
  "Cleanup and restart"
)
update_total=${#update_stages[@]}

ryoku_update_dashboard_start "$update_total" "${update_stages[@]}"

ryoku_update_run_stage 1 "$update_total" "Migration safety" update_migration_safety_stage
ryoku_update_run_stage 2 "$update_total" "Arch signing keys" update_arch_keys_stage
ryoku_update_run_stage 3 "$update_total" "System packages" ryoku-update-system-pkgs
ryoku_update_run_stage 4 "$update_total" "Ryoku base packages" update_base_packages_stage
ryoku_update_run_stage 5 "$update_total" "AUR packages" update_aur_packages_stage
ryoku_update_run_stage 6 "$update_total" "Ryoku distro packages" update_distro_packages_stage
ryoku_update_run_stage 7 "$update_total" "Ryoku shell" update_shell_stage
ryoku_update_run_stage 8 "$update_total" "Migrations" ryoku-migrate
ryoku_update_run_stage 9 "$update_total" "Cleanup and restart" update_cleanup_stage

print_final_update_result
