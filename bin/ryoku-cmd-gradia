#!/bin/bash

set -euo pipefail

script_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck disable=SC1091
source "$script_root/lib/runtime-env.sh"

gradia_bin="${RYOKU_GRADIA_BIN:-/usr/bin/gradia}"

if [[ ! -x $gradia_bin ]]; then
  if ryoku-cmd-present gradia; then
    gradia_bin="$(command -v gradia)"
  elif ryoku-cmd-present flatpak; then
    exec flatpak run be.alexandervanhee.gradia "$@"
  else
    echo "ryoku-cmd-gradia: Gradia is not installed" >&2
    exit 1
  fi
fi

patch_path=""
if [[ -d $script_root/lib/gradia-clipboard ]]; then
  patch_path="$script_root/lib/gradia-clipboard"
elif [[ -d $RYOKU_PATH/lib/gradia-clipboard ]]; then
  patch_path="$RYOKU_PATH/lib/gradia-clipboard"
fi

if [[ -n $patch_path ]]; then
  export PYTHONPATH="$patch_path${PYTHONPATH:+:$PYTHONPATH}"
fi

export RYOKU_GRADIA_WL_COPY="${RYOKU_GRADIA_WL_COPY:-wl-copy}"
export PYTHONDONTWRITEBYTECODE="${PYTHONDONTWRITEBYTECODE:-1}"

exec "$gradia_bin" "$@"
