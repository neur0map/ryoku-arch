#!/bin/bash

set -euo pipefail

input_file=""
if [[ ${1:-} == "--file" ]]; then
  if [[ -z ${2:-} ]]; then
    notify-send -u critical "QR Code" "Missing image path"
    exit 2
  fi
  input_file="$2"
  shift 2
fi

if (( $# > 0 )); then
  notify-send -u critical "QR Code" "Usage: ryoku-cmd-qr-scan [--file IMAGE]"
  exit 2
fi

for cmd in zbarimg wl-copy notify-send xdg-open; do
  if ryoku-cmd-missing "$cmd"; then
    notify-send -u normal "QR Code" "$cmd is not installed"
    exit 1
  fi
done

tmp="$input_file"
cleanup_tmp=0

if [[ -z $tmp ]]; then
  for cmd in grim slurp; do
    if ryoku-cmd-missing "$cmd"; then
      notify-send -u normal "QR Code" "$cmd is not installed"
      exit 1
    fi
  done

  tmp_dir="${XDG_RUNTIME_DIR:-/tmp}"
  tmp="$(mktemp "$tmp_dir/ryoku-qr.XXXXXX.png")"
  cleanup_tmp=1
fi

cleanup() {
  if (( cleanup_tmp )); then
    rm -f "$tmp"
  fi
}
trap cleanup EXIT

if [[ -n $input_file ]]; then
  if [[ ! -f $tmp ]]; then
    notify-send -u critical "QR Code" "No image found at $tmp"
    exit 1
  fi

  if [[ ! -r $tmp ]]; then
    notify-send -u critical "QR Code" "Cannot read image at $tmp"
    exit 1
  fi
else
  if ! geometry="$(slurp 2>/dev/null)"; then
    exit 130
  fi

  if [[ -z $geometry ]]; then
    exit 0
  fi

  grim -g "$geometry" "$tmp"
fi

result="$(zbarimg --raw "$tmp" 2>/dev/null | head -n 1 || true)"

if [[ -z $result ]]; then
  notify-send -u normal "QR Code" "No QR code found in the selected area"
  exit 0
fi

printf '%s\n' "$result" | wl-copy

case "$result" in
  http://*|https://*)
    action="$(notify-send -u normal "QR Code" "Copied URL to clipboard" -A "default=Open" || true)"
    if [[ $action == "default" ]]; then
      xdg-open "$result" >/dev/null 2>&1 || true
    fi
    ;;
  *)
    notify-send -u normal "QR Code" "Copied result to clipboard"
    ;;
esac
