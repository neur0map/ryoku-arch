#!/bin/bash

set -euo pipefail

if [[ ${1:-} == "--help" ]]; then
  cat <<'EOF'
Usage: ryoku-cmd-color-picker [--repeat]

Pick a screen color, copy it to the clipboard, and print the selected value.
With --repeat, keep picking colors until the picker is cancelled.
EOF
  exit 0
fi

repeat=false

case "${1:-}" in
  "")
    ;;
  --repeat)
    repeat=true
    ;;
  *)
    notify-send -u critical "Color picker" "Usage: ryoku-cmd-color-picker [--repeat]"
    exit 2
    ;;
esac

if (( $# > 1 )); then
  notify-send -u critical "Color picker" "Usage: ryoku-cmd-color-picker [--repeat]"
  exit 2
fi

for cmd in hyprpicker wl-copy notify-send; do
  if ryoku-cmd-missing "$cmd"; then
    notify-send -u normal "Color picker" "$cmd is not installed"
    exit 1
  fi
done

while true; do
  if ! color="$(hyprpicker -f hex -n)"; then
    if [[ $repeat == "true" ]]; then
      exit 0
    fi
    exit 130
  fi

  if [[ -n $color ]]; then
    # Copy explicitly via wl-copy (forks + persists the selection). hyprpicker's -a
    # autocopy does not survive hyprpicker exiting without a clipboard manager.
    printf '%s' "$color" | wl-copy
    printf '%s\n' "$color"
    notify-send -u low "Color picker" "Copied $color"
  fi

  [[ $repeat == "true" ]] || break
done
