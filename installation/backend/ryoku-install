#!/usr/bin/env bash
# shellcheck source-path=SCRIPTDIR
#
# ryoku-install: the Ryoku Arch install backend.
#
# answers come from RYOKU_* env vars (the TUI sets them, full contract in
# installation/backend/README.md). does a direct Arch install: partition,
# optional LUKS, format, mount, pacstrap, configure, Limine.
#
# progress sentinels to the TUI:
#   @@RYOKU_STEP <id>   stage begins
#   @@RYOKU_DONE        printed once after the final stage succeeds
# any failure exits non-zero (set -e) without @@RYOKU_DONE.
#
# RYOKU_DRYRUN=1 prints every destructive command (prefixed "DRYRUN: ") instead
# of running it, so the whole flow can be exercised without a real disk.

set -euo pipefail

SELF=$(realpath "${BASH_SOURCE[0]}")
BACKEND_DIR=$(dirname "$SELF")
LIB_DIR="$BACKEND_DIR/lib"

# shellcheck source=lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=lib/preflight.sh
source "$LIB_DIR/preflight.sh"
# shellcheck source=lib/disk.sh
source "$LIB_DIR/disk.sh"
# shellcheck source=lib/luks.sh
source "$LIB_DIR/luks.sh"
# shellcheck source=lib/filesystem.sh
source "$LIB_DIR/filesystem.sh"
# shellcheck source=lib/pacstrap.sh
source "$LIB_DIR/pacstrap.sh"
# shellcheck source=lib/mirrors.sh
source "$LIB_DIR/mirrors.sh"
# shellcheck source=lib/chroot.sh
source "$LIB_DIR/chroot.sh"
# shellcheck source=lib/deploy.sh
source "$LIB_DIR/deploy.sh"
# shellcheck source=lib/network.sh
source "$LIB_DIR/network.sh"
# shellcheck source=lib/drivers.sh
source "$LIB_DIR/drivers.sh"
# shellcheck source=lib/bootloader.sh
source "$LIB_DIR/bootloader.sh"
# shellcheck source=lib/aur.sh
source "$LIB_DIR/aur.sh"
# shellcheck source=lib/snapshots.sh
source "$LIB_DIR/snapshots.sh"

# defaults for the optional half of the contract.
: "${RYOKU_HOSTNAME:=ryoku}"
: "${RYOKU_USERNAME:=ryoku}"
: "${RYOKU_KEYMAP:=us}"
: "${RYOKU_LOCALE:=en_US.UTF-8}"
: "${RYOKU_TIMEZONE:=UTC}"
: "${RYOKU_PROFILE:=vm}"
# disk strategy is required: do NOT default it. defaulting to whole was a silent
# wipe path when the TUI dropped the pick. validation below.
: "${RYOKU_DISK_STRATEGY:=}"
: "${RYOKU_ESP_GIB:=1}"
: "${RYOKU_SWAP_GIB:=0}"
: "${RYOKU_SUBVOL_SNAPSHOTS:=1}"
: "${RYOKU_SUBVOL_HOME:=1}"
: "${RYOKU_SUBVOL_BACKUPS:=0}"
: "${RYOKU_REPO:=/usr/share/ryoku}"
: "${RYOKU_ONLINE:=1}"
# normalize the env-only switches so set -u + shellcheck stay quiet.
: "${RYOKU_DISK:=}"
: "${RYOKU_PASSWORD_HASH:=}"
: "${RYOKU_ENCRYPT:=}"
: "${RYOKU_LUKS_PASSPHRASE:=}"
: "${RYOKU_GPU_MODE:=}"
: "${RYOKU_REBOOT:=}"
: "${RYOKU_DRYRUN:=}"

# required answers.
[[ -n $RYOKU_DISK ]] || die "RYOKU_DISK is required"
[[ -n $RYOKU_PASSWORD_HASH ]] || die "RYOKU_PASSWORD_HASH is required"
case $RYOKU_DISK_STRATEGY in
  whole|alongside) ;;
  '') die "RYOKU_DISK_STRATEGY is required (use 'whole' or 'alongside'); refusing to wipe disk on empty strategy." ;;
  *)  die "RYOKU_DISK_STRATEGY='$RYOKU_DISK_STRATEGY' not supported (use 'whole' or 'alongside')." ;;
esac
# encryption pairing: catch a missing passphrase HERE, before any disk work, so
# an encrypt request can't wipe + partition + luksFormat only to die at `open`.
# luks.sh keeps the same check as defense in depth for a direct backend call.
[[ ${RYOKU_ENCRYPT:-} != 1 || -n $RYOKU_LUKS_PASSPHRASE ]] || die "RYOKU_ENCRYPT=1 but RYOKU_LUKS_PASSPHRASE is unset"

main() {
  [[ -n $RYOKU_DRYRUN ]] && log "DRY RUN: no disk is touched; commands are printed only"
  log "Ryoku install: disk=$RYOKU_DISK host=$RYOKU_HOSTNAME user=$RYOKU_USERNAME profile=$RYOKU_PROFILE"

  ryoku_preflight
  ryoku_ensure_dns
  ryoku_ensure_mirrors

  # build/verify the pacman keyring BEFORE the disk is touched: a broken keyring
  # otherwise surfaces only at pacstrap, after the wipe. offline (uses the live
  # archlinux-keyring), so it belongs in this preflight phase.
  ryoku_ensure_keyring

  step partition
  ryoku_partition
  ryoku_luks

  step filesystems
  ryoku_filesystems

  step mount
  ryoku_mount

  step pacstrap
  ryoku_rank_mirrors
  ryoku_pacstrap

  # snap-pac's pacman hooks abort in the chroot; mask them for the install and
  # restore before we unmount (see ryoku_hooks_quiet/restore).
  ryoku_hooks_quiet

  step configure
  ryoku_configure
  ryoku_deploy
  ryoku_network
  ryoku_drivers

  step bootloader
  ryoku_bootloader

  ryoku_aur || true

  # the AUR step may have installed limine-mkinitcpio-hook, whose pacman
  # hooks rebuilt the boot menu as the UKI tree: retire the flat placeholder
  # entry and repoint the default at the tree's newest kernel.
  ryoku_bootloader_finalize

  ryoku_snapshots
  ryoku_hooks_restore

  log "flushing the target to disk"
  run sync
  if [[ -z $RYOKU_DRYRUN ]]; then
    swapoff -a 2>/dev/null || true
    umount -R /mnt 2>/dev/null || true
  fi

  printf '@@RYOKU_DONE\n'
  log "install complete"

  if [[ -n $RYOKU_REBOOT ]]; then
    log "rebooting"
    run reboot
  fi
}

# failure handler on EXIT: fires on every exit but acts only on a non-zero
# status, so a clean finish is a no-op (main already unmounted /mnt and printed
# @@RYOKU_DONE). unlike a bare ERR trap this also catches an explicit die()
# (exit 1). on failure it names the stage we died in, restores the snap-pac
# hooks masked for the chroot, flushes to disk, and -- unlike the clean path --
# LEAVES /mnt mounted so the partial tree and the log can be inspected.
# @@RYOKU_DONE prints only on the clean path, so the sentinel protocol is intact.
RYOKU_STAGE=preflight
ryoku_on_exit() {
  local rc=$?
  (( rc == 0 )) && return 0
  trap - EXIT
  printf 'ERROR: install failed at stage "%s" (exit %d)\n' "${RYOKU_STAGE:-startup}" "$rc" >&2
  ryoku_hooks_restore || true
  sync || true
  printf 'log: /var/log/ryoku-install.log & journalctl -b\n' >&2
  exit "$rc"
}
trap ryoku_on_exit EXIT

main "$@"
