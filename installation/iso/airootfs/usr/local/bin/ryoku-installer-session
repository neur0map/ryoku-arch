#!/usr/bin/env bash
# Ryoku live installer session. /root/.zlogin on tty1 starts this.
#
# The installer runs graphically (cage wayland kiosk + foot truecolor terminal,
# for 24-bit color and Nerd Font glyphs) when a DRM/KMS device is present, and on
# the plain kernel VT (16 colors, no glyphs) otherwise. Both paths run the same
# ryoku-tui. The installer ALWAYS starts one way or the other; a bare recovery
# shell is the last resort and is announced with instructions, never silent (the
# recurring "dropped to a root shell with no installer" report, e.g. under Ventoy
# on GPUs where cage could not take the console).

export RYOKU_REPO=/usr/share/ryoku
export RYOKU_BACKEND=ryoku-install
export COLORTERM=truecolor   # 24-bit color for the TUI (foot supports it)
export WLR_RENDERER=pixman             # software render, fine on VMs / GPUs with no GL
export WLR_RENDERER_ALLOW_SOFTWARE=1   # live session has no GPU driver yet
# match the desktop's cursor in the live kiosk: cage/wlroots reads XCURSOR_* to
# pick the pointer theme, so without this it draws its built-in fallback bitmap.
# ryoku-cursors ships the Bibata family into the live set (see packages.x86_64).
export XCURSOR_THEME=Bibata-Modern-Ice
export XCURSOR_SIZE=24

log=/var/log/ryoku-session.log
kbfile=/tmp/ryoku-xkb   # the keyboard step writes the chosen layout here (see below)

# the console TUI: the installer on the raw VT. every non-graphical path routes
# through here so the user always reaches a working installer.
run_console() {
	echo "ryoku: starting the installer on the console (16-color fallback)." >&2
	RYOKU_SESSION=console ryoku-tui
}

# printed only when BOTH the graphical and console TUIs have exited, so a user
# who lands at the prompt knows how to finish by hand instead of facing an empty
# shell. The MOTD carries the same guidance.
recovery_notice() {
	cat >&2 <<'EOF'

ryoku: the installer has exited; you are at a plain root shell.
To install by hand: set the RYOKU_* answers and run `ryoku-install`
(see /etc/motd and /usr/share/ryoku). Graphical diagnostics: /var/log/ryoku-session.log

EOF
}

# the graphical TUI. cage's wayland compositor needs a DRM/KMS card node even
# under software rendering, so a box with no usable /dev/dri skips straight to
# the console instead of burning three cage retries. cage + wlroots log a
# harmless "renderer did not support importing dma-bufs" under software render;
# session diagnostics go to the log so the console stays clean, real failures too.
run_graphical() {
	command -v cage >/dev/null 2>&1 && command -v foot >/dev/null 2>&1 || return 1
	compgen -G '/dev/dri/card*' >/dev/null 2>&1 || return 1
	# cage's keyboard layout is fixed at launch and loadkeys never reaches a
	# wayland session, so the keyboard step writes the chosen layout to $kbfile and
	# quits; we relaunch cage under it (below) so the PASSWORD is captured in the
	# user's real layout instead of us. Without this a non-us password silently
	# mismatches every login prompt after install.
	local kmap="" lay="" var=""
	if [[ -r $kbfile ]]; then
		{ IFS= read -r kmap; IFS= read -r lay; IFS= read -r var; } <"$kbfile" || true
	fi
	local -a genv=(RYOKU_SESSION=graphical)
	[[ -n $kmap ]] && genv+=("RYOKU_KB_PRESET=$kmap")
	[[ -n $lay ]] && genv+=("RYOKU_XKB=$lay" "XKB_DEFAULT_LAYOUT=$lay")
	[[ -n $var ]] && genv+=("XKB_DEFAULT_VARIANT=$var")
	env "${genv[@]}" cage -- foot -o term=xterm-256color -f 'JetBrainsMono Nerd Font:size=14' -e ryoku-tui >"$log" 2>&1
}

# a missing installer binary is a corrupt image: say so loudly, don't hang.
if ! command -v ryoku-tui >/dev/null 2>&1; then
	echo "ryoku: FATAL: ryoku-tui is missing from this image (corrupt ISO)." >&2
	recovery_notice
	exit 0
fi

# try the graphical TUI a few times (transient wayland/seat races on real boots),
# then fall back to the console TUI. a clean quit from either ends the session.
rm -f "$kbfile"   # clear any stale layout from a prior boot; first run has no preset
tries=0
while true; do
	prev=""; [[ -r $kbfile ]] && prev=$(sed -n 2p "$kbfile")
	if run_graphical; then
		# a keyboard (re)pick rewrote $kbfile; relaunch cage under the new layout.
		now=""; [[ -r $kbfile ]] && now=$(sed -n 2p "$kbfile")
		if [[ $now != "$prev" ]]; then
			tries=0
			continue
		fi
		break
	fi
	tries=$((tries + 1))
	if ((tries >= 3)); then
		echo "ryoku: the graphical session could not start (no usable GPU/DRM, or wayland failed); see $log." >&2
		run_console
		break
	fi
	sleep 1
done

recovery_notice
