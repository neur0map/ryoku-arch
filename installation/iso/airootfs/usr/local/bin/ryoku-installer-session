#!/usr/bin/env bash
# Ryoku live installer session, started by /root/.zlogin on tty1.
#
# Runs the installer TUI inside cage (a minimal Wayland kiosk) and foot (a
# truecolor terminal) so it renders with full 24-bit color and Nerd Font glyphs.
# cage, foot, and the Nerd Font are baked into the ISO, so every machine gets the
# full experience. The kernel VT (16 colors, no Nerd Font) is only used as a last
# resort if Wayland cannot start at all, which needs a machine with no usable
# DRM/KMS and is very rare.

export RYOKU_REPO=/usr/share/ryoku
export RYOKU_BACKEND=ryoku-install
export COLORTERM=truecolor   # ask the TUI for 24-bit color; foot supports it
export WLR_RENDERER=pixman   # software render: works on VMs and GPUs with no GL

run_full() {
	cage -- foot -o term=xterm-256color -f 'JetBrainsMono Nerd Font:size=14' -e ryoku-tui
}

# Try the full graphical TUI, relaunching on a crash so the console never drops to
# a bare prompt mid-install. A clean quit ends the loop. After a few failed starts
# we assume Wayland is unavailable and fall back to the TUI on the console.
tries=0
while true; do
	if run_full; then
		break
	fi
	tries=$((tries + 1))
	if ((tries >= 3)); then
		echo "ryoku: Wayland could not start; running the installer on the console." >&2
		ryoku-tui
		break
	fi
	sleep 1
done
