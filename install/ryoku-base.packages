# ── Shell native plugin build toolchain ───────────────────────────────
# Required at runtime by shell/setup so the Ryoku QML plugin
# (libryoku-services.so + libryoku.so + libryoku-config.so) can be
# rebuilt on every install/update. Without these the QML import
# `Ryoku.Config` is missing and shell.qml fails to load with
# "Type Background unavailable".
cmake
ninja

# ── Display manager + boot splash ─────────────────────────────────────
# @os-only  (boot splash + display manager; the OS install owns these)
plymouth
sddm
# @end

# ── Audio system + visualizer ─────────────────────────────────────────
# `cava` here pulls the stock Arch package for the offline mirror. The
# install/packaging/distro-arch.sh step later replaces it with
# distro/arch/cava-ryoku, which provides=cava+libcava so the rebirth
# shell's plugin can link libcava (otherwise the dashboard music
# visualiser stays invisible). Order matters: keep cava in this list so
# the offline mirror contains a satisfying stock cava during base
# packaging, then distro-arch.sh swaps it out.
alsa-utils
aubio
cava
easyeffects
gst-plugins-bad
gst-plugins-base
gst-plugins-good
gst-plugins-ugly
pamixer
pipewire
playerctl
wireplumber

# ── Authentication / secrets / polkit ─────────────────────────────────
gnome-keyring
libsecret
polkit-gnome
# Vicinae launcher (vicinae-bin) runtime deps it does not reliably pull itself,
# pinned here so the offline ISO mirror is guaranteed to carry them via the
# retried official-package download path:
#   qtkeychain-qt6 - libqt6keychain.so.1 for the server's secret storage
#                    (backed by the gnome-keyring secret service above)
#   layer-shell-qt - the wlr-layer-shell backend the launcher window needs
#   minizip        - declared hard dependency of vicinae-bin
# Without these the launcher fails to start or cannot draw its surface.
qtkeychain-qt6
layer-shell-qt
minizip

# ── Networking ────────────────────────────────────────────────────────
inetutils
iwd
# kdeconnect + network-manager-applet provide the kdeconnectd /
# kdeconnect-indicator / nm-applet tray helpers the Hyprland exec-once lines
# start on login; without them those exec-once commands silently no-op.
kdeconnect
network-manager-applet
networkmanager-openvpn
openvpn
tailscale
ufw
wireless-regdb

# ── Power management ──────────────────────────────────────────────────
power-profiles-daemon

# ── Hardware daemons ──────────────────────────────────────────────────
