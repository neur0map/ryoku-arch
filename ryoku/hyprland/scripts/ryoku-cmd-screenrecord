#!/bin/bash

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  ryoku-cmd-screenrecord [--fullscreen|--region] [--with-desktop-audio] [--with-microphone-audio]
  ryoku-cmd-screenrecord -r|-s|-sr
  ryoku-cmd-screenrecord --stop|--pause|--status

Starts, stops, or pauses Ryoku's shell recorder.

By default it records with gpu-screen-recorder. On multi-GPU machines where the
monitor is driven by a different GPU than the one gpu-screen-recorder targets
(so it reports "no monitor"), it falls back to wf-recorder, which captures the
displayed output through the compositor and hardware-encodes on the primary GPU.

Override the backend with RYOKU_SCREENRECORD_BACKEND=auto|gsr|wf.
USAGE
}

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a ryoku-cli "$@" >/dev/null 2>&1 || true
  fi
}

require_command() {
  local command_name="$1"
  local label="$2"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    notify -u critical "Screen recording failed" "$label is not installed"
    echo "ryoku-cmd-screenrecord: missing command: $command_name" >&2
    exit 1
  fi
}

gsr_pattern='(^|/)gpu-screen-recorder( |$)'
wf_pattern='(^|/)wf-recorder( |$)'

proc_running() {
  local pattern="$1"

  if command -v pgrep >/dev/null 2>&1; then
    pgrep -f "$pattern" >/dev/null 2>&1
    return
  fi

  if command -v pidof >/dev/null 2>&1; then
    case "$pattern" in
    *gpu-screen-recorder*) pidof gpu-screen-recorder >/dev/null 2>&1; return ;;
    *wf-recorder*) pidof wf-recorder >/dev/null 2>&1; return ;;
    esac
  fi

  return 1
}

recorder_running() {
  proc_running "$gsr_pattern" || proc_running "$wf_pattern"
}

# Which backend currently owns the live recording, if any.
running_backend() {
  if proc_running "$gsr_pattern"; then
    printf 'gsr'
  elif proc_running "$wf_pattern"; then
    printf 'wf'
  fi
}

signal_recorder() {
  local signal="$1"
  local pattern="$2"

  require_command pkill pkill
  pkill "$signal" -f "$pattern" >/dev/null 2>&1 || true
}

# Must match Ryoku.Paths.recsdir in the shell (shell/utils/Paths.qml), which is
# RYOKU_SHELL_RECORDINGS_DIR or ${XDG_VIDEOS_DIR:-$HOME/Videos}/Recordings. The
# shell's recordings list only watches that exact directory, so resolving it any
# other way (e.g. via `xdg-user-dir VIDEOS`, which returns $HOME when no Videos
# dir is configured) would hide every saved recording.
recordings_dir() {
  if [[ -n ${RYOKU_SHELL_RECORDINGS_DIR:-} ]]; then
    printf '%s\n' "$RYOKU_SHELL_RECORDINGS_DIR"
    return
  fi

  printf '%s/Recordings\n' "${XDG_VIDEOS_DIR:-$HOME/Videos}"
}

next_recording_path() {
  local dir="$1"
  local name_format="${RYOKU_SCREENRECORD_NAME_FORMAT:-recording_%Y-%m-%d_%H.%M.%S}"
  local name
  local path
  local suffix=1

  name="$(date +"$name_format")"
  name="${name//\//-}"
  name="${name//$'\n'/-}"
  path="$dir/$name.mp4"

  while [[ -e $path ]]; do
    path="$dir/$name-$suffix.mp4"
    ((suffix++))
  done

  printf '%s\n' "$path"
}

# Ground truth: can gpu-screen-recorder enumerate a real monitor with the card
# it auto-selects? On multi-GPU setups where the display lives on a different
# card than the render GPU, this is false and we must use wf-recorder instead.
# The probe is time-boxed because gpu-screen-recorder's DRM enumeration can hang
# on such machines.
gsr_capture_probe() {
  local cmd="${RYOKU_SCREENRECORD_RECORDER:-gpu-screen-recorder}"
  local out

  command -v "$cmd" >/dev/null 2>&1 || return 1

  if command -v timeout >/dev/null 2>&1; then
    out="$(timeout -k 2 4 "$cmd" --list-capture-options 2>/dev/null || true)"
  else
    out="$("$cmd" --list-capture-options 2>/dev/null || true)"
  fi

  printf '%s' "$out" | grep -Eq '^[^|[:space:]]+\|[0-9]+x[0-9]+'
}

# A cheap, stable fingerprint of the GPU/monitor topology. It changes when a
# card or a connected output changes, which is exactly when the backend choice
# might need to change.
gpu_topology_signature() {
  {
    printf '%s\n' /dev/dri/card*
    cat /sys/class/drm/card*/status 2>/dev/null
  } 2>/dev/null | md5sum 2>/dev/null | cut -d' ' -f1
}

backend_cache_file() {
  printf '%s/screenrecord-backend' "${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}"
}

select_backend() {
  local backend="${RYOKU_SCREENRECORD_BACKEND:-auto}"

  case "$backend" in
  gsr|wf)
    printf '%s' "$backend"
    return 0
    ;;
  esac

  # Reuse the previously probed backend while the topology is unchanged, so the
  # (potentially slow) gpu-screen-recorder probe runs at most once per layout.
  local cache sig cached_sig cached_backend chosen
  cache="$(backend_cache_file)"
  sig="$(gpu_topology_signature)"
  if [[ -n $sig && -r $cache ]]; then
    IFS=$'\t' read -r cached_sig cached_backend <"$cache" 2>/dev/null || true
    if [[ $cached_sig == "$sig" && ($cached_backend == "gsr" || $cached_backend == "wf") ]]; then
      printf '%s' "$cached_backend"
      return 0
    fi
  fi

  if gsr_capture_probe; then
    chosen="gsr"
  elif command -v "${RYOKU_SCREENRECORD_WF:-wf-recorder}" >/dev/null 2>&1; then
    chosen="wf"
  else
    # Nothing better available; let gpu-screen-recorder run and surface its own
    # diagnostic instead of silently doing nothing.
    chosen="gsr"
  fi

  if [[ -n $sig ]]; then
    mkdir -p "$(dirname "$cache")" 2>/dev/null || true
    printf '%s\t%s\n' "$sig" "$chosen" >"$cache" 2>/dev/null || true
  fi

  printf '%s' "$chosen"
}

# slurp geometry as "WxH+X+Y" for gpu-screen-recorder. Empty output means the
# selection was cancelled.
region_geometry_gsr() {
  local slurp_cmd="${RYOKU_SCREENRECORD_SLURP:-slurp}"
  local geometry
  local pos
  local size
  local x
  local y

  require_command "$slurp_cmd" slurp
  geometry="$("$slurp_cmd" -f "%wx%h+%x+%y" 2>/dev/null || true)"
  [[ -n $geometry ]] || return 0

  if [[ $geometry == *" "* ]]; then
    pos="${geometry%% *}"
    size="${geometry#* }"
    x="${pos%,*}"
    y="${pos#*,}"
    geometry="${size}+${x}+${y}"
  fi

  if [[ ! $geometry =~ ^[0-9]+x[0-9]+[+-][0-9]+[+-][0-9]+$ ]]; then
    notify -u critical "Screen recording failed" "Invalid region: $geometry"
    echo "ryoku-cmd-screenrecord: invalid region: $geometry" >&2
    exit 1
  fi

  printf '%s' "$geometry"
}

# slurp's native "X,Y WxH" for wf-recorder -g. Empty output means cancelled.
region_geometry_wf() {
  local slurp_cmd="${RYOKU_SCREENRECORD_SLURP:-slurp}"
  local geometry

  require_command "$slurp_cmd" slurp
  geometry="$("$slurp_cmd" 2>/dev/null || true)"
  printf '%s' "$geometry"
}

# Name of the focused Hyprland output, used to target wf-recorder. Empty when it
# can't be resolved (wf-recorder then records the only/default output).
focused_output() {
  command -v hyprctl >/dev/null 2>&1 || return 0
  command -v jq >/dev/null 2>&1 || return 0
  hyprctl monitors -j 2>/dev/null \
    | jq -r '[.[] | select(.focused)][0].name // .[0].name // empty' 2>/dev/null
}

default_sink_monitor() {
  command -v pactl >/dev/null 2>&1 || return 0
  local sink
  sink="$(pactl get-default-sink 2>/dev/null || true)"
  [[ -n $sink ]] && printf '%s.monitor' "$sink"
}

default_source_name() {
  command -v pactl >/dev/null 2>&1 || return 0
  pactl get-default-source 2>/dev/null || true
}

# Resolve the render node (/dev/dri/renderD*) that shares a PCI address with the
# given card device (a real card or a ryoku-gpu-* symlink).
render_node_for_card() {
  local ref="$1"
  local card name pci node

  card="$(readlink -f "$ref" 2>/dev/null || true)"
  name="${card##*/}"
  [[ $name == card* ]] || return 1

  pci="$(readlink -f "/sys/class/drm/$name/device" 2>/dev/null || true)"
  pci="${pci##*/}"
  [[ -n $pci ]] || return 1

  node="/dev/dri/by-path/pci-${pci}-render"
  [[ -e $node ]] || return 1
  readlink -f "$node"
}

# Pick the render node for wf-recorder's VAAPI encoder: an explicit override, the
# primary GPU pinned by ryoku-gpu (AQ_DRM_DEVICES), else the first render node.
wf_vaapi_node() {
  if [[ -n ${RYOKU_SCREENRECORD_WF_DEVICE:-} ]]; then
    printf '%s' "$RYOKU_SCREENRECORD_WF_DEVICE"
    return 0
  fi

  local first node n
  if [[ -n ${AQ_DRM_DEVICES:-} ]]; then
    first="${AQ_DRM_DEVICES%%:*}"
    if node="$(render_node_for_card "$first")"; then
      printf '%s' "$node"
      return 0
    fi
  fi

  for n in /dev/dri/renderD*; do
    [[ -e $n ]] || continue
    printf '%s' "$n"
    return 0
  done

  return 1
}

stop_recording() {
  if ! recorder_running; then
    notify -u normal "Screen recording" "No active recording found"
    return 0
  fi

  signal_recorder -INT "$gsr_pattern"
  signal_recorder -INT "$wf_pattern"
  notify -u normal "Screen recording stopped" "Saving recording to Videos/Recordings"
}

pause_recording() {
  local backend
  backend="$(running_backend)"

  case "$backend" in
  gsr)
    signal_recorder -USR2 "$gsr_pattern"
    ;;
  wf)
    notify -u normal "Screen recording" "Pause isn't available while recording with wf-recorder"
    ;;
  *)
    notify -u normal "Screen recording" "No active recording found"
    ;;
  esac
}

status_recording() {
  if recorder_running; then
    echo "recording"
  else
    echo "idle"
  fi
}

start_gsr() {
  local mode="$1"
  local desktop_audio="$2"
  local microphone_audio="$3"
  local recorder_cmd="${RYOKU_SCREENRECORD_RECORDER:-gpu-screen-recorder}"
  local fps="${RYOKU_SCREENRECORD_FPS:-60}"
  local capture="screen"
  local region_geom=""
  local audio_source=""
  local output_dir
  local output_path
  local args

  require_command "$recorder_cmd" gpu-screen-recorder

  if [[ $mode == "region" ]]; then
    region_geom="$(region_geometry_gsr)"
    [[ -n $region_geom ]] || exit 0
    capture="region"
  fi

  if [[ $desktop_audio == "true" && $microphone_audio == "true" ]]; then
    audio_source="default_output|default_input"
  elif [[ $desktop_audio == "true" ]]; then
    audio_source="default_output"
  elif [[ $microphone_audio == "true" ]]; then
    audio_source="default_input"
  fi

  output_dir="$(recordings_dir)"
  mkdir -p "$output_dir"
  output_path="$(next_recording_path "$output_dir")"

  args=("$recorder_cmd" -w "$capture" -f "$fps" -c mp4 -cursor yes)
  [[ $capture == "region" ]] && args+=(-region "$region_geom")
  [[ -n $audio_source ]] && args+=(-a "$audio_source")
  args+=(-o "$output_path")

  exec "${args[@]}"
}

start_wf() {
  local mode="$1"
  local desktop_audio="$2"
  local microphone_audio="$3"
  local wf_cmd="${RYOKU_SCREENRECORD_WF:-wf-recorder}"
  local fps="${RYOKU_SCREENRECORD_FPS:-60}"
  local geom monitor audio_dev node output_dir output_path pid status
  local target_args=()
  local audio_args=()

  require_command "$wf_cmd" wf-recorder

  if [[ $mode == "region" ]]; then
    geom="$(region_geometry_wf)"
    [[ -n $geom ]] || exit 0
    target_args+=(-g "$geom")
  else
    monitor="$(focused_output)"
    [[ -n $monitor ]] && target_args+=(-o "$monitor")
  fi

  if [[ $desktop_audio == "true" ]]; then
    audio_dev="$(default_sink_monitor)"
  elif [[ $microphone_audio == "true" ]]; then
    audio_dev="$(default_source_name)"
  fi
  if [[ $desktop_audio == "true" || $microphone_audio == "true" ]]; then
    if [[ -n ${audio_dev:-} ]]; then
      audio_args+=(--audio="$audio_dev")
    else
      audio_args+=(--audio)
    fi
  fi

  output_dir="$(recordings_dir)"
  mkdir -p "$output_dir"
  output_path="$(next_recording_path "$output_dir")"

  # Explicit codec: skip the hardware/software negotiation entirely.
  if [[ -n ${RYOKU_SCREENRECORD_WF_CODEC:-} ]]; then
    exec "$wf_cmd" -r "$fps" "${target_args[@]}" "${audio_args[@]}" \
      -c "$RYOKU_SCREENRECORD_WF_CODEC" -f "$output_path"
  fi

  # Prefer GPU (VAAPI) encoding on the primary render node. If the hardware
  # encoder can't be set up (e.g. the captured buffer lives on a GPU whose VAAPI
  # can't ingest it), fall back to libx264 so a recording is always produced.
  node="$(wf_vaapi_node || true)"
  if [[ -n ${node:-} ]]; then
    "$wf_cmd" -r "$fps" "${target_args[@]}" "${audio_args[@]}" \
      -c h264_vaapi -d "$node" -F "scale_vaapi=format=nv12" -f "$output_path" &
    pid=$!
    sleep 1.5
    if kill -0 "$pid" 2>/dev/null; then
      wait "$pid"
      exit $?
    fi
    wait "$pid" 2>/dev/null && status=0 || status=$?
    # If hardware encoding produced a file, the user simply stopped it early.
    [[ -s $output_path ]] && exit "${status:-0}"
    rm -f "$output_path"
    output_path="$(next_recording_path "$output_dir")"
  fi

  exec "$wf_cmd" -r "$fps" "${target_args[@]}" "${audio_args[@]}" \
    -c libx264 -p preset=veryfast -f "$output_path"
}

start_recording() {
  local mode="$1"
  local desktop_audio="$2"
  local microphone_audio="$3"
  local backend

  if recorder_running; then
    notify -u normal "Screen recording" "A recording is already running"
    return 0
  fi

  backend="$(select_backend)"
  case "$backend" in
  wf)
    start_wf "$mode" "$desktop_audio" "$microphone_audio"
    ;;
  *)
    start_gsr "$mode" "$desktop_audio" "$microphone_audio"
    ;;
  esac
}

action="auto"
mode="fullscreen"
desktop_audio=false
microphone_audio=false

while (($# > 0)); do
  case "$1" in
  --fullscreen)
    mode="fullscreen"
    action="start"
    ;;
  --region|-r)
    mode="region"
    action="start"
    ;;
  -s)
    mode="fullscreen"
    desktop_audio=true
    action="start"
    ;;
  -sr|-rs)
    mode="region"
    desktop_audio=true
    action="start"
    ;;
  --with-desktop-audio)
    desktop_audio=true
    action="start"
    ;;
  --with-microphone-audio)
    microphone_audio=true
    action="start"
    ;;
  --stop|stop)
    action="stop"
    ;;
  --pause|-p|pause)
    action="pause"
    ;;
  --status|status)
    action="status"
    ;;
  --help|-h|help)
    usage
    exit 0
    ;;
  *)
    echo "ryoku-cmd-screenrecord: unknown argument: $1" >&2
    usage >&2
    exit 2
    ;;
  esac
  shift
done

if [[ $action == "auto" ]]; then
  if recorder_running; then
    action="stop"
  else
    action="start"
  fi
fi

case "$action" in
start)
  start_recording "$mode" "$desktop_audio" "$microphone_audio"
  ;;
stop)
  stop_recording
  ;;
pause)
  pause_recording
  ;;
status)
  status_recording
  ;;
esac
