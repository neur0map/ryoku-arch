#!/bin/bash

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  ryoku-cmd-screenrecord [--fullscreen|--region] [--with-desktop-audio] [--with-microphone-audio]
  ryoku-cmd-screenrecord -r|-s|-sr
  ryoku-cmd-screenrecord --stop|--pause|--status

Starts, stops, or pauses Ryoku's shell recorder.

By default it records with gpu-screen-recorder. On multi-GPU machines where the
monitor is driven by a different GPU than the one gpu-screen-recorder targets
(so it reports "no monitor"), it falls back to wf-recorder, which captures the
displayed output through the compositor and hardware-encodes on the primary GPU.

Override the backend with RYOKU_SCREENRECORD_BACKEND=auto|gsr|wf.
USAGE
}

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a ryoku-cli "$@" >/dev/null 2>&1 || true
  fi
}

# Hub-owned recording settings (~/.config/ryoku/recording.json), written by the
# Recording page. env vars still override, then this file, then the built-in
# default. only video encode knobs live here (fps, quality, codec, framerate
# mode, encoder, cursor); capture mode and audio are per-recording flags.
recording_config_file() {
  printf '%s/ryoku/recording.json' "${XDG_CONFIG_HOME:-$HOME/.config}"
}

cfg_get() {
  local key="$1" def="$2" val="" f
  f="$(recording_config_file)"
  if [[ -r $f ]] && command -v jq >/dev/null 2>&1; then
    val="$(jq -r "$key // empty" "$f" 2>/dev/null || true)"
  fi
  printf '%s' "${val:-$def}"
}

cfg_bool() { # -> yes|no
  local v
  v="$(cfg_get "$1" "$2")"
  if [[ $v == true || $v == yes || $v == 1 ]]; then printf 'yes'; else printf 'no'; fi
}

require_command() {
  local command_name="$1"
  local label="$2"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    notify -u critical "Screen recording failed" "$label is not installed"
    echo "ryoku-cmd-screenrecord: missing command: $command_name" >&2
    exit 1
  fi
}

gsr_pattern='(^|/)gpu-screen-recorder( |$)'
wf_pattern='(^|/)wf-recorder( |$)'

proc_running() {
  local pattern="$1"

  if command -v pgrep >/dev/null 2>&1; then
    pgrep -f "$pattern" >/dev/null 2>&1
    return
  fi

  if command -v pidof >/dev/null 2>&1; then
    case "$pattern" in
    *gpu-screen-recorder*) pidof gpu-screen-recorder >/dev/null 2>&1; return ;;
    *wf-recorder*) pidof wf-recorder >/dev/null 2>&1; return ;;
    esac
  fi

  return 1
}

recorder_running() {
  proc_running "$gsr_pattern" || proc_running "$wf_pattern"
}

# which backend owns the live recording right now, if any.
running_backend() {
  if proc_running "$gsr_pattern"; then
    printf 'gsr'
  elif proc_running "$wf_pattern"; then
    printf 'wf'
  fi
}

signal_recorder() {
  local signal="$1"
  local pattern="$2"

  require_command pkill pkill
  pkill "$signal" -f "$pattern" >/dev/null 2>&1 || true
}

# must match Ryoku.Paths.recsdir (shell/utils/Paths.qml): RYOKU_SHELL_RECORDINGS_DIR
# or ${XDG_VIDEOS_DIR:-$HOME/Videos}/Recordings. the shell's recordings list only
# watches that one dir, so any other resolution (e.g. `xdg-user-dir VIDEOS`,
# which returns $HOME when there's no Videos dir) would hide every saved
# recording.
recordings_dir() {
  if [[ -n ${RYOKU_SHELL_RECORDINGS_DIR:-} ]]; then
    printf '%s\n' "$RYOKU_SHELL_RECORDINGS_DIR"
    return
  fi

  printf '%s/Recordings\n' "${XDG_VIDEOS_DIR:-$HOME/Videos}"
}

next_recording_path() {
  local dir="$1"
  local name_format="${RYOKU_SCREENRECORD_NAME_FORMAT:-recording_%Y-%m-%d_%H.%M.%S}"
  local name
  local path
  local suffix=1

  name="$(date +"$name_format")"
  name="${name//\//-}"
  name="${name//$'\n'/-}"
  path="$dir/$name.mp4"

  while [[ -e $path ]]; do
    path="$dir/$name-$suffix.mp4"
    ((suffix++))
  done

  printf '%s\n' "$path"
}

# ground truth: can gpu-screen-recorder list a real monitor with the card it
# auto-picks? on multi-GPU boxes where the display lives on a different card
# than the render GPU this is false and we have to use wf-recorder. probe is
# time-boxed because gsr's DRM enum can hang on exactly those machines.
gsr_capture_probe() {
  local cmd="${RYOKU_SCREENRECORD_RECORDER:-gpu-screen-recorder}"
  local out

  command -v "$cmd" >/dev/null 2>&1 || return 1

  if command -v timeout >/dev/null 2>&1; then
    out="$(timeout -k 2 4 "$cmd" --list-capture-options 2>/dev/null || true)"
  else
    out="$("$cmd" --list-capture-options 2>/dev/null || true)"
  fi

  printf '%s' "$out" | grep -Eq '^[^|[:space:]]+\|[0-9]+x[0-9]+'
}

# cheap stable fingerprint of GPU/monitor topology. changes when a card or a
# connected output changes, which is exactly when the backend choice may need
# to flip.
gpu_topology_signature() {
  {
    printf '%s\n' /dev/dri/card*
    cat /sys/class/drm/card*/status 2>/dev/null
  } 2>/dev/null | md5sum 2>/dev/null | cut -d' ' -f1
}

backend_cache_file() {
  printf '%s/screenrecord-backend' "${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}"
}

select_backend() {
  local backend="${RYOKU_SCREENRECORD_BACKEND:-auto}"

  case "$backend" in
  gsr|wf)
    printf '%s' "$backend"
    return 0
    ;;
  esac

  # reuse the last probed backend while the topology hasn't changed, so the
  # (potentially slow) gsr probe runs at most once per layout.
  local cache sig cached_sig cached_backend chosen
  cache="$(backend_cache_file)"
  sig="$(gpu_topology_signature)"
  if [[ -n $sig && -r $cache ]]; then
    IFS=$'\t' read -r cached_sig cached_backend <"$cache" 2>/dev/null || true
    if [[ $cached_sig == "$sig" && ($cached_backend == "gsr" || $cached_backend == "wf") ]]; then
      printf '%s' "$cached_backend"
      return 0
    fi
  fi

  if gsr_capture_probe; then
    chosen="gsr"
  elif command -v "${RYOKU_SCREENRECORD_WF:-wf-recorder}" >/dev/null 2>&1; then
    chosen="wf"
  else
    # nothing better around; let gsr run and surface its own diagnostic instead
    # of silently doing nothing.
    chosen="gsr"
  fi

  if [[ -n $sig ]]; then
    mkdir -p "$(dirname "$cache")" 2>/dev/null || true
    printf '%s\t%s\n' "$sig" "$chosen" >"$cache" 2>/dev/null || true
  fi

  printf '%s' "$chosen"
}

# slurp geometry as "WxH+X+Y" for gpu-screen-recorder. empty = cancelled.
region_geometry_gsr() {
  local slurp_cmd="${RYOKU_SCREENRECORD_SLURP:-slurp}"
  local region_pick="${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}/region-pick"
  local geometry pos size x y

  # geometry sources in order: an explicit --geometry, the box the island's region
  # picker drew (a state file we consume so it is never reused stale), else slurp.
  if [[ -n ${region_geom_override:-} ]]; then
    geometry="$region_geom_override"
  elif [[ -s $region_pick ]]; then
    geometry="$(tr -d '[:space:]' < "$region_pick" 2>/dev/null || true)"
    rm -f "$region_pick" 2>/dev/null || true
  fi

  if [[ -z ${geometry:-} ]]; then
    require_command "$slurp_cmd" slurp
    geometry="$("$slurp_cmd" -f "%wx%h+%x+%y" 2>/dev/null || true)"
    [[ -n $geometry ]] || return 0

    if [[ $geometry == *" "* ]]; then
      pos="${geometry%% *}"
      size="${geometry#* }"
      x="${pos%,*}"
      y="${pos#*,}"
      geometry="${size}+${x}+${y}"
    fi
  fi

  if [[ ! $geometry =~ ^[0-9]+x[0-9]+[+-][0-9]+[+-][0-9]+$ ]]; then
    notify -u critical "Screen recording failed" "Invalid region: $geometry"
    echo "ryoku-cmd-screenrecord: invalid region: $geometry" >&2
    exit 1
  fi

  printf '%s' "$geometry"
}

# slurp's native "X,Y WxH" for wf-recorder -g. empty = cancelled.
region_geometry_wf() {
  local slurp_cmd="${RYOKU_SCREENRECORD_SLURP:-slurp}"
  local region_pick="${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}/region-pick"
  local geometry gsr_geom

  # island-provided region (WxH+X+Y, via --geometry or the picker file) ->
  # wf-recorder's "X,Y WxH".
  gsr_geom="${region_geom_override:-}"
  if [[ -z $gsr_geom && -s $region_pick ]]; then
    gsr_geom="$(tr -d '[:space:]' < "$region_pick" 2>/dev/null || true)"
    rm -f "$region_pick" 2>/dev/null || true
  fi
  if [[ -n $gsr_geom && $gsr_geom =~ ^([0-9]+)x([0-9]+)[+]([0-9]+)[+]([0-9]+)$ ]]; then
    printf '%s,%s %sx%s' "${BASH_REMATCH[3]}" "${BASH_REMATCH[4]}" "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
    return
  fi

  require_command "$slurp_cmd" slurp
  geometry="$("$slurp_cmd" 2>/dev/null || true)"
  printf '%s' "$geometry"
}

# focused Hyprland output name, to target wf-recorder. empty when we can't
# resolve it (wf-recorder then records the only/default output).
focused_output() {
  command -v hyprctl >/dev/null 2>&1 || return 0
  command -v jq >/dev/null 2>&1 || return 0
  hyprctl monitors -j 2>/dev/null \
    | jq -r '[.[] | select(.focused)][0].name // .[0].name // empty' 2>/dev/null
}

default_sink_monitor() {
  command -v pactl >/dev/null 2>&1 || return 0
  local sink
  sink="$(pactl get-default-sink 2>/dev/null || true)"
  [[ -n $sink ]] && printf '%s.monitor' "$sink"
}

default_source_name() {
  command -v pactl >/dev/null 2>&1 || return 0
  pactl get-default-source 2>/dev/null || true
}

# render node (/dev/dri/renderD*) sharing a PCI addr with the given card
# device (a real card or a ryoku-gpu-* symlink).
render_node_for_card() {
  local ref="$1"
  local card name pci node

  card="$(readlink -f "$ref" 2>/dev/null || true)"
  name="${card##*/}"
  [[ $name == card* ]] || return 1

  pci="$(readlink -f "/sys/class/drm/$name/device" 2>/dev/null || true)"
  pci="${pci##*/}"
  [[ -n $pci ]] || return 1

  node="/dev/dri/by-path/pci-${pci}-render"
  [[ -e $node ]] || return 1
  readlink -f "$node"
}

# pick the render node for wf-recorder's VAAPI encoder: explicit override, the
# primary GPU pinned by ryoku-gpu (AQ_DRM_DEVICES), else the first render node.
wf_vaapi_node() {
  if [[ -n ${RYOKU_SCREENRECORD_WF_DEVICE:-} ]]; then
    printf '%s' "$RYOKU_SCREENRECORD_WF_DEVICE"
    return 0
  fi

  local first node n
  if [[ -n ${AQ_DRM_DEVICES:-} ]]; then
    first="${AQ_DRM_DEVICES%%:*}"
    if node="$(render_node_for_card "$first")"; then
      printf '%s' "$node"
      return 0
    fi
  fi

  for n in /dev/dri/renderD*; do
    [[ -e $n ]] || continue
    printf '%s' "$n"
    return 0
  done

  return 1
}

stop_recording() {
  if ! recorder_running; then
    notify -u normal "Screen recording" "No active recording found"
    return 0
  fi

  signal_recorder -INT "$gsr_pattern"
  signal_recorder -INT "$wf_pattern"
  notify -u normal "Screen recording stopped" "Saving recording to Videos/Recordings"
}

pause_recording() {
  local backend
  backend="$(running_backend)"

  case "$backend" in
  gsr)
    signal_recorder -USR2 "$gsr_pattern"
    ;;
  wf)
    notify -u normal "Screen recording" "Pause isn't available while recording with wf-recorder"
    ;;
  *)
    notify -u normal "Screen recording" "No active recording found"
    ;;
  esac
}

status_recording() {
  if recorder_running; then
    echo "recording"
  else
    echo "idle"
  fi
}

# vendor id of the GPU driving the focused output, for the encoder label.
focused_gpu_vendor() {
  local out conn cardnum
  out="$(focused_output)"
  [[ -n $out ]] || return 0
  for conn in /sys/class/drm/card*-"$out"; do
    [[ -e $conn ]] || continue
    cardnum="$(basename "$conn")"
    cardnum="${cardnum%%-*}"
    cat "/sys/class/drm/$cardnum/device/vendor" 2>/dev/null && return 0
  done
}

encoder_label() {
  local backend="$1" encoder="$2" vendor
  if [[ $encoder == cpu ]]; then printf 'CPU (libx264)'; return 0; fi
  vendor="$(focused_gpu_vendor)"
  case "$vendor" in
  0x10de) printf 'NVIDIA NVENC' ;;
  0x1002) printf 'AMD VAAPI' ;;
  0x8086) printf 'Intel QSV' ;;
  *) if [[ $backend == wf ]]; then printf 'VAAPI'; else printf 'GPU (hardware)'; fi ;;
  esac
}

# machine-readable summary for the Hub's Recording page: which backend + encoder
# will run, and the resolved settings.
info_recording() {
  local backend fps quality codec fmode encoder enc
  backend="$(select_backend)"
  fps="${RYOKU_SCREENRECORD_FPS:-$(cfg_get '.fps' 60)}"
  quality="${RYOKU_SCREENRECORD_QUALITY:-$(cfg_get '.quality' very_high)}"
  codec="${RYOKU_SCREENRECORD_CODEC:-$(cfg_get '.codec' h264)}"
  fmode="${RYOKU_SCREENRECORD_FRAMERATE_MODE:-$(cfg_get '.framerateMode' cfr)}"
  encoder="${RYOKU_SCREENRECORD_ENCODER:-$(cfg_get '.encoder' gpu)}"
  enc="$(encoder_label "$backend" "$encoder")"
  printf '{"backend":"%s","encoder":"%s","fps":"%s","quality":"%s","codec":"%s","framerateMode":"%s"}\n' \
    "$backend" "$enc" "$fps" "$quality" "$codec" "$fmode"
}

start_gsr() {
  local mode="$1"
  local desktop_audio="$2"
  local microphone_audio="$3"
  local recorder_cmd="${RYOKU_SCREENRECORD_RECORDER:-gpu-screen-recorder}"
  local fps fmode quality codec encoder cursor
  local capture="screen"
  local region_geom=""
  local audio_source=""
  local output_dir
  local output_path
  local args

  fps="${RYOKU_SCREENRECORD_FPS:-$(cfg_get '.fps' 60)}"
  fmode="${RYOKU_SCREENRECORD_FRAMERATE_MODE:-$(cfg_get '.framerateMode' cfr)}"
  quality="${RYOKU_SCREENRECORD_QUALITY:-$(cfg_get '.quality' very_high)}"
  codec="${RYOKU_SCREENRECORD_CODEC:-$(cfg_get '.codec' h264)}"
  encoder="${RYOKU_SCREENRECORD_ENCODER:-$(cfg_get '.encoder' gpu)}"
  cursor="$(cfg_bool '.cursor' true)"

  require_command "$recorder_cmd" gpu-screen-recorder

  if [[ $mode == "region" ]]; then
    region_geom="$(region_geometry_gsr)"
    [[ -n $region_geom ]] || exit 0
    capture="region"
  fi

  if [[ $desktop_audio == "true" && $microphone_audio == "true" ]]; then
    audio_source="default_output|default_input"
  elif [[ $desktop_audio == "true" ]]; then
    audio_source="default_output"
  elif [[ $microphone_audio == "true" ]]; then
    audio_source="default_input"
  fi

  output_dir="$(recordings_dir)"
  mkdir -p "$output_dir"
  output_path="$(next_recording_path "$output_dir")"
  # record the output path so the studio flow (ryoku-cmd-studiorecord) can find
  # the finished clip to write its cursor sidecar and hand to the editor.
  mkdir -p "${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}" 2>/dev/null || true
  printf '%s\n' "$output_path" >"${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}/last-recording" 2>/dev/null || true

  # -fm cfr: a steady framerate every player and editor reads correctly (vfr
  # often imports as ~30fps and looks choppy). -q/-k/-encoder come from the
  # Hub's Recording page (recording.json); env vars override.
  args=("$recorder_cmd" -w "$capture" -f "$fps" -fm "$fmode" -q "$quality" -k "$codec" -encoder "$encoder" -c mp4 -cursor "$cursor")
  [[ $capture == "region" ]] && args+=(-region "$region_geom")
  [[ -n $audio_source ]] && args+=(-a "$audio_source")
  args+=(-o "$output_path")

  exec "${args[@]}"
}

start_wf() {
  local mode="$1"
  local desktop_audio="$2"
  local microphone_audio="$3"
  local wf_cmd="${RYOKU_SCREENRECORD_WF:-wf-recorder}"
  local fps quality qp crf
  local geom monitor audio_dev node output_dir output_path pid status
  local target_args=()
  local audio_args=()

  fps="${RYOKU_SCREENRECORD_FPS:-$(cfg_get '.fps' 60)}"
  quality="${RYOKU_SCREENRECORD_QUALITY:-$(cfg_get '.quality' very_high)}"

  require_command "$wf_cmd" wf-recorder

  if [[ $mode == "region" ]]; then
    geom="$(region_geometry_wf)"
    [[ -n $geom ]] || exit 0
    target_args+=(-g "$geom")
  else
    monitor="$(focused_output)"
    [[ -n $monitor ]] && target_args+=(-o "$monitor")
  fi

  if [[ $desktop_audio == "true" ]]; then
    audio_dev="$(default_sink_monitor)"
  elif [[ $microphone_audio == "true" ]]; then
    audio_dev="$(default_source_name)"
  fi
  if [[ $desktop_audio == "true" || $microphone_audio == "true" ]]; then
    if [[ -n ${audio_dev:-} ]]; then
      audio_args+=(--audio="$audio_dev")
    else
      audio_args+=(--audio)
    fi
  fi

  output_dir="$(recordings_dir)"
  mkdir -p "$output_dir"
  output_path="$(next_recording_path "$output_dir")"
  mkdir -p "${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}" 2>/dev/null || true
  printf '%s\n' "$output_path" >"${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}/last-recording" 2>/dev/null || true

  # quality preset -> VAAPI qp / x264 crf (lower = crisper).
  case "$quality" in
  ultra) qp=16; crf=17 ;;
  very_high) qp=20; crf=20 ;;
  high) qp=24; crf=23 ;;
  *) qp=28; crf=28 ;;
  esac

  # explicit codec: skip hw/sw negotiation entirely.
  if [[ -n ${RYOKU_SCREENRECORD_WF_CODEC:-} ]]; then
    exec "$wf_cmd" -r "$fps" "${target_args[@]}" "${audio_args[@]}" \
      -c "$RYOKU_SCREENRECORD_WF_CODEC" -f "$output_path"
  fi

  # try VAAPI on the primary render node first. if the hw encoder can't be set
  # up (e.g. the captured buffer lives on a GPU whose VAAPI can't ingest it),
  # fall back to libx264 so we always produce a file.
  node="$(wf_vaapi_node || true)"
  if [[ -n ${node:-} ]]; then
    "$wf_cmd" -r "$fps" "${target_args[@]}" "${audio_args[@]}" \
      -c h264_vaapi -d "$node" -p qp="$qp" -F "scale_vaapi=format=nv12" -f "$output_path" &
    pid=$!
    sleep 1.5
    if kill -0 "$pid" 2>/dev/null; then
      wait "$pid"
      exit $?
    fi
    wait "$pid" 2>/dev/null && status=0 || status=$?
    # hw encode produced something? the user just stopped it early.
    [[ -s $output_path ]] && exit "${status:-0}"
    rm -f "$output_path"
    output_path="$(next_recording_path "$output_dir")"
  fi

  exec "$wf_cmd" -r "$fps" "${target_args[@]}" "${audio_args[@]}" \
    -c libx264 -p preset=veryfast -p crf="$crf" -f "$output_path"
}

start_recording() {
  local mode="$1"
  local desktop_audio="$2"
  local microphone_audio="$3"
  local backend

  if recorder_running; then
    notify -u normal "Screen recording" "A recording is already running"
    return 0
  fi

  backend="$(select_backend)"
  case "$backend" in
  wf)
    start_wf "$mode" "$desktop_audio" "$microphone_audio"
    ;;
  *)
    start_gsr "$mode" "$desktop_audio" "$microphone_audio"
    ;;
  esac
}

action="auto"
mode="fullscreen"
desktop_audio=false
microphone_audio=false
region_geom_override=""

while (($# > 0)); do
  case "$1" in
  --fullscreen)
    mode="fullscreen"
    action="start"
    ;;
  --region|-r)
    mode="region"
    action="start"
    ;;
  -s)
    mode="fullscreen"
    desktop_audio=true
    action="start"
    ;;
  -sr|-rs)
    mode="region"
    desktop_audio=true
    action="start"
    ;;
  --with-desktop-audio)
    desktop_audio=true
    action="start"
    ;;
  --with-microphone-audio)
    microphone_audio=true
    action="start"
    ;;
  --stop|stop)
    action="stop"
    ;;
  --pause|-p|pause)
    action="pause"
    ;;
  --status|status)
    action="status"
    ;;
  --info|info)
    action="info"
    ;;
  --help|-h|help)
    usage
    exit 0
    ;;
  --geometry)
    shift
    region_geom_override="${1:-}"
    ;;
  *)
    echo "ryoku-cmd-screenrecord: unknown argument: $1" >&2
    usage >&2
    exit 2
    ;;
  esac
  shift
done

if [[ $action == "auto" ]]; then
  if recorder_running; then
    action="stop"
  else
    action="start"
  fi
fi

case "$action" in
start)
  start_recording "$mode" "$desktop_audio" "$microphone_audio"
  ;;
stop)
  stop_recording
  ;;
pause)
  pause_recording
  ;;
status)
  status_recording
  ;;
info)
  info_recording
  ;;
esac
