#!/usr/bin/env bash
# Upload a selected screen region to a paste host and open it in Google Lens.
# Self-contained: grim + slurp grab the region, curl + jq upload and read back the
# URL, xdg-open launches the search. Optional --file IMAGE skips the region grab.
set -euo pipefail

app="Google Lens"
need() { command -v "$1" >/dev/null 2>&1 || { notify-send -u normal "$app" "$1 is not installed"; exit 1; }; }

input_file=""
if [[ ${1:-} == "--file" ]]; then
  [[ -n ${2:-} ]] || { notify-send -u critical "$app" "Missing image path"; exit 2; }
  input_file="$2"; shift 2
fi
(( $# == 0 )) || { notify-send -u critical "$app" "Usage: ryoku-cmd-google-lens [--file IMAGE]"; exit 2; }

for c in curl jq notify-send xdg-open; do need "$c"; done

tmp="$input_file"
if [[ -z $tmp ]]; then
  for c in grim slurp; do need "$c"; done
  tmp="$(mktemp "${XDG_RUNTIME_DIR:-/tmp}/ryoku-google-lens.XXXXXX.png")"
  trap 'rm -f "$tmp"' EXIT
fi

if [[ -n $input_file ]]; then
  [[ -r $tmp ]] || { notify-send -u critical "$app" "Cannot read image at $tmp"; exit 1; }
else
  # slurp non-zero is a cancel (Esc); leave quietly.
  geometry="$(slurp 2>/dev/null)" || exit 130
  [[ -n $geometry ]] || exit 0
  grim -g "$geometry" "$tmp"
fi

notify-send -u low "$app" "Uploading region and opening Google Lens"

if ! response="$(curl -fsS --connect-timeout 10 --max-time 45 -F "files[]=@$tmp" https://uguu.se/upload)"; then
  notify-send -u critical "$app" "Image upload failed"
  exit 1
fi

remote_url="$(printf '%s' "$response" | jq -r '.files[0].url // .files[0].src // empty')"
[[ -n $remote_url ]] || { notify-send -u critical "$app" "Upload response had no image URL"; exit 1; }

encoded_url="$(jq -nr --arg url "$remote_url" '$url|@uri')"
xdg-open "https://www.google.com/searchbyimage?image_url=$encoded_url" >/dev/null 2>&1
