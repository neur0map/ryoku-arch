#!/usr/bin/env bash
# System read-out for the Ryoku pill's SYSTEM card: one field per line, in the
# exact order SysInfo.qml parses. Dual-GPU aware (matches GPU device classes, not
# bus ids, and strips the bus/class prefix and vendor noise). On first run it
# also assigns the user a random codename and persists it to
# ~/.local/state/ryoku/codename, so the operator handle is stable per install.
export LC_ALL=C

clean_gpu() {
    sed -E 's/^[^ ]+ [^:]*: //; s/ \(rev [0-9a-f]+\)//; s/NVIDIA Corporation //; s/Advanced Micro Devices, Inc\. //; s/Intel Corporation //; s/\[AMD\/ATI\] //; s/.*\[([^]]+)\].*/\1/' | xargs | cut -c1-30
}

gpus=$(lspci 2>/dev/null | grep -iE 'vga compatible|3d controller|display controller')
gpu1=$(printf '%s\n' "$gpus" | sed -n '1p' | clean_gpu)
gpu2=$(printf '%s\n' "$gpus" | sed -n '2p' | clean_gpu)

cf="${XDG_STATE_HOME:-$HOME/.local/state}/ryoku/codename"
if [ ! -s "$cf" ]; then
    mkdir -p "$(dirname "$cf")"
    names=(VESPER ONYX KESTREL CIPHER NOVA EMBER RONIN ZENITH OBSIDIAN HALCYON \
           VANTA KAIROS AZRAEL SABLE FENRIR ORACLE PHANTOM VECTOR RIFT ECHO \
           FLUX NEXUS QUASAR PULSAR COBALT SPECTRE VORTEX ZEPHYR AXIOM BASTION \
           DRIFT ETHER GLITCH HAVOC IGNIS KARMA LUMEN MIRAGE NOCTIS OMEN \
           PRISM QUILL RAVEN SOLACE TEMPEST UMBRA VIGIL WRAITH XENON ZEALOT \
           BLAZE CRUX DUSK FORGE GRIM HELIX ION JADE LYNX MAZE \
           NOMAD ODIN PYRE QUARTZ RUNE STYX TALON VOID WARP ZERO \
           ARGON BOREAL CINDER DELTA FABLE GOSSAMER HOLLOW INDIGO JUNO KITE)
    printf '%s\n' "${names[$((RANDOM % ${#names[@]}))]}" > "$cf"
fi
codename=$(cat "$cf")

whoami
cat /etc/hostname 2>/dev/null || hostname
grep -m1 'PRETTY_NAME' /etc/os-release 2>/dev/null | cut -d'"' -f2
uname -m
uname -r
echo "${SHELL##*/}"
grep -m1 'model name' /proc/cpuinfo | sed 's/.*: //; s/ *@ .*//; s/([^)]*)//; s/ w\/.*//' | xargs | cut -c1-26
echo "$(nproc)C / $(nproc --all)T"
echo "${gpu1:--}"
echo "$gpu2"
free -h --si | awk '/Mem:/{print $3" / "$2}'
free | awk '/Mem:/{print int($3/$2*100)}'
df -h / | awk 'NR==2{print $3" / "$2}'
df / | awk 'NR==2{print int($3/($3+$4)*100)}'
awk '{h=int($1/3600); m=int(($1%3600)/60); print h"h "m"m"}' /proc/uptime
pacman -Qq 2>/dev/null | wc -l
hyprctl monitors 2>/dev/null | awk '/x.*@/{match($0,/([0-9]+x[0-9]+)/,a); print a[1]; exit}'
hyprctl monitors 2>/dev/null | awk '/x.*@/{match($0,/@([0-9]+)/,a); print a[1]"Hz"; exit}'
echo "$codename"
