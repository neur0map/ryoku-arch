#!/usr/bin/env bash
# 力 game mode = one reversible toggle. competitive-play tune on start, back
# to normal on stop. compositor via `hyprctl eval` (no root). wifi
# power-save flipped by the privileged ryoku-wifi-powersave through pkexec
# (polkit pre-auths it, no password, toggle stays one click). dnd is the
# shell's job (Flags.dnd) and bridges in here, same as ryoku-cmd-caffeine.
#
#   status   exit 0 = on
#   start    apply, persist (idempotent, safe to re-run)
#   stop     restore, clear
#   toggle
#
# revert = exact. compositor changes are runtime eval overrides; `hyprctl
# reload` rereads Lua and clears them, so nothing to track. the wifi helper
# saves + restores the prior power-save state. `start` is safe to re-run
# after a relogin (Hyprland comes back fresh from Lua, request is still on
# disk).
set -u

state_dir="${RYOKU_STATE_PATH:-${XDG_STATE_HOME:-$HOME/.local/state}/ryoku}"
state_file="${RYOKU_GAMEMODE_STATE_FILE:-$state_dir/game-mode.enabled}"

is_on() { [[ -f $state_file ]]; }

notify() {
  command -v notify-send >/dev/null 2>&1 && notify-send -a Ryoku "$1" "$2" || true
}

# ── compositor ────────────────────────────────────────────────────────────────
# Ryoku's Hyprland runs the Lua config parser, so `hyprctl keyword` is
# rejected. `hyprctl eval` runs Lua against the same `hl` API the config
# uses (same no-flash path ryoku-hub takes). kill present-time cost (blur,
# shadow, rounding, opacity blending, animations) and flip to the
# low-latency path: immediate window rule for tearing + fullscreen-only VRR.
# per the Hyprland wiki tearing only kicks in on a fullscreen sole window,
# which is exactly the game case.
hypr_fast() {
  command -v hyprctl >/dev/null 2>&1 || return 0
  hyprctl eval '
hl.config({
  general = { allow_tearing = true },
  decoration = {
    rounding = 0,
    active_opacity = 1.0,
    inactive_opacity = 1.0,
    blur = { enabled = false },
    shadow = { enabled = false },
  },
  animations = { enabled = false },
  misc = { vrr = 2 },
})
hl.window_rule({ name = "game-mode-immediate", match = { class = ".*" }, immediate = true })
' >/dev/null 2>&1 || true
}

# reload rereads Lua and blows away every eval override above.
hypr_restore() {
  command -v hyprctl >/dev/null 2>&1 || return 0
  hyprctl reload >/dev/null 2>&1 || true
}

# ── wifi (latency only, never a cap) ──────────────────────────────────────────
# 802.11 power-save off = radio stays fully awake. kills the periodic
# micro-sleeps that spike latency on an idle link. does NOT shape, cap, or
# drop the link, so throughput is untouched. the privileged helper does it
# via iw with no reconnect and saves + restores the prior state. no wifi or
# no helper = no-op.
has_wifi() {
  local w
  for w in "${RYOKU_NET_SYSFS:-/sys/class/net}"/*/wireless; do [[ -e $w ]] && return 0; done
  return 1
}

wifi_set() {  # off | on
  local helper
  helper="$(command -v ryoku-wifi-powersave)" || return 0
  has_wifi || return 0
  pkexec "$helper" "$1" >/dev/null 2>&1 || true
}

start() {
  mkdir -p "$state_dir" 2>/dev/null || true
  hypr_fast
  wifi_set off
  printf 'enabled\n' >"$state_file" 2>/dev/null || true
  notify "力 Game Mode" "On - compositor stripped, WiFi power-save off"
}

stop() {
  hypr_restore
  wifi_set on
  rm -f "$state_file" 2>/dev/null || true
  notify "力 Game Mode" "Off - desktop restored"
}

case "${1:-toggle}" in
  status)     is_on ;;
  on | start) start ;;
  off | stop) stop ;;
  toggle)     if is_on; then stop; else start; fi ;;
  *)
    echo "usage: ryoku-cmd-game-mode [status | start | stop | toggle]" >&2
    exit 1
    ;;
esac
