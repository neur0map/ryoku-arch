#!/usr/bin/env bash
# region -> QR. grim+slurp grab, zbarimg decodes, wl-copy stores, URLs get
# xdg-open. --file IMAGE skips the grab.
set -euo pipefail

app="QR Code"
need() { command -v "$1" >/dev/null 2>&1 || { notify-send -u normal "$app" "$1 is not installed"; exit 1; }; }

input_file=""
if [[ ${1:-} == "--file" ]]; then
  [[ -n ${2:-} ]] || { notify-send -u critical "$app" "Missing image path"; exit 2; }
  input_file="$2"; shift 2
fi
(( $# == 0 )) || { notify-send -u critical "$app" "Usage: ryoku-cmd-qr-scan [--file IMAGE]"; exit 2; }

for c in zbarimg wl-copy notify-send xdg-open; do need "$c"; done

tmp="$input_file"
if [[ -z $tmp ]]; then
  for c in grim slurp; do need "$c"; done
  tmp="$(mktemp "${XDG_RUNTIME_DIR:-/tmp}/ryoku-qr.XXXXXX.png")"
  trap 'rm -f "$tmp"' EXIT
fi

if [[ -n $input_file ]]; then
  [[ -r $tmp ]] || { notify-send -u critical "$app" "Cannot read image at $tmp"; exit 1; }
else
  # slurp nonzero = Esc/cancel. bail quietly.
  geometry="$(slurp 2>/dev/null)" || exit 130
  [[ -n $geometry ]] || exit 0
  grim -g "$geometry" "$tmp"
fi

result="$(zbarimg --raw "$tmp" 2>/dev/null | head -n 1 || true)"
if [[ -z $result ]]; then
  notify-send -u normal "$app" "No QR code found in the selected area"
  exit 0
fi

printf '%s' "$result" | wl-copy
case "$result" in
  http://*|https://*)
    xdg-open "$result" >/dev/null 2>&1 || true
    notify-send -u low "$app" "Opened $result"
    ;;
  *)
    notify-send -u low "$app" "Copied to clipboard"
    ;;
esac
