#!/usr/bin/env bash
# Engine for ryovm: the data plane behind the ryovm app. A thin, JSON-speaking
# wrapper around quickemu + quickget (the QEMU front-end that auto-downloads
# ~1000 OSes and runs them with tuned defaults), so the QML never shells out to
# qemu itself. Every VM is one quickemu .conf under the VMs dir, which makes
# multi-VM native; the GPU-passthrough gaming VM (Ryoku Settings > GPU) is a
# separate, single-VM path and is deliberately untouched here.
#
# Verbs (all machine-readable verbs print one JSON document to stdout):
#   caps                              host readiness (quickemu/qemu/kvm/spice)
#   setup                            install quickemu (AUR) + spice-gtk (repo)
#   catalog [--refresh]              quickget OS catalogue (cached)
#   list                             local VMs + live run state
#   get <name>                       one VM: config + state + snapshots
#   create <os> <release> [edition]  quickget download+config (streams progress)
#   instant <os> [name] [--disposable] a prebuilt cloud image, ryoku/ryoku burn account, no installer
#   cloud-catalog                    the curated cloud-image list (JSON)
#   import <name> <iso> [guest]      a VM from any ISO (full QEMU, off-catalogue)
#   launch <name> [window|spice|headless]   start detached
#   console <name>                   open the SPICE viewer for a running VM
#   stop <name>                      power off
#   config <name> <key> <value>     edit one scalar conf key
#   rename <old> <new>               rename a VM (conf + dir + relative paths)
#   resize <name> <size>             grow the VM disk image (e.g. 80G)
#   snapshot <name> list|create|restore|delete [tag]
#   ssh <name>                       print the ssh command to the guest
#   delete <name> [--disk-only]      remove the VM (or just wipe its disk)
#   folder [name]                    print the VMs dir (or one VM dir)
set -euo pipefail

vms_dir="${RYOVM_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/ryoku/vms}"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/ryoku"
catalog_cache="$cache_dir/ryovm-catalog.json"
icon_dir="$cache_dir/ryovm-icons"
icon_ttl_days=14                 # refresh a cached OS logo after this many days

die() { printf '%s\n' "$1" >&2; exit "${2:-1}"; }
have() { command -v "$1" >/dev/null 2>&1; }

# read one scalar key from a quickemu conf without sourcing it (the confs are
# ours or quickget's, but parsing beats executing arbitrary shell either way).
conf_get() { sed -n -E "/^$2=/{s/^$2=\"?([^\"]*)\"?\$/\1/p;q}" "$1" 2>/dev/null; }

# the catalogue OS slug for a conf, used to pick the right brand logo. create and
# import stamp `ryovm_os`; quickemu ignores the unknown key. Empty when unknown
# (a hand-rolled conf), so the UI falls back to a generic glyph.
os_slug() { conf_get "$1" ryovm_os; }

# resolve a VM's runtime triplet from its conf: the on-disk name, its dir, and
# the absolute disk image. quickget writes relative disk paths, so the dir is
# resolved against the VMs dir; quickemu names runtime files after the conf.
vm_paths() {
	local conf="$1" disk
	vm_name="$(basename "$conf" .conf)"
	disk="$(conf_get "$conf" disk_img)"
	[ -z "$disk" ] && disk="$vm_name/disk.qcow2"
	case "$disk" in
		/*) vm_disk="$disk" ;;
		*)  vm_disk="$vms_dir/$disk" ;;
	esac
	vm_subdir="$(dirname "$vm_disk")"
	vm_pid="$vm_subdir/$vm_name.pid"
	vm_ports="$vm_subdir/$vm_name.ports"
}

vm_running() { # $1 = pid file
	local p
	[ -r "$1" ] || return 1
	p="$(head -n1 "$1" 2>/dev/null)"
	[ -n "$p" ] && kill -0 "$p" 2>/dev/null
}

port_of() { # $1 = ports file, $2 = name (ssh|spice)
	[ -r "$1" ] || return 0
	sed -n -E "/^$2,/{s/^$2,([0-9]+).*/\1/p;q}" "$1"
}

# the SPICE endpoint from a ports file, as the app reads it: a bare number for a
# TCP port (headless / remote), or "unix:<path>" for a local socket (windowed
# SPICE, quickemu's default). Empty when the VM exposes no SPICE.
spice_target() { # $1 = ports file, $2 = vm subdir
	[ -r "$1" ] || return 0
	local tcp unix
	tcp="$(sed -n -E '/^spice,/{s/^spice,([0-9]+).*/\1/p;q}' "$1")"
	[ -n "$tcp" ] && { printf '%s' "$tcp"; return 0; }
	unix="$(sed -n -E '/^unix,/{s/^unix,(.*)/\1/p;q}' "$1")"
	if [ -n "$unix" ]; then
		case "$unix" in /*) printf 'unix:%s' "$unix" ;; *) printf 'unix:%s/%s' "$2" "$unix" ;; esac
	fi
}

# snapshots as JSON (newest first), tolerant: a running VM holds the disk and a
# fresh/absent disk has none, so any failure is an empty list, never a hard error
# (which under set -e would abort the whole verb mid-pipe).
snaps_json() { # $1 = disk image
	local out=""
	[ -e "$1" ] && out="$(qemu-img info --output=json "$1" 2>/dev/null \
		| jq -c '[.snapshots[]? | {name:."name", date:(."date-sec"|todate)}] | reverse' 2>/dev/null || true)"
	printf '%s' "${out:-[]}"
}

# actual on-disk bytes the VM occupies under the VMs dir (the disk image, any
# local ISO, firmware vars, logs): the real allocation du reports, sparse-aware,
# which is what a "reclaim disk" frees. 0 when the VM has no dir yet.
disk_used() { # $1 = vm subdir -> bytes
	local b=""
	[ -d "$1" ] && b="$(du -sB1 "$1" 2>/dev/null | cut -f1)"
	printf '%s' "${b:-0}"
}

conf_path() { # $1 = vm name -> absolute conf path, or die
	local c="$vms_dir/$1.conf"
	[ -f "$c" ] || die "no VM named '$1'"
	printf '%s' "$c"
}

require_engine() {
	have quickemu || die "quickemu is not installed. Run setup first."
}

# ---- caps ------------------------------------------------------------------
cmd_caps() {
	local qe qg qemu kvm spice ver=""
	qe=$(have quickemu && echo true || echo false)
	qg=$(have quickget && echo true || echo false)
	qemu=$(have qemu-system-x86_64 && echo true || echo false)
	kvm=$([ -e /dev/kvm ] && [ -r /dev/kvm ] && echo true || echo false)
	spice=$( { have spicy || have remote-viewer; } && echo true || echo false)
	[ "$qe" = true ] && ver="$(quickemu --version 2>/dev/null | sed -n 1p || true)"
	local ready=false
	[ "$qe" = true ] && [ "$qemu" = true ] && [ "$kvm" = true ] && ready=true
	jq -cn --argjson quickemu "$qe" --argjson quickget "$qg" \
		--argjson qemu "$qemu" --argjson kvm "$kvm" --argjson spice "$spice" \
		--argjson ready "$ready" --arg version "$ver" \
		'{quickemu:$quickemu,quickget:$quickget,qemu:$qemu,kvm:$kvm,spice:$spice,ready:$ready,version:$version}'
}

# ---- setup -----------------------------------------------------------------
# quickemu is AUR-only; spice-gtk (spicy) is in the official repos. Route both
# through the Ryoku package helpers so the install matches every other one.
cmd_setup() {
	# shellcheck disable=SC2015  # pacman fallback runs if the helper is absent or fails; both are fine
	have ryoku-pkg-add && ryoku-pkg-add --needed spice-gtk libisoburn || sudo pacman -S --needed --noconfirm spice-gtk libisoburn
	if have ryoku-pkg-aur-add; then
		ryoku-pkg-aur-add quickemu
	elif have yay; then
		yay -S --needed --noconfirm quickemu
	elif have paru; then
		paru -S --needed --noconfirm quickemu
	else
		die "no AUR helper found (expected yay or paru) to install quickemu"
	fi
	have quickemu || die "the install finished but quickemu is still missing; see the output above"
	echo "Done — quickemu is installed. Close this window; ryovm lights up in a few seconds."
}

# ---- catalog ---------------------------------------------------------------
cmd_catalog() {
	have quickget || die "quickget is not installed. Run setup first."
	if [ "${1:-}" = "--refresh" ] || [ ! -s "$catalog_cache" ]; then
		mkdir -p "$cache_dir"
		# shellcheck disable=SC2015  # on failure, keep a usable cached catalogue if one exists
		quickget --list-json >"$catalog_cache.tmp" 2>/dev/null && mv "$catalog_cache.tmp" "$catalog_cache" \
			|| { rm -f "$catalog_cache.tmp"; [ -s "$catalog_cache" ] || die "could not fetch the OS catalogue"; \
				echo "catalogue refresh failed — showing the cached list" >&2; }
	fi
	cat "$catalog_cache"
}

# ---- list ------------------------------------------------------------------
cmd_list() {
	mkdir -p "$vms_dir"
	local first=1
	printf '['
	local conf
	for conf in "$vms_dir"/*.conf; do
		[ -e "$conf" ] || continue
		vm_paths "$conf"
		local guest os disp cores ram disk used running ssh spice disposable sealed tpm sb uefi
		guest="$(conf_get "$conf" guest_os)"
		os="$(os_slug "$conf")"
		disp="$(conf_get "$conf" display)"; [ -z "$disp" ] && disp="gtk"
		cores="$(conf_get "$conf" cpu_cores)"
		ram="$(conf_get "$conf" ram)"
		disk="$(conf_get "$conf" disk_size)"
		used="$(disk_used "$vm_subdir")"
		running=false; vm_running "$vm_pid" && running=true
		ssh=""; spice=""
		if [ "$running" = true ]; then
			ssh="$(port_of "$vm_ports" ssh)"; spice="$(spice_target "$vm_ports" "$vm_subdir")"
		fi
		disposable=false; [ "$running" = true ] && [ -e "$vm_subdir/$vm_name.disposable" ] && disposable=true
		sealed=false; [ "$(conf_get "$conf" ryovm_sealed)" = "1" ] && [ -e "$vm_disk" ] && sealed=true
		tpm=false; [ "$(conf_get "$conf" tpm)" = "on" ] && tpm=true
		sb=false; [ "$(conf_get "$conf" secureboot)" = "on" ] && sb=true
		# quickemu boots EFI unless the conf pins legacy.
		uefi=true; [ "$(conf_get "$conf" boot)" = "legacy" ] && uefi=false
		[ $first -eq 1 ] && first=0 || printf ','
		jq -cn --arg name "$vm_name" --arg guest "${guest:-linux}" --arg os "${os:-}" \
			--arg display "$disp" --arg cores "${cores:-auto}" --arg ram "${ram:-auto}" \
			--arg disk "${disk:-}" --argjson used "$used" --argjson running "$running" \
			--arg ssh "${ssh:-}" --arg spice "${spice:-}" \
			--argjson disposable "$disposable" --argjson sealed "$sealed" \
			--argjson tpm "$tpm" --argjson secureboot "$sb" --argjson uefi "$uefi" \
			--argjson exists "$([ -e "$vm_disk" ] && echo true || echo false)" \
			'{name:$name,guest:$guest,os:$os,display:$display,cores:$cores,ram:$ram,disk:$disk,diskUsed:$used,running:$running,installed:$exists,ssh:$ssh,spice:$spice,disposable:$disposable,sealed:$sealed,tpm:$tpm,secureboot:$secureboot,uefi:$uefi}'
	done
	printf ']\n'
}

# ---- get -------------------------------------------------------------------
cmd_get() {
	local conf; conf="$(conf_path "$1")"
	vm_paths "$conf"
	local guest os disp cores ram disk used running snaps="[]" disposable sealed tpm sb uefi
	guest="$(conf_get "$conf" guest_os)"
	os="$(os_slug "$conf")"
	disp="$(conf_get "$conf" display)"; [ -z "$disp" ] && disp="gtk"
	cores="$(conf_get "$conf" cpu_cores)"
	ram="$(conf_get "$conf" ram)"
	disk="$(conf_get "$conf" disk_size)"
	used="$(disk_used "$vm_subdir")"
	running=false; vm_running "$vm_pid" && running=true
	local ssh="" spice=""
	if [ "$running" = true ]; then
		ssh="$(port_of "$vm_ports" ssh)"; spice="$(spice_target "$vm_ports" "$vm_subdir")"
	fi
	snaps="$(snaps_json "$vm_disk")"
	# is anything actually answering on the forwarded ssh port? slirp accepts
	# the TCP connect no matter what, so only the SSH banner is a real signal —
	# a booting guest or a live ISO without sshd shows a forwarded port that
	# leads nowhere, and the UI should say so instead of letting a click hang.
	local ssh_ready=false
	if [ "$running" = true ] && [ -n "$ssh" ]; then
		timeout 1 bash -c "exec 3<>/dev/tcp/127.0.0.1/$ssh && head -c4 <&3 | grep -q '^SSH'" 2>/dev/null && ssh_ready=true
	fi
	disposable=false; [ "$running" = true ] && [ -e "$vm_subdir/$vm_name.disposable" ] && disposable=true
	# sealed truth for the detail view comes from the disk itself.
	sealed=false; printf '%s' "$snaps" | jq -e 'any(.[]; .name == "sealed")' >/dev/null 2>&1 && sealed=true
	tpm=false; [ "$(conf_get "$conf" tpm)" = "on" ] && tpm=true
	sb=false; [ "$(conf_get "$conf" secureboot)" = "on" ] && sb=true
	uefi=true; [ "$(conf_get "$conf" boot)" = "legacy" ] && uefi=false
	# the login ssh will use, said out loud: a password prompt for an account
	# that doesn't exist in the guest reads as a haunted machine otherwise.
	local suser; suser="$(conf_get "$conf" ryovm_ssh_user)"
	[ -n "$suser" ] || suser="${SUDO_USER:-$USER}"
	jq -cn --arg name "$vm_name" --arg guest "${guest:-linux}" --arg os "${os:-}" --arg display "$disp" \
		--arg cores "${cores:-auto}" --arg ram "${ram:-auto}" --arg disk "${disk:-}" --argjson used "$used" \
		--argjson running "$running" --arg ssh "${ssh:-}" --arg spice "${spice:-}" \
		--argjson installed "$([ -e "$vm_disk" ] && echo true || echo false)" \
		--argjson disposable "$disposable" --argjson sealed "$sealed" \
		--argjson tpm "$tpm" --argjson secureboot "$sb" --argjson uefi "$uefi" \
		--argjson sshready "$ssh_ready" --arg sshuser "$suser" \
		--argjson snapshots "$snaps" --arg conf "$conf" --arg dir "$vm_subdir" \
		'{name:$name,guest:$guest,os:$os,display:$display,cores:$cores,ram:$ram,disk:$disk,diskUsed:$used,running:$running,installed:$installed,ssh:$ssh,spice:$spice,disposable:$disposable,sealed:$sealed,tpm:$tpm,secureboot:$secureboot,uefi:$uefi,sshReady:$sshready,sshUser:$sshuser,snapshots:$snapshots,conf:$conf,dir:$dir}'
}

# ---- create (catalogue OS, in-app download with live progress) --------------
# Emits one JSON line per step so the app draws a live bar and can cancel: a
# {"phase":...} for each stage, with the Go fetcher's own {"event":...} progress
# flowing through during download. The fast path (most Linux distros) resolves a
# direct URL and downloads it in parallel with ryovm-fetch, then has quickget
# write the conf from the local image. Windows, macOS and the special-boot OSes
# fall back to quickget's own downloader (streamed as log lines), since their
# config needs quickget's full per-OS logic. Cancellation (SIGTERM from the app)
# is forwarded to the child so a half-image is cleaned up, never left behind.

# OSes whose config quickget must build itself (TPM/virtio, recovery image, or a
# legacy-boot / non-linux guest); everything else takes the fast Go path.
create_special() {
	case "$1" in
		windows|windows-server|macos|freebsd|ghostbsd|dragonflybsd|netbsd|openbsd|haiku|freedos|kolibrios|openindiana|reactos|batocera|slackware|slax|tinycore|slitaz|slint|easyos|netboot) return 0 ;;
		*) return 1 ;;
	esac
}

emit() { printf '%s\n' "$1"; }

cmd_create() {
	have quickget || { emit '{"phase":"error","message":"quickget is not installed"}'; exit 1; }
	local os="${1:-}" release="${2:-}" edition="${3:-}"
	[ -n "$os" ] && [ -n "$release" ] || { emit '{"phase":"error","message":"create needs <os> <release> [edition]"}'; exit 1; }
	mkdir -p "$vms_dir"; cd "$vms_dir"
	local name="$os-$release"; [ -n "$edition" ] && name="$name-$edition"
	[ -e "$vms_dir/$name.conf" ] && { emit "{\"phase\":\"error\",\"message\":\"$name already exists\"}"; exit 1; }

	local child="" stage=""
	# set +e in the handler: wait returns the killed child's non-zero status, which
	# under set -e would abort the trap before it cleans up and reports.
	trap 'set +e; [ -n "$child" ] && kill -TERM "$child" 2>/dev/null; wait "$child" 2>/dev/null; [ -n "$stage" ] && rm -rf "$stage"; emit "{\"phase\":\"cancelled\"}"; exit 130' TERM INT

	if ! create_special "$os" && have ryovm-fetch; then
		emit '{"phase":"resolve"}'
		local url base
		# `|| true`: no URL match must fall through to the quickget path, not
		# kill the whole engine under pipefail before any error JSON is emitted.
		url="$(quickget --url "$os" "$release" ${edition:+"$edition"} 2>/dev/null | grep -oE 'https?://[^ ]+' | head -1 || true)"
		base="${url##*/}"
		case "$base" in
			*.iso|*.img|*.ISO|*.IMG)
				stage="$vms_dir/.staging-$name"
				rm -rf "$stage"; mkdir -p "$stage"
				emit "{\"phase\":\"download\",\"name\":\"$name\"}"
				ryovm-fetch "$url" "$stage/$base" & child=$!
				local rc=0; wait "$child" || rc=$?; child=""
				[ "$rc" -eq 0 ] || { rm -rf "$stage"; emit '{"phase":"error","message":"download failed"}'; exit 1; }
				emit '{"phase":"config"}'
				quickget --create-config "$name" "$stage/$base" >/dev/null 2>&1 & child=$!
				local crc=0; wait "$child" || crc=$?; child=""
				[ "$crc" -eq 0 ] || { rm -rf "$stage"; emit '{"phase":"error","message":"could not write the VM config"}'; exit 1; }
				rm -rf "$stage"
				grep -q '^ryovm_os=' "$vms_dir/$name.conf" 2>/dev/null || echo "ryovm_os=\"$os\"" >>"$vms_dir/$name.conf"
				emit "{\"phase\":\"done\",\"name\":\"$name\"}"
				return 0 ;;
		esac
		# no single-file URL: fall through to quickget's own downloader.
	fi

	# fallback: quickget downloads + configures; stream its output as log lines
	# through a temp file that tail --pid follows until quickget exits. Snapshot
	# the conf set first: only a conf NEW since then counts as the result, so a
	# failed gnome build can never claim a pre-existing kde sibling as success.
	emit "{\"phase\":\"download\",\"name\":\"$name\",\"fallback\":true}"
	local before; before="$(ls "$vms_dir"/*.conf 2>/dev/null || true)"
	local logf; logf="$(mktemp)"
	setsid quickget "$os" "$release" ${edition:+"$edition"} >"$logf" 2>&1 & child=$!
	tail --pid="$child" -n +1 -f "$logf" 2>/dev/null | while IFS= read -r line; do
		[ -n "$line" ] && emit "$(jq -cn --arg l "$line" '{phase:"log",line:$l}')"
	done || true
	local rc=0; wait "$child" 2>/dev/null || rc=$?; child=""
	local lastline; lastline="$(tail -n1 "$logf" 2>/dev/null | tr -d '\r' || true)"
	rm -f "$logf"
	# stamp + report only what this run actually produced.
	local c made=""
	for c in "$vms_dir/$os-$release"*.conf; do
		[ -e "$c" ] || continue
		case "$before" in *"$c"*) continue ;; esac
		grep -q '^ryovm_os=' "$c" || echo "ryovm_os=\"$os\"" >>"$c"
		made="$(basename "$c" .conf)"
	done
	local g="" mi=""
	# a made config whose ISO never landed is a blocked or failed download
	# (Microsoft IP-gates Windows); clear the shell and report the real cause,
	# whatever quickget's exit code claimed, so the yard never lists a dead machine.
	if [ -n "$made" ]; then
		g="$(conf_get "$vms_dir/$made.conf" guest_os)"
		mi="$(conf_get "$vms_dir/$made.conf" iso)"
		case "$mi" in ""|/*) : ;; *) mi="$vms_dir/$mi" ;; esac
		if [ -n "$mi" ] && [ ! -f "$mi" ]; then
			# never rm a dir that holds a real disk; a blocked download has none.
			ls "${vms_dir:?}/${made:?}/"*.qcow2 >/dev/null 2>&1 || rm -rf "${vms_dir:?}/${made:?}"
			rm -f "${vms_dir:?}/${made:?}.conf"
			case "$g" in
				windows|windows-server)
					emit '{"phase":"error","message":"Windows downloads are blocked by Microsoft on this network.\nDownload the ISO from microsoft.com/software-download in a browser, then use Load ISO: drivers, TPM and Secure Boot are configured for you."}' ;;
				*)
					emit '{"phase":"error","message":"The install media did not download.\nTry again, or build from a local ISO with Load ISO."}' ;;
			esac
			exit 1
		fi
	fi
	if [ "$rc" -eq 0 ] && [ -n "$made" ]; then
		# quickget's per-VM virtio-win pull lands an anti-bot HTML stub; point the
		# machine at the shared, validated driver CD instead (fetched on demand by
		# `virtio`) so Windows setup finds the disk once the drivers land.
		case "$g" in
			windows|windows-server)
				rm -f "$vms_dir/$made/virtio-win.iso" 2>/dev/null
				if grep -qE '^fixed_iso=' "$vms_dir/$made.conf"; then
					sed -i -E "s|^fixed_iso=.*|fixed_iso=\"$(virtioWin)\"|" "$vms_dir/$made.conf"
				else
					echo "fixed_iso=\"$(virtioWin)\"" >>"$vms_dir/$made.conf"
				fi ;;
		esac
		emit "{\"phase\":\"done\",\"name\":\"$made\"}"
	else
		emit "$(jq -cn --arg m "download failed${lastline:+: $lastline}" '{phase:"error",message:$m}')"
		exit 1
	fi
}

# ---- import (any ISO, off-catalogue, full control) -------------------------
cmd_import() {
	local name="${1:?import needs a name}" iso="${2:?import needs an ISO path}" guest="${3:-linux}" os="${4:-}"
	[ -f "$iso" ] || die "ISO not found: $iso"
	mkdir -p "$vms_dir"
	local conf="$vms_dir/$name.conf"
	[ -e "$conf" ] && die "a VM named '$name' already exists"
	{
		echo "guest_os=\"$guest\""
		echo "disk_img=\"$name/disk.qcow2\""
		echo "iso=\"$iso\""
		echo "disk_size=\"64G\""
		# the guest type doubles as the logo slug when no catalogue OS is given
		# (windows/macos/android all have brand icons; linux falls back to a glyph).
		echo "ryovm_os=\"${os:-$guest}\""
	} >"$conf"
	# Windows ships no in-box virtio driver, so a plain ISO install finds no disk
	# without the driver CD; point it at the shared VirtIO CD (fetched on demand
	# by `virtio`). 11 also wants a TPM to pass setup; Secure Boot stays off since
	# Arch's edk2 has no MS-key vars, so on would reject the signed loader.
	case "$guest" in
		windows|windows-server)
			echo 'tpm="on"' >>"$conf"
			echo 'secureboot="off"' >>"$conf"
			echo "fixed_iso=\"$(virtioWin)\"" >>"$conf"
			;;
	esac
	echo "Created $conf"
}

# ---- virtio-win (Windows storage/network drivers) --------------------------
# Windows carries no virtio driver, so its installer needs the virtio-win CD to
# see a virtio disk or NIC. quickget pulls it per-VM from fedorapeople, which now
# sits behind an anti-bot wall that returns an HTML page in place of the ISO: a
# stub CD, and the installer finds no disk. We keep one validated copy in the
# image cache, shared by every Windows machine, from a mirror that serves bytes.
virtioWin() { printf '%s' "$(imagesDir)/virtio-win.iso"; }

# a real ISO9660 image carries "CD001" at 0x8001; an HTML stub or a truncated
# download does not. The size floor rejects a partial that happens to align.
valid_iso() {
	[ -f "$1" ] && [ "$(stat -c%s "$1" 2>/dev/null || echo 0)" -ge 52428800 ] \
		&& dd if="$1" bs=1 skip=32769 count=5 2>/dev/null | grep -q CD001
}

# fetch the driver CD into the cache once, validating the bytes; a mirror that
# serves them first, the fedorapeople origin as a last resort.
ensure_virtio_win() {
	local dst; dst="$(virtioWin)"
	valid_iso "$dst" && return 0
	mkdir -p "$(dirname "$dst")"
	local tmp="$dst.part" u
	for u in \
		"https://fedora-virt.repo.nfrance.com/virtio-win/direct-downloads/stable-virtio/virtio-win.iso" \
		"https://fedorapeople.org/groups/virt/virtio-win/direct-downloads/stable-virtio/virtio-win.iso"
	do
		rm -f "$tmp"
		if have ryovm-fetch; then ryovm-fetch "$u" "$tmp" 2>/dev/null
		else curl -fsSL -A "Mozilla/5.0" --retry 2 -o "$tmp" "$u" 2>/dev/null; fi
		valid_iso "$tmp" && { mv -f "$tmp" "$dst"; return 0; }
	done
	rm -f "$tmp"; return 1
}

# ryovm virtio          : ensure the shared driver CD exists and is real
# ryovm virtio <name>   : also point that VM's fixed_iso at it, replacing a stub
#                         a failed quickget download may have left in the VM dir.
cmd_virtio() {
	emit '{"phase":"download","name":"virtio-win"}'
	ensure_virtio_win || { emit '{"phase":"error","message":"could not fetch the VirtIO driver CD"}'; exit 1; }
	local vw; vw="$(virtioWin)"
	local name="${1:-}"
	if [ -n "$name" ]; then
		local conf; conf="$(conf_path "$name")"
		vm_paths "$conf"
		rm -f "$vm_subdir/virtio-win.iso" 2>/dev/null
		if grep -qE '^fixed_iso=' "$conf"; then
			sed -i -E "s|^fixed_iso=.*|fixed_iso=\"$vw\"|" "$conf"
		else
			echo "fixed_iso=\"$vw\"" >>"$conf"
		fi
	fi
	emit "$(jq -cn --arg p "$vw" '{phase:"done",iso:$p}')"
}

# ---- instant (a prebuilt cloud image, no installer) ------------------------
# The Kali/Vagrant model: distros publish qcow2 images that are ALREADY
# installed. ryovm fetches one (cached + shared), makes a thin copy-on-write
# overlay, and attaches a cloud-init "cidata" seed that bakes in the Ryoku burn
# account (ryoku/ryoku + the burn key + passwordless sudo) on first boot. No
# 14-step installer, ssh-able in under a minute. quickget deliberately excludes
# cloud images, so the catalogue is ours.
imagesDir() { printf '%s' "$vms_dir/.images"; }
burnKey()   { printf '%s' "${XDG_DATA_HOME:-$HOME/.local/share}/ryoku/keys/ryovm"; }

# ensure the burn keypair exists (ed25519, no passphrase): the identity the app
# logs into every burn/instant machine with.
ensure_burn_key() {
	local k; k="$(burnKey)"
	[ -f "$k" ] && return 0
	mkdir -p "$(dirname "$k")"
	ssh-keygen -t ed25519 -N "" -C "ryovm-burn" -f "$k" -q 2>/dev/null || die "could not create the burn key"
}

# the curated cloud-image catalogue: os slug -> qcow2 url (or a fedora-style
# resolver), the image's own default login, and whether the guest needs sudo
# installed for the burn account. Every URL is a rolling "latest" pointer so it
# never goes stale. Sizes are the download, not the (auto-grown) virtual disk.
cloud_catalog() {
	cat <<-'JSON'
	[
	 {"os":"ubuntu","name":"Ubuntu 24.04 LTS","user":"ubuntu","size":"593M","sudo":false,
	  "url":"https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"},
	 {"os":"debian","name":"Debian 13","user":"debian","size":"325M","sudo":false,
	  "url":"https://cloud.debian.org/images/cloud/trixie/latest/debian-13-genericcloud-amd64.qcow2"},
	 {"os":"fedora","name":"Fedora Cloud","user":"fedora","size":"557M","sudo":false,
	  "resolve":"fedora"},
	 {"os":"archlinux","name":"Arch Linux","user":"arch","size":"559M","sudo":false,
	  "url":"https://geo.mirror.pkgbuild.com/images/latest/Arch-Linux-x86_64-cloudimg.qcow2"},
	 {"os":"alpine","name":"Alpine Linux","user":"alpine","size":"175M","sudo":true,
	  "url":"https://dl-cdn.alpinelinux.org/alpine/v3.24/releases/cloud/generic_alpine-3.24.1-x86_64-uefi-cloudinit-r0.qcow2"},
	 {"os":"opensuse","name":"openSUSE Tumbleweed","user":"opensuse","size":"293M","sudo":false,
	  "url":"https://download.opensuse.org/tumbleweed/appliances/openSUSE-Tumbleweed-Minimal-VM.x86_64-Cloud.qcow2"},
	 {"os":"rocky","name":"Rocky Linux 10","user":"rocky","size":"545M","sudo":false,
	  "url":"https://dl.rockylinux.org/pub/rocky/10/images/x86_64/Rocky-10-GenericCloud-Base.latest.x86_64.qcow2"},
	 {"os":"alma","name":"AlmaLinux 10","user":"almalinux","size":"573M","sudo":false,
	  "url":"https://repo.almalinux.org/almalinux/10/cloud/x86_64/images/AlmaLinux-10-GenericCloud-latest.x86_64.qcow2"}
	]
	JSON
}
cmd_cloud_catalog() { cloud_catalog; }

# resolve a catalogue entry's real qcow2 URL. Most are direct rolling pointers;
# Fedora embeds the respin in the filename, so it's resolved via releases.json.
cloud_resolve_url() { # $1 = entry json
	local e="$1" r
	r="$(printf '%s' "$e" | jq -r '.resolve // empty')"
	if [ "$r" = "fedora" ]; then
		curl -fsSL "https://fedoraproject.org/releases.json" 2>/dev/null \
			| jq -r 'map(select(.arch=="x86_64" and .variant=="Cloud" and (.link|endswith(".qcow2")) and (.link|contains("Generic")) and (.link|contains("UKI")|not))) | sort_by(.version) | last | .link' 2>/dev/null
		return
	fi
	printf '%s' "$e" | jq -r '.url'
}

# ---- toolset: cross-distro dev tools baked in by cloud-init ------------------
# The user picks tools (git, node, docker, ...); the seed installs them on first
# boot with the target distro's own package names. cloud-init's packages: module
# dispatches to apt/dnf/pacman/apk/zypper by name; runcmd: handles the rest
# (docker service + group, rustup, spice-vdagent). Heavy tools re-install on
# every DISPOSABLE boot (minutes) — the golden template (template/spawn) bakes
# them once and is the right home for a disposable-with-tools workflow.

# os slug -> package family.
pkg_family() {
	case "$1" in
		ubuntu|debian) echo apt ;;
		fedora)        echo dnf-fedora ;;
		rocky|alma)    echo dnf-rhel ;;
		archlinux)     echo pacman ;;
		alpine)        echo apk ;;
		opensuse)      echo zypper ;;
		*)             echo apt ;;
	esac
}

# packages for one tool on one family (space-separated; empty = runcmd-only).
tool_pkgs() { # $1 tool  $2 family
	case "$1:$2" in
		git:*)          echo git ;;
		build:apt)      echo build-essential ;;
		build:pacman)   echo base-devel ;;
		build:apk)      echo build-base ;;
		build:*)        echo gcc gcc-c++ make ;;
		python:apt)     echo python3 python3-pip python3-venv ;;
		python:apk)     echo python3 py3-pip ;;
		python:pacman)  echo python python-pip ;;
		python:*)       echo python3 python3-pip ;;
		node:zypper)    echo nodejs-default npm-default ;;
		node:*)         echo nodejs npm ;;
		go:apt)         echo golang-go ;;
		go:dnf-fedora|go:dnf-rhel) echo golang ;;
		go:*)           echo go ;;
		rust:apt)       echo rustc cargo ;;
		rust:pacman)    echo rust ;;
		rust:*)         echo rust cargo ;;
		docker:apt)     echo docker.io docker-compose-v2 ;;
		docker:dnf-fedora) echo moby-engine docker-compose ;;
		docker:pacman)  echo docker docker-compose docker-buildx ;;
		docker:apk)     echo docker docker-cli-compose ;;
		docker:zypper)  echo docker docker-compose ;;
		docker:dnf-rhel) echo ;;                    # repo-added in runcmd
		podman:*)       echo podman ;;
		jq:*)           echo jq ;;
		net:*)          echo curl wget ;;
		cli:apt|cli:dnf-fedora|cli:dnf-rhel) echo htop tmux vim ripgrep fd-find unzip ;;
		cli:*)          echo htop tmux vim ripgrep fd unzip ;;
		spice:*)        echo spice-vdagent qemu-guest-agent ;;
	esac
}

# runcmd YAML list-items for one tool on one family (each printed line "  - ...").
tool_runcmd() { # $1 tool  $2 family
	case "$1:$2" in
		docker:apk)
			printf '  - rc-update add docker default\n  - rc-service docker start\n  - addgroup ryoku docker\n' ;;
		docker:dnf-rhel)
			printf '  - dnf -y install dnf-plugins-core\n'
			printf '  - dnf config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo\n'
			printf '  - dnf -y install docker-ce docker-ce-cli containerd.io docker-compose-plugin\n'
			printf '  - systemctl enable --now docker\n  - groupadd -f docker\n  - usermod -aG docker ryoku\n' ;;
		docker:*)
			printf '  - systemctl enable --now docker\n  - groupadd -f docker\n  - usermod -aG docker ryoku\n' ;;
		rustup:*)
			printf "  - [ su, -l, ryoku, -c, \"curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y\" ]\n" ;;
		spice:apk)
			printf '  - rc-update add spice-vdagentd default\n  - rc-service spice-vdagentd start\n' ;;
		spice:*)
			printf '  - systemctl enable --now spice-vdagentd\n' ;;
	esac
}

# build the cidata seed ISO for a VM: a cloud-init NoCloud payload that creates
# the ryoku burn account (password ryoku, passwordless sudo, the burn key + any
# host keys), bakes the OSC-52 `clip` helper, and installs the chosen toolset.
# Re-read on every disposable boot (the overlay resets), applied once on a
# persistent one. The volid MUST be cidata.
write_seed() { # $1=dir $2=name $3=want_sudo $4=os $5=tools_csv $6=extra_csv $7=want_base
	local dir="$1" name="$2" want_sudo="$3" os="${4:-}" tools_csv="${5:-}" extra_csv="${6:-}" want_base="${7:-true}"
	ensure_burn_key
	local keys; keys="$(printf '      - %s\n' "$(cat "$(burnKey).pub")")"
	local k
	for k in "$HOME"/.ssh/id_*.pub; do
		[ -f "$k" ] && keys="$keys"$'\n'"$(printf '      - %s' "$(cat "$k")")"
	done

	# resolve the toolset to packages: + runcmd: for this distro. Each cloud-init
	# packages: item must be ONE package (a "- nodejs npm" line installs nothing),
	# so split the CSV tool list with read -ra (comma) and keep the inner package
	# split on the default IFS (space). $() strips a block's trailing newline, so
	# re-add one between runcmd blocks or they merge.
	local fam; fam="$(pkg_family "$os")"
	local pkg_lines="" run_lines="" t p rc
	[ "$want_sudo" = true ] && pkg_lines="  - sudo"$'\n'
	local tools_arr extra_arr
	IFS=',' read -ra tools_arr <<<"$tools_csv"
	for t in "${tools_arr[@]}"; do
		[ -n "$t" ] || continue
		for p in $(tool_pkgs "$t" "$fam"); do pkg_lines="$pkg_lines  - $p"$'\n'; done
		rc="$(tool_runcmd "$t" "$fam")"
		[ -n "$rc" ] && run_lines="$run_lines$rc"$'\n'
	done
	IFS=',' read -ra extra_arr <<<"$extra_csv"
	for p in "${extra_arr[@]}"; do
		p="$(printf '%s' "$p" | tr -d ' ')"
		[ -n "$p" ] && pkg_lines="$pkg_lines  - $p"$'\n'
	done

	# bash-completion is always baked into a provisioned machine: every cloud
	# image ships bash but no programmable completion, so <tab> feels dead next
	# to a real desktop (git subcommands, service names, package names — nothing
	# completes). It's tiny and universally wanted. Alpine's login shell is ash,
	# so it also needs bash itself for the completion to have a shell to load in.
	# A spawn (want_base=false) inherits it from its template's base and keeps the
	# refresh seed empty so it still boots in seconds.
	if [ "$want_base" = true ]; then
		case "$fam" in
			apk) pkg_lines="$pkg_lines  - bash"$'\n'"  - bash-completion"$'\n' ;;
			*)   pkg_lines="$pkg_lines  - bash-completion"$'\n' ;;
		esac
	fi

	# shellcheck disable=SC2016  # printf emits a literal script; $vars must not expand here
	{
		printf '#cloud-config\n'
		printf 'hostname: %s\n' "$name"
		printf 'ssh_pwauth: true\n'
		# a fresh index is required before any install (apt 404s, pacman needs -Sy).
		if [ -n "$pkg_lines" ] || [ -n "$run_lines" ]; then printf 'package_update: true\n'; else printf 'package_update: false\n'; fi
		printf 'package_upgrade: false\n'
		printf 'chpasswd:\n  expire: false\n'
		printf 'users:\n'
		printf '  - name: ryoku\n'
		printf '    plain_text_passwd: ryoku\n'
		printf '    lock_passwd: false\n'
		printf '    sudo: "ALL=(ALL) NOPASSWD:ALL"\n'
		printf '    groups: [wheel, adm, sudo]\n'
		printf '    ssh_authorized_keys:\n'
		printf '%s\n' "$keys"
		# the clip helper: copy stdin to the HOST clipboard over the ssh terminal
		# via OSC 52 (kitty writes it). No package cost; always baked.
		printf 'write_files:\n'
		printf '  - path: /usr/local/bin/clip\n'
		printf '    permissions: "0755"\n'
		printf '    content: |\n'
		printf '      #!/bin/sh\n'
		printf '      b64=$(base64 2>/dev/null | tr -d "\\n")\n'
		printf '      if [ -n "$TMUX" ]; then printf "\\033Ptmux;\\033\\033]52;c;%%s\\007\\033\\\\" "$b64" > /dev/tty\n'
		printf '      else printf "\\033]52;c;%%s\\007" "$b64" > /dev/tty; fi\n'
		if [ -n "$pkg_lines" ]; then printf 'packages:\n%s' "$pkg_lines"; fi
		if [ -n "$run_lines" ]; then printf 'runcmd:\n%s' "$run_lines"; fi
	} >"$dir/user-data"
	# bumping instance-id forces cloud-init to re-run on a reused disk.
	printf 'instance-id: iid-%s-%s\nlocal-hostname: %s\n' "$name" "$(date +%s)" "$name" >"$dir/meta-data"
	iso_build "$dir/seed.iso" "$dir/user-data" "$dir/meta-data" || return 1
}

# build a cidata ISO with whatever tool is installed. xorriso is in the Arch
# repos (libisoburn); genisoimage/mkisofs come from cdrtools (AUR). The volid
# MUST be cidata — that's the only thing cloud-init's NoCloud datasource scans.
iso_build() { # $1 = out.iso, $2.. = files
	local out="$1"; shift
	if have genisoimage; then
		genisoimage -quiet -output "$out" -volid cidata -joliet -rock "$@" 2>/dev/null
	elif have xorriso; then
		xorriso -as mkisofs -quiet -o "$out" -V cidata -J -r "$@" >/dev/null 2>&1
	elif have mkisofs; then
		mkisofs -quiet -output "$out" -volid cidata -joliet -rock "$@" 2>/dev/null
	else
		return 1
	fi
}
have_iso_builder() { have genisoimage || have xorriso || have mkisofs; }

cmd_instant() {
	local os="" name="" disposable="" sealme="" tools="" extra="" a
	for a in "$@"; do
		case "$a" in
			--disposable) disposable=1 ;;
			--sealed)     sealme=1 ;;
			--tools=*)    tools="${a#--tools=}" ;;
			--pkgs=*)     extra="${a#--pkgs=}" ;;
			*) [ -z "$os" ] && os="$a" || name="$a" ;;
		esac
	done
	# the clip helper is always baked; spice-vdagent gives console clipboard.
	# both are cheap; a user who wants nothing else still gets clipboard.
	[ -n "$os" ] || { emit '{"phase":"error","message":"instant needs an OS (e.g. debian)"}'; exit 1; }
	have_iso_builder || { emit '{"phase":"error","message":"no ISO builder — install xorriso: sudo pacman -S libisoburn"}'; exit 1; }
	have qemu-img || { emit '{"phase":"error","message":"qemu-img is missing"}'; exit 1; }

	local entry; entry="$(cloud_catalog | jq -c --arg q "$os" 'first(.[] | select(.os==$q))')"
	[ -n "$entry" ] && [ "$entry" != null ] || { emit "{\"phase\":\"error\",\"message\":\"no cloud image named '$os'\"}"; exit 1; }
	[ -z "$name" ] && name="$os-instant"
	mkdir -p "$vms_dir"
	[ -e "$vms_dir/$name.conf" ] && { emit "{\"phase\":\"error\",\"message\":\"$name already exists\"}"; exit 1; }

	local want_sudo; want_sudo="$(printf '%s' "$entry" | jq -r '.sudo')"
	local url; url="$(cloud_resolve_url "$entry")"
	[ -n "$url" ] || { emit '{"phase":"error","message":"could not resolve the image URL"}'; exit 1; }

	# cache the base image once, shared by every instant/spawn off this OS.
	mkdir -p "$(imagesDir)"
	local base; base="$(imagesDir)/$os-cloud.qcow2"
	local child="" sub=""
	trap 'set +e; [ -n "$child" ] && kill -TERM "$child" 2>/dev/null; wait "$child" 2>/dev/null; rm -f "$base.part"; [ -n "$sub" ] && rm -rf "$sub"; emit "{\"phase\":\"cancelled\"}"; exit 130' TERM INT
	if [ ! -s "$base" ]; then
		emit "{\"phase\":\"download\",\"name\":\"$name\"}"
		if have ryovm-fetch; then
			ryovm-fetch "$url" "$base.part" & child=$!
			local rc=0; wait "$child" || rc=$?; child=""
			[ "$rc" -eq 0 ] || { rm -f "$base.part"; emit '{"phase":"error","message":"image download failed"}'; exit 1; }
		else
			curl -fL --retry 3 -o "$base.part" "$url" 2>/dev/null || { rm -f "$base.part"; emit '{"phase":"error","message":"image download failed"}'; exit 1; }
		fi
		mv "$base.part" "$base"
	fi

	emit '{"phase":"config"}'
	sub="$vms_dir/$name"; mkdir -p "$sub"
	# a thin copy-on-write overlay over the read-only cached base, grown to a
	# usable size (cloud-init's growpart expands the rootfs on first boot).
	qemu-img create -f qcow2 -F qcow2 -b "$base" "$sub/disk.qcow2" 32G >/dev/null 2>&1 \
		|| { rm -rf "$sub"; emit '{"phase":"error","message":"could not create the disk overlay"}'; exit 1; }
	write_seed "$sub" "$name" "$want_sudo" "$os" "$tools" "$extra" \
		|| { rm -rf "$sub"; emit '{"phase":"error","message":"could not build the cloud-init seed"}'; exit 1; }

	# quickemu conf: point at the overlay, attach the seed as a read-only cdrom
	# via extra_args (a first-class conf key), and set preallocation so quickemu
	# does not mistake the tiny fresh overlay for an unused disk and refuse.
	{
		echo "guest_os=\"linux\""
		echo "disk_img=\"$name/disk.qcow2\""
		echo "preallocation=\"metadata\""
		echo "extra_args=\"-drive file=$sub/seed.iso,media=cdrom,readonly=on\""
		echo "ryovm_os=\"$os\""
		echo "ryovm_ssh_user=\"ryoku\""
		echo "ryovm_burn=\"1\""
		[ -n "$tools" ] && echo "ryovm_tools=\"$tools\""
	} >"$vms_dir/$name.conf"
	[ -n "$sealme" ] && echo 'ryovm_sealed="1"' >>"$vms_dir/$name.conf"

	trap - TERM INT
	# seal the pristine cloud state so restore-seal returns here.
	if [ -n "$sealme" ]; then
		qemu-img snapshot -c sealed "$sub/disk.qcow2" >/dev/null 2>&1 || true
	fi
	emit "{\"phase\":\"done\",\"name\":\"$name\"}"
	# auto-launch: instant means instant.
	if [ -n "$disposable" ]; then
		cmd_launch "$name" headless --disposable >/dev/null 2>&1 || true
	else
		cmd_launch "$name" headless >/dev/null 2>&1 || true
	fi
}

# ---- template / spawn (golden image: bake tools once, spawn fast) -----------
# The disposable-with-tools answer. A disposable re-runs cloud-init every boot,
# so heavy tools would reinstall each time. Instead: build ONE machine with the
# toolset (a keeper instant, tools installed on its first boot), template it
# (flatten to an immutable base), then spawn thin overlays that inherit the
# tools read-only and boot in seconds — disposable or not.
templatesDir() { printf '%s' "$(imagesDir)/templates"; }

cmd_template() {
	local src="${1:?template needs a source VM}" tpl="${2:-$1}"
	local conf; conf="$(conf_path "$src")"
	vm_paths "$conf"
	vm_running "$vm_pid" && die "stop $src before templating it"
	[ -e "$vm_disk" ] || die "$src has no disk yet"
	mkdir -p "$(templatesDir)"
	local out; out="$(templatesDir)/$tpl.qcow2"
	[ -e "$out" ] && die "a template named '$tpl' already exists"
	# flatten the distro-base + this VM's deltas into one standalone qcow2, then
	# freeze it read-only: every spawn overlays this file, and a mutable base
	# would corrupt its children the moment the source booted again.
	local child=""
	trap 'set +e; [ -n "$child" ] && kill -TERM "$child" 2>/dev/null; wait "$child" 2>/dev/null; rm -f "$out.part"; exit 130' TERM INT
	qemu-img convert -O qcow2 "$vm_disk" "$out.part" & child=$!
	wait "$child" || { child=""; rm -f "$out.part"; trap - TERM INT; die "could not build the template"; }
	child=""; trap - TERM INT
	mv "$out.part" "$out"; chmod 0444 "$out"
	jq -cn --arg os "$(conf_get "$conf" ryovm_os)" --arg tools "$(conf_get "$conf" ryovm_tools)" \
		--arg base "$out" '{os:$os,tools:$tools,base:$base}' >"$(templatesDir)/$tpl.json"
	echo "templated $src as '$tpl'"
}

cmd_templates() {
	mkdir -p "$(templatesDir)"
	local first=1 m
	printf '['
	for m in "$(templatesDir)"/*.json; do
		[ -e "$m" ] || continue
		[ $first -eq 1 ] && first=0 || printf ','
		jq -c --arg name "$(basename "$m" .json)" '. + {name:$name}' "$m"
	done
	printf ']\n'
}

cmd_spawn() {
	local tpl="" name="" disposable="" a
	for a in "$@"; do
		case "$a" in
			--disposable) disposable=1 ;;
			*) [ -z "$tpl" ] && tpl="$a" || name="$a" ;;
		esac
	done
	[ -n "$tpl" ] || { emit '{"phase":"error","message":"spawn needs a template"}'; exit 1; }
	local meta; meta="$(templatesDir)/$tpl.json"
	[ -f "$meta" ] || { emit "{\"phase\":\"error\",\"message\":\"no template '$tpl'\"}"; exit 1; }
	local base os; base="$(jq -r .base "$meta")"; os="$(jq -r .os "$meta")"
	[ -s "$base" ] || { emit '{"phase":"error","message":"template base is missing"}'; exit 1; }
	[ -n "$name" ] || name="$tpl-$(date +%s | tail -c 5)"
	mkdir -p "$vms_dir"
	[ -e "$vms_dir/$name.conf" ] && { emit "{\"phase\":\"error\",\"message\":\"$name already exists\"}"; exit 1; }
	emit '{"phase":"config"}'
	local sub="$vms_dir/$name"; mkdir -p "$sub"
	qemu-img create -f qcow2 -F qcow2 -b "$base" "$sub/disk.qcow2" 32G >/dev/null 2>&1 \
		|| { rm -rf "$sub"; emit '{"phase":"error","message":"overlay failed"}'; exit 1; }
	# the tools + ryoku account (and bash-completion) are already baked into the
	# base; the spawn needs no packages: seed. A tiny seed only refreshes the
	# hostname/instance so cloud-init settles quickly. want_base=false keeps it
	# empty so the clone still boots in seconds. ssh identity stays burn policy.
	write_seed "$sub" "$name" false "$os" "" "" false \
		|| { rm -rf "$sub"; emit '{"phase":"error","message":"seed failed"}'; exit 1; }
	{
		echo "guest_os=\"linux\""
		echo "disk_img=\"$name/disk.qcow2\""
		echo "preallocation=\"metadata\""
		echo "extra_args=\"-drive file=$sub/seed.iso,media=cdrom,readonly=on\""
		echo "ryovm_os=\"$os\""
		echo "ryovm_ssh_user=\"ryoku\""
		echo "ryovm_burn=\"1\""
		echo "ryovm_template=\"$tpl\""
	} >"$vms_dir/$name.conf"
	emit "{\"phase\":\"done\",\"name\":\"$name\"}"
	if [ -n "$disposable" ]; then
		cmd_launch "$name" headless --disposable >/dev/null 2>&1 || true
	else
		cmd_launch "$name" headless >/dev/null 2>&1 || true
	fi
}

# ---- launch ----------------------------------------------------------------
# Detach so the engine returns at once and the VM (and any viewer) outlives it.
# display: window (gtk) | spice (spicy viewer + clipboard) | headless (none).
# --disposable runs the session on quickemu's --status-quo (qemu -snapshot):
# every disk write lands in a temp overlay and burns up at power-off, so a
# sealed machine boots identical every time. A marker file beside the pid lets
# list/get report the mode while it runs.
cmd_launch() {
	require_engine
	local conf; conf="$(conf_path "$1")"
	local mode="${2:-window}" display disposable=""
	[ "${3:-}" = "--disposable" ] && disposable=1
	case "$mode" in
		window)   display="gtk" ;;
		spice)    display="spice" ;;
		headless) display="none" ;;
		*) die "launch display must be window|spice|headless" ;;
	esac
	vm_paths "$conf"
	vm_running "$vm_pid" && die "$vm_name is already running"
	# an uninstalled machine boots from its ISO; if that download never finished,
	# quickemu aborts with a raw qemu "Could not open" line. Say it plainly.
	local isoref diskref
	isoref="$(conf_get "$conf" iso)"; diskref="$(conf_get "$conf" disk_img)"
	if [ -n "$isoref" ]; then
		case "$isoref" in /*) : ;; *) isoref="$vms_dir/$isoref" ;; esac
		case "$diskref" in ""|/*) : ;; *) diskref="$vms_dir/$diskref" ;; esac
		{ [ -f "$isoref" ] || { [ -n "$diskref" ] && [ -f "$diskref" ]; }; } \
			|| die "$vm_name has no install media: its ISO never finished downloading. Re-create the machine, or import an ISO from disk."
	fi
	# quickemu sources the conf after parsing --display, so the conf's display=
	# overrides the flag; sync the requested mode into the conf first, else a
	# headless or spice launch silently opens the conf's window instead.
	if ! grep -qxE "display=\"$display\"" "$conf"; then
		if grep -qE '^display=' "$conf"; then
			sed -i -E "s|^display=.*|display=\"$display\"|" "$conf"
		else
			printf 'display="%s"\n' "$display" >>"$conf"
		fi
	fi
	cd "$vms_dir"
	local log="$vm_subdir/$vm_name.launch.log"
	mkdir -p "$vm_subdir"
	# --viewer none for the non-SPICE modes: quickemu validates its default
	# viewer (spicy) even when the display never uses one, so a box without
	# spice-gtk could not launch a plain gtk window or a headless machine.
	local viewer=()
	[ "$display" != "spice" ] && viewer=(--viewer none)
	local extra=()
	if [ -n "$disposable" ]; then
		extra+=(--status-quo)
		: > "$vm_subdir/$vm_name.disposable"
	else
		rm -f "$vm_subdir/$vm_name.disposable"
	fi
	setsid quickemu --vm "$vm_name.conf" --display "$display" "${viewer[@]}" "${extra[@]}" >"$log" 2>&1 < /dev/null &
	local qpid=$!
	# poll for readiness instead of one fixed beat: a slow first boot (qcow2
	# creation, EFI vars) takes longer than any constant, and calling it a
	# failure while the window then appears makes the board contradict itself.
	# Fail only when quickemu itself has died AND no pid file ever appeared;
	# the first line of the die() carries the cause (the UI keeps line one).
	for _ in $(seq 1 32); do
		vm_running "$vm_pid" && break
		kill -0 "$qpid" 2>/dev/null || break
		sleep 0.25
	done
	if ! vm_running "$vm_pid" && ! kill -0 "$qpid" 2>/dev/null; then
		die "the VM failed to start: $(tail -n1 "$log" 2>/dev/null)
$(tail -n 12 "$log" 2>/dev/null)"
	fi
	echo "launched $vm_name ($mode)"
}

# ---- console (attach a SPICE viewer to a running VM) -----------------------
cmd_console() {
	local conf; conf="$(conf_path "$1")"
	vm_paths "$conf"
	vm_running "$vm_pid" || die "$vm_name is not running"
	local spice; spice="$(spice_target "$vm_ports" "$vm_subdir")"
	[ -n "$spice" ] || die "$vm_name has no SPICE console; relaunch it in SPICE or Headless mode"
	local viewer
	case "$spice" in
		unix:*)
			local sock="${spice#unix:}"
			if have spicy; then viewer=(spicy --title "$vm_name" --uri="spice+unix://$sock")
			elif have remote-viewer; then viewer=(remote-viewer "spice+unix://$sock")
			else die "no SPICE viewer found (install spice-gtk)"; fi ;;
		*)
			if have spicy; then viewer=(spicy --title "$vm_name" --port "$spice")
			elif have remote-viewer; then viewer=(remote-viewer "spice://localhost:$spice")
			else die "no SPICE viewer found (install spice-gtk)"; fi ;;
	esac
	setsid "${viewer[@]}" >/dev/null 2>&1 < /dev/null &
	echo "console opened for $vm_name"
}

# ---- stop ------------------------------------------------------------------
# Graceful first: press the ACPI power button over the QEMU monitor socket and
# give the guest up to 20s to shut down clean. A SIGKILL'd qemu loses the
# guest's unflushed writes and can leave the qcow2 with leaked clusters — a
# machine provisioned seconds before a hard stop came back missing files.
# --force (or a guest that ignores ACPI, or no monitor) still kills.
cmd_stop() {
	require_engine
	local conf; conf="$(conf_path "$1")"
	local force="${2:-}"
	vm_paths "$conf"
	cd "$vms_dir"
	if [ "$force" != "--force" ] && vm_running "$vm_pid" && [ -S "$vm_subdir/$vm_name-monitor.socket" ] && have python3; then
		python3 -c 'import socket,sys,time; s=socket.socket(socket.AF_UNIX); s.settimeout(2); s.connect(sys.argv[1]); time.sleep(0.2); s.sendall(b"system_powerdown\n"); time.sleep(0.3)' \
			"$vm_subdir/$vm_name-monitor.socket" >/dev/null 2>&1 || true
		for _ in $(seq 1 80); do
			vm_running "$vm_pid" || { echo "stopped $vm_name (clean shutdown)"; return 0; }
			sleep 0.25
		done
	fi
	quickemu --vm "$vm_name.conf" --kill >/dev/null 2>&1 || true
	# don't return while qemu still holds the image lock: a seal or snapshot
	# issued right after "stopped" would race the dying process and fail.
	for _ in $(seq 1 20); do
		vm_running "$vm_pid" || break
		sleep 0.25
	done
	echo "stopped $vm_name"
}

# ---- config (edit one scalar key) ------------------------------------------
cmd_config() {
	local conf; conf="$(conf_path "$1")"
	local key="${2:?config needs a key}" val="${3-}"
	case "$key" in
		cpu_cores|ram|disk_size|display|guest_os|secureboot|tpm|iso|ryovm_os|ryovm_ssh_user|ryovm_burn) ;;
		*) die "config key not allowed: $key" ;;
	esac
	vm_paths "$conf"
	vm_running "$vm_pid" && die "stop $vm_name before changing its configuration"
	if [ "$val" = "auto" ] || [ -z "$val" ]; then
		sed -i -E "/^$key=/d" "$conf"
		echo "cleared $key on $vm_name"
	elif grep -qE "^$key=" "$conf"; then
		sed -i -E "s|^$key=.*|$key=\"$val\"|" "$conf"
		echo "set $key=$val on $vm_name"
	else
		echo "$key=\"$val\"" >>"$conf"
		echo "set $key=$val on $vm_name"
	fi
}

# ---- snapshot --------------------------------------------------------------
cmd_snapshot() {
	local conf; conf="$(conf_path "$1")"; shift
	local sub="${1:?snapshot needs list|create|restore|delete}"; shift || true
	vm_paths "$conf"
	[ -e "$vm_disk" ] || die "$vm_name has no disk yet; launch it once first"
	case "$sub" in
		list)
			snaps_json "$vm_disk"; echo ;;
		create|restore|delete)
			local tag="${1:?$sub needs a tag}"
			vm_running "$vm_pid" && die "stop $vm_name before managing snapshots"
			case "$sub" in
				create)  qemu-img snapshot -c "$tag" "$vm_disk" && echo "snapshot '$tag' created" ;;
				restore) qemu-img snapshot -a "$tag" "$vm_disk" && echo "restored '$tag'" ;;
				delete)  qemu-img snapshot -d "$tag" "$vm_disk" && echo "deleted '$tag'" ;;
			esac ;;
		*) die "unknown snapshot subcommand: $sub" ;;
	esac
}

# ---- ssh -------------------------------------------------------------------
# Every VM forwards its guest :22 onto the same small host-port range, so the
# global known_hosts collides the moment a second machine answers on a port a
# first one once used — "REMOTE HOST IDENTIFICATION HAS CHANGED" against your
# own VM. Each machine gets its own known-hosts file beside its disk instead,
# with accept-new so the first connect just works and a genuinely changed key
# still fails loudly.
cmd_ssh() {
	local conf; conf="$(conf_path "$1")"
	vm_paths "$conf"
	vm_running "$vm_pid" || die "$vm_name is not running"
	local port; port="$(port_of "$vm_ports" ssh)"
	[ -n "$port" ] || die "$vm_name has no forwarded SSH port"
	# the guest account rarely has to match the host user: ryovm_ssh_user in
	# the conf pins the login (config verb sets it); host username is only the
	# fallback guess.
	local user; user="$(conf_get "$conf" ryovm_ssh_user)"
	local ident=""; [ -f "$(burnKey)" ] && ident="-i $(burnKey) "
	# host-key policy: an installed machine has a stable identity, pinned to its
	# own known_hosts (accept-new). A burn/cloud machine REGENERATES its host key
	# on every boot (cloud-init), so pinning it would reject the very next
	# disposable boot as a changed host — a throwaway has no identity to verify,
	# so accept anything and store nothing.
	local hostpol
	if [ "$(conf_get "$conf" ryovm_burn)" = "1" ]; then
		hostpol="-o UserKnownHostsFile=/dev/null -o StrictHostKeyChecking=no -o LogLevel=ERROR"
	else
		hostpol="-o UserKnownHostsFile=$vm_subdir/$vm_name.known_hosts -o StrictHostKeyChecking=accept-new"
	fi
	# TERM=xterm-256color: a booting/minimal guest has no terminfo for
	# xterm-kitty (or foot/wezterm/...), so clear/less/vim would die with
	# "unknown terminal type". Advertise the one every guest ships.
	# `env TERM=...` not a bare `TERM=...` prefix: the app runs this via an
	# unquoted $cmd, and a shell assignment prefix is only honoured in literal
	# command syntax, never from an expansion (it'd try to run the assignment as
	# a command — exit 127). env is a real binary, so it works everywhere: the
	# app's $cmd, a pasted copy, and a bare CLI invocation.
	echo "env TERM=xterm-256color ssh $hostpol -o ConnectTimeout=8 ${ident}-p $port ${user:-${SUDO_USER:-$USER}}@localhost"
}

# ---- delete ----------------------------------------------------------------
# No require_engine: deleting is file removal, and a box that imported a
# machine before installing the engine must be able to remove it again. The
# quickemu calls are best-effort tidying; the rm fallbacks are the guarantee.
cmd_delete() {
	local conf; conf="$(conf_path "$1")"
	vm_paths "$conf"
	vm_running "$vm_pid" && die "stop $vm_name before deleting it"
	cd "$vms_dir"
	if [ "${2:-}" = "--disk-only" ]; then
		have quickemu && quickemu --vm "$vm_name.conf" --delete-disk >/dev/null 2>&1 || true
		rm -f "$vm_disk"
		echo "reclaimed the disk for $vm_name"
	else
		have quickemu && quickemu --vm "$vm_name.conf" --delete-vm >/dev/null 2>&1 || true
		[ -d "$vm_subdir" ] && [ "$vm_subdir" != "$vms_dir" ] && rm -rf "$vm_subdir"
		rm -f "$conf"
		echo "deleted $vm_name"
	fi
}

# ---- rename ----------------------------------------------------------------
# Rename a VM: its conf, the per-VM subdir (the quickget/import layout), the
# runtime files named after it, and any disk_img/iso path that pointed into the
# old subdir. A non-standard disk_img (absolute, or outside the subdir) keeps
# its path; only the conf is renamed.
cmd_rename() {
	local old="${1:?rename needs <old> <new>}" new="${2:?rename needs <old> <new>}"
	case "$new" in *[/\ ]*|"") die "invalid name: '$new'" ;; esac
	local conf; conf="$(conf_path "$old")"
	vm_paths "$conf"
	vm_running "$vm_pid" && die "stop $old before renaming it"
	[ -e "$vms_dir/$new.conf" ] && die "a VM named '$new' already exists"
	# repoint any disk_img/iso relative to the old subdir before moving anything,
	# so a bad substitution fails before a single file is touched (# delimiter:
	# the pattern itself carries / and the (disk_img|iso) alternation).
	sed -i -E "s#^((disk_img|iso)=\")$old/#\1$new/#" "$conf"
	if [ -d "$vms_dir/$old" ]; then
		[ -e "$vms_dir/$new" ] && die "$vms_dir/$new already exists"
		mv "$vms_dir/$old" "$vms_dir/$new"
		local f b
		for f in "$vms_dir/$new/$old".* "$vms_dir/$new/$old"-*; do
			[ -e "$f" ] || continue
			b="$(basename "$f")"; mv "$f" "$vms_dir/$new/$new${b#"$old"}"
		done
	fi
	mv "$conf" "$vms_dir/$new.conf"
	echo "renamed $old to $new"
}

# ---- resize (grow the disk image) ------------------------------------------
# qemu-img resize only grows here (shrinking a live filesystem corrupts it); the
# guest still has to extend its partition to use the new space. Keeps disk_size
# in the conf in step so the UI shows the new cap.
cmd_resize() {
	local conf; conf="$(conf_path "$1")"
	local size="${2:?resize needs a size (e.g. 80G)}"
	[[ "$size" =~ ^[0-9]+[MG]$ ]] || die "size must look like 64G or 4096M"
	vm_paths "$conf"
	vm_running "$vm_pid" && die "stop $vm_name before resizing its disk"
	[ -e "$vm_disk" ] || die "$vm_name has no disk yet; launch it once first"
	qemu-img resize "$vm_disk" "$size" >/dev/null 2>&1 || die "could not grow the disk to $size"
	if grep -qE '^disk_size=' "$conf"; then sed -i -E "s|^disk_size=.*|disk_size=\"$size\"|" "$conf"; else echo "disk_size=\"$size\"" >>"$conf"; fi
	echo "resized $vm_name disk to $size"
}

# ---- seal (the golden-state anchor for disposable machines) -----------------
# Set the machine up once, then seal it: one reserved qcow2 snapshot ("sealed")
# capturing the golden state, and a conf stamp so the library can badge it
# without probing every disk. Disposable runs never touch the disk, so the seal
# stays pristine forever; a normal run that dirties the machine can always be
# rolled back to the seal. Re-sealing replaces the old seal with the current
# state.
cmd_seal() {
	local conf; conf="$(conf_path "${1:?seal needs a VM name}")"
	vm_paths "$conf"
	vm_running "$vm_pid" && die "stop $vm_name before sealing it"
	[ -e "$vm_disk" ] || die "$vm_name has no disk yet; install it first, then seal"
	# a machine stopped a breath ago can still hold the image lock while qemu
	# exits; retry briefly instead of failing the seal on the race.
	local t ok=""
	for t in $(seq 1 12); do
		if qemu-img snapshot -d sealed "$vm_disk" >/dev/null 2>&1 || true; qemu-img snapshot -c sealed "$vm_disk" 2>/dev/null; then
			ok=1; break
		fi
		sleep 0.5
	done
	[ -n "$ok" ] || die "could not write the seal"
	if grep -qE '^ryovm_sealed=' "$conf"; then
		sed -i -E 's|^ryovm_sealed=.*|ryovm_sealed="1"|' "$conf"
	else
		echo 'ryovm_sealed="1"' >>"$conf"
	fi
	echo "sealed $vm_name at its current state"
}

# restore-seal: roll the disk back to the sealed state (a guarded action in the
# UI). The seal itself survives the rollback, ready for the next one.
cmd_restore_seal() {
	local conf; conf="$(conf_path "${1:?restore-seal needs a VM name}")"
	vm_paths "$conf"
	vm_running "$vm_pid" && die "stop $vm_name before restoring the seal"
	qemu-img snapshot -a sealed "$vm_disk" || die "no seal to restore on $vm_name"
	echo "restored $vm_name to its sealed state"
}

# ---- usb (host devices + per-VM assignment) ---------------------------------
# list <name>: host USB devices (root hubs excluded), each with its assignment
# state in the VM's conf. set <name> <vid:pid> on|off: edit the quickemu
# usb_devices=(...) array. Assignment applies at the next launch; quickemu hands
# the devices to qemu at boot (and fixes their node permissions when needed).
cmd_usb() {
	local sub="${1:?usb needs list|set}"; shift
	local conf; conf="$(conf_path "${1:?usb needs a VM name}")"; shift || true
	# current assignments, parsed without sourcing the conf (same rule as
	# conf_get: parsing beats executing).
	local line devices=() tok
	line="$(sed -n -E 's/^usb_devices=\((.*)\)/\1/p' "$conf")"
	if [ -n "$line" ]; then
		while IFS= read -r tok; do
			tok="${tok//\"/}"
			[ -n "$tok" ] && devices+=("$tok")
		done < <(printf '%s' "$line" | grep -oE '"[^"]*"')
	fi
	case "$sub" in
		list)
			local first=1
			printf '['
			local l id name on d
			while IFS= read -r l; do
				id="$(printf '%s' "$l" | sed -n -E 's/^.*ID ([0-9a-f]{4}:[0-9a-f]{4}).*$/\1/p')"
				name="$(printf '%s' "$l" | sed -n -E 's/^.*ID [0-9a-f]{4}:[0-9a-f]{4} ?(.*)$/\1/p')"
				[ -z "$id" ] && continue
				case "$name" in *"root hub"*) continue ;; esac
				on=false
				for d in "${devices[@]}"; do [ "$d" = "$id" ] && { on=true; break; }; done
				[ $first -eq 1 ] && first=0 || printf ','
				jq -cn --arg id "$id" --arg name "${name:-USB device}" --argjson on "$on" \
					'{id:$id,name:$name,assigned:$on}'
			done < <(lsusb 2>/dev/null)
			printf ']\n' ;;
		set)
			local id="${1:?usb set needs <vid:pid>}" want="${2:?usb set needs on|off}"
			[[ "$id" =~ ^[0-9a-f]{4}:[0-9a-f]{4}$ ]] || die "bad device id: $id"
			vm_paths "$conf"
			vm_running "$vm_pid" && die "stop $vm_name before changing USB devices"
			local out=() d
			for d in "${devices[@]}"; do [ "$d" != "$id" ] && out+=("$d"); done
			[ "$want" = on ] && out+=("$id")
			sed -i -E '/^usb_devices=/d' "$conf"
			if [ "${#out[@]}" -gt 0 ]; then
				local newline="usb_devices=(" q
				for q in "${out[@]}"; do newline+="\"$q\" "; done
				printf '%s)\n' "${newline% }" >>"$conf"
			fi
			echo "usb $id $want for $vm_name" ;;
		*) die "unknown usb subcommand: $sub" ;;
	esac
}

# ---- portfwd: host->guest port forwards (quickemu's port_forwards array) ----
# user-mode net, applied at launch; stop-required, parsed not sourced (like usb).
cmd_portfwd() {
	local sub="${1:?portfwd needs list|add|remove}"; shift
	local conf; conf="$(conf_path "${1:?portfwd needs a VM name}")"; shift || true
	local line fwds=() tok
	line="$(sed -n -E 's/^port_forwards=\((.*)\)/\1/p' "$conf")"
	if [ -n "$line" ]; then
		while IFS= read -r tok; do
			tok="${tok//\"/}"
			[ -n "$tok" ] && fwds+=("$tok")
		done < <(printf '%s' "$line" | grep -oE '"[^"]*"')
	fi
	case "$sub" in
		list)
			local first=1 f h g
			printf '['
			for f in "${fwds[@]}"; do
				h="${f%%:*}"; g="${f##*:}"
				[ $first -eq 1 ] && first=0 || printf ','
				jq -cn --arg host "$h" --arg guest "$g" '{host:$host,guest:$guest}'
			done
			printf ']\n' ;;
		add|remove)
			local spec="${1:?portfwd $sub needs <hostport:guestport>}"
			vm_paths "$conf"
			vm_running "$vm_pid" && die "stop $vm_name before changing port forwards"
			local out=() f
			if [ "$sub" = add ]; then
				[[ "$spec" =~ ^[0-9]+:[0-9]+$ ]] || die "bad forward '$spec' (want hostport:guestport)"
				local hp="${spec%%:*}" gp="${spec##*:}"
				{ [ "$hp" -ge 1 ] && [ "$hp" -le 65535 ] && [ "$gp" -ge 1 ] && [ "$gp" -le 65535 ]; } || die "port out of range in '$spec'"
				for f in "${fwds[@]}"; do [ "${f%%:*}" != "$hp" ] && out+=("$f"); done
				out+=("$spec")
			else
				for f in "${fwds[@]}"; do [ "$f" != "$spec" ] && out+=("$f"); done
			fi
			sed -i -E '/^port_forwards=/d' "$conf"
			if [ "${#out[@]}" -gt 0 ]; then
				local newline="port_forwards=(" q
				for q in "${out[@]}"; do newline+="\"$q\" "; done
				printf '%s)\n' "${newline% }" >>"$conf"
			fi
			echo "port forwards updated for $vm_name" ;;
		*) die "unknown portfwd subcommand: $sub" ;;
	esac
}

# ---- folder ----------------------------------------------------------------
cmd_folder() {
	if [ -n "${1:-}" ]; then
		local conf; conf="$(conf_path "$1")"; vm_paths "$conf"; printf '%s\n' "$vm_subdir"
	else
		mkdir -p "$vms_dir"; printf '%s\n' "$vms_dir"
	fi
}

# ---- icon (cached brand logo for an OS slug) -------------------------------
# Resolves a catalogue OS slug to a local logo path, downloading from the
# quickemu-icons set on a miss or after the TTL. Prefers the crisp SVG and falls
# back to the PNG. A `<os>.miss` marker negative-caches a confirmed no-art result
# (only ~37 of ~93 OSes ship art) so warm launches skip the two 404s. Prints the
# cached path, or nothing when there's no art (the UI then draws a monogram).
cmd_icon() {
	local os="${1:?icon needs an OS slug}"
	mkdir -p "$icon_dir"
	local svg="$icon_dir/$os.svg" png="$icon_dir/$os.png" miss="$icon_dir/$os.miss" f
	for f in "$svg" "$png"; do
		if [ -s "$f" ]; then
			local age=$(( ( $(date +%s) - $(stat -c %Y "$f" 2>/dev/null || echo 0) ) / 86400 ))
			[ "$age" -lt "$icon_ttl_days" ] && { printf '%s\n' "$f"; return 0; }
		fi
	done
	serve_stale() { for f in "$svg" "$png"; do [ -s "$f" ] && { printf '%s\n' "$f"; return 0; }; done; return 1; }
	# fresh negative cache: known no-art, skip the network.
	if [ -f "$miss" ]; then
		local mage=$(( ( $(date +%s) - $(stat -c %Y "$miss" 2>/dev/null || echo 0) ) / 86400 ))
		[ "$mage" -lt "$icon_ttl_days" ] && { serve_stale || true; return 0; }
	fi
	# primary source: simple-icons (MIT, monochrome), tinted to the app's cream
	# so every mark reads as the same stamped ink on the dark plate — one visual
	# system across the whole catalogue, and it covers OSes quickemu-icons does
	# not (fedora included). The quickemu-icons colour badges stay as fallback.
	local si="$os"
	case "$os" in
		alma) si="almalinux" ;;
		alpine) si="alpinelinux" ;;
		kali) si="kalilinux" ;;
		macos) si="apple" ;;
		void) si="voidlinux" ;;
		garuda) si="garudalinux" ;;
		ubuntu-server) si="ubuntu" ;;
		centos-stream) si="centos" ;;
		parrotsec) si="parrotsecurity" ;;
		proxmox-ve) si="proxmox" ;;
		lmde) si="linuxmint" ;;
		windows|windows-server) si="" ;;   # trademarked; quickemu-icons' badge serves
	esac
	if [ -n "$si" ] && curl -fsSL "https://raw.githubusercontent.com/simple-icons/simple-icons/develop/icons/$si.svg" -o "$svg.tmp" 2>/dev/null && [ -s "$svg.tmp" ]; then
		sed -i 's/<svg /<svg fill="#e6dccb" /' "$svg.tmp"
		mv "$svg.tmp" "$svg"; rm -f "$png" "$miss"; printf '%s\n' "$svg"; return 0
	fi
	rm -f "$svg.tmp"
	# fallback: the catalogue's own art URLs (quickemu-icons badges).
	[ -s "$catalog_cache" ] || { serve_stale || true; return 0; }
	local svgurl pngurl
	svgurl="$(jq -r --arg os "$os" 'first(.[] | select(.OS==$os) | .SVG) // empty' "$catalog_cache" 2>/dev/null)"
	pngurl="$(jq -r --arg os "$os" 'first(.[] | select(.OS==$os) | .PNG) // empty' "$catalog_cache" 2>/dev/null)"
	if [ -n "$svgurl" ] && curl -fsSL "$svgurl" -o "$svg.tmp" 2>/dev/null && [ -s "$svg.tmp" ]; then
		mv "$svg.tmp" "$svg"; rm -f "$png" "$miss"; printf '%s\n' "$svg"; return 0
	fi
	rm -f "$svg.tmp"
	if [ -n "$pngurl" ] && curl -fsSL "$pngurl" -o "$png.tmp" 2>/dev/null && [ -s "$png.tmp" ]; then
		mv "$png.tmp" "$png"; rm -f "$miss"; printf '%s\n' "$png"; return 0
	fi
	rm -f "$png.tmp"
	: > "$miss"            # record the miss so the next launch skips the network
	serve_stale || true
}

# ---- prefetch (warm every catalogue logo in parallel) ----------------------
# Downloads all OS logos concurrently (honoring the cache + miss markers) so the
# Catalog paints from local files instead of 93 serial CDN hits, and prints a
# JSON object {os: "/abs/path"} of the OSes that have art. The UI seeds its path
# cache from this, so warm tiles render the local file at once (no per-card
# round-trip) and logo-bearers float to a "Popular" section.
cmd_prefetch() {
	[ -s "$catalog_cache" ] || cmd_catalog >/dev/null 2>&1 || true
	[ -s "$catalog_cache" ] || { echo '{}'; return 0; }
	mkdir -p "$icon_dir"
	local self; self="$(command -v ryovm 2>/dev/null || printf '%s' "$0")"
	jq -r '[.[].OS] | unique | .[]' "$catalog_cache" 2>/dev/null \
		| xargs -P 12 -I {} "$self" icon {} >/dev/null 2>&1 || true
	jq -r '[.[].OS] | unique | .[]' "$catalog_cache" 2>/dev/null \
		| while IFS= read -r os; do
			for f in "$icon_dir/$os.svg" "$icon_dir/$os.png"; do
				[ -s "$f" ] && { printf '%s\t%s\n' "$os" "$f"; break; }
			done
		done | jq -R 'split("\t") | {(.[0]): .[1]}' | jq -cs 'add // {}'
}

# ---- paths (where things live + who provides the catalogue) ----------------
cmd_paths() {
	jq -cn --arg vms "$vms_dir" --arg cache "$cache_dir" --arg icons "$icon_dir" \
		--arg catalog "$catalog_cache" \
		'{vms:$vms,cache:$cache,icons:$icons,catalog:$catalog,
		  provider:"quickemu + quickget",
		  icons_provider:"quickemu-icons",
		  source:"github.com/quickemu-project"}'
}

# ---- mon: live control of a running VM ------------------------------------
# Talks to the sockets quickemu already opens (HMP monitor + optional guest
# agent) via the ryovm-mon helper. Additive and read-mostly; the engine only
# resolves the paths. A stopped VM reports running:false, never an error.
cmd_mon() {
	local conf; conf="$(conf_path "$1")"
	vm_paths "$conf"
	local sub="${2:-stats}" arg="${3:-}"
	command -v ryovm-mon >/dev/null 2>&1 || die "ryovm-mon is not installed"
	local mon="$vm_subdir/$vm_name-monitor.socket"
	local agent="$vm_subdir/$vm_name-agent.sock"; [ -S "$agent" ] || agent="-"
	local pid="$vm_pid"; [ -r "$pid" ] || pid="-"
	case "$sub" in
		stats)   ryovm-mon stats "$mon" "$agent" "$pid" ;;
		power)   [ -n "$arg" ] || die "power needs pause|resume|reset|shutdown"; ryovm-mon power "$mon" "$arg" ;;
		balloon) [ -n "$arg" ] || die "balloon needs a size in MB"; ryovm-mon balloon "$mon" "$arg" ;;
		pin)     ryovm-mon pin "$mon" "$vm_pid" "${arg:-auto}" ;;
		*)       die "mon: unknown subcommand '$sub'" ;;
	esac
}

cmd="${1:-}"; shift || true
case "$cmd" in
	caps)     cmd_caps "$@" ;;
	setup)    cmd_setup "$@" ;;
	catalog)  cmd_catalog "$@" ;;
	list)     cmd_list "$@" ;;
	get)      cmd_get "$@" ;;
	create)   cmd_create "$@" ;;
	instant)  cmd_instant "$@" ;;
	cloud-catalog) cmd_cloud_catalog "$@" ;;
	template) cmd_template "$@" ;;
	templates) cmd_templates "$@" ;;
	spawn)    cmd_spawn "$@" ;;
	import)   cmd_import "$@" ;;
	virtio)   cmd_virtio "$@" ;;
	launch)   cmd_launch "$@" ;;
	console)  cmd_console "$@" ;;
	stop)     cmd_stop "$@" ;;
	config)   cmd_config "$@" ;;
	rename)   cmd_rename "$@" ;;
	resize)   cmd_resize "$@" ;;
	snapshot) cmd_snapshot "$@" ;;
	seal)     cmd_seal "$@" ;;
	restore-seal) cmd_restore_seal "$@" ;;
	usb)      cmd_usb "$@" ;;
	portfwd)  cmd_portfwd "$@" ;;
	ssh)      cmd_ssh "$@" ;;
	delete)   cmd_delete "$@" ;;
	folder)   cmd_folder "$@" ;;
	icon)     cmd_icon "$@" ;;
	prefetch) cmd_prefetch "$@" ;;
	paths)    cmd_paths "$@" ;;
	mon)      cmd_mon "$@" ;;
	*) die "usage: ryovm caps|setup|catalog|cloud-catalog|list|get|create|instant|template|templates|spawn|import|launch|console|stop|config|rename|resize|snapshot|seal|restore-seal|usb|portfwd|ssh|delete|folder|icon|prefetch|paths|mon" 2 ;;
esac
