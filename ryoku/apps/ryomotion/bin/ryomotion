#!/usr/bin/env bash
#
# ryomotion: the Ryoku Motion backend. Records the screen with a cursor track,
# and renders a project into a polished demo -- the recording placed on a padded
# gradient background with rounded corners and a soft shadow (the Beautify look),
# plus cursor-follow zoom. The zoom math (depth scales, easing, transition
# windows) is ported from openscreen (MIT); see docs/ for attribution.
#
#   ryomotion record [--region|--monitor]   start recording (screen + cursor track)
#   ryomotion stop                           stop the active recording
#   ryomotion status                         print recording state as JSON
#   ryomotion render <project.json> [out]    render a project to mp4/gif
#
# A project.json is a small document the editor writes; `render` is pure and
# testable: give it a clip and it produces a framed, zoomed video.
set -euo pipefail

# ---- openscreen-ported constants -------------------------------------------
# ZOOM_DEPTH_SCALES[1..6] and the transition windows come straight from
# openscreen's video-editor (types.ts / zoomRegionUtils.ts).
zoom_scale_for_depth() {
  case "$1" in
  1) printf '1.25' ;; 2) printf '1.5' ;; 3) printf '1.8' ;;
  4) printf '2.2' ;; 5) printf '3.5' ;; 6) printf '5.0' ;;
  *) printf '1.8' ;;
  esac
}
ZOOM_IN_SEC=1.5226      # openscreen ZOOM_IN_TRANSITION_WINDOW_MS (1015.05*1.5)
ZOOM_OUT_SEC=1.01505    # openscreen TRANSITION_WINDOW_MS
SHADOW_BLUR=24          # openscreen shadow blur px
SHADOW_DY=10            # openscreen shadow y offset px

state_dir() { printf '%s/ryoku/ryomotion' "${XDG_STATE_HOME:-$HOME/.local/state}"; }
projects_dir() { printf '%s/Videos/Ryoku Motion' "$HOME"; }
rec_pidfile() { printf '%s/record.pids' "$(state_dir)"; }

die() { echo "ryomotion: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing command: $1"; }

# ---- cursor telemetry logger -----------------------------------------------
# Samples hyprctl cursorpos at ~60Hz and writes "elapsedMs cx cy" with cx,cy
# normalized to the captured region, so render can pan a zoom to the cursor.
# Runs until killed (record stop sends SIGTERM).
cmd_cursorlog() {
  local out="$1" rx="$2" ry="$3" rw="$4" rh="$5"
  command -v hyprctl >/dev/null 2>&1 || exit 0
  local start now ms pos x y
  start=$(date +%s%3N)
  : >"$out"
  while :; do
    pos=$(hyprctl cursorpos 2>/dev/null || true)   # "x, y"
    x=${pos%%,*}; y=${pos#*,}; x=${x// /}; y=${y// /}
    [[ $x =~ ^-?[0-9]+$ && $y =~ ^-?[0-9]+$ ]] || { sleep 0.016; continue; }
    now=$(date +%s%3N); ms=$((now - start))
    awk -v ms="$ms" -v x="$x" -v y="$y" -v rx="$rx" -v ry="$ry" -v rw="$rw" -v rh="$rh" \
      'BEGIN { cx=(x-rx)/rw; cy=(y-ry)/rh;
               if(cx<0)cx=0; if(cx>1)cx=1; if(cy<0)cy=0; if(cy>1)cy=1;
               printf "%d %.4f %.4f\n", ms, cx, cy }' >>"$out"
    sleep 0.016
  done
}

# ---- record ----------------------------------------------------------------
# Best-effort screen capture with gpu-screen-recorder + a parallel cursor track.
# Needs a live Hyprland session; the editor drives start/stop.
cmd_record() {
  local mode="monitor" geom="" mon rx ry rw rh
  case "${1:-}" in --region) mode="region" ;; --monitor|--fullscreen|"") mode="monitor" ;; esac
  need gpu-screen-recorder; need hyprctl; need jq
  mkdir -p "$(state_dir)" "$(projects_dir)"

  mon=$(hyprctl monitors -j 2>/dev/null | jq -r '[.[] | select(.focused)][0] // .[0]')
  [[ -n $mon && $mon != null ]] || die "no monitor found"
  local mname
  mname=$(printf '%s' "$mon" | jq -r '.name')
  rx=$(printf '%s' "$mon" | jq -r '.x'); ry=$(printf '%s' "$mon" | jq -r '.y')
  rw=$(printf '%s' "$mon" | jq -r '(.width / (.scale // 1)) | floor')
  rh=$(printf '%s' "$mon" | jq -r '(.height / (.scale // 1)) | floor')

  local gsr_target="$mname"
  if [[ $mode == region ]]; then
    need slurp
    geom=$(slurp -f '%x %y %w %h' 2>/dev/null || true)
    [[ -n $geom ]] || die "region selection cancelled"
    read -r rx ry rw rh <<<"$geom"
    gsr_target="region"
  fi

  local ts base clip cur proj
  ts=$(date +%Y-%m-%d_%H.%M.%S)
  base="$(projects_dir)/motion_${ts}"
  clip="${base}.mp4"; cur="${base}.cursor"; proj="${base}.json"

  cmd_cursorlog "$cur" "$rx" "$ry" "$rw" "$rh" &
  local logpid=$!

  local -a gargs=(-o "$clip" -f 60 -q very_high -cursor yes)
  if [[ $gsr_target == region ]]; then gargs+=(-w region -region "${rw}x${rh}+${rx}+${ry}"); else gargs+=(-w "$mname"); fi
  gpu-screen-recorder "${gargs[@]}" >/dev/null 2>&1 &
  local gsrpid=$!

  printf '%s\n%s\n' "$gsrpid" "$logpid" >"$(rec_pidfile)"
  # seed a project the editor can open the moment recording stops.
  jq -n --arg clip "$clip" --arg cur "$cur" \
    '{clip:$clip, cursor:$cur, aspect:"auto",
      bg:{kind:"gradient", a:"#4facfe", b:"#00c6a7", solid:"#2b3350", angle:135, image:""},
      padding:0.06, roundness:18, shadow:0.35, border:{w:0, color:"#ffffff"},
      cursor_opts:{show:true, scale:1, smooth:0.35}, music:{path:"", volume:0.6},
      zoom:{auto:true, depth:3, regions:[]}, trims:[], speeds:[], texts:[],
      fps:60, quality:"good", format:"mp4"}' >"$proj"
  echo "$proj"
}

cmd_stop() {
  local pf; pf="$(rec_pidfile)"
  [[ -r $pf ]] || die "no active recording"
  local gsrpid logpid; { read -r gsrpid; read -r logpid; } <"$pf"
  # gsr flushes the muxer on SIGINT; the logger just dies.
  [[ -n ${gsrpid:-} ]] && kill -INT "$gsrpid" 2>/dev/null || true
  [[ -n ${logpid:-} ]] && kill -TERM "$logpid" 2>/dev/null || true
  rm -f "$pf"
}

cmd_status() {
  local pf; pf="$(rec_pidfile)"
  if [[ -r $pf ]]; then
    local gsrpid; read -r gsrpid <"$pf"
    if [[ -n ${gsrpid:-} ]] && kill -0 "$gsrpid" 2>/dev/null; then echo '{"recording":true}'; return; fi
  fi
  echo '{"recording":false}'
}

# ---- render ----------------------------------------------------------------
# Build the ffmpeg crop expression that zooms into each region's focus with the
# openscreen easing (smootherstep approximation of cubicBezier(0.16,1,0.3,1)),
# ramping in over ZOOM_IN_SEC and out over ZOOM_OUT_SEC. Emits Z, FX, FY exprs.
# smootherstep(p) = p^3 (p(6p-15)+10). ffmpeg has clip()/min()/between().
zoom_exprs() {
  local depth="$1"; shift            # remaining args: "s e cx cy" per region
  local scale; scale=$(zoom_scale_for_depth "$depth")
  local Z="1" FX="0.5" FY="0.5" r s e cx cy
  for r in "$@"; do
    read -r s e cx cy <<<"$r"
    # p in [0,1]: ramps up over ZOOM_IN_SEC from s, down over ZOOM_OUT_SEC to e.
    local pin pout p es ze
    pin="clip((t-$s)/$ZOOM_IN_SEC,0,1)"
    pout="clip(($e-t)/$ZOOM_OUT_SEC,0,1)"
    p="min($pin,$pout)"
    es="($p*$p*$p*($p*($p*6-15)+10))"          # smootherstep(p)
    ze="(1+($scale-1)*$es)"
    Z="if(between(t,$s,$e),$ze,$Z)"
    FX="if(between(t,$s,$e),$cx,$FX)"
    FY="if(between(t,$s,$e),$cy,$FY)"
  done
  printf '%s\t%s\t%s\n' "$Z" "$FX" "$FY"
}

# When zoom is on but no regions are set, derive them from the cursor track:
# walk ~2.5s windows and emit a region wherever the cursor moved (activity),
# focused where the cursor ended up. Contiguous active windows overlap via the
# lead-in, so the zoom stays up through sustained activity. Caps at 6.
auto_regions() {
  local cur="$1"
  [[ -r $cur ]] || return 0
  awk '
    BEGIN { WIN = 2.5; MOVE = 0.05; LEAD = 0.35 }
    { t = $1 / 1000; x = $2; y = $3; n++; T[n] = t; X[n] = x; Y[n] = y }
    END {
      if (n < 2) exit
      wstart = T[1]; moved = 0; lx = X[1]; ly = Y[1]; regions = 0
      for (i = 1; i <= n; i++) {
        dx = X[i] - lx; dy = Y[i] - ly; moved += sqrt(dx * dx + dy * dy); lx = X[i]; ly = Y[i]
        if (T[i] - wstart >= WIN || i == n) {
          if (moved > MOVE && regions < 6) {
            s = wstart - LEAD; if (s < 0) s = 0
            printf "%.2f %.2f %.3f %.3f\n", s, T[i], X[i], Y[i]
            regions++
          }
          wstart = T[i]; moved = 0
        }
      }
    }
  ' "$cur"
}

cmd_render() {
  local proj="${1:?project.json required}" out="${2:-}"
  need ffmpeg; need ffprobe; need jq; need magick
  [[ -r $proj ]] || die "no such project: $proj"

  local clip cur fmt fps quality pad round shadow borderW borderColor zen depth aspect musicPath musicVol
  clip=$(jq -r '.clip' "$proj"); cur=$(jq -r '.cursor // ""' "$proj")
  fmt=$(jq -r '.format // "mp4"' "$proj"); fps=$(jq -r '.fps // 60' "$proj")
  quality=$(jq -r '.quality // "good"' "$proj")
  pad=$(jq -r '.padding // 0.06' "$proj"); round=$(jq -r '.roundness // 18' "$proj")
  shadow=$(jq -r '.shadow // 0.35' "$proj")
  borderW=$(jq -r '.border.w // 0' "$proj"); borderColor=$(jq -r '.border.color // "#ffffff"' "$proj")
  zen=$(jq -r 'if (.zoom.auto // false) then "true" elif ((.zoom.regions // [] | length) > 0) then "true" else "false" end' "$proj")
  depth=$(jq -r '.zoom.depth // 3' "$proj"); aspect=$(jq -r '.aspect // "auto"' "$proj")
  musicPath=$(jq -r '.music.path // ""' "$proj"); musicVol=$(jq -r '.music.volume // 0.6' "$proj")
  [[ -r $clip ]] || die "clip not found: $clip"
  [[ -n $out ]] || out="${proj%.json}_export.${fmt}"

  # atempo only spans 0.5..2.0; chain to reach any rate.
  _atempo() { awk -v s="$1" 'BEGIN{o="";while(s>2){o=o"atempo=2.0,";s/=2}while(s<0.5){o=o"atempo=0.5,";s*=2}printf "%satempo=%.4f", o, s}'; }

  local W H DUR
  W=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=p=0 "$clip" | head -1)
  H=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of csv=p=0 "$clip" | head -1)
  DUR=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$clip" | head -1)
  [[ -n $W && -n $H ]] || die "cannot probe clip dimensions"
  DUR=${DUR:-0}

  local tmp bg mask; tmp=$(mktemp -d); bg="$tmp/bg.png"; mask="$tmp/mask.png"
  trap 'rm -rf "${tmp:-}"' EXIT

  # canvas = padded video, expanded to the chosen aspect, video centred.
  local cw ch vx vy
  read -r cw ch vx vy _ < <(awk -v w="$W" -v h="$H" -v p="$pad" -v asp="$aspect" 'BEGIN{
    m=(w>h?w:h); pad=int(m*p+0.5); bw=w+2*pad; bh=h+2*pad; cw=bw; ch=bh; ar=0;
    if(asp=="16:9")ar=16/9; else if(asp=="9:16")ar=9/16; else if(asp=="4:3")ar=4/3; else if(asp=="1:1")ar=1;
    if(ar>0){ curr=bw/bh; if(curr<ar)cw=int(bh*ar+0.5); else if(curr>ar)ch=int(bw/ar+0.5) }
    if(cw%2)cw++; if(ch%2)ch++; vx=int((cw-w)/2); vy=int((ch-h)/2); if(vx<0)vx=0; if(vy<0)vy=0;
    printf "%d %d %d %d %d\n", cw, ch, vx, vy, pad }')

  # background
  local kind a b solid angle image
  kind=$(jq -r '.bg.kind // "gradient"' "$proj")
  a=$(jq -r '.bg.a // "#4facfe"' "$proj"); b=$(jq -r '.bg.b // "#00c6a7"' "$proj")
  solid=$(jq -r '.bg.solid // "#2b3350"' "$proj"); angle=$(jq -r '.bg.angle // 135' "$proj")
  image=$(jq -r '.bg.image // ""' "$proj")
  case "$kind" in
  solid) magick -size "${cw}x${ch}" "xc:${solid}" "$tmp/base.png" ;;
  image) if [[ -r $image ]]; then magick "$image" -resize "${cw}x${ch}^" -gravity center -extent "${cw}x${ch}" "$tmp/base.png"
         else magick -size "${cw}x${ch}" "xc:${solid}" "$tmp/base.png"; fi ;;
  *) magick -size "${cw}x${ch}" -define gradient:angle="$angle" "gradient:${a}-${b}" "$tmp/base.png" 2>/dev/null \
       || magick -size "${cw}x${ch}" "gradient:${a}-${b}" "$tmp/base.png" ;;
  esac

  # shadow: blurred rounded black rect at the video rect, offset (0, SHADOW_DY).
  local sx0 sy0 sx1 sy1 salpha
  sx0=$vx; sy0=$((vy + SHADOW_DY)); sx1=$((vx + W - 1)); sy1=$((vy + H - 1 + SHADOW_DY))
  salpha=$(awk -v s="$shadow" 'BEGIN{printf "%.3f", s}')
  magick "$tmp/base.png" \
    \( -size "${cw}x${ch}" xc:none -fill "rgba(0,0,0,${salpha})" \
       -draw "roundrectangle ${sx0},${sy0} ${sx1},${sy1} ${round},${round}" -blur "0x${SHADOW_BLUR}" \) \
    -compose over -composite "$bg"
  magick -size "${W}x${H}" xc:black -fill white \
    -draw "roundrectangle 0,0 $((W - 1)),$((H - 1)) ${round},${round}" "$mask"

  # optional border, overlaid on the video edges.
  local border_input=()
  if [[ $(awk -v x="$borderW" 'BEGIN{print (x>0)}') == 1 ]]; then
    local bhw; bhw=$(awk -v x="$borderW" 'BEGIN{printf "%d", x/2}')
    magick -size "${W}x${H}" xc:none -stroke "$borderColor" -strokewidth "$borderW" -fill none \
      -draw "roundrectangle ${bhw},${bhw} $((W - 1 - bhw)),$((H - 1 - bhw)) ${round},${round}" "$tmp/border.png"
    border_input=(-i "$tmp/border.png")
  fi

  # zoom crop expression (project regions, else cursor-derived).
  local vf_zoom=""
  if [[ $zen == true ]]; then
    mapfile -t regions < <(jq -r '.zoom.regions[]? | "\(.start) \(.end) \(.cx // 0.5) \(.cy // 0.5)"' "$proj")
    if ((${#regions[@]} == 0)) && [[ -n $cur && -r $cur ]]; then mapfile -t regions < <(auto_regions "$cur"); fi
    if ((${#regions[@]} > 0)); then
      local Z FX FY
      IFS=$'\t' read -r Z FX FY < <(zoom_exprs "$depth" "${regions[@]}")
      vf_zoom="crop=w='iw/(${Z})':h='ih/(${Z})':x='(iw-iw/(${Z}))*(${FX})':y='(ih-ih/(${Z}))*(${FY})',scale=${W}:${H}:flags=bicubic,"
    fi
  fi

  # text overlays: drawtext on the framed canvas, enabled over each span.
  local drawchain=""
  while IFS=$'\t' read -r ts te tx ty tsz tcol ttext; do
    [[ -n $ts ]] || continue
    local esc fs
    esc=$(printf '%s' "$ttext" | sed -e 's/\\/\\\\/g' -e 's/:/\\:/g' -e "s/'/\\\\'/g" -e 's/%/\\%/g')
    fs=$(awk -v s="$tsz" -v c="$ch" 'BEGIN{printf "%d", s*c}')
    drawchain="${drawchain},drawtext=text='${esc}':font='Space Grotesk':fontcolor=${tcol}:fontsize=${fs}:x=(${cw}*${tx}-text_w/2):y=(${ch}*${ty}-text_h/2):enable='between(t,${ts},${te})'"
  done < <(jq -r '.texts[]? | "\(.start)\t\(.end)\t\(.x)\t\(.y)\t\(.size)\t\(.color)\t\(.text)"' "$proj")

  # video overlays (clip-in-clip): scaled + positioned on the canvas, per span.
  local overlay_input=() ovs_ok=() op ostart oend ox oy osc
  while IFS=$'\t' read -r op ostart oend ox oy osc; do
    [[ -n $op && -r $op ]] || continue
    overlay_input+=(-i "$op")
    ovs_ok+=("${op}"$'\t'"${ostart}"$'\t'"${oend}"$'\t'"${ox}"$'\t'"${oy}"$'\t'"${osc}")
  done < <(jq -r '.overlays[]? | "\(.path)\t\(.start)\t\(.end)\t\(.x)\t\(.y)\t\(.scale)"' "$proj")

  # final segments from trims (spans to remove) + speeds (per-span rate).
  jq -r '.trims[]? | "\(.start) \(.end)"' "$proj" >"$tmp/trims"
  jq -r '.speeds[]? | "\(.start) \(.end) \(.speed)"' "$proj" >"$tmp/speeds"
  mapfile -t segs < <(awk -v dur="$DUR" '
    ARGIND==1 { ts[++nt]=$1; te[nt]=$2; next }
    ARGIND==2 { ss[++ns]=$1; se[ns]=$2; sp[ns]=$3 }
    function spd(t,  i){ for(i=1;i<=ns;i++) if(t>=ss[i] && t<se[i]) return sp[i]; return 1 }
    END {
      for(i=1;i<=nt;i++)for(j=i+1;j<=nt;j++)if(ts[j]<ts[i]){x=ts[i];ts[i]=ts[j];ts[j]=x;x=te[i];te[i]=te[j];te[j]=x}
      cur=0; kn=0
      for(i=1;i<=nt;i++){ if(ts[i]>cur){ks[++kn]=cur;ke[kn]=ts[i]} if(te[i]>cur)cur=te[i] }
      if(cur<dur-0.001){ks[++kn]=cur;ke[kn]=dur}
      if(kn==0){ks[1]=0;ke[1]=dur;kn=1}
      for(k=1;k<=kn;k++){
        nb=0; bnd[++nb]=ks[k]; bnd[++nb]=ke[k]
        for(i=1;i<=ns;i++){ if(ss[i]>ks[k]&&ss[i]<ke[k])bnd[++nb]=ss[i]; if(se[i]>ks[k]&&se[i]<ke[k])bnd[++nb]=se[i] }
        for(i=1;i<=nb;i++)for(j=i+1;j<=nb;j++)if(bnd[j]<bnd[i]){x=bnd[i];bnd[i]=bnd[j];bnd[j]=x}
        for(i=1;i<nb;i++){ aa=bnd[i]; bb=bnd[i+1]; if(bb-aa<0.03)continue; printf "%.3f %.3f %.4f\n", aa, bb, spd((aa+bb)/2) }
      }
    }' "$tmp/trims" "$tmp/speeds")

  # a plain pass = one segment, full length, unit speed, no trims.
  local simple=0 s0 e0 sp0
  if ((${#segs[@]} == 0)); then simple=1
  elif ((${#segs[@]} == 1)); then
    read -r s0 e0 sp0 <<<"${segs[0]}"
    [[ $(awk -v s="$sp0" 'BEGIN{print (s==1)}') == 1 ]] && simple=1
  fi

  # downscale for quality tiers (never upscale).
  local scalev="" crf=18
  case "$quality" in
  medium) (( ch > 720 )) && scalev="scale=-2:720:flags=bicubic,"; crf=21 ;;
  good)   (( ch > 1080 )) && scalev="scale=-2:1080:flags=bicubic," ;;
  esac

  # video filtergraph. inputs: 0 clip, 1 bg, 2 mask, [border], [music].
  local fg framed nextidx
  fg="[0:v]setpts=PTS-STARTPTS,${vf_zoom}scale=${W}:${H}:flags=bicubic,format=rgba[vz];[vz][2:v]alphamerge[vr];[1:v][vr]overlay=${vx}:${vy}:format=auto[fr0]"
  framed="fr0"; nextidx=3
  if ((${#border_input[@]} > 0)); then fg="${fg};[fr0][${nextidx}:v]overlay=${vx}:${vy}[fr1]"; framed="fr1"; nextidx=$((nextidx + 1)); fi
  if [[ -n $drawchain ]]; then fg="${fg};[${framed}]${drawchain#,}[frd]"; framed="frd"; fi
  # composite the video overlays onto the framed canvas (original timeline).
  local oi os2 oe2 ox2 oy2 osc2 ow2
  for ((oi = 0; oi < ${#ovs_ok[@]}; oi++)); do
    IFS=$'\t' read -r _ os2 oe2 ox2 oy2 osc2 <<<"${ovs_ok[$oi]}"
    ow2=$(awk -v c="$cw" -v s="$osc2" 'BEGIN{printf "%d", c*s}')
    fg="${fg};[${nextidx}:v]scale=w=${ow2}:h=-2[ovs$oi];[${framed}][ovs$oi]overlay=x='(main_w*${ox2}-overlay_w/2)':y='(main_h*${oy2}-overlay_h/2)':enable='between(t,${os2},${oe2})'[ovf$oi]"
    framed="ovf$oi"; nextidx=$((nextidx + 1))
  done

  local mapv="[outv]" i n
  if ((simple == 1)); then
    fg="${fg};[${framed}]${scalev}format=yuv420p[outv]"
  else
    n=${#segs[@]}; local splitlbl="" concatv=""
    for ((i = 0; i < n; i++)); do splitlbl="${splitlbl}[fs$i]"; concatv="${concatv}[v$i]"; done
    fg="${fg};[${framed}]split=${n}${splitlbl}"
    for ((i = 0; i < n; i++)); do read -r s0 e0 sp0 <<<"${segs[$i]}"; fg="${fg};[fs$i]trim=start=${s0}:end=${e0},setpts=(PTS-STARTPTS)/${sp0}[v$i]"; done
    fg="${fg};${concatv}concat=n=${n}:v=1:a=0[cv];[cv]${scalev}format=yuv420p[outv]"
  fi

  # audio: original track cut+re-timed to match, plus optional music.
  local afg="" aud="" mapa="" musidx
  local hasA; hasA=$(ffprobe -v error -select_streams a -show_entries stream=index -of csv=p=0 "$clip" | head -1)
  if [[ -n $hasA ]]; then
    if ((simple == 1)); then afg="[0:a]asetpts=PTS-STARTPTS[aud]"; aud="aud"
    else
      local aconcat=""
      for ((i = 0; i < ${#segs[@]}; i++)); do
        read -r s0 e0 sp0 <<<"${segs[$i]}"
        afg="${afg}${afg:+;}[0:a]atrim=start=${s0}:end=${e0},asetpts=PTS-STARTPTS,$(_atempo "$sp0")[a$i]"
        aconcat="${aconcat}[a$i]"
      done
      afg="${afg};${aconcat}concat=n=${#segs[@]}:v=0:a=1[aud]"; aud="aud"
    fi
  fi
  local music_input=()
  if [[ -n $musicPath && -r $musicPath ]]; then
    music_input=(-i "$musicPath")
    musidx=$nextidx
    local mvol; mvol=$(awk -v v="$musicVol" 'BEGIN{printf "%.3f", v}')
    if [[ -n $aud ]]; then afg="${afg};[${musidx}:a]volume=${mvol}[mus];[${aud}][mus]amix=inputs=2:duration=first:dropout_transition=0[outa]"
    else afg="${afg}${afg:+;}[${musidx}:a]volume=${mvol}[outa]"; fi
    mapa="[outa]"
  elif [[ -n $aud ]]; then mapa="[${aud}]"; fi

  local full="$fg${afg:+;$afg}"
  local -a inputs=(-i "$clip" -i "$bg" -i "$mask" "${border_input[@]}" "${overlay_input[@]}" "${music_input[@]}")

  if [[ $fmt == gif ]]; then
    local gfps comp; gfps=$(awk -v f="$fps" 'BEGIN{print (f>30?20:f)}'); comp="$tmp/composite.mp4"
    ffmpeg -y "${inputs[@]}" -filter_complex "$full" -map "$mapv" -an -c:v libx264 -pix_fmt yuv420p -crf 18 -preset fast "$comp" 2>"$tmp/err" || { tail -6 "$tmp/err" >&2; die "gif compositing failed"; }
    ffmpeg -y -i "$comp" -vf "fps=${gfps},palettegen=stats_mode=diff" "$tmp/pal.png" 2>/dev/null || die "gif palette failed"
    ffmpeg -y -i "$comp" -i "$tmp/pal.png" -lavfi "fps=${gfps}[x];[x][1:v]paletteuse=dither=sierra2_4a" "$out" 2>/dev/null || die "gif render failed"
  else
    local -a amap
    if [[ -n $mapa ]]; then amap=(-map "$mapa" -c:a aac -b:a 192k); else amap=(-an); fi
    ffmpeg -y "${inputs[@]}" -filter_complex "$full" -map "$mapv" "${amap[@]}" \
      -c:v libx264 -pix_fmt yuv420p -crf "$crf" -preset medium -movflags +faststart "$out" 2>"$tmp/err" || { tail -6 "$tmp/err" >&2; die "mp4 render failed"; }
  fi
  echo "$out"
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
  record) cmd_record "$@" ;;
  stop) cmd_stop "$@" ;;
  status) cmd_status "$@" ;;
  render) cmd_render "$@" ;;
  _cursorlog) cmd_cursorlog "$@" ;;
  ""|-h|--help)
    grep -E '^#( |$)' "$0" | sed -E 's/^# ?//'; ;;
  *) die "unknown command: $cmd (try --help)" ;;
  esac
}
main "$@"
