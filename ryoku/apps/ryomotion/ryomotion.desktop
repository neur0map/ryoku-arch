[Desktop Entry]
Type=Application
Name=Ryoku Motion
GenericName=Screen Demo Editor
Comment=Record your screen and turn it into a polished demo: framed backgrounds, cursor-follow zoom, export to MP4 or GIF
Exec=flock -n -o /tmp/ryomotion.lock qs -c ryomotion
Terminal=false
Icon=ryomotion
Categories=Utility;AudioVideo;Video;
Keywords=screen;record;demo;video;zoom;capture;motion;ryomotion;
