#!/usr/bin/env bash
# Summon a single-instance window to the current workspace and focus it; launch
# it if it isn't running yet. Single-instance apps (flock + qs) otherwise strand
# their window on whatever workspace they first opened on, so re-pressing the
# keybind from another workspace appears to do nothing.
#   ryoku-summon <window-title> <launch command...>
set -uo pipefail

title="${1:?window title required}"; shift
[ "$#" -gt 0 ] || { echo "ryoku-summon: launch command required" >&2; exit 2; }

# match the live title first, then the initial title: a window whose app
# retitles itself dynamically would otherwise fall through to the flock
# launcher, which exits nonzero on the held lock and looks like a dead key.
addr="$(hyprctl clients -j 2>/dev/null | jq -r --arg t "$title" '([.[] | select(.title == $t)] + [.[] | select(.initialTitle == $t)])[0].address // empty' 2>/dev/null || true)"

if [ -n "$addr" ]; then
	ws="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id' 2>/dev/null || true)"
	[ -n "$ws" ] && hyprctl dispatch "hl.dsp.window.move({ workspace = $ws, window = \"address:$addr\" })" >/dev/null 2>&1
	hyprctl dispatch "hl.dsp.focus({ window = \"address:$addr\" })" >/dev/null 2>&1
else
	exec "$@"
fi
