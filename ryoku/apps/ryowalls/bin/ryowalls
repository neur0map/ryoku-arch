#!/usr/bin/env bash
# Engine for ryowalls: search and download wallpapers (wallhaven + curated /
# scraped live sources), a palette verb that prints an image's wallust scheme for
# the honest live preview, an adjust verb that grades an image (brightness /
# contrast / saturation / warmth / vignette) for the editor, and an enhance verb
# that AI-upscales an image or video on the GPU with progress. WALLHAVEN_API_KEY
# raises limits; the palette + adjust verbs take the same flags the desktop applies.
set -euo pipefail

api="https://wallhaven.cc/api/v1"
dest="$HOME/Pictures/Wallpapers"
key="${WALLHAVEN_API_KEY:-}"
ua="Mozilla/5.0"

# where the live wallpaper is recorded; the enhance worker checks it before
# swapping a crisp version onto the desktop, so a job that finishes after the
# user has moved on never yanks an old wallpaper back (the swap-back bug).
state_file="${XDG_STATE_HOME:-$HOME/.local/state}/ryoku-wallpaper"
enh_state="${XDG_STATE_HOME:-$HOME/.local/state}/ryoku-ryowalls-enhance.json"
still_current() { [ "$(cat "$state_file" 2>/dev/null)" = "$1" ]; }

# progress the ryowalls UI polls while enhancing: {file, phase, done, total}.
# phase is probe | extract | enhance | assemble | done | sharp | error | unsupported.
enh_write() {
	mkdir -p "$(dirname "$enh_state")" 2>/dev/null || true
	jq -cn --arg file "$1" --arg phase "$2" --argjson dn "${3:-0}" --argjson total "${4:-0}" \
		'{file:$file,phase:$phase,done:$dn,total:$total}' >"$enh_state" 2>/dev/null || true
}

# final verdict, one JSON line on stdout: the state file races the process exit,
# so the numbers behind a skip ride the exit instead. "sharp" carries px (the
# side that was measured) and cap (the threshold it met) so the UI can say WHY
# nothing happened — a silent or bare skip reads as a broken button. An error
# carries why (gpu | read | tools | io | assemble): blaming the GPU for a
# truncated download sends users chasing drivers that were never involved.
enh_verdict() { # result kind [px] [cap] [out] [why]
	jq -cn --arg result "$1" --arg kind "$2" --argjson px "${3:-0}" --argjson cap "${4:-0}" \
		--arg out "${5:-}" --arg why "${6:-}" \
		'{result:$result,kind:$kind,px:$px,cap:$cap}
		 + (if $out == "" then {} else {out:$out} end)
		 + (if $why == "" then {} else {why:$why} end)' 2>/dev/null || true
}

# screen_cap: the width livewall actually decodes a live wallpaper at, so enhance
# skips only a source that already meets it (a smaller one gains real detail).
# Mirrors the shell's liveCapWidth: the widest monitor's logical width (physical
# / fractional scale), clamped to 2560 for RAM; 1920 when hyprctl is absent.
screen_cap() {
	local w
	w="$(hyprctl monitors -j 2>/dev/null | jq -r '[.[] | (.width / (.scale // 1))] | max | floor' 2>/dev/null)"
	case "$w" in '' | *[!0-9]*) w=1920 ;; esac
	[ "$w" -lt 1280 ] && w=1280
	[ "$w" -gt 2560 ] && w=2560
	printf '%s' "$w"
}

# waifu2x picks the highest-scored Vulkan GPU by default; on a hybrid laptop that
# is the dGPU, which here fails vkCreateDevice when suspended AND intermittently
# emits all-black frames under PRIME (a clean probe, then garbage on the real
# run). A small probe cannot catch that, so the enhance instead runs each GPU on
# the actual clip, validates the output, and keeps the first that is not black;
# the last good GPU is remembered so the reliable one is tried first next time.
w2x_model="/usr/share/waifu2x-ncnn-vulkan/models-cunet"

# sane_img: succeed only when an image has real content, not the near-black /
# flat garbage a wedged or overloaded GPU can emit. Guards every waifu2x output
# so a bad run is discarded, never written over a good source.
sane_img() {
	local m s
	# [0]: probe the first frame only — a bare %[fx:...] on an animation prints
	# one value per frame concatenated ("0.4966390.496639"), which awk reads as
	# garbage and the sanity gate then rejects every animated enhance.
	m="$(identify -format '%[fx:mean]' "$1[0]" 2>/dev/null)"
	s="$(identify -format '%[fx:standard_deviation]' "$1[0]" 2>/dev/null)"
	[ -n "$m" ] && [ -n "$s" ] && awk -v m="$m" -v s="$s" 'BEGIN{exit !(m>0.02 && s>0.01)}'
}
w2x_gpu_pref="${XDG_STATE_HOME:-$HOME/.local/state}/ryoku-w2x-gpu"
# w2x_order: GPU indices to attempt, last-known-good first (persisted after a
# clean run) then every index.
w2x_order() {
	local p
	p="$(cat "$w2x_gpu_pref" 2>/dev/null || true)"
	case "$p" in 0 | 1 | 2 | 3) printf '%s 0 1 2 3' "$p" ;; *) printf '0 1 2 3' ;; esac
}

# real dimensions for a batch of local clips: newline-separated paths in,
# "path<TAB>WxH" rows out ("" when unreadable). The local grids badge from
# this, and the amber low-res hint marks exactly the clips worth enhancing.
# Only videos get probed — clip pools stay small, image pools don't. 8 probes
# at a time: the UI renders only after the whole list closes, so one serial
# ffprobe per clip would hold a big pool's grid hostage. Each row is a single
# short write (well under PIPE_BUF), so parallel probes never interleave; the
# path is passed as a positional, never spliced into the sh -c text.
vid_res_map() {
	xargs -r -d '\n' -n 1 -P 8 sh -c \
		'printf "%s\t%s\n" "$1" "$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 "$1" 2>/dev/null | head -1)"' _
}

# downloads land as-is now; enhancing is an explicit, on-demand action.
finish() { printf '%s\n' "$1"; }

# enhance an image in place on the GPU: waifu2x doubles the resolution and
# denoises. 4k sources are already sharp, so skip them (minutes of GPU, no gain).
enhance_image() {
	local f="$1" ext tmp h gpu gpus
	ext="$(printf '%s' "${f##*.}" | tr '[:upper:]' '[:lower:]')"
	[ "$ext" = jpeg ] && ext=jpg
	# [0]: probe the first frame only — on an animated webp/gif a bare %h prints
	# every frame's height concatenated ("12001200"), which would both misread a
	# 1080p wallpaper as past-4K and put that nonsense number in the verdict.
	h="$(identify -format '%h' "$f[0]" 2>/dev/null || echo 0)"
	case "$h" in '' | *[!0-9]*) h=0 ;; esac
	[ "$h" -gt 0 ] || { enh_write "$f" error; enh_verdict error image 0 0 "" read; return 1; }
	if [ "$h" -ge 2160 ]; then enh_write "$f" "sharp"; enh_verdict sharp image "$h" 2160; return 2; fi
	command -v waifu2x-ncnn-vulkan >/dev/null 2>&1 || { enh_write "$f" unsupported; enh_verdict unsupported image; return 3; }
	enh_write "$f" enhance
	tmp="$f.up.$ext"
	read -ra gpus <<<"$(w2x_order)"
	for gpu in "${gpus[@]}"; do
		rm -f "$tmp"
		waifu2x-ncnn-vulkan -i "$f" -o "$tmp" -s 2 -n 2 -g "$gpu" -m "$w2x_model" >/dev/null 2>&1 || continue
		if [ -s "$tmp" ] && sane_img "$tmp"; then
			mv -f "$tmp" "$f"
			printf '%s' "$gpu" >"$w2x_gpu_pref" 2>/dev/null || true
			enh_write "$f" "done"
			enh_verdict done image
			return 0
		fi
	done
	rm -f "$tmp"; enh_write "$f" error; enh_verdict error image 0 0 "" gpu; return 1
}

# enhance a video frame by frame: ffmpeg extracts, waifu2x doubles every frame,
# ffmpeg reassembles at the source rate (audio copied when present). Runs in the
# foreground so the UI can track the phase and frame count; only swaps the crisp
# clip onto the desktop if it is still the live wallpaper when it lands.
enhance_video() {
	local f="$1" d fps w cap total wpid gpu out chk ok gpus
	command -v ffmpeg >/dev/null 2>&1 || { enh_write "$f" error; enh_verdict error video 0 0 "" tools; return 1; }
	command -v waifu2x-ncnn-vulkan >/dev/null 2>&1 || { enh_write "$f" unsupported; enh_verdict unsupported video; return 3; }
	enh_write "$f" probe
	# livewall decodes a live wallpaper at the screen width (screen_cap); a source
	# already that wide gains nothing on screen, but a smaller one (e.g. a 720p
	# moewalls loop on a 1440p panel) gets real detail, so only skip at/above it.
	# || true: ffprobe failing on a truncated download must fall through to the
	# extract error below, not errexit the whole verb with no verdict written.
	w="$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=p=0 "$f" 2>/dev/null | head -1 || true)"
	cap="$(screen_cap)"
	if [ "${w:-0}" -ge "$cap" ]; then enh_write "$f" "sharp"; enh_verdict sharp video "${w:-0}" "$cap"; return 2; fi
	fps="$(ffprobe -v error -select_streams v:0 -show_entries stream=r_frame_rate -of csv=p=0 "$f" 2>/dev/null | head -1 || true)"
	[ -n "$fps" ] && [ "$fps" != "0/0" ] || fps=30
	d="$(mktemp -d)" || { enh_write "$f" error; enh_verdict error video 0 0 "" io; return 1; }
	mkdir -p "$d/in" "$d/out"
	enh_write "$f" extract
	if ! ffmpeg -y -i "$f" -qscale:v 1 -qmin 1 -qmax 1 -vsync 0 "$d/in/%08d.png" >/dev/null 2>&1; then
		rm -rf "$d"; enh_write "$f" error; enh_verdict error video 0 0 "" read; return 1
	fi
	total="$(find "$d/in" -name '*.png' | wc -l)"
	[ "${total:-0}" -gt 0 ] || { rm -rf "$d"; enh_write "$f" error; enh_verdict error video 0 0 "" read; return 1; }
	# try each GPU on the real clip and validate a middle frame: a hybrid dGPU can
	# pass a small probe then emit all-black, so only the actual output proves a
	# GPU. Last good GPU first; the first clean run wins and is remembered.
	# ok starts assigned: a bare `local ok` stays unset, and when every GPU fails
	# set -u would kill the [ -n "$ok" ] check before the error verdict prints.
	ok=""
	read -ra gpus <<<"$(w2x_order)"
	for gpu in "${gpus[@]}"; do
		rm -rf "$d/out"; mkdir -p "$d/out"
		enh_write "$f" enhance 0 "$total"
		waifu2x-ncnn-vulkan -i "$d/in" -o "$d/out" -s 2 -n 2 -g "$gpu" -m "$w2x_model" >/dev/null 2>&1 &
		wpid=$!
		while kill -0 "$wpid" 2>/dev/null; do
			enh_write "$f" enhance "$(find "$d/out" -name '*.png' 2>/dev/null | wc -l)" "$total"
			sleep 1
		done
		wait "$wpid" || continue
		chk="$(printf '%08d' "$(( total / 2 > 0 ? total / 2 : 1 ))")"
		if [ -s "$d/out/$chk.png" ] && sane_img "$d/out/$chk.png"; then
			printf '%s' "$gpu" >"$w2x_gpu_pref" 2>/dev/null || true
			ok=1; break
		fi
	done
	[ -n "$ok" ] || { rm -rf "$d"; enh_write "$f" error; enh_verdict error video 0 0 "" gpu; return 1; }
	enh_write "$f" assemble "$total" "$total"
	if ! ffmpeg -y -framerate "$fps" -i "$d/out/%08d.png" -i "$f" -map 0:v:0 -map 1:a:0? -c:a copy -c:v libx264 -pix_fmt yuv420p -movflags +faststart "$d/final.mp4" >/dev/null 2>&1; then
		rm -rf "$d"; enh_write "$f" error; enh_verdict error video 0 0 "" assemble; return 1
	fi
	# non-destructive: waifu2x output is H.264, so write a correctly-named .mp4
	# beside the source and switch to it, never overwriting the original clip.
	out="${f%.*}.mp4"
	mv -f "$d/final.mp4" "$out" || { rm -rf "$d"; enh_write "$f" error; enh_verdict error video 0 0 "" io; return 1; }
	rm -rf "$d"
	enh_write "$out" "done" "$total" "$total"
	enh_verdict done video 0 0 "$out"
	still_current "$f" && ryoku-shell wallpaper set "$out" >/dev/null 2>&1 || true
}

# grade an image with imagemagick: brightness / contrast / saturation / warmth,
# optional vignette. The same pipeline drives the small live preview and the
# full-res bake, so the rice preview is exactly what Set writes. warmth shifts
# the red / blue channels (warm = redder, cool = bluer); --size caps the long
# edge for a fast preview render. src may be a local path or an http(s) url.
adjust_image() {
	local src="$1" out="$2"; shift 2
	local br=0 ct=0 sat=0 warm=0 vig=0 size=0 rmul bmul
	while [ $# -gt 0 ]; do
		case "$1" in
		--brightness) br="$2"; shift 2 ;;
		--contrast) ct="$2"; shift 2 ;;
		--saturation) sat="$2"; shift 2 ;;
		--warmth) warm="$2"; shift 2 ;;
		--vignette) vig=1; shift ;;
		--size) size="$2"; shift 2 ;;
		*) shift ;;
		esac
	done
	local in="$src" tmp=""
	if printf '%s' "$src" | grep -qE '^https?://'; then
		tmp="$(mktemp)"; curl -fsSL -A "$ua" "$src" -o "$tmp" || { rm -f "$tmp"; return 1; }
		in="$tmp"
	fi
	local args=()
	[ "${size:-0}" -gt 0 ] && args+=(-resize "${size}x${size}>")
	if [ "$warm" -ne 0 ]; then
		rmul="$(awk -v w="$warm" 'BEGIN{printf "%.4f", 1 + w*0.0018}')"
		bmul="$(awk -v w="$warm" 'BEGIN{printf "%.4f", 1 - w*0.0018}')"
		args+=(-channel R -evaluate multiply "$rmul" +channel -channel B -evaluate multiply "$bmul" +channel)
	fi
	args+=(-modulate "$((100 + br)),$((100 + sat)),100")
	[ "$ct" -ne 0 ] && args+=(-brightness-contrast "0x${ct}")
	[ "$vig" = 1 ] && args+=(-background black -vignette 0x18)
	mkdir -p "$(dirname "$out")" 2>/dev/null || true
	magick "$in" "${args[@]}" "$out"
	local rc=$?
	[ -n "$tmp" ] && rm -f "$tmp"
	return $rc
}

auth=()
[ -n "$key" ] && auth=(-H "X-API-Key: $key")

cmd="${1:-}"; shift || true

case "$cmd" in
search)
	query=""; page=1; top_range=""; ratios=""; purity=""; as_json=0
	while [ $# -gt 0 ]; do
		case "$1" in
		--query) query="$2"; shift 2 ;;
		--page) page="$2"; shift 2 ;;
		--top-range) top_range="$2"; shift 2 ;;
		--ratios) ratios="$2"; shift 2 ;;
		--purity) purity="$2"; shift 2 ;;
		--json) as_json=1; shift ;;
		*) shift ;;
		esac
	done
	params=(-G "$api/search" --data-urlencode "page=$page")
	if [ -n "$top_range" ]; then
		params+=(--data-urlencode "sorting=toplist" --data-urlencode "topRange=$top_range")
	else
		params+=(--data-urlencode "sorting=date_added")
	fi
	[ -n "$query" ] && params+=(--data-urlencode "q=$query")
	[ -n "$ratios" ] && params+=(--data-urlencode "ratios=$ratios")
	[ -n "$purity" ] && params+=(--data-urlencode "purity=$purity")
	resp="$(curl -fsSL "${auth[@]}" "${params[@]}")"
	if [ "$as_json" = 1 ]; then
		jq -c '.data[] | {
			id: .id,
			path: .path,
			thumb: .thumbs.small,
			large: .thumbs.original,
			resolution: .resolution,
			name: .id,
			wallhaven_url: .url
		}' <<<"$resp"
	else
		jq -r '.data[].path' <<<"$resp"
	fi
	;;
download)
	id="${1:?id required}"; url="${2:?url required}"
	mkdir -p "$dest"
	ext="${url##*.}"; [ "${#ext}" -gt 5 ] && ext="jpg"
	out="$dest/wallhaven-$id.$ext"
	curl -fsSL "${auth[@]}" "$url" -o "$out"
	finish "$out"
	;;
palette)
	url=""; pal=""; cs=""; backend=""; sat=""; thr=""; contrast=0
	while [ $# -gt 0 ]; do
		case "$1" in
		--palette) pal="$2"; shift 2 ;;
		--colorspace) cs="$2"; shift 2 ;;
		--backend) backend="$2"; shift 2 ;;
		--saturation) sat="$2"; shift 2 ;;
		--threshold) thr="$2"; shift 2 ;;
		--contrast) contrast=1; shift ;;
		*) [ -z "$url" ] && url="$1"; shift ;;
		esac
	done
	: "${url:?image url required}"
	tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
	img="$tmp/img"
	if [ -f "$url" ]; then cp -- "$url" "$img"; else curl -fsSL "${auth[@]}" "$url" -o "$img"; fi
	# Skip templates, sequences and hooks, cache in the scratch dir: generating
	# the scheme never disturbs the running desktop. Tune flags mirror the apply.
	wargs=(run "$img" -T -s -q --no-hooks --print-scheme)
	[ -n "$pal" ] && wargs+=(-p "$pal")
	[ -n "$cs" ] && wargs+=(-c "$cs")
	[ -n "$backend" ] && wargs+=(-b "$backend")
	[ -n "$sat" ] && wargs+=(--saturation "$sat")
	[ -n "$thr" ] && wargs+=(-t "$thr")
	[ "$contrast" = 1 ] && wargs+=(-k)
	XDG_CACHE_HOME="$tmp/cache" wallust "${wargs[@]}"
	;;
moewalls-search)
	# Anime / aesthetic live wallpapers from moewalls.com. No API, but it runs
	# WordPress, so its wp-json feed lists posts with a poster (featuredmedia); the
	# looping preview.webm derives straight from that poster's path, no per-post
	# fetch. No query browses the anime category. Same item shape as `search`.
	query=""; page=1
	while [ $# -gt 0 ]; do
		case "$1" in
		--query) query="$2"; shift 2 ;;
		--page) page="$2"; shift 2 ;;
		--json) shift ;;
		*) shift ;;
		esac
	done
	mw="https://moewalls.com/wp-json/wp/v2/posts"
	params=(-G "$mw" --data-urlencode "per_page=24" --data-urlencode "page=$page" --data-urlencode "_embed=1")
	if [ -n "$query" ]; then
		params+=(--data-urlencode "search=$query")
	else
		params+=(--data-urlencode "categories=18") # anime
	fi
	resp="$(curl -fsSL -A "$ua" "${params[@]}")"
	# poster: /uploads/YYYY/MM/BASE-thumb.jpg -> preview: /uploads/preview/YYYY/BASE-preview.webm
	# resolution stays empty: previews range from 720p to 1440p and dual-wide, and
	# neither the URL nor the poster metadata says which — a hardcoded label made
	# enhance look broken ("Already sharp" on a clip the grid had promised was 720p).
	jq -c '.[]
		| (._embedded["wp:featuredmedia"][0].source_url // "") as $thumb
		| ($thumb | sub("/uploads/(?<y>[0-9]{4})/[0-9]{2}/(?<b>[^/]+)-thumb\\.(jpe?g|png)"; "/uploads/preview/\(.y)/\(.b)-preview.webm")) as $vid
		| ($vid | if . != $thumb then . else "" end) as $webm
		| {
			id: (.id|tostring),
			thumb: $thumb,
			video: $webm,
			dl: $webm,
			resolution: "",
			name: (.title.rendered | gsub(" Live Wallpaper$"; "")),
			moewalls_url: .link
		}' <<<"$resp"
	;;
moewalls-download)
	# Save a moewalls preview.webm into livewalls so the switcher picks it up too.
	id="${1:?id required}"; url="${2:?url required}"
	dest="$HOME/Pictures/livewalls"; mkdir -p "$dest"
	ext="${url##*.}"; [ "${#ext}" -gt 5 ] && ext="webm"
	out="$dest/moewalls-$id.$ext"
	curl -fsSL -A "$ua" "$url" -o "$out"
	finish "$out"
	;;
motionbgs-search)
	# motionbgs.com has no API: enumerate posters off the server-rendered listing
	# (each carries the media id), then address the video by id via /dl/hd (1080p,
	# streamed in the preview) and /dl/4k (the master, downloaded on Save). Grid
	# shows only the small poster, so nothing heavy is pulled while browsing.
	query=""; page=1
	while [ $# -gt 0 ]; do
		case "$1" in
		--query) query="$2"; shift 2 ;;
		--page) page="$2"; shift 2 ;;
		--json) shift ;;
		*) shift ;;
		esac
	done
	mb="https://motionbgs.com"
	if [ -n "$query" ]; then
		q2="$(printf '%s' "$query" | tr '[:upper:] ' '[:lower:]-')"
		path="/tag:$q2/"; [ "$page" -gt 1 ] && path="/tag:$q2/$page"
	else
		path="/"; [ "$page" -gt 1 ] && path="/$page"
	fi
	html="$(curl -fsSL -A "$ua" -e "$mb/" "$mb$path")"
	# posters look like /i/c/{WxH}/media/{id}/{name}[.{res}].jpg. Take the media id
	# from the path, skip tiny icon crops (<300px wide), dedupe by id, cap 24.
	printf '%s' "$html" | grep -oE '/i/c/[0-9]+x[0-9]+/media/[0-9]+/[^"'"'"' ]+\.jpe?g' \
		| awk -F'/' 'BEGIN{OFS="\t"} { split($4,c,"x"); if (c[1]+0 < 300) next; if (seen[$6]++) next; print $6, $0 }' \
		| head -24 \
		| while IFS="$(printf '\t')" read -r id poster; do
			fname="${poster##*/}"
			base="$(printf '%s' "$fname" | sed -E 's#\.[0-9]+x[0-9]+##; s#\.jpe?g$##')"
			res="$(printf '%s' "$fname" | sed -nE 's#.*\.([0-9]+x[0-9]+)\.jpe?g$#\1#p')"
			jq -cn --arg t "$mb$poster" --arg v "$mb/dl/hd/$id/" --arg d "$mb/dl/4k/$id/" \
				--arg n "$(printf '%s' "$base" | tr '-' ' ')" --arg id "$id" --arg r "$res" \
				'{id:$id,thumb:$t,video:$v,dl:$d,resolution:$r,name:$n}'
		done
	;;
motionbgs-download)
	id="${1:?id required}"; url="${2:?url required}"
	dest="$HOME/Pictures/livewalls"; mkdir -p "$dest"
	out="$dest/motionbgs-$id.mp4"
	curl -fsSL -A "$ua" -e "https://motionbgs.com/" "$url" -o "$out"
	finish "$out"
	;;
library-list)
	# Browse any GitHub repo of wallpapers the user added. Two shapes, auto-detected
	# off the repo tree: a livewalls/registry.json (curated, like ryoku-extras) or a
	# plain folder tree (each item dir = a video + a sibling poster, like Taiizor/Store).
	# Smart: emits poster + stream URL + full-download URL; nothing is pulled here.
	repo=""; branch=""; subpath=""; query=""; page=1; ltype="all"
	while [ $# -gt 0 ]; do
		case "$1" in
		--repo) repo="$2"; shift 2 ;;
		--branch) branch="$2"; shift 2 ;;
		--path) subpath="$2"; shift 2 ;;
		--query) query="$2"; shift 2 ;;
		--page) page="$2"; shift 2 ;;
		--type) ltype="$2"; shift 2 ;;
		--json) shift ;;
		*) [ -z "$repo" ] && repo="$1"; shift ;;
		esac
	done
	: "${repo:?owner/repo required}"
	tok="${GITHUB_TOKEN:-}"; [ -z "$tok" ] && tok="$(gh auth token 2>/dev/null || true)"
	auth=(); [ -n "$tok" ] && auth=(-H "Authorization: Bearer $tok")
	[ -z "$branch" ] && branch="$(curl -fsSL -A "$ua" "${auth[@]}" "https://api.github.com/repos/$repo" 2>/dev/null | jq -r '.default_branch // "main"')"
	rawb="https://raw.githubusercontent.com/$repo/$branch"
	cache="${XDG_CACHE_HOME:-$HOME/.cache}/ryoku/ryowalls"; mkdir -p "$cache"
	ck="$cache/tree-$(printf '%s' "$repo@$branch" | tr -c '[:alnum:]' '_').json"
	# cache the tree for an hour so paging/searching does not re-hit the API.
	if [ ! -s "$ck" ] || [ "$(( $(date +%s) - $(stat -c %Y "$ck" 2>/dev/null || echo 0) ))" -gt 3600 ]; then
		curl -fsSL -A "$ua" "${auth[@]}" "https://api.github.com/repos/$repo/git/trees/$branch?recursive=1" -o "$ck.tmp" 2>/dev/null && mv "$ck.tmp" "$ck"
	fi
	[ -s "$ck" ] || { echo "could not read $repo" >&2; exit 4; }
	ql="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')"
	from=$(( (page - 1) * 24 )); to=$(( page * 24 ))
	regp="$(jq -r '[.tree[].path | select(endswith("livewalls/registry.json") or . == "registry.json")][0] // ""' "$ck")"
	if [ -n "$regp" ]; then
		curl -fsSL -A "$ua" "$rawb/$regp" 2>/dev/null | jq -c --arg rawb "$rawb" --arg q "$ql" --arg type "$ltype" --argjson from "$from" --argjson to "$to" '
			def abs(p): if (p|test("^https?://")) then p else ($rawb + "/" + p) end;
			[ .wallpapers[]?
			  | select($type != "images")
			  | select($q == "" or (.name|ascii_downcase|contains($q)) or (any((.tags // [])[]; ascii_downcase|contains($q))))
			  | { id: .id, kind: "video", thumb: abs(.poster), video: abs(.video), dl: abs(.video), resolution: "", name: .name } ]
			| .[$from:$to][]'
		exit 0
	fi
	# a repo can hold videos (item dir = clip + sibling poster) AND standalone image
	# wallpapers. Emit both with a kind, filtered by --type (all | live | images).
	jq -c --arg rawb "$rawb" --arg sub "$subpath" --arg q "$ql" --arg type "$ltype" --argjson from "$from" --argjson to "$to" '
		def enc: split("/") | map(@uri) | join("/");
		def humanize: sub("-[0-9]+$";"") | gsub("[-_]";" ");
		[.tree[].path] as $all
		| ($all | map(select($sub == "" or startswith($sub)))) as $scoped
		| ($scoped | map(select(test("\\.(mp4|webm|mkv|mov)$";"i")))) as $vids
		| ($scoped | map(select(test("\\.(jpe?g|png|webp)$";"i")))) as $imgs
		| ($vids | map(sub("/[^/]+$";"")) | unique) as $viddirs
		| ($vids | group_by(sub("/[^/]+$";"")) | map({key:(.[0]|sub("/[^/]+$";"")), value:length}) | from_entries) as $vpd
		| (
		    ($imgs | map(select((sub("/[^/]+$";"")) as $d | ($viddirs | index($d)) | not) | select(test("thumb|poster|cover";"i")|not))
		      | map({ kind:"image", path:., dir:(sub("/[^/]+$";"")), thumb:., media:.,
		              name: (sub("^.*/";"")|sub("\\.[^.]+$";"")|humanize) }))
		    +
		    ($vids | map(
		      (sub("/[^/]+$";"")) as $dir
		      | ($imgs | map(select(startswith($dir + "/")))) as $di
		      | ((($di | map(select(test("thumb|poster|cover";"i"))))[0]) // ($di[0]) // "") as $poster
		      | { kind:"video", path:., dir:$dir, thumb:$poster, media:.,
		          name: (if ($vpd[$dir] // 2)==1 then ($dir|sub("^.*/";"")) else (.|sub("^.*/";"")|sub("\\.[^.]+$";"")) end | humanize) }))
		  )
		| map(select($type=="all" or ($type=="live" and .kind=="video") or ($type=="images" and .kind=="image")))
		| map(select($q=="" or (.path|ascii_downcase|contains($q))))
		| .[$from:$to][]
		| { id:.path, kind:.kind, thumb:(if .thumb=="" then "" else ($rawb+"/"+(.thumb|enc)) end), video:(if .kind=="video" then ($rawb+"/"+(.media|enc)) else "" end), dl:($rawb+"/"+(.media|enc)), resolution:"", name:.name }' "$ck"
	;;
library-download)
	# Full-quality download on Save. Videos land in livewalls, images in
	# Wallpapers, so each pool stays clean and Super+W cycles them right.
	id="${1:?id required}"; url="${2:?url required}"
	ext="${url##*.}"; ext="${ext%%\?*}"
	case "$ext" in
	mp4|webm|mkv|mov) dest="$HOME/Pictures/livewalls" ;;
	jpg|jpeg|png|webp) dest="$HOME/Pictures/Wallpapers" ;;
	*) ext="mp4"; dest="$HOME/Pictures/livewalls" ;;
	esac
	mkdir -p "$dest"
	out="$dest/lib-$(printf '%s' "$url" | md5sum | cut -c1-12).$ext"
	curl -fsSL -A "$ua" "$url" -o "$out"
	finish "$out"
	;;
extras-search)
	# Curated live wallpapers from the ryoku-extras repo (livewalls/registry.json).
	# Posters are in-repo (raw), clips are Release assets (absolute URLs in the
	# registry). No key. --query filters by name/tag client-side (small catalogue).
	query=""
	while [ $# -gt 0 ]; do
		case "$1" in
		--query) query="$2"; shift 2 ;;
		--page) shift 2 ;;
		--json) shift ;;
		*) shift ;;
		esac
	done
	xbase="${RYOKU_EXTRAS_BASE:-https://raw.githubusercontent.com/neur0map/ryoku-extras/main}"
	xbase="${xbase%/}"
	resp="$(curl -fsSL -A "$ua" "$xbase/livewalls/registry.json")"
	q="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')"
	jq -c --arg base "$xbase" --arg q "$q" '.wallpapers[]
		| select($q == "" or (.name|ascii_downcase|contains($q)) or (any((.tags // [])[]; ascii_downcase|contains($q))))
		| {
			id: .id,
			thumb: ($base + "/" + .poster),
			video: .video,
			dl: .video,
			resolution: "",
			name: .name,
			author: (.author // "")
		}' <<<"$resp"
	;;
extras-download)
	# Save a curated clip into livewalls. -L follows the Release redirect.
	id="${1:?id required}"; url="${2:?url required}"
	dest="$HOME/Pictures/livewalls"; mkdir -p "$dest"
	ext="${url##*.}"; [ "${#ext}" -gt 5 ] && ext="mp4"
	out="$dest/ryoku-$id.$ext"
	curl -fsSL -A "$ua" "$url" -o "$out"
	finish "$out"
	;;
live-list)
	# Local live wallpapers the user dropped or downloaded. Newest first, each
	# badged with its real resolution (parallel probe, order restored via map).
	dir="$HOME/Pictures/livewalls"; mkdir -p "$dir"
	mapfile -t vids < <(find "$dir" -maxdepth 1 -type f \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' \) -printf '%T@\t%p\n' 2>/dev/null | sort -rn | cut -f2-)
	declare -A vres=()
	[ "${#vids[@]}" -gt 0 ] && while IFS="$(printf '\t')" read -r vf vr; do vres["$vf"]="$vr"; done < <(printf '%s\n' "${vids[@]}" | vid_res_map)
	for f in "${vids[@]}"; do
		jq -cn --arg p "$f" --arg n "$(basename "$f")" --arg r "${vres[$f]:-}" '{id: $p, thumb: "", video: $p, resolution: $r, name: $n}'
	done
	;;
live-import)
	# Copy the user's own mp4 into livewalls.
	src="${1:?source required}"; src="${src#file://}"
	dir="$HOME/Pictures/livewalls"; mkdir -p "$dir"
	out="$dir/$(basename "$src")"
	cp -f -- "$src" "$out"
	printf '%s\n' "$out"
	;;
enhance)
	# On-demand enhance of a wallpaper already on disk (image or video). Blocks
	# while it works, writing progress the UI polls; the video path guards its
	# desktop swap on the file still being live, so a late finish can't yank an
	# old wallpaper back.
	f="${1:?path required}"
	ext="$(printf '%s' "${f##*.}" | tr '[:upper:]' '[:lower:]')"
	case "$ext" in
	mp4 | webm | mkv | mov) enhance_video "$f" ;;
	*) enhance_image "$f" ;;
	esac
	;;
adjust)
	# Grade an image (brightness/contrast/saturation/warmth[/vignette]) into a new
	# file. src may be a url; --size caps the long edge for a fast preview render.
	# Prints the output path so the UI can point the preview or the set at it.
	src="${1:?source required}"; out="${2:?output required}"; shift 2
	adjust_image "$src" "$out" "$@" && printf '%s\n' "$out"
	;;
local-list)
	# Wallpapers already on this machine: images in ~/Pictures/Wallpapers and live
	# clips in ~/Pictures/livewalls, in one grid so you can reset or prune them.
	# Newest first. --type all|images|live narrows, --query filters by filename.
	ltype="all"; query=""
	while [ $# -gt 0 ]; do
		case "$1" in
		--type) ltype="$2"; shift 2 ;;
		--query) query="$2"; shift 2 ;;
		--json) shift ;;
		*) shift ;;
		esac
	done
	ql="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')"
	mapfile -t lrows < <({
		[ "$ltype" = live ] || find "$HOME/Pictures/Wallpapers" -maxdepth 1 -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) -printf '%T@\timage\t%p\n' 2>/dev/null
		[ "$ltype" = images ] || find "$HOME/Pictures/livewalls" -maxdepth 1 -type f \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' \) -printf '%T@\tvideo\t%p\n' 2>/dev/null
	} | sort -rn | cut -f2-)
	vids=()
	for row in "${lrows[@]}"; do
		[ "${row%%$'\t'*}" = video ] && vids+=("${row#*$'\t'}")
	done
	declare -A vres=()
	[ "${#vids[@]}" -gt 0 ] && while IFS="$(printf '\t')" read -r vf vr; do vres["$vf"]="$vr"; done < <(printf '%s\n' "${vids[@]}" | vid_res_map)
	for row in "${lrows[@]}"; do
		kind="${row%%$'\t'*}"; f="${row#*$'\t'}"
		n="$(basename "$f")"
		[ -z "$ql" ] || case "$(printf '%s' "$n" | tr '[:upper:]' '[:lower:]')" in *"$ql"*) ;; *) continue ;; esac
		if [ "$kind" = video ]; then
			jq -cn --arg p "$f" --arg n "$n" --arg r "${vres[$f]:-}" '{id:$p, thumb:"", video:$p, resolution:$r, name:$n}'
		else
			jq -cn --arg p "$f" --arg n "$n" '{id:$p, path:$p, thumb:$p, large:$p, resolution:"", name:$n}'
		fi
	done
	;;
local-remove)
	# Delete on-disk wallpapers the UI picked. Guard hard: only unlink files under
	# ~/Pictures/Wallpapers or ~/Pictures/livewalls, never anything else.
	for f in "$@"; do
		case "$f" in
		"$HOME/Pictures/Wallpapers/"* | "$HOME/Pictures/livewalls/"*) [ -f "$f" ] && rm -f -- "$f" ;;
		esac
	done
	;;
caps)
	# what enhancement the machine can do, so the UI offers, installs, or hides.
	# vulkan = a GPU that can run it; upscaler = the ncnn tool installed (one tool
	# now sharpens both images and, frame by frame, video).
	vk=false; up=false
	[ -n "$(ls /usr/share/vulkan/icd.d/*.json 2>/dev/null)" ] && vk=true
	{ command -v waifu2x-ncnn-vulkan || command -v realesrgan-ncnn-vulkan; } >/dev/null 2>&1 && up=true
	jq -cn --argjson vk "$vk" --argjson up "$up" '{vulkan:$vk,upscaler:$up}'
	;;
*)
	echo "usage: ryowalls search --query <q> --page <n> [--top-range <r>] [--ratios <r>] --json | download <id> <url> | palette <url> [flags] | adjust <src> <out> [--brightness N] [--contrast N] [--saturation N] [--warmth N] [--vignette] [--size W] | enhance <path> | moewalls-search [--query <q>] [--page <n>] --json | moewalls-download <id> <url> | extras-search [--query <q>] --json | extras-download <id> <url> | live-list | live-import <src> | local-list [--type <t>] [--query <q>] | local-remove <path>..." >&2
	exit 2
	;;
esac
