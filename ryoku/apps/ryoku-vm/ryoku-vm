#!/usr/bin/env bash
# launch the configured Ryoku VM from the app launcher. ryoku-hub does the
# real work (pass the dGPU to the VM, start it, open Looking Glass). run it
# detached so any blocker (relogin, reboot, one-time setup) surfaces as a
# desktop notification instead of failing silently.
set -u

if ! out="$(ryoku-hub vm launch 2>&1)"; then
  notify-send -a "Ryoku VM" "Ryoku VM" "${out:-Could not launch the VM. Open Ryoku Settings > GPU.}"
  exit 1
fi
