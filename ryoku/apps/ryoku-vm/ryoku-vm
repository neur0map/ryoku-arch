#!/usr/bin/env bash
# Launch the configured Ryoku VM from the app launcher. ryoku-hub does the work
# (hand the dGPU to the VM, start it, open Looking Glass); we run it detached, so we
# surface any blocker -- a needed relogin, reboot, or one-time setup -- as a desktop
# notification instead of failing silently.
set -u

if ! out="$(ryoku-hub vm launch 2>&1)"; then
  notify-send -a "Ryoku VM" "Ryoku VM" "${out:-Could not launch the VM. Open Ryoku Settings > GPU.}"
  exit 1
fi
