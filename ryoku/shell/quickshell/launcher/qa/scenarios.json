{
  "scenarios": [
    {
      "id": "sock-roundtrip",
      "name": "Socket toggle opens then closes the palette",
      "covers": "shell.qml command socket fast path",
      "steps": [
        "sh mkdir -p /tmp/launcher-qa-fixtures",
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'toggle\\n'; sleep .3)|socat - UNIX-CONNECT:$S >/tmp/launcher-qa-fixtures/t1.out; sleep .7; (printf 'state\\n'; sleep .5)|socat - UNIX-CONNECT:$S >/tmp/launcher-qa-fixtures/s1.json",
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'toggle\\n'; sleep .3)|socat - UNIX-CONNECT:$S >/dev/null; sleep .7"
      ],
      "asserts": [".open == false"],
      "shell_asserts": [
        "grep -q '^ok' /tmp/launcher-qa-fixtures/t1.out",
        "jq -e '.open == true' /tmp/launcher-qa-fixtures/s1.json >/dev/null"
      ]
    },
    {
      "id": "sock-unknown-err",
      "name": "Unknown socket command answers err and changes nothing",
      "covers": "shell.qml runCommand fallback contract",
      "steps": [
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'frobnicate\\n'; sleep .3)|socat - UNIX-CONNECT:$S >/tmp/launcher-qa-fixtures/err.out"
      ],
      "asserts": [".open == false"],
      "shell_asserts": ["grep -q '^err' /tmp/launcher-qa-fixtures/err.out"]
    },
    {
      "id": "show-resets-clean",
      "name": "Reopening resets query, grid, help to a clean rest state",
      "covers": "Launcher.onShownChanged reset",
      "steps": ["show", "type kitty", "hide", "show"],
      "asserts": [".open == true", ".query == \"\"", ".resting == true", ".gridMode == false", ".help == false"]
    },
    {
      "id": "app-exact",
      "name": "Exact app name puts the app first with Launch verb",
      "covers": "apps provider ranking + primary action",
      "steps": ["show", "type kitty", "settle"],
      "asserts": [
        ".resultCount >= 1",
        ".results[0].title == \"kitty\"",
        ".results[0].type == \"App\"",
        ".selectedActions[0] == \"Launch\""
      ],
      "screenshot": true
    },
    {
      "id": "app-prefix-rank",
      "name": "Name-prefix match outranks looser matches",
      "covers": "fuzzy 3-tier ranking",
      "steps": ["show", "type neo", "settle"],
      "asserts": [".results[0].title | test(\"^Neo\"; \"i\")"]
    },
    {
      "id": "app-subsequence",
      "name": "Character subsequence still finds the app",
      "covers": "fuzzy tier 3 subsequence",
      "steps": ["show", "type fntfrg", "settle"],
      "asserts": ["[.results[] | select(.title == \"FontForge\")] | length == 1"]
    },
    {
      "id": "app-genericname",
      "name": "Match via generic name / keywords (terminal finds kitty)",
      "covers": "fuzzy haystack includes genericName+keywords",
      "steps": ["show", "type terminal", "settle"],
      "asserts": ["[.results[] | select(.title == \"kitty\" and .type == \"App\")] | length == 1"]
    },
    {
      "id": "app-launch-frecency",
      "name": "Enter launches the app, closes palette, bumps frecency",
      "covers": "activation, execDetached, Frecency.bump persistence",
      "steps": [
        "sh mkdir -p /tmp/launcher-qa-fixtures; hyprctl clients -j | jq '[.[]|select(.class==\"kitty\")]|length' >/tmp/launcher-qa-fixtures/kitty.before; jq -r '[to_entries[]|select(.key|test(\"kitty\";\"i\"))|.value] | add // 0' ~/.local/state/ryoku/launcher-usage.json 2>/dev/null >/tmp/launcher-qa-fixtures/frec.before || echo 0 >/tmp/launcher-qa-fixtures/frec.before",
        "show", "type kitty", "settle", "key Return", "sleep 2"
      ],
      "asserts": [".open == false"],
      "shell_asserts": [
        "b=$(cat /tmp/launcher-qa-fixtures/kitty.before); a=$(hyprctl clients -j | jq '[.[]|select(.class==\"kitty\")]|length'); [ \"$a\" -gt \"$b\" ]",
        "b=$(cat /tmp/launcher-qa-fixtures/frec.before); a=$(jq -r '[to_entries[]|select(.key|test(\"kitty\";\"i\"))|.value] | add // 0' ~/.local/state/ryoku/launcher-usage.json); [ \"$a\" -gt \"$b\" ]"
      ],
      "teardown": [
        "addr=$(hyprctl clients -j | jq -r '[.[]|select(.class==\"kitty\")]|sort_by(.pid)|last.address'); [ -n \"$addr\" ] && hyprctl dispatch closewindow address:$addr"
      ]
    },
    {
      "id": "nomatch-web-fallback",
      "name": "Unmatched plain query still offers exactly the web fallback row",
      "covers": "web provider low-ranked fallback",
      "steps": ["show", "type qzwxecrv", "settle"],
      "asserts": [
        ".resultCount == 1",
        ".results[0].subtitle == \"Search Google\"",
        ".results[0].type == \"Web\""
      ],
      "screenshot": true
    },
    {
      "id": "grid-open",
      "name": "Ctrl+A at rest opens the all-apps grid",
      "covers": "gridMode toggle",
      "steps": ["show", "ctrl a", "sleep 0.6"],
      "asserts": [".gridMode == true", ".open == true"],
      "screenshot": true
    },
    {
      "id": "grid-escape-back",
      "name": "Escape leaves the grid but keeps the palette open",
      "covers": "escape precedence: grid before close",
      "steps": ["show", "ctrl a", "sleep 0.5", "key Escape", "sleep 0.4"],
      "asserts": [".gridMode == false", ".open == true", ".resting == true"]
    },
    {
      "id": "help-open",
      "name": "F1 opens the help cheat-sheet",
      "covers": "help panel toggle",
      "steps": ["show", "key F1", "sleep 0.6"],
      "asserts": [".help == true", ".open == true"],
      "screenshot": true
    },
    {
      "id": "help-escape-back",
      "name": "Escape leaves help but keeps the palette open",
      "covers": "escape precedence: help before close",
      "steps": ["show", "key F1", "sleep 0.5", "key Escape", "sleep 0.4"],
      "asserts": [".help == false", ".open == true"]
    },
    {
      "id": "nav-down-moves",
      "name": "Arrow keys move the selection",
      "covers": "keyboard selection movement",
      "steps": ["show", "type a", "settle", "key Down Down", "sleep 0.3"],
      "asserts": [".selectedIndex == 2", ".resultCount >= 3"]
    },
    {
      "id": "nav-clamp-end",
      "name": "Selection clamps at the last result",
      "covers": "selection clamping",
      "steps": ["show", "type kitty", "settle", "key Down Down Down Down Down Down Down Down", "sleep 0.3"],
      "asserts": [".selectedIndex == .resultCount - 1"]
    },
    {
      "id": "panel-open",
      "name": "Ctrl+K opens the action panel for the selected row",
      "covers": "ActionPanel open + selectedActions",
      "steps": ["show", "type kitty", "settle", "ctrl k", "sleep 0.5"],
      "asserts": [".panelOpen == true", ".selectedActions | length >= 1"],
      "screenshot": true
    },
    {
      "id": "panel-escape-first",
      "name": "Escape closes the action panel before anything else",
      "covers": "escape precedence: panel first",
      "steps": ["show", "type kitty", "settle", "ctrl k", "sleep 0.4", "key Escape", "sleep 0.4"],
      "asserts": [".panelOpen == false", ".open == true", ".query == \"kitty\""]
    },
    {
      "id": "actions-catalog",
      "name": "Bare / lists the full 24-action catalog with tabs",
      "covers": "actions provider + category tabs browse",
      "steps": ["show", "type /", "settle"],
      "asserts": [
        ".actionMode == true",
        ".modeLabel == \"ACTIONS\"",
        ".resultCount == 24",
        ".results[0].title == \"Lock Screen\""
      ],
      "screenshot": true
    },
    {
      "id": "actions-filter-exact",
      "name": "/night narrows to exactly Night Light",
      "covers": "action fuzzy filter",
      "steps": ["show", "type /night", "settle"],
      "asserts": [".resultCount == 1", ".results[0].title == \"Night Light\""]
    },
    {
      "id": "actions-category-word",
      "name": "/media matches the whole Media category",
      "covers": "category keyword matching",
      "steps": ["show", "type /media", "settle"],
      "asserts": [".resultCount == 5", "[.results[].type] | unique == [\"Media\"]"]
    },
    {
      "id": "actions-tab-cycle",
      "name": "Tab cycles category tabs and narrows the list, Shift+Tab restores",
      "covers": "CategoryTabs cycle + provider narrowing",
      "steps": [
        "show", "type /", "settle", "key Tab", "sleep 0.5",
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'state\\n'; sleep .5)|socat - UNIX-CONNECT:$S >/tmp/launcher-qa-fixtures/tabs.state",
        "key ISO_Left_Tab", "sleep 0.5"
      ],
      "asserts": [".resultCount == 24"],
      "shell_asserts": [
        "jq -e '([.results[].type] | unique == [\"System\"]) and .resultCount < 24' /tmp/launcher-qa-fixtures/tabs.state >/dev/null"
      ]
    },
    {
      "id": "actions-subsequence",
      "name": "/scn subsequence-matches Screenshot and Screen Record",
      "covers": "action subsequence matching",
      "steps": ["show", "type /scn", "settle"],
      "asserts": [
        "[.results[] | select(.title == \"Screenshot\")] | length == 1",
        "[.results[] | select(.title == \"Screen Record\")] | length == 1"
      ]
    },
    {
      "id": "calc-prefix",
      "name": "=2+2 shows 4 in CALC mode",
      "covers": "calc provider prefix mode",
      "steps": ["show", "type =2+2", "settle"],
      "asserts": [
        ".modeLabel == \"CALC\"",
        ".results[0].title == \"4\"",
        ".results[0].type == \"Calc\""
      ],
      "screenshot": true
    },
    {
      "id": "calc-numeric-fallback",
      "name": "Numeric-looking plain query gets a calc row without prefix",
      "covers": "calc numericFallback in fan-out",
      "steps": ["show", "type 17*3", "settle"],
      "asserts": ["[.results[] | select(.type == \"Calc\" and .title == \"51\")] | length == 1"]
    },
    {
      "id": "calc-units",
      "name": "Unit conversion works (=100 cm to m)",
      "covers": "qalc unit conversion pass-through",
      "steps": ["show", "type =100 cm to m", "settle"],
      "asserts": [".results[0].type == \"Calc\"", ".results[0].title | test(\"^1\\\\s?m$\")"]
    },
    {
      "id": "calc-copy-on-enter",
      "name": "Enter on a calc result copies it to the clipboard and closes",
      "covers": "calc Copy action",
      "steps": ["sh wl-copy qa-sentinel-before", "show", "type =6*7", "settle", "key Return", "sleep 1"],
      "asserts": [".open == false"],
      "shell_asserts": ["[ \"$(wl-paste -n 2>/dev/null)\" = \"42\" ]"]
    },
    {
      "id": "clip-list",
      "name": "; lists clipboard history in CLIPBOARD mode",
      "covers": "clipboard provider listing",
      "steps": [
        "sh printf 'qa-clip-alpha-7391' | cliphist store",
        "show", "type ;", "settle"
      ],
      "asserts": [".modeLabel == \"CLIPBOARD\"", ".resultCount >= 1"],
      "screenshot": true
    },
    {
      "id": "clip-filter",
      "name": ";qa-clip filters history to the seeded entry",
      "covers": "clipboard substring filter",
      "steps": [
        "sh printf 'qa-clip-alpha-7391' | cliphist store",
        "show", "type ;qa-clip", "settle"
      ],
      "asserts": ["[.results[] | select(.title | contains(\"qa-clip-alpha-7391\"))] | length >= 1"]
    },
    {
      "id": "clip-recopy",
      "name": "Enter re-copies the selected history entry",
      "covers": "clipboard Copy action",
      "steps": [
        "sh printf 'qa-clip-alpha-7391' | cliphist store; wl-copy qa-other-content",
        "show", "type ;qa-clip-alpha", "settle", "key Return", "sleep 1"
      ],
      "asserts": [".open == false"],
      "shell_asserts": ["[ \"$(wl-paste -n 2>/dev/null)\" = \"qa-clip-alpha-7391\" ]"],
      "teardown": ["cliphist list | grep qa-clip | while read -r l; do printf '%s' \"$l\" | cliphist delete; done; wl-copy -c"]
    },
    {
      "id": "find-file",
      "name": "/file finds a file at home by name",
      "covers": "find provider file mode",
      "steps": [
        "sh touch ~/qa_probe_launcher.txt",
        "show", "type /file qa_probe_launcher", "settle"
      ],
      "asserts": [
        ".modeLabel == \"FILE\"",
        ".results[0].title == \"qa_probe_launcher.txt\"",
        ".results[0].type == \"File\""
      ],
      "screenshot": true
    },
    {
      "id": "find-folder",
      "name": "/folder finds a directory by name",
      "covers": "find provider folder mode",
      "steps": [
        "sh mkdir -p ~/qa_probe_dir",
        "show", "type /folder qa_probe_dir", "settle"
      ],
      "asserts": [".modeLabel == \"FOLDER\"", "[.results[] | select(.title == \"qa_probe_dir\")] | length == 1"],
      "teardown": ["rmdir ~/qa_probe_dir 2>/dev/null || true"]
    },
    {
      "id": "find-image",
      "name": "/image finds an image by name",
      "covers": "find provider image extension filter",
      "steps": [
        "sh mkdir -p ~/Pictures; printf 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==' | base64 -d > ~/Pictures/qa_probe_img.png",
        "show", "type /image qa_probe_img", "settle"
      ],
      "asserts": [".modeLabel == \"IMAGE\"", "[.results[] | select(.title == \"qa_probe_img.png\")] | length == 1"],
      "teardown": ["rm -f ~/Pictures/qa_probe_img.png"]
    },
    {
      "id": "find-empty-state",
      "name": "/file with no hits shows the empty state, not a hang",
      "covers": "find empty result + No matches UI",
      "steps": ["show", "type /file zzzznoexistfile", "settle"],
      "asserts": [".resultCount == 0", ".searching == false"],
      "screenshot": true,
      "teardown": ["rm -f ~/qa_probe_launcher.txt"]
    },
    {
      "id": "pkg-search",
      "name": "> searches packages across sources",
      "covers": "packages provider gpk search",
      "steps": ["show", "type >firefox", "settle 40"],
      "asserts": [".modeLabel == \"PACKAGE\"", "[.results[] | select(.title | test(\"firefox\"; \"i\"))] | length >= 1"],
      "screenshot": true,
      "network": true
    },
    {
      "id": "pkg-installed-row",
      "name": ">kitty surfaces the installed package",
      "covers": "packages verb/installed marker",
      "steps": ["show", "type >kitty", "settle 40"],
      "asserts": ["[.results[] | select((.title | test(\"^kitty\\\\s\")) and (.subtitle | test(\"^pacman\")))] | length >= 1"],
      "screenshot": true,
      "network": true
    },
    {
      "id": "web-prefix-answer",
      "name": "? query fetches a DDG instant answer panel",
      "covers": "web provider instant answers + AnswerPanel",
      "steps": ["show", "type ?what is nmap", "settle 15", "sleep 1"],
      "asserts": [".modeLabel == \"WEB\"", ".answerMode == true"],
      "screenshot": true,
      "network": true
    },
    {
      "id": "web-bang-engine",
      "name": "?!gh routes the search row to GitHub",
      "covers": "bang engine routing",
      "steps": ["show", "type ?!gh quickshell", "settle"],
      "asserts": ["[.results[] | select(.subtitle == \"Search GitHub\")] | length == 1"]
    },
    {
      "id": "web-plain-no-answer",
      "name": "Plain unprefixed query never fires the answer fetch",
      "covers": "web fallback row without DDG fetch",
      "steps": ["show", "type nmap", "settle"],
      "asserts": [".answerMode == false", "[.results[] | select(.subtitle == \"Search Google\")] | length == 1"]
    },
    {
      "id": "win-row",
      "name": "Open window surfaces as a Window row with class subtitle",
      "covers": "windows provider listing",
      "steps": [
        "sh kitty --title qa-probe-win sh -c 'sleep 180' & sleep 1.5",
        "show", "type qa-probe-win", "settle"
      ],
      "asserts": [
        "[.results[] | select(.title == \"qa-probe-win\" and .type == \"Window\" and .subtitle == \"kitty\")] | length == 1"
      ],
      "teardown": [
        "pid=$(hyprctl clients -j | jq -r '.[]|select(.title==\"qa-probe-win\").pid' | head -1); [ -n \"$pid\" ] && kill $pid || true"
      ]
    },
    {
      "id": "win-focus",
      "blocked": "compositor: every IPC-context focus path (lua dispatch, cycle_next, direction focus, wlr foreign-toplevel activate) is a silent no-op on hyprland 0.55.4; keybind-context dispatchers work. Launcher wiring is correct and verified to issue the activation.",
      "name": "Enter on a window row focuses that window",
      "covers": "windows Focus action via Hyprland dispatch",
      "steps": [
        "sh hyprctl activewindow -j | jq -r .address >/tmp/launcher-qa-fixtures/orig.addr; kitty --title qa-probe-win sh -c 'sleep 180' & sleep 1.5; hyprctl dispatch \"hl.dsp.focus({ window = \\\"address:$(cat /tmp/launcher-qa-fixtures/orig.addr)\\\" })\"",
        "sleep 0.5",
        "show", "type qa-probe-win", "settle", "key Return", "sleep 1.5"
      ],
      "asserts": [".open == false"],
      "shell_asserts": ["[ \"$(hyprctl activewindow -j | jq -r .title)\" = \"qa-probe-win\" ]"],
      "teardown": [
        "pid=$(hyprctl clients -j | jq -r '.[]|select(.title==\"qa-probe-win\").pid' | head -1); [ -n \"$pid\" ] && kill $pid || true",
        "o=$(cat /tmp/launcher-qa-fixtures/orig.addr 2>/dev/null); [ -n \"$o\" ] && hyprctl dispatch \"hl.dsp.focus({ window = \\\"address:$o\\\" })\" || true"
      ]
    },
    {
      "id": "snippet-copy",
      "name": "Snippet row copies its expanded body on Enter",
      "covers": "snippets provider + placeholder expansion",
      "steps": [
        "sh mkdir -p ~/.config/ryoku; printf '[{\"name\":\"qa-sig\",\"body\":\"QA-BODY {date}\"}]' > ~/.config/ryoku/launcher-snippets.json; wl-copy qa-sentinel; sleep 0.5",
        "show", "type qa-sig", "settle",
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'state\\n'; sleep .5)|socat - UNIX-CONNECT:$S >/tmp/launcher-qa-fixtures/snip.state",
        "key Return", "sleep 1"
      ],
      "asserts": [".open == false"],
      "shell_asserts": [
        "jq -e '[.results[] | select(.title == \"qa-sig\" and .type == \"Snippet\")] | length == 1' /tmp/launcher-qa-fixtures/snip.state >/dev/null",
        "wl-paste -n 2>/dev/null | grep -q '^QA-BODY 20'"
      ],
      "teardown": ["rm -f ~/.config/ryoku/launcher-snippets.json; wl-copy -c"]
    },
    {
      "id": "quicklink-row",
      "name": "Quicklink surfaces by name",
      "covers": "quicklinks provider",
      "steps": [
        "sh mkdir -p ~/.config/ryoku; printf '[{\"name\":\"qa wiki\",\"url\":\"https://wiki.archlinux.org/index.php?search={query}\"}]' > ~/.config/ryoku/launcher-quicklinks.json; sleep 0.5",
        "show", "type qa wiki", "settle"
      ],
      "asserts": ["[.results[] | select(.title == \"qa wiki\" and .type == \"Quicklink\")] | length == 1"],
      "teardown": ["rm -f ~/.config/ryoku/launcher-quicklinks.json"]
    },
    {
      "id": "script-provider",
      "name": "rofi-script rows appear for keyword query and get env per protocol",
      "covers": "script provider rofi protocol pass 1",
      "steps": [
        "sh mkdir -p /tmp/launcher-qa-fixtures ~/.config/ryoku; printf '#!/bin/sh\\necho \"$ROFI_RETV|$ROFI_INFO|$1\" >> /tmp/launcher-qa-fixtures/qaz.log\\nprintf \"QA Row One\\\\nQA Row Two\\\\n\"\\n' > /tmp/launcher-qa-fixtures/qaz.sh; chmod +x /tmp/launcher-qa-fixtures/qaz.sh; printf '[{\"keyword\":\"qaz\",\"name\":\"QA Script\",\"exec\":\"/tmp/launcher-qa-fixtures/qaz.sh\"}]' > ~/.config/ryoku/launcher-scripts.json; rm -f /tmp/launcher-qa-fixtures/qaz.log; sleep 0.5",
        "show", "type qaz hello", "settle"
      ],
      "asserts": [
        "[.results[] | select(.title == \"QA Row One\")] | length == 1",
        "[.results[] | select(.title == \"QA Row Two\")] | length == 1"
      ],
      "shell_asserts": ["grep -q '^0|hello|' /tmp/launcher-qa-fixtures/qaz.log"],
      "teardown": ["rm -f ~/.config/ryoku/launcher-scripts.json"]
    },
    {
      "id": "prefix-chip-modes",
      "name": "Prefix chips label every routed mode correctly",
      "covers": "SearchRow mode chip routing",
      "steps": [
        "show", "type ;", "sleep 0.4",
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'state\\n'; sleep .5)|socat - UNIX-CONNECT:$S | jq -r .modeLabel >/tmp/launcher-qa-fixtures/chips.out",
        "hide", "show", "type =1", "sleep 0.4",
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'state\\n'; sleep .5)|socat - UNIX-CONNECT:$S | jq -r .modeLabel >>/tmp/launcher-qa-fixtures/chips.out",
        "hide", "show", "type @x", "sleep 0.4",
        "sh S=$XDG_RUNTIME_DIR/ryoku-launcher.sock; (printf 'state\\n'; sleep .5)|socat - UNIX-CONNECT:$S | jq -r .modeLabel >>/tmp/launcher-qa-fixtures/chips.out",
        "hide", "show", "type /folder x", "sleep 0.4"
      ],
      "asserts": [".modeLabel == \"FOLDER\""],
      "shell_asserts": ["printf 'CLIPBOARD\\nCALC\\nYT MUSIC\\n' | diff - /tmp/launcher-qa-fixtures/chips.out"]
    },
    {
      "id": "yt-search",
      "name": "@ searches YT Music and lists playable tracks",
      "covers": "ytmusic provider InnerTube search",
      "steps": ["show", "type @never gonna give you up", "settle 25", "sleep 1"],
      "asserts": [".modeLabel == \"YT MUSIC\"", ".resultCount >= 1"],
      "screenshot": true,
      "network": true
    },
    {
      "id": "yt-link-row",
      "name": "Pasted YouTube link surfaces a one-tap Play row unprefixed",
      "covers": "ytmusic urlFallback link parse",
      "steps": ["show", "type https://www.youtube.com/watch?v=dQw4w9WgXcQ", "settle 15"],
      "asserts": ["[.results[] | select((.title + .subtitle + .verb) | test(\"play\"; \"i\"))] | length >= 1"],
      "screenshot": true,
      "network": true
    },
    {
      "id": "ask-mode-ui",
      "name": "Backslash enters Rashin ask mode with RASHIN chip",
      "covers": "ask mode routing + panel",
      "steps": ["show", "type \\what is ryoku", "sleep 0.8"],
      "asserts": [".askMode == true", ".modeLabel == \"RASHIN\""],
      "screenshot": true
    },
    {
      "id": "ask-resume-list",
      "name": "Bare backslash shows the ask panel in resume/recall state",
      "covers": "ask resume list",
      "steps": ["show", "type \\", "sleep 0.8"],
      "asserts": [".askMode == true"],
      "screenshot": true
    },
    {
      "id": "rest-dashboard",
      "name": "Rest state shows the dashboard (clock, greeting, weather glance)",
      "covers": "RestDashboard visual",
      "steps": ["show", "sleep 1.2"],
      "asserts": [".resting == true", ".open == true", ".resultCount == .totalCount"],
