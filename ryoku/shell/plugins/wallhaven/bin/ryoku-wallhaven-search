#!/usr/bin/env bash
# Wallhaven CLI used by the plugin service. Two verbs:
#   search --query <q> --page <n> [--top-range <1d|3d|1w|1M|...>] --json
#       -> one JSON object per result line (id, path, thumb, resolution, name,
#          wallhaven_url)
#   download <id> <fullResolutionUrl>
#       -> downloads into ~/Pictures/Wallpapers and prints the local path
# An optional WALLHAVEN_API_KEY in the environment raises rate limits and unlocks
# NSFW per the account; absent, anonymous search still works.
set -euo pipefail

api="https://wallhaven.cc/api/v1"
dest="$HOME/Pictures/Wallpapers"
key="${WALLHAVEN_API_KEY:-}"

auth=()
[ -n "$key" ] && auth=(-H "X-API-Key: $key")

cmd="${1:-}"; shift || true

case "$cmd" in
search)
	query=""; page=1; top_range=""; as_json=0
	while [ $# -gt 0 ]; do
		case "$1" in
		--query) query="$2"; shift 2 ;;
		--page) page="$2"; shift 2 ;;
		--top-range) top_range="$2"; shift 2 ;;
		--json) as_json=1; shift ;;
		*) shift ;;
		esac
	done
	params=(-G "$api/search" --data-urlencode "page=$page")
	if [ -n "$top_range" ]; then
		params+=(--data-urlencode "sorting=toplist" --data-urlencode "topRange=$top_range")
	else
		params+=(--data-urlencode "sorting=date_added")
	fi
	[ -n "$query" ] && params+=(--data-urlencode "q=$query")
	resp="$(curl -fsSL "${auth[@]}" "${params[@]}")"
	if [ "$as_json" = 1 ]; then
		jq -c '.data[] | {
			id: .id,
			path: .path,
			thumb: .thumbs.small,
			resolution: .resolution,
			name: .id,
			wallhaven_url: .url
		}' <<<"$resp"
	else
		jq -r '.data[].path' <<<"$resp"
	fi
	;;
download)
	id="${1:?id required}"; url="${2:?url required}"
	mkdir -p "$dest"
	ext="${url##*.}"; [ "${#ext}" -gt 5 ] && ext="jpg"
	out="$dest/wallhaven-$id.$ext"
	curl -fsSL "${auth[@]}" "$url" -o "$out"
	printf '%s\n' "$out"
	;;
*)
	echo "usage: ryoku-wallhaven-search search --query <q> --page <n> [--top-range <r>] --json | download <id> <url>" >&2
	exit 2
	;;
esac
