#!/usr/bin/env bash
#
# sddm/setup: wire SDDM as the graphical login manager at install time.
#
# runs on the target (typically from the install backend, in the chroot or
# via sudo). the plumbing that makes a fresh box boot into the SDDM greeter
# instead of a bare tty:
#
#   1. enable sddm.service
#   2. default systemd target = graphical
#   3. strip pam_gnome_keyring from /etc/pam.d/sddm. a password SDDM login
#      must NOT spawn an encrypted login keyring: it clashes with the
#      passwordless Default_keyring used for auto-unlock.
#   4. make sure a hyprland.desktop wayland session exists so SDDM can launch it
#
# the greeter THEME itself is installed by install-qylock. this script only
# does the SDDM service/session wiring; keep the two separate so a cosmetic
# theme failure never stops the login manager from coming up.
#
# usage:
#   setup                run the wiring
#   setup --dry-run      print the plan, change nothing
#   RYOKU_DRYRUN=1 setup  same, via the shared installer switch

set -euo pipefail

RYOKU_DRYRUN="${RYOKU_DRYRUN:-0}"
for arg in "$@"; do
  case "$arg" in
    --dry-run) RYOKU_DRYRUN=1 ;;
    -h | --help)
      sed -n '2,21p' "$0"
      exit 0
      ;;
    *)
      echo "setup: unknown argument: $arg" >&2
      exit 1
      ;;
  esac
done

run() {
  if [[ $RYOKU_DRYRUN == 1 ]]; then
    printf 'DRYRUN: %s\n' "$*"
    return 0
  fi
  "$@"
}

# root for system paths; sudo when we're not already root.
if (( EUID == 0 )); then
  PRIV=()
else
  PRIV=(sudo)
fi
priv() { run "${PRIV[@]}" "$@"; }

PAM_FILE="/etc/pam.d/sddm"
SESSION_DIR="/usr/share/wayland-sessions"
HYPRLAND_SESSION="$SESSION_DIR/hyprland.desktop"

# --- 1. enable the service ---------------------------------------------------
echo "  enabling sddm.service"
priv systemctl enable sddm.service

# --- 2. default to the graphical target --------------------------------------
# a plain Arch chroot leaves default.target = multi-user.target = boots to a
# getty, SDDM never starts. the pacman post-install hook that normally flips
# this doesn't fire in a chroot, so set it explicitly.
echo "  setting default target -> graphical.target"
priv systemctl set-default graphical.target

# --- 3. drop pam_gnome_keyring from the SDDM PAM stack -----------------------
if [[ -f $PAM_FILE ]]; then
  if grep -q 'pam_gnome_keyring\.so' "$PAM_FILE"; then
    echo "  removing pam_gnome_keyring from $PAM_FILE"
    priv sed -i '/pam_gnome_keyring\.so/d' "$PAM_FILE"
  else
    echo "  pam_gnome_keyring already absent from $PAM_FILE"
  fi
else
  echo "  note: $PAM_FILE not present yet; nothing to strip"
fi

# --- 4. make sure a Hyprland wayland session exists --------------------------
session_found=false
for session in hyprland.desktop Hyprland.desktop hyprland-uwsm.desktop; do
  if [[ -f $SESSION_DIR/$session ]]; then
    session_found=true
    echo "  hyprland session present: $session"
    break
  fi
done

if [[ $session_found == false ]]; then
  echo "  writing fallback session -> $HYPRLAND_SESSION"
  priv mkdir -p "$SESSION_DIR"
  if [[ $RYOKU_DRYRUN == 1 ]]; then
    printf 'DRYRUN: write (root) %s:\n%s\n' "$HYPRLAND_SESSION" \
      "[Desktop Entry]
Name=Hyprland
Comment=An intelligent dynamic tiling Wayland compositor
Exec=Hyprland
Type=Application"
  else
    "${PRIV[@]}" tee "$HYPRLAND_SESSION" >/dev/null <<'EOF'
[Desktop Entry]
Name=Hyprland
Comment=An intelligent dynamic tiling Wayland compositor
Exec=Hyprland
Type=Application
EOF
  fi
fi

echo "SDDM wiring complete."
