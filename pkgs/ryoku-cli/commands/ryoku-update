#!/usr/bin/env bash
# Rebuild Ryoku from the flake. The installed profile (amd-nvidia|amd|intel) is
# recorded at /etc/ryoku/profile by the installer; the running hostname does not
# name the config. Override the flake source with RYOKU_FLAKE or the profile
# with RYOKU_PROFILE. Extra arguments pass through to nixos-rebuild.
set -euo pipefail

FLAKE="${RYOKU_FLAKE:-github:neur0map/ryoku-arch/nixos}"

# --rollback short-circuits to the previous generation and exits.
if [[ "${1:-}" == "--rollback" ]]; then
  sudo nixos-rebuild switch --rollback
  exit 0
fi

profile="${RYOKU_PROFILE:-$(cat /etc/ryoku/profile 2>/dev/null || true)}"
if [[ -z $profile ]]; then
  echo "ryoku-update: unknown profile; set RYOKU_PROFILE or /etc/ryoku/profile" >&2
  exit 1
fi

sudo nixos-rebuild switch --flake "${FLAKE}#${profile}" "$@"

echo "Updated ${profile}. To revert: ryoku-update --rollback."
