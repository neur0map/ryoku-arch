# Maintainer: Carlos Mejia (neur0map)
#
# ryoku-tui: the unified Ryoku control center TUI (bubbletea + lipgloss).
# A single binary that renders the branded menu (Update / Doctor / Recovery /
# Logs / Manage packages) and streams each action's live output. It replaces
# the gum-based update dashboard and doctor UI.
#
# Built from the in-tree Go module at $RYOKU_PATH/tui. distro-arch.sh exports
# RYOKU_PATH and runs `makepkg` here; the build copies that source into $srcdir
# so the package is self-contained.
#
# Build with:
#
#     cd distro/arch/ryoku-tui
#     RYOKU_PATH=$(git rev-parse --show-toplevel) makepkg -si

pkgname=ryoku-tui
pkgver=1.0.0
pkgrel=1
pkgdesc='Unified Ryoku control center TUI (update, doctor, recovery) built with bubbletea + lipgloss'
arch=(x86_64 aarch64)
url='https://github.com/neur0map/ryoku-arch'
license=(GPL3)
depends=(glibc)
makedepends=(go git)
options=(!debug)

_srcdir() {
  # Prefer the installed/checked-out repo; fall back to walking up from here.
  if [[ -n ${RYOKU_PATH:-} && -d $RYOKU_PATH/tui ]]; then
    printf '%s\n' "$RYOKU_PATH/tui"
    return
  fi
  printf '%s\n' "$(cd "$startdir/../../../tui" && pwd)"
}

prepare() {
  local src
  src="$(_srcdir)"
  [[ -d $src ]] || { echo "ryoku-tui: cannot find Go source ($src)" >&2; return 1; }
  rm -rf "$srcdir/tui"
  cp -aT "$src" "$srcdir/tui"
}

build() {
  cd "$srcdir/tui"
  export CGO_ENABLED=0 GOFLAGS="-buildvcs=false -trimpath" GOPATH="$srcdir/gopath"
  go build -ldflags "-s -w -X main.buildVersion=$pkgver" -o "$srcdir/ryoku-tui" .
}

package() {
  install -Dm0755 "$srcdir/ryoku-tui" "$pkgdir/usr/bin/ryoku-tui"
  install -Dm0644 "$srcdir/tui/go.mod" "$pkgdir/usr/share/licenses/$pkgname/go.mod" 2>/dev/null || true
}
