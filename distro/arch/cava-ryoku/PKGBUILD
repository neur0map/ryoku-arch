# Maintainer: Carlos Mejia (neur0map)
# Contributor: Carl Smedstad <carsme@archlinux.org>  (upstream Arch PKGBUILD)
#
# Drop-in replacement for the official `cava` package that additionally
# ships the shared library `libcava.so` + headers + `libcava.pc`. The
# Ryoku quickshell plugin (`shell/plugin/src/Ryoku/Services/cavaprovider.cpp`)
# links libcava at build time via `pkg_check_modules(Cava libcava)`; without
# this library the plugin compiles a stub that never starts the audio
# processor, leaving the dashboard music visualiser silently invisible
# (Audio.cava.values stays at all-zeros, bars clamp to 1e-3 * size).
#
# Built from LukashonakV/cava, the same Caelestia-recommended cava fork
# whose autotools build emits libcava + libcava.pc via libtool while still
# producing the regular `cava` binary, so this package transparently
# replaces stock cava without dropping the console visualiser.
#
# Build with:
#
#     cd distro/arch/cava-ryoku
#     makepkg -si
#
# To keep pacman from clobbering it on `-Syu`, add `IgnorePkg = cava` to
# /etc/pacman.conf, or rebuild this PKGBUILD whenever upstream Arch bumps
# `pkgver`. `provides=(cava=...)` keeps any package that depends on `cava`
# satisfied; `provides=(libcava=...)` lets dependents express the library
# requirement explicitly.

pkgname=cava-ryoku
_upstream=cava
pkgver=0.10.7
pkgrel=1
pkgdesc='Console-based Audio Visualizer + libcava shared library (Ryoku, LukashonakV fork)'
arch=(x86_64 aarch64)
url='https://github.com/LukashonakV/cava'
license=(MIT)
provides=("$_upstream=$pkgver-$pkgrel" "libcava=$pkgver-$pkgrel")
conflicts=("$_upstream")
depends=(
  fftw
  glibc
  iniparser
  # Input backends
  alsa-lib
  jack
  libpipewire
  libpulse
  portaudio
  sndio
  # Output backends
  ncurses
  sdl2
)
makedepends=(autoconf automake libtool pkgconf)
source=("$_upstream-$pkgver.tar.gz::$url/archive/$pkgver.tar.gz")
sha256sums=('50cc6413e9c96c503657f814744a2baf429a24ff9fed31a8343e0ed285269eff')

prepare() {
  cd "$_upstream-$pkgver"
  echo "$pkgver" > version
  autoreconf -vif
}

build() {
  cd "$_upstream-$pkgver"
  # configure.ac shells out to `git describe` for the libcava ABI version.
  # Without a ceiling, git walks up out of $srcdir and picks up whichever
  # git repo built this PKGBUILD (e.g. ryoku-arch's `unstable-dev-latest`
  # tag, which libtool rejects). Force git to stop at $srcdir so the
  # ABI version falls back to 0:0:0 cleanly.
  GIT_CEILING_DIRECTORIES="$srcdir" ./configure --prefix=/usr --libdir=/usr/lib
  GIT_CEILING_DIRECTORIES="$srcdir" make
}

package() {
  cd "$_upstream-$pkgver"
  make DESTDIR="$pkgdir" install
  # Strip libtool archive (Arch policy: no .la files in packages).
  rm -f "$pkgdir/usr/lib/libcava.la"
  install -Dm0644 -t "$pkgdir/usr/share/doc/$pkgname" README.md CAVACORE.md
  install -Dm0644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE
}
