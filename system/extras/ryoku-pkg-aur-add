#!/usr/bin/env bash

# AUR install via the system helper. yay = bootstrapped at install time,
# paru = accepted fallback. extras actuator routes anything not in the
# official repos through here.
#
# Each package is installed on its own, not as one `yay -S a b c` batch: one
# AUR build failing (a flaky dependency, a missing multilib provider) aborts a
# batch and strands every other package, so a whole bundle's AUR half comes up
# empty because of one bad apple. Per-package, a failure is isolated and the
# actuator's own pkg_installed check reports each one accurately.

set -uo pipefail

(($#)) || {
  echo "ryoku-pkg-aur-add: no packages given" >&2
  exit 2
}

helper=""
for h in yay paru; do
  if command -v "$h" >/dev/null 2>&1; then
    helper=$h
    break
  fi
done

[[ -n $helper ]] || {
  echo "ryoku-pkg-aur-add: no AUR helper found (expected yay or paru)" >&2
  exit 1
}

rc=0
for pkg in "$@"; do
  echo "==> $helper -S $pkg"
  "$helper" -S --needed --noconfirm "$pkg" || {
    echo "ryoku-pkg-aur-add: $pkg did not install, continuing with the rest" >&2
    rc=1
  }
done
exit $rc
