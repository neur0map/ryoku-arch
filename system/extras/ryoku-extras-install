#!/usr/bin/env bash

# Extras actuator: installs, removes, and reports state for bundles in the
# ryoku-extras catalogue. The Hub's Extras section drives it; a bundle is a
# list of items, each a `package` (auto-routed to official repos or AUR), a
# `script` (small installer from ryoku-extras/installers), or a `plugin`
# (shell plugin fetched to ~/.local/share/ryoku/plugins; place via Settings,
# Plugins).
#
#   ryoku-extras-install status [bundle <id>]   print item state as JSON, no change
#   ryoku-extras-install install bundle <id>    install every absent item
#   ryoku-extras-install install item <id> <n>  install one item
#   ryoku-extras-install remove bundle <id>     remove the bundle's package items
#   ryoku-extras-install remove item <id> <n>   remove one package item
#
# ryoku-hub owns the network and the cache; this just reads the catalogue
# under `ryoku-hub extras cache` and asks for an installer path on demand, so
# fetching lives in one place. Package installs need a TTY for the sudo
# prompt, so the Hub launches install/remove in a floating terminal; status is
# a silent query the UI calls inline. RYOKU_EXTRAS_DRYRUN=1 prints the planned
# actions without touching the system.

set -uo pipefail

DRYRUN=${RYOKU_EXTRAS_DRYRUN:-}

# Script installers drop tools into ~/.local/bin (npm prefix, GOBIN, pipx).
# The graphical session doesn't always carry that on PATH, so prepend it
# before any detection runs or fresh script items will read as still missing.
export PATH="$HOME/.local/bin:$PATH"

die() {
  echo "ryoku-extras-install: $1" >&2
  exit 1
}

cache_dir() {
  ryoku-hub extras cache 2>/dev/null
}

# Path to a bundle's definition, fetching the catalogue once if not cached.
bundle_file() {
  local id=$1 cache f
  cache=$(cache_dir) || die "could not resolve the extras cache (is ryoku-hub installed?)"
  f="$cache/bundles/$id/bundle.json"
  if [[ ! -f $f ]]; then
    ryoku-hub extras catalog >/dev/null 2>&1 || true
  fi
  [[ -f $f ]] || die "unknown bundle '$id' (not in the catalogue)"
  printf '%s\n' "$f"
}

registry_ids() {
  local cache reg
  cache=$(cache_dir) || return 1
  reg="$cache/bundles/registry.json"
  [[ -f $reg ]] || ryoku-hub extras catalog >/dev/null 2>&1 || true
  [[ -f $reg ]] || return 1
  jq -r '.bundles[].id' "$reg"
}

report_dir() {
  printf '%s/ryoku-extras\n' "${XDG_RUNTIME_DIR:-/tmp}"
}

# --- detection (one implementation, used by status and the install path) ------

pkg_installed() { pacman -Qq "$1" >/dev/null 2>&1; }
pkg_official() { pacman -Si "$1" >/dev/null 2>&1; }
cmd_present() { command -v "$1" >/dev/null 2>&1; }

# Where an installed plugin's source lives (read by the runtime + Settings).
# The catalogue ships the source; install copies it here.
plugin_dir() { printf '%s/ryoku/plugins/%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}" "$1"; }
plugin_installed() { [[ -f "$(plugin_dir "$1")/manifest.json" ]]; }
nautilus_track() { printf '%s/ryoku/nautilus/%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}" "$1"; }
nautilus_installed() { [[ -f "$(nautilus_track "$1")/manifest.json" ]]; }

# Current state of one item, ignoring any in-flight operation.
item_state() {
  local type=$1 name=$2 detect=$3
  case "$type" in
    package) pkg_installed "$name" && echo present || echo absent ;;
    script) cmd_present "$detect" && echo present || echo absent ;;
    plugin) plugin_installed "$name" && echo present || echo absent ;;
    nautilus-pack) nautilus_installed "$name" && echo present || echo absent ;;
    *) echo absent ;;
  esac
}

# --- report file (the Hub watches one JSON per bundle while work runs) ---------

declare -A STATE REASON

flush_report() {
  local id=$1 phase=$2 dir items="{}" n tmp
  dir=$(report_dir)
  mkdir -p "$dir"
  for n in "${!STATE[@]}"; do
    items=$(jq --arg k "$n" --arg s "${STATE[$n]}" --arg r "${REASON[$n]:-}" \
      '.[$k] = ({status: $s} + (if $r == "" then {} else {reason: $r} end))' <<<"$items")
  done
  tmp=$(mktemp "$dir/.$id.XXXXXX")
  jq -n --arg id "$id" --arg phase "$phase" --argjson items "$items" \
    '{id: $id, phase: $phase, items: $items}' >"$tmp" && mv -f "$tmp" "$dir/$id.json"
}

set_state() {
  STATE[$1]=$2
  REASON[$1]=${3:-}
}

# --- parsing ------------------------------------------------------------------

# Emit "type<TAB>name<TAB>detect<TAB>summary" for the bundle's items, optionally
# only the one named by $2.
bundle_items() {
  local file=$1 only=${2:-}
  if [[ -n $only ]]; then
    jq -r --arg n "$only" \
      '.items[] | select(.name == $n) | [.type, .name, (.detect // .name), (.tier // "core"), ((.interactive // false)|tostring), (.summary // "")] | @tsv' "$file"
  else
    jq -r '.items[] | [.type, .name, (.detect // .name), (.tier // "core"), ((.interactive // false)|tostring), (.summary // "")] | @tsv' "$file"
  fi
}

# --- status -------------------------------------------------------------------

status_bundle_json() {
  local id=$1 file type name detect summary tier interactive out="[]"
  file=$(bundle_file "$id") || return 1
  while IFS=$'\t' read -r type name detect tier interactive summary; do
    [[ -n $name ]] || continue
    out=$(jq --arg t "$type" --arg n "$name" --arg s "$(item_state "$type" "$name" "$detect")" \
      --arg sum "$summary" '. + [{type: $t, name: $n, status: $s, summary: $sum}]' <<<"$out")
  done < <(bundle_items "$file")
  jq -n --arg id "$id" --argjson items "$out" '{id: $id, items: $items}'
}

cmd_status() {
  if [[ ${1:-} == bundle ]]; then
    [[ -n ${2:-} ]] || die "status bundle needs an id"
    status_bundle_json "$2"
    return
  fi
  local id out="[]"
  while read -r id; do
    [[ -n $id ]] || continue
    out=$(jq --argjson b "$(status_bundle_json "$id")" '. + [$b]' <<<"$out")
  done < <(registry_ids)
  jq -n --argjson bundles "$out" '{bundles: $bundles}'
}

# --- install ------------------------------------------------------------------

run_pkg() {
  # $1 = backend helper, rest = package names
  local helper=$1
  shift
  if [[ -n $DRYRUN ]]; then
    echo "DRYRUN: $helper $*"
    return 0
  fi
  "$helper" "$@"
}

run_script() {
  local name=$1 path
  if [[ -n $DRYRUN ]]; then
    echo "DRYRUN: run installer $name"
    return 0
  fi
  path=$(ryoku-hub extras installer "$name" 2>/dev/null) || return 1
  [[ -f $path ]] || return 1
  bash "$path"
}

# Drop the plugin's source tree into the data dir the runtime + Settings
# read. ryoku-hub owns the network, we just trigger it.
run_plugin_install() {
  local name=$1
  if [[ -n $DRYRUN ]]; then
    echo "DRYRUN: install plugin $name"
    return 0
  fi
  ryoku-hub extras plugin "$name" >/dev/null 2>&1
}

run_nautilus_install() {
  local name=$1
  if [[ -n $DRYRUN ]]; then echo "DRYRUN: install nautilus pack $name"; return 0; fi
  ryoku-hub extras nautilus "$name" >/dev/null 2>&1
}

# Remove the plugin's source tree. The placement in plugins.json is left
# alone, so re-installing drops it back where the user had it.
run_plugin_remove() {
  local name=$1 dir
  dir=$(plugin_dir "$name")
  if [[ -n $DRYRUN ]]; then
    echo "DRYRUN: remove plugin dir $dir"
    return 0
  fi
  rm -rf "$dir"
}

# Run a bundle's declared prerequisites before any package is routed, so a
# package that only lives in an extra repo (Steam in multilib) classifies
# and installs correctly.
ensure_requires() {
  local file=$1 req
  while read -r req; do
    [[ -n $req ]] || continue
    case "$req" in
      multilib)
        if [[ -n $DRYRUN ]]; then
          echo "DRYRUN: ensure the multilib repo is enabled"
        else
          echo "==> Ensuring the multilib repo is enabled"
          ryoku-pkg-multilib || true
        fi
        ;;
      cachyos)
        if [[ -n $DRYRUN ]]; then
          echo "DRYRUN: ensure the CachyOS repository is enabled"
        else
          echo "==> Ensuring the CachyOS repository is enabled"
          ryoku-pkg-cachyos || die "could not enable the CachyOS repository"
        fi
        ;;
      *) die "this bundle needs a newer Ryoku (unknown requirement '$req'); run 'ryoku update' first" ;;
    esac
  done < <(jq -r '.requires[]? // empty' "$file")
}

install_set() {
  local id=$1 only=${2:-} file type name detect summary tier interactive
  file=$(bundle_file "$id")
  ensure_requires "$file"

  local -a repo=() aur=() scripts=() plugins=() nautilus_packs=()
  declare -A SCRIPT_DETECT=() SCRIPT_INT=()

  while IFS=$'\t' read -r type name detect tier interactive summary; do
    [[ -n $name ]] || continue
    # optional items only install one at a time (item scope), never in "install all".
    if [[ -z $only && $tier == optional ]]; then continue; fi
    case "$type" in
      package)
        if pkg_installed "$name"; then
          set_state "$name" present
        elif pkg_official "$name"; then
          repo+=("$name")
        else
          aur+=("$name")
        fi
        ;;
      script)
        if cmd_present "$detect"; then
          set_state "$name" present
        else
          scripts+=("$name")
          SCRIPT_DETECT[$name]=$detect
          SCRIPT_INT[$name]=$interactive
        fi
        ;;
      plugin)
        if plugin_installed "$name"; then
          set_state "$name" present
        else
          plugins+=("$name")
        fi
        ;;
      nautilus-pack)
        if nautilus_installed "$name"; then
          set_state "$name" present
        else
          nautilus_packs+=("$name")
        fi
        ;;
      *)
        set_state "$name" failed "unknown item type '$type'"
        ;;
    esac
  done < <(bundle_items "$file" "$only")

  local n
  for n in "${repo[@]}" "${aur[@]}" "${scripts[@]}" "${plugins[@]}" "${nautilus_packs[@]}"; do set_state "$n" installing; done
  flush_report "$id" running

  if ((${#repo[@]})); then
    echo "==> Installing from the official repos: ${repo[*]}"
    run_pkg ryoku-pkg-add "${repo[@]}" || true
    for n in "${repo[@]}"; do
      if [[ -n $DRYRUN ]] || pkg_installed "$n"; then
        set_state "$n" installed
      else
        set_state "$n" failed "pacman did not install it"
      fi
    done
    flush_report "$id" running
  fi

  if ((${#aur[@]})); then
    echo "==> Installing from the AUR: ${aur[*]}"
    run_pkg ryoku-pkg-aur-add "${aur[@]}" || true
    for n in "${aur[@]}"; do
      if [[ -n $DRYRUN ]] || pkg_installed "$n"; then
        set_state "$n" installed
      else
        set_state "$n" failed "the AUR build did not complete"
      fi
    done
    flush_report "$id" running
  fi

  for n in "${scripts[@]}"; do
    echo "==> Running installer: $n"
    if run_script "$n"; then
      if [[ -n $DRYRUN ]] || cmd_present "${SCRIPT_DETECT[$n]}"; then
        set_state "$n" installed
      elif [[ ${SCRIPT_INT[$n]:-false} == true ]]; then
        set_state "$n" deferred "needs a manual download; re-run this item when ready"
      else
        set_state "$n" failed "the installer ran but '${SCRIPT_DETECT[$n]}' is still missing"
      fi
    else
      if [[ ${SCRIPT_INT[$n]:-false} == true ]]; then
        set_state "$n" deferred "needs a manual download; re-run this item when ready"
      else
        set_state "$n" failed "the installer exited with an error"
      fi
    fi
    flush_report "$id" running
  done

  for n in "${plugins[@]}"; do
    echo "==> Installing plugin: $n"
    if run_plugin_install "$n" && { [[ -n $DRYRUN ]] || plugin_installed "$n"; }; then
      set_state "$n" installed
    else
      set_state "$n" failed "could not fetch the plugin from the catalogue"
    fi
    flush_report "$id" running
  done

  for n in "${nautilus_packs[@]}"; do
    echo "==> Installing file-manager scripts: $n"
    if run_nautilus_install "$n" && { [[ -n $DRYRUN ]] || nautilus_installed "$n"; }; then
      set_state "$n" installed
    else
      set_state "$n" failed "could not fetch the scripts from the catalogue"
    fi
    flush_report "$id" running
  done

  flush_report "$id" "done"
}

# --- remove -------------------------------------------------------------------

remove_set() {
  local id=$1 only=${2:-} file type name detect summary tier interactive
  file=$(bundle_file "$id")

  local -a pkgs=()
  while IFS=$'\t' read -r type name detect tier interactive summary; do
    [[ -n $name ]] || continue
    case "$type" in
      package)
        if pkg_installed "$name"; then
          pkgs+=("$name")
          set_state "$name" removing
        else
          set_state "$name" absent
        fi
        ;;
      script)
        set_state "$name" skipped "scripts are not auto-removed"
        ;;
      plugin)
        if plugin_installed "$name"; then
          run_plugin_remove "$name"
          if [[ -n $DRYRUN ]] || ! plugin_installed "$name"; then
            set_state "$name" removed
          else
            set_state "$name" failed "could not remove the plugin files"
          fi
        else
          set_state "$name" absent
        fi
        ;;
      nautilus-pack)
        if nautilus_installed "$name"; then
          if [[ -n $DRYRUN ]]; then
            echo "DRYRUN: remove nautilus pack $name"; set_state "$name" removed
          elif ryoku-hub extras nautilusremove "$name" >/dev/null 2>&1 && ! nautilus_installed "$name"; then
            set_state "$name" removed
          else
            set_state "$name" failed "could not remove the scripts"
          fi
        else
          set_state "$name" absent
        fi
        ;;
    esac
  done < <(bundle_items "$file" "$only")

  flush_report "$id" running

  if ((${#pkgs[@]})); then
    echo "==> Removing: ${pkgs[*]}"
    run_pkg ryoku-pkg-remove "${pkgs[@]}" || true
    local n
    for n in "${pkgs[@]}"; do
      if [[ -n $DRYRUN ]] || ! pkg_installed "$n"; then
        set_state "$n" removed
      else
        set_state "$n" failed "pacman kept it (still required by another package?)"
      fi
    done
  fi

  flush_report "$id" "done"
}

summary_pause() {
  local failed=0 n
  for n in "${!STATE[@]}"; do
    [[ ${STATE[$n]} == failed ]] && failed=1
  done
  if ((failed)) && [[ -t 0 && -z $DRYRUN ]]; then
    echo ""
    read -rp "Some items failed. Press Enter to close this window. " -t 60 _ || true
  fi
}

# --- dispatch -----------------------------------------------------------------

case "${1:-}" in
  status)
    cmd_status "${2:-}" "${3:-}"
    ;;
  install)
    case "${2:-}" in
      bundle) [[ -n ${3:-} ]] || die "install bundle needs an id"; install_set "$3" ;;
      item) [[ -n ${4:-} ]] || die "install item needs <id> <name>"; install_set "$3" "$4" ;;
      *) die "install needs 'bundle <id>' or 'item <id> <name>'" ;;
    esac
    summary_pause
    ;;
  remove)
    case "${2:-}" in
      bundle) [[ -n ${3:-} ]] || die "remove bundle needs an id"; remove_set "$3" ;;
      item) [[ -n ${4:-} ]] || die "remove item needs <id> <name>"; remove_set "$3" "$4" ;;
      *) die "remove needs 'bundle <id>' or 'item <id> <name>'" ;;
    esac
    summary_pause
    ;;
  *)
    cat >&2 <<'USAGE'
usage:
  ryoku-extras-install status [bundle <id>]
  ryoku-extras-install install bundle <id>
  ryoku-extras-install install item <id> <name>
  ryoku-extras-install remove bundle <id>
  ryoku-extras-install remove item <id> <name>
USAGE
    exit 2
    ;;
esac
