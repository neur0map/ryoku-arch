// Game Mode's WiFi power-save helper, authorized without a password so the deck
// toggle stays one click. Scoped to exactly /usr/bin/ryoku-wifi-powersave for an
// active local user in the wheel group. The helper only toggles 802.11 power-save
// (a benign radio power-management setting) and takes no arbitrary input, so a
// passwordless grant is safe.
polkit.addRule(function (action, subject) {
    if (action.id === "org.freedesktop.policykit.exec" &&
        action.lookup("program") === "/usr/bin/ryoku-wifi-powersave" &&
        subject.local && subject.active && subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }
});
