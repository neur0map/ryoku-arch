#!/usr/bin/env bash
#
# ryoku-monitor: DPI-derived display scaling for Hyprland.
#
# Scale is never hardcoded. `autoscale` derives a per-output scale from each
# monitor's real pixel density (resolution / physical size in mm) so high-DPI
# panels are zoomed and low-DPI external monitors are left at 1x. It applies the
# scale live through `hyprctl keyword monitor` and writes the result to the
# monitors drop-in that the Lua hyprland.lua require()s, so the layout survives a
# reload or relogin. `persist` captures the current live layout without
# recomputing the scale.
#
# GDK_SCALE is kept in step so GTK and XWayland apps stay crisp: it follows the
# shared integer scale when every active monitor agrees on one (>=2x), otherwise
# 1 (Wayland handles fractional scaling for native apps).
#
# A catch-all monitor rule is written last so a freshly plugged display still
# comes up sensibly at scale 1 until the next autoscale.

set -euo pipefail

# Drop-in Hyprland require()s; overwritten in full on every run (never skip-if-exists).
monitors_conf="${RYOKU_MONITORS_CONF:-${XDG_CONFIG_HOME:-$HOME/.config}/hypr/monitors.lua}"

# Named monitor profiles (Ryoku Settings). Keyed by hardware identity, not the
# connector name, so a layout follows the physical displays across reshuffles.
monitors_dir="${RYOKU_MONITORS_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/monitors}"

# Manual monitor overrides. ~/.config/hypr/monitors_user.lua is hand-written and
# required by hyprland.lua after the generated monitors.lua, so anything set there
# wins. autoscale leaves any output named in it untouched, so auto-detection never
# fights a panel you have pinned (a fake or generic EDID that needs a forced mode
# or modeline, or a layout you want kept).
monitors_user="${RYOKU_MONITORS_USER:-${XDG_CONFIG_HOME:-$HOME/.config}/hypr/monitors_user.lua}"

# Last layout applied from Ryoku Settings (Apply, not a named profile). autoscale
# recalls it for the connected display set so an explicit choice -- a hand-set
# scale above all -- survives a relogin instead of being recomputed from DPI.
# Keyed by hardware identity like a profile, but implicit and singular (the most
# recent Apply); a forced DPI pass clears it.
applied_layout="${RYOKU_MONITORS_APPLIED:-${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/monitors-applied.json}"

# Output names the user pinned in monitors_user.lua, one per line (empty if none).
pinned_outputs() {
  [[ -f $monitors_user ]] || return 0
  grep -oE 'output[[:space:]]*=[[:space:]]*"[^"]+"' "$monitors_user" 2>/dev/null \
    | sed -E 's/.*"([^"]*)".*/\1/' | grep -v '^$' || true
}

require_hyprctl() {
  # Fixture mode (tests) never touches the live compositor.
  [[ -n ${RYOKU_MONITOR_JSON:-} ]] && return 0
  command -v hyprctl >/dev/null 2>&1 || {
    echo "ryoku-monitor: hyprctl not found" >&2
    exit 1
  }
}

require_jq() {
  command -v jq >/dev/null 2>&1 || {
    echo "ryoku-monitor: jq not found" >&2
    exit 1
  }
}

# Live monitor state as JSON. RYOKU_MONITOR_JSON points at a fixture file for
# tests (and suppresses the live hyprctl side effects below).
monitors_json() {
  if [[ -n ${RYOKU_MONITOR_JSON:-} ]]; then
    cat "$RYOKU_MONITOR_JSON"
  else
    hyprctl monitors all -j
  fi
}

# Emit "name|WxH@rate|XxY|wanted_scale|current_scale" for each enabled monitor,
# where wanted_scale is the DPI bucket (px * 25.4 / physical-mm) snapped to the
# nearest Hyprland-valid scale for the panel: a 1/120 multiple whose logical
# width AND height are both whole pixels. Hyprland rejects anything else (1.5 on
# a 2560 panel is 1706.67px wide, an "Invalid scale" error overlay), so the raw
# bucket cannot be applied as-is. Missing or implausible physical size (EDID
# lies, virtual outputs) falls back to 1x.
dpi_specs() {
  jq -r '
    def abs: if . < 0 then - . else . end;
    # Nearest scale to $target that Hyprland accepts for a w x h panel: a 1/120
    # multiple (1.0 .. 3.0) whose logical width and height both land on whole
    # pixels. This mirrors what robust tools (HyprDynamicMonitors, omarchy) do.
    def snap($w; $h; $target):
      [ range(120; 361) | . / 120
        | select(((($w / .) - (($w / .) | round)) | abs) < 0.01
             and ((($h / .) - (($h / .) | round)) | abs) < 0.01) ] as $valid
      | if ($valid | length) == 0 then 1.0
        else ($valid | min_by(((. - $target) | abs)) | (. * 10000 | round) / 10000) end;
    def dpiscale($w; $h; $pw):
      ( if ($pw // 0) <= 0 then 1.0
        else ($w * 25.4 / $pw) as $d
        | if   ($d < 40 or $d > 700) then 1.0
          elif $d <= 120 then 1.0
          elif $d <= 150 then 1.25
          elif $d <= 230 then 1.5
          elif $d <= 290 then 1.75
          else 2.0 end
        end ) as $target
      | snap($w; $h; $target);
    .[] | select(.disabled | not)
    | "\(.name)|\(.width)x\(.height)@\(.refreshRate | round)|\(.x)x\(.y)|\(dpiscale(.width; .height; .physicalWidth))|\(.scale)"
  '
}

# Integer GDK_SCALE when every active monitor shares one whole-number scale >=2,
# else 1. Reads monitor JSON on stdin.
gdk_scale_value() {
  jq -r '
    [ .[] | select(.disabled | not) | .scale ] as $s |
    if ($s | length) > 0 and ($s | unique | length) == 1
       and ($s[0] == ($s[0] | floor)) and $s[0] >= 2
    then ($s[0] | floor) else 1 end
  '
}

# Compute GDK_SCALE from the live layout, apply it live (skipped in fixture mode),
# and echo the chosen value.
sync_gdk_scale() {
  local gdk
  gdk="$(monitors_json | gdk_scale_value 2>/dev/null)"
  [[ $gdk =~ ^[0-9]+$ ]] || gdk=1
  if [[ -z ${RYOKU_MONITOR_JSON:-} ]]; then
    hyprctl eval "hl.env(\"GDK_SCALE\", \"$gdk\")" >/dev/null 2>&1 || true
  fi
  printf '%s\n' "$gdk"
}

# Write the monitors drop-in (Lua, hl API) from the live layout: one hl.monitor
# per output, the GDK_SCALE env, and a hotplug-friendly catch-all last.
write_monitors_conf() {
  local gdk="$1"
  local pinned_json
  pinned_json="$(pinned_outputs | jq -R . | jq -s .)"
  mkdir -p "$(dirname "$monitors_conf")"
  {
    printf '%s\n' "-- Managed by ryoku-monitor. Scale and position are captured from the live"
    printf '%s\n' "-- session (DPI-derived, never hardcoded); refresh is always highrr so a"
    printf '%s\n' "-- slow-training link cannot pin a low rate. Edits may be overwritten;"
    printf '%s\n' "-- re-run ryoku-monitor autoscale to regenerate."
    printf '\n'
    monitors_json | jq -r --argjson pinned "$pinned_json" '
      .[] | select(.name as $n | ($pinned | index($n)) == null) |
      if .disabled then
        "hl.monitor({ output = \"\(.name)\", disabled = true })"
      else
        "hl.monitor({ output = \"\(.name)\", mode = \"" + (if (.mirrorOf // "none") != "none" then "\(.width)x\(.height)@\(.refreshRate | round)" else "highrr" end) + "\", position = \"\(.x)x\(.y)\", scale = \(.scale)"
        + (if .transform != 0 then ", transform = \(.transform)" else "" end)
        + (if .vrr then ", vrr = 1" else "" end)
        + (if (.mirrorOf // "none") != "none" then ", mirror = \"\(.mirrorOf)\"" else "" end)
        + " })"
      end
    '
    printf '\n'
    printf '%s\n' "-- Keep GTK and XWayland apps crisp: shared integer scale when every monitor"
    printf '%s\n' "-- agrees (>=2x), else 1 (Wayland scales native apps fractionally itself)."
    printf 'hl.env("GDK_SCALE", "%s")\n' "$gdk"
    printf '\n'
    printf '%s\n' "-- Catch-all for monitors not listed above (hotplug-friendly, safe 1x default)."
    printf '%s\n' 'hl.monitor({ output = "", mode = "highrr", position = "auto", scale = 1 })'
  } >"$monitors_conf"
}

# Apply a monitor rule live. The Lua config manager rejects `hyprctl keyword`,
# so live changes go through `hyprctl eval` running the hl.monitor API.
apply_monitor() {
  [[ -n ${RYOKU_MONITOR_JSON:-} ]] && return 0
  hyprctl eval "hl.monitor({ $1 })" >/dev/null 2>&1
}

# Ride out a cold-boot DisplayPort link that first advertises a low refresh (common
# on a discrete GPU): while an enabled, non-mirrored output runs below the top rate
# its EDID lists, re-assert highrr and wait. Bounded, and a no-op once every output
# already sits at its max, so it only costs time on a link still training.
settle_refresh() {
  [[ -n ${RYOKU_MONITOR_JSON:-} ]] && return 0
  local tries=0 name
  while ((tries < 6)); do
    monitors_json | jq -e '
      any(.[];
        (.disabled | not)
        and ((.mirrorOf // "none") == "none")
        and ((.availableModes // []
              | map(capture("@(?<r>[0-9.]+)Hz") | .r | tonumber)
              | max // 0) - .refreshRate > 1))' >/dev/null 2>&1 || return 0
    while IFS= read -r name; do
      [[ -n $name ]] || continue
      apply_monitor "output = \"$name\", mode = \"highrr\"" || true
    done < <(monitors_json | jq -r '.[] | select((.disabled | not) and ((.mirrorOf // "none") == "none")) | .name')
    sleep 2
    tries=$((tries + 1))
  done
}

cmd_autoscale() {
  require_hyprctl
  require_jq
  if [[ "${1:-}" == "--no-profile" ]]; then
    # A forced DPI pass (Extend, or the hub's DPI button) also forgets the last
    # applied override, so the DPI result is what survives the next login.
    rm -f "$applied_layout"
  else
    # Login/hotplug: an explicit choice for this display set wins over DPI -- a
    # named profile first, then the last layout applied from Ryoku Settings -- so a
    # hand-set scale is not reset on the next login.
    local prof
    if prof="$(matching_profile)" && [[ -n $prof ]]; then
      cmd_load "$prof"
      return
    fi
    if applied_matches; then
      load_layout_file "$applied_layout"
      echo "ryoku-monitor: recalled the applied layout -> $monitors_conf"
      return
    fi
  fi
  local pinned
  pinned="$(pinned_outputs)"
  # Two passes, so the layout matches reality. First apply each monitor's DPI
  # scale: Hyprland snaps a requested scale to the nearest one that yields whole
  # logical pixels (e.g. 1.5 on a 2560 panel becomes 1.6), so the accepted scale
  # is only known after it is applied.
  local name mode wanted current
  while IFS='|' read -r name mode _ wanted current; do
    [[ -n $name ]] || continue
    grep -qxF "$name" <<<"$pinned" && continue
    if awk -v a="$current" -v b="$wanted" 'BEGIN { exit (a == b) ? 1 : 0 }'; then
      apply_monitor "output = \"$name\", mode = \"$mode\", scale = $wanted"
      echo "ryoku-monitor: $name -> scale $wanted"
    fi
  done < <(monitors_json | dpi_specs)

  # Then lay the displays in one non-overlapping row, left to right by current x,
  # advancing by each monitor's real logical width (pixels / accepted scale). A
  # stale or "auto" x can collide once scales differ, and computing from the
  # requested scale would leave a gap where Hyprland snapped it; reading the live
  # scale here keeps the seam exact, so a freshly plugged display sits flush.
  local w scale curx cury newpos x=0
  while IFS='|' read -r name w scale curx cury; do
    [[ -n $name ]] || continue
    grep -qxF "$name" <<<"$pinned" && continue
    newpos="${x}x0"
    [[ $newpos != "${curx}x${cury}" ]] && apply_monitor "output = \"$name\", position = \"$newpos\""
    x=$(awk -v X="$x" -v W="$w" -v S="$scale" 'BEGIN { printf "%d", X + int(W / S + 0.5) }')
  done < <(monitors_json | jq -r '[ .[] | select(.disabled | not) ] | sort_by(.x) | .[] | "\(.name)|\(.width)|\(.scale)|\(.x)|\(.y)"')
  settle_refresh
  local gdk
  gdk="$(sync_gdk_scale)"
  write_monitors_conf "$gdk"
  echo "ryoku-monitor: wrote $monitors_conf (GDK_SCALE=$gdk)"
}

cmd_persist() {
  require_hyprctl
  require_jq
  local gdk
  gdk="$(sync_gdk_scale)"
  write_monitors_conf "$gdk"
  echo "ryoku-monitor: wrote $monitors_conf (GDK_SCALE=$gdk)"
}

# Mirror every other enabled monitor onto SRC (default: the focused one) so all
# displays show the same image, then persist so it survives a relogin.
cmd_mirror() {
  require_hyprctl
  require_jq
  local src="${1:-}"
  [[ -n $src ]] || src="$(monitors_json | jq -r 'first(.[] | select(.focused) | .name) // empty')"
  [[ -n $src ]] || src="$(monitors_json | jq -r 'first(.[] | select(.disabled | not) | .name) // empty')"
  [[ -n $src ]] || { echo "ryoku-monitor: no monitor to mirror" >&2; return 1; }
  local name n=0
  while IFS= read -r name; do
    [[ -n $name && $name != "$src" ]] || continue
    if apply_monitor "output = \"$name\", mode = \"preferred\", position = \"auto\", scale = 1, mirror = \"$src\""; then
      echo "ryoku-monitor: $name mirrors $src"
      n=$((n + 1))
    fi
  done < <(monitors_json | jq -r '.[] | select(.disabled | not) | .name')
  if (( n > 0 )); then cmd_persist >/dev/null; else echo "ryoku-monitor: only one display; nothing to mirror"; fi
}

# Clear mirroring and lay the displays side by side again, DPI-scaled.
cmd_extend() {
  require_hyprctl
  require_jq
  local name
  while IFS= read -r name; do
    [[ -n $name ]] || continue
    apply_monitor "output = \"$name\", mode = \"preferred\", position = \"auto\", scale = 1, mirror = \"none\""
  done < <(monitors_json | jq -r '.[] | select(.disabled | not) | .name')
  cmd_autoscale --no-profile
}

# Toggle mirror <-> extend (the Super+P display switch).
cmd_toggle() {
  require_hyprctl
  require_jq
  if monitors_json | jq -e 'any(.[]; (.mirrorOf // "none") != "none")' >/dev/null 2>&1; then
    cmd_extend
  else
    cmd_mirror
  fi
}

# --- GUI and profile support (Ryoku Settings) ----------------------------
#
# The hub reads the live layout with `list`, applies a user-chosen layout with
# `apply` (live only) or `save NAME` (live + a named profile), and recalls one
# with `load NAME`. Profiles match on monitor hardware identity, so they survive
# connector renames; `autoscale` applies a matching profile at login/hotplug.

# Emit the connected monitors as GUI-ready JSON: identity, current mode, layout,
# and the available modes for the resolution picker.
cmd_list() {
  require_hyprctl
  require_jq
  monitors_json | jq -c '[ .[] | {
    name, description, make, model, serial,
    id: ((.make // "") + "|" + (.model // "") + "|" + (.serial // "")),
    width, height, refresh: (.refreshRate | round),
    x, y, scale, transform, vrr, disabled, focused,
    mirror: (.mirrorOf // "none"),
    modes: (.availableModes // [])
  } ]'
}

# Apply an explicit layout (JSON array of monitor specs on stdin) live, one
# hl.monitor per entry.
apply_specs() {
  local args
  while IFS= read -r args; do
    [[ -n $args ]] || continue
    apply_monitor "$args"
  done < <(jq -r '
    .[] |
    if .disabled then "output = \"\(.output)\", disabled = true"
    else "output = \"\(.output)\", mode = \"\(.mode)\", position = \"\(.position)\", scale = \(.scale)"
      + (if (.transform // 0) != 0 then ", transform = \(.transform)" else "" end)
      + (if (.vrr // 0) != 0 then ", vrr = \(.vrr)" else "" end)
      + (if (.mirror // "") != "" and (.mirror // "") != "none" then ", mirror = \"\(.mirror)\"" else "" end)
    end')
}

# Write monitors.lua from an explicit layout (JSON array on stdin), preserving the
# chosen modes (unlike persist, which captures highrr). Keeps GDK_SCALE in step
# and appends the hotplug catch-all.
write_monitors_explicit() {
  local specs gdk
  specs="$(cat)"
  gdk="$(printf '%s' "$specs" | jq -r '
    [ .[] | select(.disabled | not) | .scale ] as $s |
    if ($s | length) > 0 and ($s | unique | length) == 1
       and ($s[0] == ($s[0] | floor)) and $s[0] >= 2
    then ($s[0] | floor) else 1 end')"
  [[ $gdk =~ ^[0-9]+$ ]] || gdk=1
  if [[ -z ${RYOKU_MONITOR_JSON:-} ]]; then
    hyprctl eval "hl.env(\"GDK_SCALE\", \"$gdk\")" >/dev/null 2>&1 || true
  fi
  mkdir -p "$(dirname "$monitors_conf")"
  {
    printf '%s\n' "-- Managed by ryoku-monitor (Ryoku Settings layout). The per-output modes are"
    printf '%s\n' "-- the ones chosen in the Displays section; edits here may be overwritten."
    printf '\n'
    printf '%s' "$specs" | jq -r '
      .[] |
      if .disabled then
        "hl.monitor({ output = \"\(.output)\", disabled = true })"
      else
        "hl.monitor({ output = \"\(.output)\", mode = \"\(.mode)\", position = \"\(.position)\", scale = \(.scale)"
        + (if (.transform // 0) != 0 then ", transform = \(.transform)" else "" end)
        + (if (.vrr // 0) != 0 then ", vrr = \(.vrr)" else "" end)
        + (if (.mirror // "") != "" and (.mirror // "") != "none" then ", mirror = \"\(.mirror)\"" else "" end)
        + " })"
      end'
    printf '\n'
    printf '%s\n' "-- Keep GTK and XWayland apps crisp (shared integer scale when every monitor"
    printf '%s\n' "-- agrees at >=2x, else 1)."
    printf 'hl.env("GDK_SCALE", "%s")\n' "$gdk"
    printf '\n'
    printf '%s\n' "-- Catch-all for monitors not listed above (hotplug-friendly, safe 1x default)."
    printf '%s\n' 'hl.monitor({ output = "", mode = "highrr", position = "auto", scale = 1 })'
  } >"$monitors_conf"
}

# Apply a layout live and remember it as the implicit applied layout, so the
# choice (a hand-set scale above all) survives a relogin: autoscale recalls it for
# this display set instead of recomputing from DPI. JSON array as $1 or on stdin.
cmd_apply() {
  require_hyprctl
  require_jq
  local json="${1:-}"
  [[ -n $json ]] || json="$(cat)"
  printf '%s' "$json" | apply_specs
  printf '%s' "$json" | write_monitors_explicit
  mkdir -p "$(dirname "$applied_layout")"
  printf '%s' "$json" | jq '{monitors: .}' >"$applied_layout"
  echo "ryoku-monitor: applied layout -> $monitors_conf"
}

# Save the layout as a named, hardware-keyed profile and apply it now. JSON array
# as $2 or on stdin.
cmd_save() {
  require_hyprctl
  require_jq
  local name="${1:-}" json="${2:-}"
  [[ -n $name ]] || { echo "ryoku-monitor: save needs a profile name" >&2; return 1; }
  [[ -n $json ]] || json="$(cat)"
  mkdir -p "$monitors_dir"
  printf '%s' "$json" | jq '{monitors: .}' >"$monitors_dir/$name.json"
  printf '%s' "$json" | apply_specs
  printf '%s' "$json" | write_monitors_explicit
  echo "ryoku-monitor: saved profile $name"
}

# Hardware identities of the connected monitors, sorted and de-duplicated. The
# profile-match key.
connected_ids() {
  monitors_json | jq -r '[ .[] | ((.make // "") + "|" + (.model // "") + "|" + (.serial // "")) ] | sort | unique | .[]'
}

# Name of the first saved profile whose monitor set matches the connected one (by
# hardware identity), or nothing.
matching_profile() {
  [[ -d $monitors_dir ]] || return 1
  local conn f pids
  conn="$(connected_ids)"
  for f in "$monitors_dir"/*.json; do
    [[ -e $f ]] || continue
    pids="$(jq -r '[ .monitors[].id ] | sort | unique | .[]' "$f" 2>/dev/null)"
    if [[ -n $pids && "$pids" == "$conn" ]]; then
      basename "$f" .json
      return 0
    fi
  done
  return 1
}

# Apply a saved layout file ({monitors:[...]}), mapping each saved monitor to the
# connector that now carries its hardware identity, so DP-1/DP-2 swaps do not
# matter. Shared by named-profile load and the implicit applied-layout recall.
load_layout_file() {
  local file="$1" resolved
  resolved="$(jq -n --argjson live "$(monitors_json)" --slurpfile prof "$file" '
    [ $prof[0].monitors[]
      | . as $m
      | (first($live[] | select(((.make // "") + "|" + (.model // "") + "|" + (.serial // "")) == $m.id) | .name)) as $out
      | select($out != null)
      | $m + { output: $out } ]')"
  printf '%s' "$resolved" | apply_specs
  printf '%s' "$resolved" | write_monitors_explicit
}

# Apply a saved, named profile by hardware identity.
cmd_load() {
  require_hyprctl
  require_jq
  local name="${1:-}" file
  file="$monitors_dir/$name.json"
  [[ -f $file ]] || { echo "ryoku-monitor: no such profile: $name" >&2; return 1; }
  load_layout_file "$file"
  echo "ryoku-monitor: loaded profile $name"
}

# True when the implicit applied layout exists and matches the connected set.
applied_matches() {
  [[ -f $applied_layout ]] || return 1
  local conn pids
  conn="$(connected_ids)"
  pids="$(jq -r '[ .monitors[].id ] | sort | unique | .[]' "$applied_layout" 2>/dev/null)"
  [[ -n $pids && "$pids" == "$conn" ]]
}

# List saved profiles as JSON, each tagged with whether it matches the connected
# monitor set.
cmd_profiles() {
  require_jq
  local conn arr f name pids match
  conn="$(connected_ids 2>/dev/null)"
  arr="[]"
  if [[ -d $monitors_dir ]]; then
    for f in "$monitors_dir"/*.json; do
      [[ -e $f ]] || continue
      name="$(basename "$f" .json)"
      pids="$(jq -r '[ .monitors[].id ] | sort | unique | .[]' "$f" 2>/dev/null)"
      match=false
      [[ -n $pids && "$pids" == "$conn" ]] && match=true
      arr="$(jq --arg n "$name" --argjson m "$match" --slurpfile p "$f" \
        '. + [ { name: $n, matches: $m, monitors: $p[0].monitors } ]' <<<"$arr")"
    done
  fi
  printf '%s\n' "$arr"
}

cmd_rm() {
  local name="${1:-}"
  [[ -n $name ]] || { echo "ryoku-monitor: rm needs a profile name" >&2; return 1; }
  rm -f "$monitors_dir/$name.json"
  echo "ryoku-monitor: removed profile $name"
}

usage() {
  cat <<'EOF'
Usage: ryoku-monitor <command>

  autoscale   Derive each monitor's scale from its DPI, apply it live, and write
              the monitors drop-in (default ~/.config/hypr/monitors.lua).
  persist     Write the monitors drop-in from the current live layout (no rescale).
  mirror [SRC] Mirror every other display onto SRC (default: the focused one).
  extend      Clear mirroring and lay displays side by side, DPI-scaled.
  toggle      Switch between mirror and extend.
  list        Print the connected monitors as JSON (for Ryoku Settings).
  apply JSON  Apply an explicit layout live (JSON array of monitor specs).
  save NAME JSON  Apply a layout and save it as a hardware-keyed profile.
  load NAME   Apply a saved profile, matching displays by hardware identity.
  profiles    List saved profiles as JSON (each tagged if it matches now).
  rm NAME     Delete a saved profile.

Both sync GDK_SCALE for GTK/XWayland apps. DPI buckets: <=120=1x, <=150=1.25,
<=230=1.5, <=290=1.75, >290=2x.
EOF
}

main() {
  case "${1:-}" in
    autoscale) cmd_autoscale "${2:-}" ;;
    persist) cmd_persist ;;
    mirror) cmd_mirror "${2:-}" ;;
    extend) cmd_extend ;;
    toggle) cmd_toggle ;;
    list) cmd_list ;;
    apply) cmd_apply "${2:-}" ;;
    save) cmd_save "${2:-}" "${3:-}" ;;
    load) cmd_load "${2:-}" ;;
    profiles) cmd_profiles ;;
    rm) cmd_rm "${2:-}" ;;
    -h | --help | help) usage ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
}

# Run only when executed; sourcing (tests) just loads the functions.
if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  main "$@"
fi
