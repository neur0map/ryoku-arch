#!/usr/bin/env bash
#
# ryoku-windows-entry: keep a Windows chainload entry in the Limine boot menu,
# auto-detected on any drive.
#
# why: Limine's own FIND_BOOTLOADERS only scans the ESP that holds limine.conf,
# so a Windows install on a *separate* drive is never picked up -- once Ryoku
# owns the boot order the machine has no way back into Windows. so we scan
# every EFI System Partition for the Windows boot manager
# (EFI/Microsoft/Boot/bootmgfw.efi) and write a Limine entry for it. two forms:
# when Windows' ESP IS Limine's own boot volume (the shared-ESP alongside install)
# we use `boot():/...` -- Limine's 9.x+ uuid() cross-volume chainload panics
# ("Failed to open image") when the target is the boot volume itself; only a
# genuine cross-DRIVE Windows gets `uuid(<gpt-part-guid>):/...`. the entry sits in
# a marker-fenced block, so a re-run updates it in place (no duplicates) and
# foreign entries (kernels, snapshots) are left alone.
#
# subcommands:
#   detect       = print "<gpt-part-guid><TAB><device>" for the Windows ESP, if any
#   emit <guid>  = print the Limine entry block for a GUID
#   sync [conf]  = ensure the managed Windows block exists in `conf`
#                  (default = the live limine.conf), adding or updating as needed
#
# test seams (so conf-editing runs hermetically against no real disks):
#   RYOKU_WINDOWS_GUID  set short-circuits the scan; empty => "no Windows",
#                       non-empty => report that GUID as the detected Windows ESP.
#   RYOKU_WINDOWS_DEV   device string paired with RYOKU_WINDOWS_GUID (display only).
#
# mounting to probe an ESP needs root; run as root (the installer and the
# limine-entry-tool post.d hook both do).

set -euo pipefail

# fences are Limine comments (a line starting with '#' is ignored), so safe
# inside limine.conf yet exact regex-free anchors for idempotent edits.
readonly BEGIN_MARK="# >>> ryoku-windows-entry (managed) >>>"
readonly END_MARK="# <<< ryoku-windows-entry (managed) <<<"
readonly WIN_PATH="/EFI/Microsoft/Boot/bootmgfw.efi"

# ── detection ─────────────────────────────────────────────────────────────────

# probe_device DEV: true when DEV's fs holds the Windows boot manager. uses an
# existing mountpoint when DEV is already mounted, else a temp RO mount, always
# unmounted (umount then rmdir, in that order).
probe_device() {
  local dev="$1" mp tmp rc=1
  mp="$(findmnt -nro TARGET --source "$dev" 2>/dev/null | head -n1 || true)"
  if [[ -n $mp ]]; then
    [[ -e "$mp$WIN_PATH" ]]
    return
  fi
  command -v mount >/dev/null 2>&1 || return 1
  tmp="$(mktemp -d)" || return 1
  if mount -o ro "$dev" "$tmp" 2>/dev/null; then
    [[ -e "$tmp$WIN_PATH" ]] && rc=0
    umount "$tmp" 2>/dev/null || true
  fi
  rmdir "$tmp" 2>/dev/null || true
  return $rc
}

# print "<guid><TAB><device>" for the first ESP carrying the Windows boot
# manager, or return 1 when none is found.
detect_windows() {
  # test seam: a defined RYOKU_WINDOWS_GUID short-circuits the scan.
  if [[ -n ${RYOKU_WINDOWS_GUID+x} ]]; then
    [[ -n $RYOKU_WINDOWS_GUID ]] || return 1
    printf '%s\t%s\n' "$RYOKU_WINDOWS_GUID" "${RYOKU_WINDOWS_DEV:-/dev/test}"
    return 0
  fi

  command -v lsblk >/dev/null 2>&1 || return 1
  local dev fstype partuuid parttype
  # only vfat partitions and GPT ESPs are chainload candidates; on GPT, PARTUUID
  # is exactly the partition GUID uuid() resolves.
  while read -r dev fstype partuuid parttype; do
    [[ -n $dev && -n $partuuid ]] || continue
    [[ $fstype == vfat || ${parttype,,} == c12a7328-* ]] || continue
    if probe_device "$dev"; then
      printf '%s\t%s\n' "$partuuid" "$dev"
      return 0
    fi
  done < <(lsblk -rpno NAME,FSTYPE,PARTUUID,PARTTYPE 2>/dev/null)
  return 1
}

# ── config editing ────────────────────────────────────────────────────────────

# emit_entry GUID [same_volume]: the Limine /Windows block. a non-empty second
# arg means Windows' ESP is Limine's own boot volume, so use boot(): (protocol
# efi) -- uuid() to the boot volume itself panics on 9.x+. else uuid() for a
# genuine cross-drive Windows.
emit_entry() {
  local guid="$1" same_volume="${2:-}"
  if [[ -n $same_volume ]]; then
    cat <<EOF
/Windows
    comment: Boot into Windows
    protocol: efi
    path: boot():$WIN_PATH
EOF
  else
    cat <<EOF
/Windows
    comment: Boot into Windows
    protocol: efi_chainload
    path: uuid($guid):$WIN_PATH
EOF
  fi
}

# conf_partuuid CONF: GPT PARTUUID of the volume backing CONF -- the partition
# Limine boots from when CONF is the live config. RYOKU_CONF_PARTUUID overrides
# for hermetic tests.
conf_partuuid() {
  if [[ -n ${RYOKU_CONF_PARTUUID+x} ]]; then printf '%s' "$RYOKU_CONF_PARTUUID"; return 0; fi
  command -v findmnt >/dev/null 2>&1 || return 1
  local dev
  dev="$(findmnt -nvo SOURCE --target "$1" 2>/dev/null | head -n1 || true)"
  [[ -n $dev ]] || return 1
  lsblk -rpno PARTUUID "$dev" 2>/dev/null | head -n1
}

# echo FILE with any prior managed Windows block removed. title-anchored and
# fence-tolerant. why: limine-entry-tool 1.37 adopts our flat "/Ryoku Linux"
# placeholder and re-serializes the begin fence (an attached configLine) ABOVE
# the generated "//<kernel>" UKI children, so the old fence-to-fence delete
# swallowed the kernels and permanently flattened the menu. so we remove ONLY
# (a) the fence marker lines wherever they land (even indented as a configLine,
# hence the trim) and (b) the "/Windows" node itself -- its title plus its
# indented body. any OTHER top-level entry (a trimmed line starting with "/",
# which also covers "//" UKI children) ends the removal region, so kernels and
# foreign entries are never spanned. a repeat "/Windows" re-arms the region, so
# stray duplicates are all removed (sync then re-appends exactly one).
strip_managed() {
  awk -v b="$BEGIN_MARK" -v e="$END_MARK" '
    { t = $0; sub(/^[[:space:]]+/, "", t) }
    t == b || t == e            { skip = 0; next }
    t == "/Windows"             { skip = 1; next }
    skip && t ~ /^\//           { skip = 0; print; next }
    skip && $0 ~ /^[[:space:]]/ { next }
    skip                        { skip = 0 }
    { print }
  ' "$1"
}

# rewrite CONF so it carries exactly one managed Windows block for GUID.
# atomic: write a temp, then mv into place.
sync_conf() {
  local conf="$1" guid="$2" same_volume="${3:-}" tmp
  tmp="$(mktemp)" || return 1
  if [[ -f $conf ]]; then
    strip_managed "$conf" >"$tmp"
  fi
  {
    printf '%s\n' "$BEGIN_MARK"
    emit_entry "$guid" "$same_volume"
    printf '%s\n' "$END_MARK"
  } >>"$tmp"
  mv "$tmp" "$conf"
}

# the limine.conf the running firmware actually reads, searched in the same
# precedence Limine uses, then the bootctl-reported ESP.
live_conf() {
  local c esp
  for c in /boot/limine/limine.conf /boot/limine.conf /efi/limine/limine.conf /efi/limine.conf; do
    [[ -f $c ]] && { printf '%s' "$c"; return 0; }
  done
  if command -v bootctl >/dev/null 2>&1; then
    esp="$(bootctl --print-esp-path 2>/dev/null | head -n1 || true)"
    [[ -n $esp && -f "$esp/limine/limine.conf" ]] && { printf '%s' "$esp/limine/limine.conf"; return 0; }
    [[ -n $esp && -f "$esp/limine.conf" ]] && { printf '%s' "$esp/limine.conf"; return 0; }
  fi
  return 1
}

# ── subcommands ───────────────────────────────────────────────────────────────

cmd_detect() {
  detect_windows
}

cmd_emit() {
  local guid="${1:-}"
  [[ -n $guid ]] || { echo "ryoku-windows-entry: emit needs a GUID" >&2; return 1; }
  emit_entry "$guid"
}

cmd_sync() {
  local conf="${1:-}"
  if [[ -z $conf ]]; then
    conf="$(live_conf)" || {
      echo "ryoku-windows-entry: no limine.conf found; nothing to do" >&2
      return 0
    }
  fi
  local out guid confuuid same_volume=""
  if out="$(detect_windows)"; then
    guid="${out%%$'\t'*}"
    # same volume as Limine's own config = a shared ESP: use boot(), not uuid().
    confuuid="$(conf_partuuid "$conf" 2>/dev/null || true)"
    [[ -n $confuuid && ${confuuid,,} == "${guid,,}" ]] && same_volume=1
    sync_conf "$conf" "$guid" "$same_volume"
    if [[ -n $same_volume ]]; then
      echo "ryoku-windows-entry: Windows chainload entry -> boot(): (shared ESP) in $conf"
    else
      echo "ryoku-windows-entry: Windows chainload entry -> uuid($guid) in $conf"
    fi
  else
    # conservative: a missing Windows might just be a detached drive, so an
    # existing managed block stays put rather than getting ripped out.
    echo "ryoku-windows-entry: no Windows boot manager found; left $conf unchanged"
  fi
}

usage() {
  cat <<'USAGE'
Usage: ryoku-windows-entry <command>

Keep a Windows chainload entry in the Limine boot menu, auto-detected on any drive.

Commands:
  detect          Print "<gpt-part-guid>\t<device>" for the Windows ESP, if any.
  emit <guid>     Print the Limine entry block for a partition GUID.
  sync [conf]     Add or update the managed Windows entry in limine.conf
                  (default: the live limine.conf). Idempotent.
USAGE
}

case "${1:-sync}" in
  detect) cmd_detect ;;
  emit) cmd_emit "${2:-}" ;;
  sync) cmd_sync "${2:-}" ;;
  -h | --help | help) usage ;;
  *)
    echo "ryoku-windows-entry: unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
