# Ryoku default tofi configuration.
# Minimal defaults; themes may override via ~/.config/ryoku/current/theme/tofi.conf
# (not wired up yet; acts as a passive inclusion hook).

font = JetBrainsMono Nerd Font
font-size = 12
prompt-text = "> "

width = 50%
height = 40%
anchor = center
horizontal = false

background-color = #181818
text-color = #ebdbb2
selection-color = #8ec07c
prompt-color = #fabd2f
input-color = #ebdbb2

border-width = 2
border-color = #3c3836
outline-width = 0
corner-radius = 6

padding-top = 16
padding-bottom = 16
padding-left = 16
padding-right = 16

num-results = 10
result-spacing = 6

hide-cursor = true
ascii-input = false
