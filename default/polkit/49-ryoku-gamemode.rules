// Ryoku: allow active wheel-group sessions to start/stop the game mode
// hardware-performance unit without a password, so the shell's one-click
// game mode toggle works. Scope is intentionally narrow: only start/stop/
// restart, only the two known instance names, only active+local sessions,
// only wheel members.
polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.systemd1.manage-units") return;
    if (!subject.active || !subject.local) return;
    if (!subject.isInGroup("wheel")) return;

    var unit = action.lookup("unit") || "";
    if (!/^ryoku-gamemode-perf@(full|base)\.service$/.test(unit)) return;

    var verb = action.lookup("verb") || "";
    if (["start", "stop", "restart"].indexOf(verb) === -1) return;

    return polkit.Result.YES;
});
