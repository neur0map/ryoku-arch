# Editor used by CLI
export RYOKU_EDITOR="${RYOKU_EDITOR:-nvim}"
export EDITOR="$RYOKU_EDITOR"
export VISUAL="${RYOKU_VISUAL:-$EDITOR}"
export SUDO_EDITOR="${RYOKU_SUDO_EDITOR:-$VISUAL}"
export BAT_THEME=ansi

# Mirror the desktop session runtime contract so SSH shells behave the same way.
for _ryoku_runtime_env in \
  "$HOME/.local/share/ryoku/lib/runtime-env.sh" \
  "$HOME/.local/share/omarchy/lib/runtime-env.sh"; do
  if [[ -r $_ryoku_runtime_env ]]; then
    source "$_ryoku_runtime_env"
    break
  fi
done
unset _ryoku_runtime_env

case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) export PATH="$PATH:$HOME/.local/bin" ;;
esac
