#!/bin/bash

# After resume, ask active Ryoku user sessions to recover Niri/Ryoku UI state.

set -euo pipefail

phase="${1:-}"

[[ $phase == "post" ]] || exit 0

recover_user_session() {
  local uid="$1"
  local uid_dir="$2"
  local bus_address="unix:path=$uid_dir/bus"
  local passwd_entry user_name home_dir user_env ryoku_path recover_cmd

  passwd_entry="$(getent passwd "$uid" 2>/dev/null || true)"
  [[ -n $passwd_entry ]] || return 0

  IFS=: read -r user_name _ _ _ _ home_dir _ <<< "$passwd_entry"
  [[ -n $user_name && -n $home_dir && -d $home_dir ]] || return 0

  user_env="$(
    sudo -u "#$uid" env \
      HOME="$home_dir" \
      USER="$user_name" \
      LOGNAME="$user_name" \
      XDG_RUNTIME_DIR="$uid_dir" \
      DBUS_SESSION_BUS_ADDRESS="$bus_address" \
      systemctl --user show-environment 2>/dev/null || true
  )"

  ryoku_path="$(printf '%s\n' "$user_env" | sed -n 's/^RYOKU_PATH=//p' | head -n1)"
  recover_cmd=""

  if [[ -n $ryoku_path && -x $ryoku_path/bin/ryoku-session-recover ]]; then
    recover_cmd="$ryoku_path/bin/ryoku-session-recover"
  elif [[ -x $home_dir/.local/share/ryoku/bin/ryoku-session-recover ]]; then
    recover_cmd="$home_dir/.local/share/ryoku/bin/ryoku-session-recover"
  fi

  [[ -n $recover_cmd ]] || return 0

  sudo -u "#$uid" env \
    HOME="$home_dir" \
    USER="$user_name" \
    LOGNAME="$user_name" \
    XDG_RUNTIME_DIR="$uid_dir" \
    DBUS_SESSION_BUS_ADDRESS="$bus_address" \
    "$recover_cmd" --quiet --resume >/dev/null 2>&1 || true
}

run_recovery() {
  local uid_dir uid

  for uid_dir in /run/user/*; do
    [[ -d $uid_dir && -S $uid_dir/bus ]] || continue
    uid="$(basename "$uid_dir")"
    [[ $uid =~ ^[0-9]+$ ]] || continue
    recover_user_session "$uid" "$uid_dir"
  done
}

if [[ ${RYOKU_SESSION_RECOVER_SYNC:-0} == "1" ]]; then
  run_recovery
else
  (
    sleep 1
    run_recovery
  ) &
fi
