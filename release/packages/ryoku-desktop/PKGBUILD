# Maintainer: Ryoku <releases@ryoku.dev>
#
# Ryoku desktop umbrella. pulls the Ryoku components + the user-facing runtime,
# lays the base config under /usr/share/ryoku/config (mirrors the ~/.config tree
# that `ryoku materialize` copies into a user's home), and drops the helper
# scripts + the GPU udev rule.
#
# built from in-repo sources, no tarball fetch. publish CI runs makepkg inside
# this dir from a full checkout, so the repo root is three levels up.
pkgname=ryoku-desktop
pkgver=${RYOKU_PKGVER:-0.1.0}
pkgrel=1
pkgdesc="Ryoku desktop: Hyprland + Quickshell configuration, helpers, and runtime"
# package() compiles Go helpers (ryovm-fetch), so the payload is arch-specific.
arch=('x86_64')
url="https://ryoku.dev"
license=('GPL-3.0-or-later')
# go builds the app helpers (ryovm-fetch); cmake+Qt6 build any compiled ryoku/apps app.
makedepends=('go' 'cmake' 'ninja' 'qt6-base' 'qt6-declarative')
depends=(
  # Ryoku. the monorepo components are pinned to this build's own version:
  # every publish rebuilds them all with one shared RYOKU_PKGVER, and the shell
  # QML in this package must never run against another release's compiled
  # plugin or daemon (a partial upgrade now fails loudly instead of skewing).
  "ryoku-shell=$pkgver"
  "ryoku-hub=$pkgver"
  "ryoku-rashin=$pkgver"
  "ryoku-blobs=$pkgver"
  "ryoku=$pkgver"
  'ryoku-keyring'
  # the RyokuArch package manager (GlazePKG)
  'gpk'
  # compositor + Wayland session
  'hyprland'
  # Hyprland compositor plugins the Hub can toggle (Appearance / Animations).
  # pinned to this build's version like the other monorepo packages, so a plugin
  # .so never runs against a different release's headers. Off by default; the
  # generated settings.lua only loads one once the user enables it.
  "hypr-dynamic-cursors=$pkgver"
  "ryoku-hypr-plugins=$pkgver"
  "hyprglass=$pkgver"
  "imgborders=$pkgver"
  'xorg-xwayland'
  'qt6-wayland'
  'qt6-5compat'
  'qt6-svg'
  'hyprpolkitagent'
  'xdg-desktop-portal-hyprland'
  'xdg-desktop-portal-gtk'
  # the standalone Adwaita-dark GTK theme the Hyprland autostart selects
  # (gsettings gtk-theme). a hard depend so `ryoku update` pulls it onto existing
  # boxes: nothing else brings it in, and without it the name has nothing on disk,
  # so the portal file chooser (GTK3) falls back to light in the dark session.
  'gnome-themes-extra'
  # Qt icon theme the shipped qt6ct.conf (config/qt6ct/qt6ct.conf) selects, so
  # named freedesktop icons (e.g. the Avahi entries' network-wired) resolve in
  # the launcher's all-apps grid instead of a broken-image placeholder.
  'papirus-icon-theme'
  # shell + apps configured here
  'quickshell'
  'kitty'
  'fish'
  'starship'
  'fastfetch'
  'yazi'
  'neovim'
  # file manager + its stash right-click integration. nautilus-python loads
  # ryoku-stash-menu.py (Install/Compress/Send with Ryoku); a hard depend, not
  # optional, so `ryoku update` pulls it onto existing boxes that predate it (an
  # optdepend never installs on -Syu) and the right-click menu actually shows up.
  'nautilus'
  'nautilus-python'
  # tools the shipped autostart, pill, ryoshot, and helper scripts call by name
  'hypridle'
  'brightnessctl'
  'playerctl'
  'wl-clipboard'
  'cliphist'
  'hyprpicker'
  'grim'
  'slurp'
  'cava'
  'jq'
  'imagemagick'
  # wallpaper -> color palette generator. the shell runs `wallust run <image>`
  # on every wallpaper change to retint kitty / Hyprland / the shell (the
  # "match wallpaper" colors). ships from the [ryoku] repo -- not the AUR, whose
  # pinned Codeberg-archive checksum drifts and breaks the build -- so it resolves
  # as a hard depend and reaches every box on `ryoku update`.
  'wallust'
  # live (video) wallpapers: the daemon grabs one frame with ffmpeg to derive the
  # wallust palette. official repo, so a hard depend reaches existing boxes.
  'ffmpeg'
  # qt6-multimedia + qt6-declarative back the QML video surfaces: ryowalls' live
  # previews, the shell's video-wallpaper preview, and the qylock lockscreen.
  # official repo, hard depends so they reach existing boxes on `ryoku update`.
  'qt6-multimedia'
  'qt6-declarative'
  # Ryoku Motion: the screen-demo recorder and editor (OpenScreen fork, built for
  # the [ryoku] repo). The shell's record island opens it for a studio capture or
  # to import a clip; ships in the ISO and reaches boxes on `ryoku update`.
  'ryomotion'
  # ryoshot Beautify's HD export and ryowalls Enhance AI-upscale on the GPU with
  # this. official repo (extra), so a hard depend ships it in the ISO install and
  # reaches existing boxes on `ryoku update` -- an optdepend never installs on -Syu,
  # and the HD toggle / Enhance are meant to work for every user out of the box.
  'waifu2x-ncnn-vulkan'
  # Hub's ISO picker (GPU passthrough VM) shells out to a file chooser
  'zenity'
  # Game Mode wifi power-save toggle (ryoku-wifi-powersave runs iw)
  'iw'
  # Bluetooth: the pill link + Hub Connections drive bluetoothd over D-Bus
  # (Quickshell.Bluetooth) and shell out to bluetoothctl to pair; the .install
  # enables bluetooth.service once so upgrades from bluez-less installs work.
  'bluez'
  'bluez-utils'
  # rtkit hands PipeWire's audio thread realtime scheduling; without it the
  # thread runs SCHED_OTHER and crackles under load. .install enables the daemon.
  'rtkit'
  # fonts the shell UI hardcodes: Inter, JetBrainsMono Nerd, Noto Sans CJK, and
  # Material Symbols Rounded (every pill/bar icon, via MaterialIcon.qml). all
  # official repo, so a hard depend reaches existing boxes on `ryoku update`;
  # without the symbols font each icon renders as its ligature name ("wifi").
  'ttf-jetbrains-mono-nerd'
  'inter-font'
  'noto-fonts'
  'noto-fonts-cjk'
  'noto-fonts-emoji'
  'ttf-material-symbols-variable'
)
optdepends=(
  'awww: animated wallpaper transitions (AUR)'
  'mpvpaper: video (live) wallpaper playback, ryowalls Live tab (AUR)'
  'tesseract: OCR text grab (pill Super+D)'
  'tesseract-data-eng: English OCR language data'
  'zbar: QR code scanning (pill Super+D)'
  'gpu-screen-recorder: pill Super+U screen recording (hardware-encoded)'
  'wf-recorder: Ryoku Motion recording + pill Super+U multi-GPU capture'
  'hyprsunset: night-light color temperature (pill Super+U)'
  'openrgb: keyboard and LED accent sync via ryoku-leds'
  'wtype: voice-dictation typing on Wayland (Voxtype)'
  'chromium: web browser'
  'qemu-desktop: GPU-passthrough VM (Ryoku Settings > GPU)'
  'libvirt: VM management for the passthrough VM'
  'edk2-ovmf: UEFI and Secure Boot firmware for the VM'
  'swtpm: TPM 2.0 for the Windows 11 VM'
  'looking-glass: low-latency VM display in a desktop window'
  'quickemu: build and run virtual machines in ryovm'
  'spice-gtk: SPICE console + headless VM viewer for ryovm'
)
install="$pkgname.install"
source=()

_repo="$startdir/../../.."

package() {
  local cfg="$pkgdir/usr/share/ryoku/config"

  # --- base configs under /usr/share/ryoku/config, mirroring ~/.config -------
  # `ryoku materialize` copies this tree verbatim into the user's ~/.config.

  # Hyprland: whole tree. includes scripts/ (shell calls
  # ~/.config/hypr/scripts/* by absolute path) and the hardware-managed
  # gpu/keyboard/monitors drop-ins.
  install -d "$cfg/hypr"
  cp -a "$_repo/ryoku/hyprland/." "$cfg/hypr/"

  # Quickshell desktop components, Hub's config nested under hub/.
  install -d "$cfg/quickshell"
  cp -a "$_repo/ryoku/shell/quickshell/." "$cfg/quickshell/"
  install -d "$cfg/quickshell/hub"
  cp -a "$_repo/ryoku/hub/quickshell/." "$cfg/quickshell/hub/"

  # First-party GUI apps: a Quickshell app (ryowalls, ryovm) ships its
  # quickshell/ tree as qs -c <name>; a compiled app (ryomotion) has a
  # CMakeLists.txt and builds to a /usr/bin/<name> binary. Either way its bin/
  # helpers, .desktop and icon are installed. Dropping in a new app dir ships it.
  local appdir appname icon gomod helperdir helper b d has_qs has_cmake
  for appdir in "$_repo"/ryoku/apps/*/; do
    has_qs=0; [ -d "${appdir}quickshell" ] && has_qs=1
    has_cmake=0; [ -f "${appdir}CMakeLists.txt" ] && has_cmake=1
    [ "$has_qs" = 1 ] || [ "$has_cmake" = 1 ] || continue
    appname="$(basename "$appdir")"
    if [ "$has_qs" = 1 ]; then
      install -d "$cfg/quickshell/$appname"
      cp -a "${appdir}quickshell/." "$cfg/quickshell/$appname/"
    fi
    if [ "$has_cmake" = 1 ]; then
      # compiled Qt app: build to a binary named for the app dir.
      cmake -S "$appdir" -B "${appdir}build" -G Ninja -DCMAKE_BUILD_TYPE=Release
      cmake --build "${appdir}build"
      install -Dm755 "${appdir}build/$appname" "$pkgdir/usr/bin/$appname"
    fi
    if [ -d "${appdir}bin" ]; then
      for b in "${appdir}bin/"*; do
        [ -f "$b" ] && install -Dm755 "$b" "$pkgdir/usr/bin/$(basename "$b")"
      done
    fi
    # Go helper(s): a subdir with go.mod builds to a bin named for the module.
    for gomod in "${appdir}"*/go.mod; do
      [ -f "$gomod" ] || continue
      helperdir="$(dirname "$gomod")"
      helper="$(sed -n -E 's/^module[[:space:]]+//p' "$gomod" | head -1)"
      [ -n "$helper" ] || continue
      ( cd "$helperdir" && go build -o "$helper" . )
      install -Dm755 "$helperdir/$helper" "$pkgdir/usr/bin/$helper"
    done
    for d in "${appdir}"*.desktop; do
      [ -f "$d" ] && install -Dm644 "$d" "$pkgdir/usr/share/applications/$(basename "$d")"
    done
    icon="${appdir}quickshell/logo.svg"
    [ -f "$icon" ] || icon="${appdir}logo.svg"
    [ -f "$icon" ] || icon="$_repo/ryoku/assets/brand/logo-mark.svg"
    install -Dm644 "$icon" "$pkgdir/usr/share/icons/hicolor/scalable/apps/$appname.svg"
  done

  # Ryoku.PluginKit: the signature QML kit a shell plugin imports for its
  # content. pure QML, lives on the system import path next to Ryoku.Blobs so
  # plugins (loaded from outside the shell tree) can import it.
  install -d "$pkgdir/usr/lib/qt6/qml/Ryoku/PluginKit"
  cp -a "$_repo/ryoku/shell/quickshell/plugins/kit/." "$pkgdir/usr/lib/qt6/qml/Ryoku/PluginKit/"
  rm -f "$pkgdir/usr/lib/qt6/qml/Ryoku/PluginKit/install.sh"
  chmod -R u=rwX,go=rX "$pkgdir/usr/lib/qt6/qml/Ryoku/PluginKit"

  # wallust palette gen (templates feed kitty, Hyprland, shell colors).
  install -d "$cfg/wallust"
  cp -a "$_repo/ryoku/shell/wallust/." "$cfg/wallust/"

  # per-app configs
  install -Dm644 "$_repo/ryoku/apps/fish/config.fish"       "$cfg/fish/config.fish"
  install -Dm644 "$_repo/ryoku/apps/fish/conf.d/rashin.fish" "$cfg/fish/conf.d/rashin.fish"
  install -Dm644 "$_repo/ryoku/shell/qt6ct/qt6ct.conf"     "$cfg/qt6ct/qt6ct.conf"
  install -Dm644 "$_repo/ryoku/apps/starship/starship.toml" "$cfg/starship.toml"
  install -Dm644 "$_repo/ryoku/apps/fastfetch/config.jsonc" "$cfg/fastfetch/config.jsonc"
  # the fastfetch logo the config above draws. ships beside config.jsonc so
  # `ryoku materialize` lays both together on every update; seeding it only as a
  # brand asset (installer-time) left updated machines pointing at a file they
  # never received, and fastfetch silently fell back to the Arch logo.
  install -Dm644 "$_repo/ryoku/assets/brand/fastfetch-emblem.png" \
    "$cfg/fastfetch/fastfetch-emblem.png"
  # pipewire: audio follows a newly connected device (BT headset, USB DAC)
  install -d "$cfg/pipewire"
  cp -a "$_repo/ryoku/apps/pipewire/." "$cfg/pipewire/"
  # wireplumber: Bluetooth codec policy (mSBC calls, hi-fi A2DP); system drop-in,
  # user-overridable from ~/.config/wireplumber/wireplumber.conf.d/.
  install -Dm644 "$_repo/ryoku/apps/wireplumber/wireplumber.conf.d/51-ryoku-bluetooth.conf" \
    "$pkgdir/etc/wireplumber/wireplumber.conf.d/51-ryoku-bluetooth.conf"
  install -Dm644 "$_repo/ryoku/apps/yazi/yazi.toml"         "$cfg/yazi/yazi.toml"
  install -d "$cfg/kitty"
  cp -a "$_repo/ryoku/apps/kitty/." "$cfg/kitty/"

  # neovim (LazyVim seed): the config only, not the repo docs.
  install -Dm644 "$_repo/ryoku/apps/nvim/init.lua"       "$cfg/nvim/init.lua"
  install -Dm644 "$_repo/ryoku/apps/nvim/.ryoku-lazyvim" "$cfg/nvim/.ryoku-lazyvim"
  cp -a "$_repo/ryoku/apps/nvim/lua" "$cfg/nvim/"

  # pip: PEP 668 --user installs (materialized to ~/.config/pip/pip.conf).
  install -Dm644 "$_repo/ryoku/apps/pip/pip.conf" "$cfg/pip/pip.conf"
  # neovim as the default text/code editor: the handler ships system-wide and
  # the mimeapps map is materialized, so the mapping reaches installs on update.
  install -Dm644 "$_repo/ryoku/apps/nvim/ryoku-nvim.desktop" \
    "$pkgdir/usr/share/applications/ryoku-nvim.desktop"
  install -Dm644 "$_repo/ryoku/apps/mimeapps.list" "$cfg/mimeapps.list"

  # user session target
  install -Dm644 "$_repo/ryoku/shell/systemd/user/hyprland-session.target" \
    "$cfg/systemd/user/hyprland-session.target"

  # cp -a kept source mode bits; normalize so hypr/scripts stays executable
  # and the rest is world-readable data.
  chmod -R u=rwX,go=rX "$pkgdir/usr/share/ryoku"

  # --- helper scripts on PATH (/usr/bin) ------------------------------------
  # the pill, Hub, and shell also call the hypr/scripts copies above by absolute
  # path; these are for CLI use + the hardware helpers Hyprland autostart calls
  # by bare name.
  local s
  for s in "$_repo"/ryoku/hyprland/scripts/ryoku-cmd-*; do
    install -Dm755 "$s" "$pkgdir/usr/bin/${s##*/}"
  done
  for s in "$_repo"/system/hardware/*/ryoku-*; do
    install -Dm755 "$s" "$pkgdir/usr/bin/${s##*/}"
  done
  for s in "$_repo"/system/extras/ryoku-*; do
    install -Dm755 "$s" "$pkgdir/usr/bin/${s##*/}"
  done
  install -Dm755 "$_repo/ryoku/apps/fastfetch/ryoku-fastfetch" \
    "$pkgdir/usr/bin/ryoku-fastfetch"

  # plugin placement helper: desktop drag + Ryoku Settings call it to persist
  # a plugin's host/position into ~/.config/ryoku/plugins.json.
  install -Dm755 "$_repo/ryoku/shell/quickshell/plugins/ryoku-plugins-place" \
    "$pkgdir/usr/bin/ryoku-plugins-place"

  # Nautilus stash actions: a nautilus-python extension that adds the deck's
  # install/compress/LocalSend actions to the file-manager right-click menu.
  # Loaded for every user from the system extensions dir, so it needs no
  # per-user materialize.
  install -Dm644 "$_repo/ryoku/apps/nautilus/ryoku-stash-menu.py" \
    "$pkgdir/usr/share/nautilus-python/extensions/ryoku-stash-menu.py"

  # GPU primary-renderer udev rule: boot-stable /dev/dri/ryoku-gpu-* symlinks
  # that ryoku-gpu pins via AQ_DRM_DEVICES. vendor location = active on boot,
  # so `ryoku-gpu install-udev` is never needed on an installed system.
  install -Dm644 "$_repo/system/hardware/gpu/90-ryoku-gpu.rules" \
    "$pkgdir/usr/lib/udev/rules.d/90-ryoku-gpu.rules"

  # Game Mode wifi power-save: a polkit rule authorizes the privileged helper
  # (ryoku-wifi-powersave, installed to /usr/bin by the hardware glob above)
  # without a password, so the deck toggle stays one click.
  install -Dm644 "$_repo/system/hardware/network/49-ryoku-wifi-powersave.rules" \
    "$pkgdir/usr/share/polkit-1/rules.d/49-ryoku-wifi-powersave.rules"

  # Windows dual-boot: cross-drive detector + a limine-entry-tool post.d hook
  # that re-asserts the uuid()-addressed chainload entry whenever the boot menu
  # is regenerated -- separate-drive Windows survives kernel updates.
  install -Dm755 "$_repo/system/boot/limine/ryoku-windows-entry" \
    "$pkgdir/usr/bin/ryoku-windows-entry"
  install -Dm755 "$_repo/system/boot/limine/45-ryoku-windows" \
    "$pkgdir/etc/boot/hooks/post.d/45-ryoku-windows"
}
