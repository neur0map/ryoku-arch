# Maintainer: Ryoku <releases@ryoku.dev>
#
# ryoku-hypr-plugins: the official hyprland-plugins the Ryoku Hub exposes,
# hyprbars (window title bars) and hyprfocus (focus animation), built together
# from one hyprwm/hyprland-plugins checkout. Both install under
# /usr/lib/hyprland/plugins/, loaded by the Hub's generated settings.lua (Look
# tab title bars, Animations tab focus flash) via hl.plugin.load; a missing or
# ABI-mismatched plugin is guarded there and degrades to off.
#
# Hyprland plugins are ABI-locked to the compositor. prepare() reads the build
# host's Hyprland version and checks out the matching commit from upstream's
# hyprpm.toml (the same map hyprpm uses), so a [ryoku] rebuild always builds
# against whatever Hyprland it ships, with no manual commit bumps. When that map
# has no pin for the shipped Hyprland yet, prepare() falls back to the
# default-branch HEAD (as hyprpm does) rather than failing, so a Hyprland release
# outpacing the pin table can't abort the whole [ryoku] publish.
#
# (hyprscrolling is intentionally not built here: the scrolling layout moved into
# Hyprland core in 0.54, so the Hub configures it through the core `scrolling`
# category, no plugin.)
pkgname=ryoku-hypr-plugins
pkgver=${RYOKU_PKGVER:-0.1.0}
pkgrel=1
pkgdesc="Hyprland plugins for Ryoku: hyprbars (title bars) and hyprfocus (focus animation)"
arch=('x86_64')
url="https://github.com/hyprwm/hyprland-plugins"
license=('BSD-3-Clause')
depends=('hyprland')
makedepends=('hyprland' 'pkgconf' 'make' 'gcc' 'git' 'libdrm' 'libinput' 'pixman' 'wayland' 'libxkbcommon' 'pango' 'cairo')
source=("hyprland-plugins::git+https://github.com/hyprwm/hyprland-plugins.git")
sha256sums=('SKIP')

prepare() {
  cd "$srcdir/hyprland-plugins"
  local hv commit
  hv="$(pkg-config --modversion hyprland)"
  # hyprpm.toml lines: ["<hyprland-commit>", "<plugin-commit>"], # <version>
  commit="$(grep -F "$hv" hyprpm.toml | grep -oE '[0-9a-f]{40}' | sed -n 2p)"
  if [[ -n "$commit" ]]; then
    echo "PKGBUILD: hyprland-plugins -> $commit (Hyprland $hv)"
    git checkout -q "$commit"
  else
    # no pin for this Hyprland yet: build the fetched default-branch HEAD, as
    # hyprpm does when no pin matches (upstream keeps HEAD on the latest
    # Hyprland). failing here would abort the whole [ryoku] publish under set -e.
    echo "PKGBUILD: no hyprpm.toml pin for Hyprland $hv; building hyprland-plugins HEAD" >&2
  fi
}

build() {
  cd "$srcdir/hyprland-plugins"
  make -C hyprbars all
  make -C hyprfocus all
}

package() {
  install -Dm755 "$srcdir/hyprland-plugins/hyprbars/hyprbars.so" \
    "$pkgdir/usr/lib/hyprland/plugins/hyprbars.so"
  install -Dm755 "$srcdir/hyprland-plugins/hyprfocus/hyprfocus.so" \
    "$pkgdir/usr/lib/hyprland/plugins/hyprfocus.so"
}
