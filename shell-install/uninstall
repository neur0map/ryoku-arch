#!/bin/bash

# Reverse a Ryoku Shell install by replaying the manifest in reverse: disable
# services, remove the symlinks/dirs/session entry we created, then restore
# any files we backed up. Packages are left installed unless --purge-packages.
#
# Usage:
#   shell-install/uninstall [--dry-run] [--purge-packages]

set -euo pipefail

RSI_HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

PURGE=0
for arg in "$@"; do
  case "$arg" in
    --dry-run) export RSI_DRY_RUN=1 ;;
    --purge-packages) PURGE=1 ;;
    -h | --help)
      sed -n '3,11p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "unknown argument: $arg" >&2; exit 2 ;;
  esac
done

# shellcheck source=lib/env.sh
. "$RSI_HERE/lib/env.sh"
# shellcheck source=lib/ui.sh
. "$RSI_HERE/lib/ui.sh"

[[ -f $RSI_MANIFEST ]] || rsi_die "no manifest at $RSI_MANIFEST; nothing to uninstall"

# Guard: only ever delete paths under $HOME (the session entry is removed via
# its own explicit branch with sudo).
rsi_safe_rm() {
  local path="$1"
  case "$path" in
    "$HOME"/*) ;;
    *) rsi_warn "refusing to remove path outside HOME: $path"; return 0 ;;
  esac
  if rsi_dry; then rsi_dim "  would remove $path"; else rm -rf -- "$path"; fi
}

rsi_banner
rsi_step "replaying manifest in reverse"

mapfile -t lines <"$RSI_MANIFEST"
pkgs=()

for (( i=${#lines[@]}-1; i>=0; i-- )); do
  IFS=$'\t' read -r action a1 a2 <<<"${lines[i]}"
  case "$action" in
    service)
      if rsi_dry; then rsi_dim "  would disable $a1"; else systemctl --user disable "$a1" >/dev/null 2>&1 || true; fi
      ;;
    link | file)
      rsi_safe_rm "$a1"
      ;;
    dir)
      rsi_safe_rm "$a1"
      ;;
    session)
      if rsi_dry; then rsi_dim "  would sudo rm $a1"; else sudo rm -f -- "$a1"; fi
      ;;
    backup)
      if [[ -e $a2 ]]; then
        if rsi_dry; then
          rsi_dim "  would restore $a2 -> $a1"
        else
          mkdir -p "$(dirname "$a1")"
          rm -rf -- "$a1"
          cp -a -- "$a2" "$a1"
        fi
      fi
      ;;
    pkg)
      pkgs+=("$a1")
      ;;
  esac
done

if (( PURGE == 1 )) && (( ${#pkgs[@]} > 0 )); then
  rsi_step "purging packages this install added: ${pkgs[*]}"
  if command -v pacman >/dev/null 2>&1; then
    if rsi_dry; then rsi_dim "  would: sudo pacman -Rns --noconfirm ${pkgs[*]}"; else sudo pacman -Rns --noconfirm "${pkgs[@]}" || rsi_warn "some packages could not be removed (shared deps)"; fi
  else
    rsi_warn "package purge only implemented for pacman; remove manually: ${pkgs[*]}"
  fi
fi

if ! rsi_dry; then
  systemctl --user daemon-reload >/dev/null 2>&1 || true
  : >"$RSI_MANIFEST"
fi

rsi_ok "uninstall complete. Log out and pick your previous session."
