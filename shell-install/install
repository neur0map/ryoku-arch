#!/bin/bash

# Ryoku Shell installer (experimental). Layers the Ryoku desktop shell onto an
# existing Linux system in user scope, coexisting with the current setup and
# reversible via shell-install/uninstall.
#
# Usage:
#   shell-install/install [--dry-run] [--yes] [--minimal]
#
#   --dry-run   show the full plan and change nothing
#   --yes       skip the confirmation prompt (still prints the plan)
#   --minimal   install only the shell-critical packages, not the full app set

set -euo pipefail

RSI_HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

for arg in "$@"; do
  case "$arg" in
    --dry-run) export RSI_DRY_RUN=1 ;;
    --yes | -y) export RSI_ASSUME_YES=1 ;;
    --minimal) export RSI_MINIMAL=1 ;;
    -h | --help)
      sed -n '3,13p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *)
      echo "unknown argument: $arg" >&2
      exit 2
      ;;
  esac
done

# shellcheck source=lib/env.sh
. "$RSI_HERE/lib/env.sh"
# shellcheck source=lib/ui.sh
. "$RSI_HERE/lib/ui.sh"
# shellcheck source=lib/manifest.sh
. "$RSI_HERE/lib/manifest.sh"
# shellcheck source=lib/backup.sh
. "$RSI_HERE/lib/backup.sh"
# shellcheck source=distros/detect.sh
. "$RSI_HERE/distros/detect.sh"
# shellcheck source=lib/packages.sh
. "$RSI_HERE/lib/packages.sh"
# shellcheck source=lib/preflight.sh
. "$RSI_HERE/lib/preflight.sh"
# shellcheck source=lib/deploy.sh
. "$RSI_HERE/lib/deploy.sh"

trap rsi_sudo_done EXIT

rsi_banner
rsi_safety
rsi_review

rsi_sudo_prime
rsi_system_update
rsi_manifest_init
rsi_backup_setup
rsi_install_packages
rsi_deploy
rsi_verify

if rsi_dry; then
  rsi_say ""
  rsi_ok "dry run complete: nothing was changed"
  exit 0
fi

case ":$PATH:" in
  *":$RSI_BIN_HOME:"*) ;;
  *) rsi_warn "$RSI_BIN_HOME is not on your PATH; add it to run ryoku-* commands from a terminal (the Ryoku session itself uses absolute paths and works regardless)." ;;
esac

rsi_header "Done"
rsi_ok "Ryoku shell installed."
rsi_say ""
rsi_say "  ${RSI_BOLD}Reboot now${RSI_OFF}, then at the login screen pick the ${RSI_ACCENT}Ryoku${RSI_OFF} session and log in."
rsi_say "  Your current desktop will not change until you start the Ryoku session,"
rsi_say "  so the live screen, wallpaper, and keybinds stay as they are until then."
rsi_say ""
rsi_say "  Revert any time:  $RSI_HERE/uninstall"
rsi_say "  Build log:        ${XDG_STATE_HOME:-$HOME/.local/state}/ryoku-shell-setup.log"
