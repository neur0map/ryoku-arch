# Ryoku Arch: developer-local session notes.
# Individual session logs stay out of the repo; only the README and
# TEMPLATE ship.
/logs/*.md
!/logs/README.md
!/logs/TEMPLATE.md
/.worktrees/

# ISO build artifacts.
/iso/out/
/iso/work/

# Editor / agent metadata
/.claude/
/.codex

# Superpowers brainstorming session artifacts
.superpowers/

# Per-run ISO build logs
tests/logs/
