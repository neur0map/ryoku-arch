#!/bin/bash

set -euo pipefail

runtime_env="${RYOKU_PATH:-$HOME/.local/share/ryoku}/lib/runtime-env.sh"
if [[ -f $runtime_env ]]; then
  # shellcheck source=/dev/null
  source "$runtime_env"
else
  ryoku-cmd-present() {
    command -v "$1" >/dev/null 2>&1
  }
fi

usage() {
  cat <<'EOF'
Usage:
  ryoku-cmd-audio-default SINK_NAME

Set the active PipeWire/Pulse default output sink. This uses pactl first,
then wpctl, then repairs stale WirePlumber runtime metadata when needed.
EOF
}

current_sink() {
  pactl get-default-sink 2>/dev/null || true
}

verify_sink() {
  [[ $(current_sink) == "$sink_name" ]]
}

if (( $# != 1 )); then
  usage >&2
  exit 2
fi

sink_name="$1"

ryoku-cmd-present pactl || {
  echo "ryoku-cmd-audio-default: pactl is not installed" >&2
  exit 1
}

pactl set-default-sink "$sink_name" >/dev/null 2>&1 || true
sleep 0.05
verify_sink && exit 0

if ryoku-cmd-present wpctl && ryoku-cmd-present jq; then
  sink_object_id="$(
    pactl -f json list sinks 2>/dev/null \
      | jq -r --arg name "$sink_name" '.[] | select(.name == $name) | .properties."object.id" // empty' \
      | head -n 1
  )"
  if [[ -n $sink_object_id && $sink_object_id != "null" ]]; then
    wpctl set-default "$sink_object_id" >/dev/null 2>&1 || true
    sleep 0.05
    verify_sink && exit 0
  fi
fi

if ryoku-cmd-present pw-metadata; then
  pw-metadata -n default 0 default.audio.sink "{\"name\":\"$sink_name\"}" >/dev/null 2>&1 || true
  sleep 0.05
  verify_sink && exit 0
fi

echo "ryoku-cmd-audio-default: failed to set default sink: $sink_name" >&2
exit 1
