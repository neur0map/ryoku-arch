#!/bin/bash

set -euo pipefail

script_path="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s\n' "${BASH_SOURCE[0]}")"
script_dir="$(cd -- "$(dirname -- "$script_path")" && pwd)"
shell_root="$(cd -- "$script_dir/.." && pwd)"
source_path_file="$shell_root/.ryoku-source-path"
default_ryoku_path="$HOME/.local/share/ryoku"
checkout_ryoku_path=""
source_ryoku_path=""

is_git_repo() {
  local path="${1:-}"

  [[ -n $path ]] && git -C "$path" rev-parse --show-toplevel >/dev/null 2>&1
}

if [[ -r $source_path_file ]]; then
  read -r source_ryoku_path <"$source_path_file" || source_ryoku_path="$default_ryoku_path"
  [[ -n $source_ryoku_path ]] || source_ryoku_path="$default_ryoku_path"
elif [[ -n ${RYOKU_PATH:-} ]] && is_git_repo "$RYOKU_PATH"; then
  source_ryoku_path="$RYOKU_PATH"
elif checkout_ryoku_path="$(git -C "$shell_root" rev-parse --show-toplevel 2>/dev/null)" \
  && [[ -f $checkout_ryoku_path/lib/runtime-env.sh ]]; then
  source_ryoku_path="$checkout_ryoku_path"
elif [[ -n ${RYOKU_PATH:-} ]]; then
  source_ryoku_path="$RYOKU_PATH"
else
  source_ryoku_path="$default_ryoku_path"
fi

ryoku_path="$source_ryoku_path"
if [[ -n ${RYOKU_SETTINGS_UPDATE_PATH:-} ]]; then
  ryoku_path="$RYOKU_SETTINGS_UPDATE_PATH"
elif [[ -r $source_path_file ]] && is_git_repo "$default_ryoku_path"; then
  ryoku_path="$default_ryoku_path"
fi

export RYOKU_SOURCE_PATH="$source_ryoku_path"
export RYOKU_PATH="$ryoku_path"

if [[ -f $ryoku_path/lib/runtime-env.sh ]]; then
  # shellcheck disable=SC1091
  source "$ryoku_path/lib/runtime-env.sh"
else
  export RYOKU_STATE_PATH="${RYOKU_STATE_PATH:-$HOME/.local/state/ryoku}"
fi

# Never let any git call in this helper block on a credential prompt: the
# settings update panel must fail cleanly (and never demand a GitHub account)
# when offline or when the shipped .git still carries a leaked CI auth header.
# Exported here so both the bash git calls below and the embedded Python (which
# copies the environment) inherit it.
export GIT_TERMINAL_PROMPT=0
export GIT_ASKPASS=/bin/true
export GCM_INTERACTIVE=never

remote_url="${RYOKU_UPDATE_REMOTE_URL:-https://github.com/neur0map/ryoku-arch.git}"

usage() {
  cat <<'EOF'
Usage: ryoku-settings-about <status|check-updates|doctor|refresh-shell|medevac|switch-channel|open-url> [args]

Commands:
  status                 Print Ryoku version, checkout branch, and channel JSON
  check-updates          Fetch the checkout branch and print incoming commits JSON
  doctor                 Run global ryoku-doctor and print captured output JSON
  refresh-shell          Restart the Ryoku shell through ryoku-restart-shell
  medevac                Launch the last-resort ryoku-call911now curl recovery
  start-update BRANCH    Launch a terminal update for the checked update branch
  switch-channel BRANCH  Launch the branch switcher for main or unstable-dev
  open-url URL           Open an https URL in the user's browser

MedEvac installed command:
  ryoku-call911now
  RYOKU_UPDATE_BRANCH=unstable-dev ryoku-call911now
EOF
}

json_error() {
  local message="$1"

  python3 - "$message" <<'PY'
import json
import sys

print(json.dumps({"ok": False, "error": sys.argv[1]}))
PY
}

about_json() {
  local mode="$1"

  python3 - "$mode" "$RYOKU_PATH" "$RYOKU_SOURCE_PATH" "$RYOKU_STATE_PATH" "${XDG_CONFIG_HOME:-$HOME/.config}" "$remote_url" <<'PY'
import json
import os
import subprocess
import sys
from pathlib import Path

mode, repo, source_repo, state_dir, config_home, remote_url = sys.argv[1:7]
repo_path = Path(repo).expanduser()
source_path = Path(source_repo).expanduser()
channels = {"main", "unstable-dev"}
labels = {
    "main": "Stable (main)",
    "unstable-dev": "Unstable (unstable-dev)",
}

def run_git(*args):
    env = os.environ.copy()
    env["GIT_TERMINAL_PROMPT"] = "0"
    env["GIT_ASKPASS"] = "/bin/true"
    env["GCM_INTERACTIVE"] = "never"
    result = subprocess.run(
        # -c http.extraheader= neutralizes any leaked CI auth header still in the
        # shipped .git so a public-repo fetch never tries (and fails) to auth.
        ["git", "-c", "http.extraheader=", "-C", str(repo_path), *args],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=env,
        check=False,
    )
    return result.returncode, result.stdout.strip(), result.stderr.strip()

def read_json(path):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            value = json.load(handle)
        return value if isinstance(value, dict) else {}
    except Exception:
        return {}

def current_branch():
    code, out, _ = run_git("rev-parse", "--abbrev-ref", "HEAD")
    if code != 0 or not out:
        return "unknown"
    return "detached" if out == "HEAD" else out

def valid_branch_name(branch):
    if branch in {"", "unknown", "detached"}:
        return False
    code, _, _ = run_git("check-ref-format", "--branch", branch)
    return code == 0

def short_head():
    code, out, _ = run_git("rev-parse", "--short", "HEAD")
    return out if code == 0 and out else "unknown"

def version():
    version_file = repo_path / "VERSION"
    base = "preview"
    try:
        text = version_file.read_text(encoding="utf-8").strip().splitlines()
        if text and text[0].strip():
            base = text[0].strip()
    except Exception:
        pass

    head = short_head()
    return f"{base} (g{head})" if head != "unknown" else base

def configured_channel(branch):
    env_channel = os.environ.get("RYOKU_UPDATE_BRANCH", "")
    if env_channel in channels:
        return env_channel

    state_file = Path(state_dir).expanduser() / "channel"
    try:
        state_channel = state_file.read_text(encoding="utf-8").strip()
        if state_channel in channels:
            return state_channel
    except Exception:
        pass

    legacy_config = Path(config_home).expanduser() / "ryoku-shell" / "config.json"
    data = read_json(legacy_config)
    shell_updates = data.get("shellUpdates", {})
    if isinstance(shell_updates, dict) and shell_updates.get("channel") in channels:
        return shell_updates["channel"]

    if branch in channels:
        return branch
    return "main"

def update_branch(branch, channel):
    if valid_branch_name(branch):
        return branch
    return channel

def dirty_status():
    code, out, _ = run_git("status", "--porcelain", "--untracked-files=normal")
    return code == 0 and bool(out)

def base_info():
    branch = current_branch()
    channel = configured_channel(branch)
    update = update_branch(branch, channel)
    official_checkout = branch in channels
    channel_matches_checkout = official_checkout and branch == channel
    if channel_matches_checkout:
        checkout_mode = "official"
    elif official_checkout:
        checkout_mode = "mismatch"
    elif valid_branch_name(branch):
        checkout_mode = "custom"
    else:
        checkout_mode = "unknown"
    return {
        "ok": True,
        "version": version(),
        "head": short_head(),
        "currentBranch": branch,
        "configuredChannel": channel,
        "configuredChannelLabel": labels.get(channel, channel),
        "updateBranch": update,
        "updateBranchLabel": labels.get(update, update),
        "packageChannel": "main",
        "packageChannelLabel": "Main package mirror",
        "officialCheckout": official_checkout,
        "channelMatchesCheckout": channel_matches_checkout,
        "checkoutMode": checkout_mode,
        "channels": [
            {"id": "main", "label": labels["main"], "description": "Main stable release channel"},
            {"id": "unstable-dev", "label": labels["unstable-dev"], "description": "Development channel with newer Ryoku changes"},
        ],
        "dirty": dirty_status(),
        "path": str(repo_path),
        "sourcePath": str(source_path),
        "updatePath": str(repo_path),
        "remote": remote_url,
    }

def fetch_channel(channel):
    refspec = f"+refs/heads/{channel}:refs/remotes/origin/{channel}"
    return run_git("fetch", "--prune", remote_url, refspec)

def fetch_peer_channels(branch):
    for channel in sorted(channels):
        if channel == branch:
            continue
        fetch_channel(channel)

def remote_ref_exists(ref):
    code, _, _ = run_git("rev-parse", "--verify", ref)
    return code == 0

def official_remote_contains_head():
    code, head, _ = run_git("rev-parse", "HEAD")
    if code != 0 or not head:
        return False

    for channel in sorted(channels):
        ref = f"origin/{channel}"
        if not remote_ref_exists(ref):
            continue
        code, _, _ = run_git("merge-base", "--is-ancestor", "HEAD", ref)
        if code == 0:
            return True
        code, out, _ = run_git("reflog", "show", "--format=%H", ref)
        if code == 0 and head in out.splitlines():
            return True
    return False

def _parse_commits(out):
    commits = []
    for line in out.splitlines():
        parts = line.split("\x1f")
        if len(parts) < 4:
            continue
        commits.append({
            "hash": parts[0],
            "subject": parts[1],
            "author": parts[2],
            "relativeTime": parts[3],
        })
    return commits

def incoming_commits(remote_ref):
    code, out, _ = run_git("log", "--max-count=20", "--pretty=format:%h%x1f%s%x1f%an%x1f%cr", f"HEAD..{remote_ref}")
    if code != 0 or not out:
        return []
    return _parse_commits(out)

def outgoing_commits(remote_ref):
    # Local commits that are not on the remote — these are what block a
    # fast-forward update when the checkout has diverged.
    code, out, _ = run_git("log", "--max-count=20", "--pretty=format:%h%x1f%s%x1f%an%x1f%cr", f"{remote_ref}..HEAD")
    if code != 0 or not out:
        return []
    return _parse_commits(out)

def update_state(ahead, behind, can_fast_forward, can_realign, branch):
    if behind > 0 and can_fast_forward:
        return {
            "updateState": "ready",
            "updateStateLabel": "Ready to update",
            "updateStateDetail": f"{behind} incoming commit(s) can be fast-forwarded into {branch}.",
            "blockReason": "",
        }

    if behind > 0 and can_realign:
        return {
            "updateState": "ready",
            "updateStateLabel": "Ready to update",
            "updateStateDetail": f"{branch} can realign to origin/{branch}; the local branch only contains known Ryoku release history.",
            "blockReason": "",
        }

    if behind > 0:
        if ahead > 0:
            reason = f"This checkout has {ahead} local commit(s) and {behind} incoming commit(s), so it cannot fast-forward to origin/{branch}."
        else:
            reason = f"This checkout cannot fast-forward to origin/{branch}. Run doctor or review the branch before updating."
        return {
            "updateState": "blocked",
            "updateStateLabel": "Update blocked",
            "updateStateDetail": reason,
            "blockReason": reason,
        }

    if ahead > 0:
        return {
            "updateState": "ahead",
            "updateStateLabel": "Local commits ahead",
            "updateStateDetail": f"This checkout has {ahead} local commit(s) that are not on origin/{branch}.",
            "blockReason": "",
        }

    return {
        "updateState": "current",
        "updateStateLabel": "Up to date",
        "updateStateDetail": f"{branch} is current.",
        "blockReason": "",
    }

def friendly_fetch_error(err, branch):
    # Map raw git stderr ("fatal: unable to access ...: Could not resolve host")
    # to a clean, reassuring line for the settings panel. No GitHub account is
    # ever required to check for updates, so never surface an auth prompt hint.
    text = (err or "").lower()
    if ("could not resolve host" in text
            or "temporary failure in name resolution" in text
            or "name or service not known" in text):
        return "You appear to be offline. Connect to the internet and try again."
    if ("could not connect" in text or "failed to connect" in text
            or "connection refused" in text or "connection timed out" in text
            or "timed out" in text or "network is unreachable" in text):
        return "Couldn't reach the update server. Check your connection and try again."
    if ("authentication failed" in text or "could not read username" in text
            or "terminal prompts disabled" in text or "permission denied" in text
            or "403" in text or "401" in text):
        return "Couldn't reach the update server. No GitHub account is needed; try again later."
    return f"Couldn't check {branch} for updates right now. Try again later."

def check_updates():
    info = base_info()
    branch = info["updateBranch"]

    if not valid_branch_name(branch):
        info.update({
            "ok": False,
            "error": f"Unable to determine a safe update branch from checkout {info['currentBranch']}",
            "incoming": [],
            "aheadCount": 0,
            "behindCount": 0,
            "updateAvailable": False,
            "canFastForward": False,
            "canStartUpdate": False,
            "updateState": "error",
            "updateStateLabel": "Unable to check",
            "updateStateDetail": f"Unable to determine a safe update branch from checkout {info['currentBranch']}",
            "blockReason": f"Unable to determine a safe update branch from checkout {info['currentBranch']}",
        })
        return info

    code, _, err = fetch_channel(branch)
    if code != 0:
        message = friendly_fetch_error(err, branch)
        info.update({
            "ok": False,
            "error": message,
            "incoming": [],
            "aheadCount": 0,
            "behindCount": 0,
            "updateAvailable": False,
            "canFastForward": False,
            "canStartUpdate": False,
            "updateState": "error",
            "updateStateLabel": "Couldn't check",
            "updateStateDetail": message,
            "blockReason": message,
        })
        return info

    if branch in channels:
        fetch_peer_channels(branch)

    remote_ref = f"origin/{branch}"
    code, counts, err = run_git("rev-list", "--left-right", "--count", f"HEAD...{remote_ref}")
    ahead = 0
    behind = 0
    if code == 0 and counts:
        values = counts.split()
        if len(values) >= 2:
            ahead = int(values[0])
            behind = int(values[1])

    _, remote_head, _ = run_git("rev-parse", "--short", remote_ref)
    ancestor_code, _, _ = run_git("merge-base", "--is-ancestor", "HEAD", remote_ref)
    can_fast_forward = ancestor_code == 0 and behind > 0
    can_realign = branch in channels and behind > 0 and not can_fast_forward and official_remote_contains_head()
    commits = incoming_commits(remote_ref)
    local = outgoing_commits(remote_ref)

    _, local_head, _ = run_git("rev-parse", "--short", "HEAD")

    info.update({
        "ok": True,
        "remoteBranch": remote_ref,
        "remoteHead": remote_head or "unknown",
        "localHead": local_head or info.get("head", "unknown"),
        "aheadCount": ahead,
        "behindCount": behind,
        "updateAvailable": behind > 0,
        "canFastForward": can_fast_forward,
        "canRealignOfficialBranch": can_realign,
        "canStartUpdate": can_fast_forward or can_realign,
        "incoming": commits,
        "local": local,
    })
    info.update(update_state(ahead, behind, can_fast_forward, can_realign, branch))
    return info

if not (repo_path / ".git").exists():
    print(json.dumps({
        "ok": False,
        "error": f"Ryoku checkout is not a git repository: {repo_path}",
        "path": str(repo_path),
        "sourcePath": str(source_path),
        "updatePath": str(repo_path),
    }))
    sys.exit(0)

if mode == "status":
    print(json.dumps(base_info()))
elif mode == "check-updates":
    print(json.dumps(check_updates()))
else:
    print(json.dumps({"ok": False, "error": f"Unknown mode: {mode}"}))
PY
}

doctor_json() {
  local output_file status doctor_cmd

  if [[ -x $RYOKU_PATH/bin/ryoku-doctor ]]; then
    doctor_cmd="$RYOKU_PATH/bin/ryoku-doctor"
  else
    doctor_cmd="$(command -v ryoku-doctor || true)"
  fi

  if [[ -z $doctor_cmd ]]; then
    json_error "ryoku-doctor was not found"
    return 0
  fi

  output_file="$(mktemp)"
  set +e
  RYOKU_DOCTOR_ASSUME_NO=1 "$doctor_cmd" >"$output_file" 2>&1
  status=$?
  set -e

  python3 - "$status" "$output_file" <<'PY'
import json
import sys
from pathlib import Path

status = int(sys.argv[1])
output = Path(sys.argv[2]).read_text(encoding="utf-8", errors="replace")
print(json.dumps({
    "ok": status == 0,
    "exitCode": status,
    "scope": "global",
    "output": output.strip(),
}))
PY
  rm -f "$output_file"
}

switch_channel() {
  local channel="${1:-}"
  local channel_q command path_q update_bin update_bin_q

  case "$channel" in
    main | unstable-dev) ;;
    *)
      json_error "Invalid channel: $channel"
      return 1
      ;;
  esac

  if ! command -v ryoku-launch-floating-terminal-with-presentation >/dev/null 2>&1; then
    json_error "ryoku-launch-floating-terminal-with-presentation was not found"
    return 1
  fi

  update_bin="$RYOKU_PATH/bin/ryoku-update"
  if [[ ! -x $update_bin ]]; then
    json_error "ryoku-update was not found in $RYOKU_PATH/bin"
    return 1
  fi

  path_q="$(shell_quote "$RYOKU_PATH")"
  update_bin_q="$(shell_quote "$update_bin")"
  channel_q="$(shell_quote "$channel")"
  # Channel switching is one command now: ryoku-update -sc shows its confirm
  # gate in the floating terminal so the switch stays deliberate.
  command="RYOKU_PATH=$path_q $update_bin_q -sc $channel_q"

  ryoku-launch-floating-terminal-with-presentation "$command" >/dev/null 2>&1 &
  python3 - "$channel" <<'PY'
import json
import sys

print(json.dumps({
    "ok": True,
    "channel": sys.argv[1],
    "message": f"Started branch switch to {sys.argv[1]} in a terminal.",
}))
PY
}

valid_branch_name() {
  git check-ref-format --branch "$1" >/dev/null 2>&1
}

current_checkout_branch() {
  git -C "$RYOKU_PATH" rev-parse --abbrev-ref HEAD 2>/dev/null || printf '%s\n' "unknown"
}

shell_quote() {
  printf '%q' "$1"
}

shell_single_quote() {
  local value="$1"

  printf "'%s'" "$(printf '%s' "$value" | sed "s/'/'\\\\''/g")"
}

update_current_branch() {
  local branch="${1:-}"
  local current_branch=""
  local remote_ref=""

  valid_branch_name "$branch" || {
    echo "ryoku-settings-about: invalid update branch: $branch" >&2
    return 1
  }

  current_branch="$(current_checkout_branch)"
  [[ $current_branch == "$branch" ]] || {
    echo "ryoku-settings-about: refusing to update $branch while checkout is $current_branch" >&2
    return 1
  }

  remote_ref="origin/$branch"
  git -c http.extraheader= -C "$RYOKU_PATH" fetch --prune "$remote_url" "+refs/heads/$branch:refs/remotes/origin/$branch"
  git -C "$RYOKU_PATH" merge --ff-only "$remote_ref"

  if [[ -x $RYOKU_PATH/shell/setup ]]; then
    "$RYOKU_PATH/shell/setup" install -y -q --skip-deps --skip-setups --skip-sysupdate
  fi
}

start_update() {
  local branch="${1:-}"
  local current_branch command helper_q path_q branch_q remote_q update_bin update_q

  valid_branch_name "$branch" || {
    json_error "Invalid update branch: $branch"
    return 1
  }

  current_branch="$(current_checkout_branch)"
  [[ $current_branch == "$branch" ]] || {
    json_error "Refusing to update $branch while checkout is $current_branch"
    return 1
  }

  if ! command -v ryoku-launch-floating-terminal-with-presentation >/dev/null 2>&1; then
    json_error "ryoku-launch-floating-terminal-with-presentation was not found"
    return 1
  fi

  path_q="$(shell_quote "$RYOKU_PATH")"
  branch_q="$(shell_quote "$branch")"

  # One updater: hand straight off to ryoku-update in the terminal. It owns the fetch,
  # fast-forward / realign and decides what to run — including the system, AUR and shell
  # stages when the Ryoku git tree is already current. Pre-gating here on the git delta
  # (behind == 0) made the GUI refuse to even open the terminal whenever only packages,
  # not Ryoku itself, had updates, so the update button looked like it never did anything.
  case "$branch" in
    main | unstable-dev)
      update_bin="$RYOKU_PATH/bin/ryoku-update"
      if [[ ! -x $update_bin ]]; then
        json_error "ryoku-update was not found in $RYOKU_PATH/bin"
        return 1
      fi
      update_q="$(shell_quote "$update_bin")"
      command="RYOKU_PATH=$path_q RYOKU_UPDATE_BRANCH=$branch_q $update_q"
      ;;
    *)
      helper_q="$(shell_quote "$script_path")"
      remote_q="$(shell_quote "$remote_url")"
      command="RYOKU_PATH=$path_q RYOKU_UPDATE_REMOTE_URL=$remote_q $helper_q update-current-run $branch_q"
      ;;
  esac

  ryoku-launch-floating-terminal-with-presentation "$command" >/dev/null 2>&1 &
  python3 - "$branch" <<'PY'
import json
import sys

print(json.dumps({
    "ok": True,
    "branch": sys.argv[1],
    "message": f"Started Ryoku update for {sys.argv[1]} in a terminal.",
}))
PY
}

start_medevac() {
  local channel="${1:-main}"
  local command local_call local_call_q branch_q

  if ! command -v ryoku-launch-floating-terminal-with-presentation >/dev/null 2>&1; then
    json_error "ryoku-launch-floating-terminal-with-presentation was not found"
    return 1
  fi

  if ! command -v bash >/dev/null 2>&1; then
    json_error "bash was not found; Ryoku MedEvac needs bash to run the portable recovery command"
    return 1
  fi

  case "$channel" in
    main | unstable-dev) ;;
    *)
      json_error "Invalid MedEvac channel: $channel"
      return 1
      ;;
  esac

  branch_q="$(shell_quote "$channel")"
  local_call="$RYOKU_PATH/bin/ryoku-call911now"

  if [[ ! -x $local_call ]]; then
    local_call="$(command -v ryoku-call911now 2>/dev/null || true)"
  fi

  if [[ -z $local_call || ! -x $local_call ]]; then
    json_error "Ryoku MedEvac needs the baked ryoku-call911now command; run ryoku-update first if this install is stale"
    return 1
  fi

  local_call_q="$(shell_quote "$local_call")"
  command="env RYOKU_UPDATE_BRANCH=$branch_q $local_call_q"

  ryoku-launch-floating-terminal-with-presentation "$command" >/dev/null 2>&1 &
  python3 - "$local_call" "$channel" <<'PY'
import json
import sys

print(json.dumps({
    "ok": True,
    "command": sys.argv[1],
    "channel": sys.argv[2],
    "message": f"Started Ryoku MedEvac for {sys.argv[2]} in a terminal.",
}))
PY
}

open_url() {
  local url="${1:-}"

  case "$url" in
    https://*) ;;
    *)
      json_error "Only https URLs can be opened from settings"
      return 1
      ;;
  esac

  if command -v xdg-open >/dev/null 2>&1; then
    setsid xdg-open "$url" >/dev/null 2>&1 &
  fi
}

refresh_shell() {
  local restart_bin

  restart_bin="$(command -v ryoku-restart-shell 2>/dev/null || true)"
  if [[ -z $restart_bin ]]; then
    json_error "ryoku-restart-shell was not found"
    return 1
  fi

  nohup bash -c 'sleep 0.2; exec "$1"' bash "$restart_bin" >/dev/null 2>&1 &
  python3 <<'PY'
import json

print(json.dumps({
    "ok": True,
    "message": "Restarting Ryoku shell.",
}))
PY
}

command="${1:-status}"
(($# == 0)) || shift

case "$command" in
  status)
    about_json "status"
    ;;
  check-updates)
    about_json "check-updates"
    ;;
  doctor)
    doctor_json
    ;;
  refresh-shell)
    refresh_shell
    ;;
  medevac)
    start_medevac "$@"
    ;;
  start-update)
    start_update "$@"
    ;;
  update-current-run)
    update_current_branch "$@"
    ;;
  switch-channel)
    switch_channel "$@"
    ;;
  open-url)
    open_url "$@"
    ;;
  -h | --help | help)
    usage
    ;;
  *)
    echo "ryoku-settings-about: unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
