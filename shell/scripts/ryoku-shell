#!/bin/bash

set -euo pipefail

qs_bin="${RYOKU_QS_BIN:-qs}"
runtime_dir="${RYOKU_SHELL_RUNTIME_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-shell}"
lib_dir="${RYOKU_SHELL_LIB_DIR:-$HOME/.local/lib/ryoku-shell}"
qml_dir="${RYOKU_SHELL_QML_DIR:-$HOME/.local/lib/qt6/qml}"
xkb_rules="${RYOKU_SHELL_XKB_RULES_PATH:-/usr/share/X11/xkb/rules/base.lst}"
systemd_user_dir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
systemd_dropin_dir="$systemd_user_dir/ryoku-shell.service.d"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
shell_root="$(cd -- "$script_dir/.." && pwd)"
ryoku_path="${RYOKU_PATH:-$HOME/.local/share/ryoku}"

export RYOKU_PATH="$ryoku_path"
export RYOKU_SHELL_LIB_DIR="$lib_dir"
export RYOKU_SHELL_XKB_RULES_PATH="$xkb_rules"
export QML_IMPORT_PATH="$qml_dir${QML_IMPORT_PATH:+:$QML_IMPORT_PATH}"
export QML2_IMPORT_PATH="$qml_dir${QML2_IMPORT_PATH:+:$QML2_IMPORT_PATH}"
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland;xcb}"
if [[ -d $RYOKU_PATH/bin ]]; then
  case ":$PATH:" in
    *":$RYOKU_PATH/bin:"*) ;;
    *) export PATH="$RYOKU_PATH/bin:$PATH" ;;
  esac
fi
unset QS_CONFIG_NAME QS_CONFIG_PATH QS_MANIFEST

usage() {
  cat <<'EOF'
Usage: ryoku-shell <command> [args]

Runtime:
  run | start [--session]     Start the Ryoku shell
  stop | kill                 Stop the Ryoku shell
  restart                     Restart the Ryoku shell
  status                      List running Quickshell instances
  path                        Print the runtime path
  logs                        Show Quickshell logs

IPC:
  launcher                    Toggle launcher
  session                     Toggle session menu
  dashboard | island          Toggle top island
  utilities                   Toggle utilities
  settings                    Open settings
  ipc <target> <fn> [args]    Raw Quickshell IPC call
EOF
}

require_runtime() {
  [[ -f $runtime_dir/shell.qml ]] || {
    echo "ryoku-shell: missing runtime at $runtime_dir" >&2
    echo "ryoku-shell: run shell/setup install from the Ryoku checkout" >&2
    exit 1
  }
}

ipc_call() {
  require_runtime
  "$qs_bin" -p "$runtime_dir" ipc call "$@"
}

lock_qylock_direct() {
  local lock_script="$HOME/.local/share/quickshell-lockscreen/lock.sh"

  if [[ -x $lock_script ]]; then
    env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST "$lock_script"
  else
    loginctl lock-session
  fi
}

lock_screen() {
  if [[ -f $runtime_dir/shell.qml ]] && "$qs_bin" -p "$runtime_dir" ipc call lock lock >/dev/null 2>&1; then
    return
  fi

  lock_qylock_direct
}

install_service() {
  local source_service=""
  local candidate
  local target_service="$systemd_user_dir/ryoku-shell.service"

  for candidate in \
    "$shell_root/assets/systemd/ryoku-shell.service" \
    "$runtime_dir/assets/systemd/ryoku-shell.service" \
    "${RYOKU_PATH:-$HOME/.local/share/ryoku}/shell/assets/systemd/ryoku-shell.service" \
    "$HOME/.local/share/ryoku-shell/assets/systemd/ryoku-shell.service"; do
    if [[ -f $candidate ]]; then
      source_service="$candidate"
      break
    fi
  done

  [[ -f $source_service ]] || {
    echo "ryoku-shell: missing service asset" >&2
    exit 1
  }

  mkdir -p "$systemd_user_dir"
  install -m 0644 "$source_service" "$target_service"
  if ! grep -Fq "ryoku-shell-cleanup-orphans" "$target_service"; then
    legacy_cleanup="ryoku-shell cleanup-orphans"
    if grep -Fq "$legacy_cleanup" "$target_service"; then
      sed -i "\\|$legacy_cleanup|c\\ExecStopPost=-%h/.local/share/ryoku/bin/ryoku-shell-cleanup-orphans --quiet" "$target_service"
    else
      printf '\nExecStopPost=-%%h/.local/share/ryoku/bin/ryoku-shell-cleanup-orphans --quiet\n' >>"$target_service"
    fi
  fi
  rm -f "$systemd_dropin_dir/ryoku-dev-qs.conf"
  rm -f "$systemd_dropin_dir/qt6-fractional-scale-workaround.conf"
  rmdir "$systemd_dropin_dir" >/dev/null 2>&1 || true
  systemctl --user daemon-reload >/dev/null 2>&1 || true
}

enable_service() {
  install_service

  # Hyprland can be started directly or through UWSM. Keep the service file
  # compositor-neutral and let Hyprland exec-once start the service.
  if [[ ${RYOKU_COMPOSITOR:-} == "hyprland" || -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
    systemctl --user reset-failed ryoku-shell.service >/dev/null 2>&1 || true
  fi
}

command="${1:-run}"
(($# == 0)) || shift

case "$command" in
  run|start)
    require_runtime
    if [[ ${1:-} == "--session" ]]; then
      shift
    fi
    exec "$qs_bin" -p "$runtime_dir" "$@"
    ;;
  stop|kill)
    "$qs_bin" kill -p "$runtime_dir" --any-display
    ;;
  restart)
    "$qs_bin" kill -p "$runtime_dir" --any-display >/dev/null 2>&1 || true
    exec "$0" run "$@"
    ;;
  status)
    "$qs_bin" list -a
    ;;
  logs)
    "$qs_bin" log -p "$runtime_dir" "$@"
    ;;
  path)
    printf '%s\n' "$runtime_dir"
    ;;
  launcher|overview)
    ipc_call drawers toggle launcher
    ;;
  session)
    ipc_call drawers toggle session
    ;;
  dashboard|island)
    ipc_call drawers toggle dashboard
    ;;
  utilities)
    ipc_call drawers toggle utilities
    ;;
  settings|control-center|controlCenter|globalActions)
    ipc_call controlCenter toggle
    ;;
  lock)
    lock_screen
    ;;
  picker)
    ipc_call picker open
    ;;
  screenshot)
    ipc_call picker openFreeze
    ;;
  wallpaper)
    ipc_call wallpaper "$@"
    ;;
  mpris)
    ipc_call mpris "$@"
    ;;
  brightness)
    ipc_call brightness "$@"
    ;;
  audio)
    ipc_call audio "$@"
    ;;
  notifications|notifs)
    ipc_call notifs "$@"
    ;;
  ipc)
    ipc_call "$@"
    ;;
  service)
    subcommand="${1:-status}"
    (($# == 0)) || shift
    case "$subcommand" in
      install)
        install_service
        ;;
      enable)
        enable_service
        ;;
      disable)
        systemctl --user disable --now ryoku-shell.service >/dev/null 2>&1 || true
        ;;
      start|stop|restart|status)
        systemctl --user "$subcommand" ryoku-shell.service "$@"
        ;;
      logs)
        journalctl --user -u ryoku-shell.service "$@"
        ;;
      *)
        echo "ryoku-shell: unknown service command: $subcommand" >&2
        exit 2
        ;;
    esac
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "ryoku-shell: unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
