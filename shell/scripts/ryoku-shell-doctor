#!/bin/bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
shell_root="$(cd -- "$script_dir/.." && pwd)"
repo_root="$(cd -- "$shell_root/.." && pwd)"
runtime_dir="${RYOKU_SHELL_RUNTIME_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-shell}"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku-shell"
systemd_user_dir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
qs_bin="${RYOKU_QS_BIN:-qs}"

doctor_step=0
doctor_total=26
doctor_passed=0
doctor_failed=0
doctor_fixed=0
doctor_warnings=0
doctor_report_dir=""
doctor_report_file=""

usage() {
  cat <<'EOF'
Usage: ryoku-shell-doctor [-h]

Diagnoses the current Hyprland Ryoku shell runtime.
EOF
}

doctor_anonymize_report_line() {
  local line="$*"
  local home_path="${HOME:-}"
  local user_name=""
  local host_name=""

  user_name="$(id -un 2>/dev/null || true)"
  host_name="$(hostname 2>/dev/null || true)"

  if [[ -n $home_path ]]; then
    line="${line//$home_path/~}"
  fi

  line="$(printf '%s\n' "$line" | sed -E 's#/home/[^/[:space:]]+#~#g; s#/run/user/[0-9]+#/run/user/<uid>#g')"

  if [[ -n $user_name ]]; then
    line="${line//$user_name/<user>}"
  fi

  if [[ -n $host_name ]]; then
    line="${line//$host_name/<host>}"
  fi

  printf '%s\n' "$line"
}

doctor_report_line() {
  [[ -n $doctor_report_file ]] || return 0
  doctor_anonymize_report_line "$*" >>"$doctor_report_file"
}

doctor_report_value() {
  local label="$1"
  local value="${2:-unknown}"

  doctor_report_line "${label}: ${value:-unknown}"
}

doctor_report_issue() {
  local status="$1"
  shift

  doctor_report_line "- ${status} $*"
}

doctor_pretty() {
  [[ ${RYOKU_DOCTOR_PLAIN:-0} == "1" ]] && return 1
  if [[ ${RYOKU_DOCTOR_PRETTY:-0} == "1" ]]; then
    command -v ryoku-tui >/dev/null 2>&1
    return
  fi

  [[ -t 1 ]] && command -v ryoku-tui >/dev/null 2>&1
}

doctor_title() {
  if doctor_pretty; then
    ryoku-tui style \
      --border rounded \
      --border-foreground 6 \
      --foreground 15 \
      --padding "1 3" \
      "Ryoku Doctor flight deck" \
      "Hyprland shell health + automatic repair"
  else
    echo "Ryoku Doctor flight deck"
    echo "Hyprland shell health + automatic repair"
  fi
}

doctor_status_line() {
  local kind="$1"
  local message="$2"
  local color="7"

  case "$kind" in
    OK) color="2" ;;
    WARN) color="3" ;;
    FIX) color="6" ;;
    FAIL) color="1" ;;
  esac

  if doctor_pretty; then
    ryoku-tui style --foreground "$color" "${kind}: ${message}"
  else
    echo "${kind}: ${message}"
  fi
}

load_hyprland_env_from_quickshell() {
  local output
  local line
  local current_pid=""
  local current_config=""
  local pid=""
  local key
  local value

  [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} && -n ${WAYLAND_DISPLAY:-} ]] && return 0

  if ! output="$(env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST "$qs_bin" list --all 2>/dev/null)"; then
    return 1
  fi

  while IFS= read -r line; do
    case "$line" in
      Instance\ *)
        current_pid=""
        current_config=""
        ;;
      *"Process ID:"*)
        current_pid="${line#*Process ID: }"
        ;;
      *"Config path:"*)
        current_config="${line#*Config path: }"
        if [[ $current_config == "$runtime_dir/shell.qml" && -n $current_pid ]]; then
          pid="$current_pid"
          break
        fi
        ;;
    esac
  done <<<"$output"

  [[ -n $pid && -r /proc/$pid/environ ]] || return 1

  while IFS='=' read -r key value; do
    case "$key" in
      HYPRLAND_INSTANCE_SIGNATURE|WAYLAND_DISPLAY|XDG_RUNTIME_DIR|XDG_CURRENT_DESKTOP)
        export "$key=$value"
        ;;
    esac
  done < <(tr '\0' '\n' <"/proc/$pid/environ")

  [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} || -n ${WAYLAND_DISPLAY:-} ]]
}

detect_compositor() {
  load_hyprland_env_from_quickshell || true

  if [[ ${XDG_CURRENT_DESKTOP:-} == *"Hyprland"* || -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
    printf '%s\n' "Hyprland"
    return 0
  fi

  if command -v hyprctl >/dev/null 2>&1 && hyprctl version >/dev/null 2>&1; then
    printf '%s\n' "Hyprland"
    return 0
  fi

  printf '%s\n' "unknown"
  return 1
}

service_state() {
  if command -v systemctl >/dev/null 2>&1; then
    systemctl --user is-active ryoku-shell.service 2>/dev/null || printf '%s\n' "unknown"
  else
    printf '%s\n' "unknown"
  fi
}

doctor_report_init() {
  local report_base="${TMPDIR:-/tmp}"

  doctor_report_dir="$(mktemp -d "${report_base}/ryoku-doctor-report.XXXXXXXX" 2>/dev/null || true)"
  if [[ -z $doctor_report_dir ]]; then
    return 0
  fi

  doctor_report_file="$doctor_report_dir/report.txt"
  : >"$doctor_report_file" || {
    doctor_report_dir=""
    doctor_report_file=""
    return 0
  }
  chmod 600 "$doctor_report_file" 2>/dev/null || true

  doctor_report_line "Ryoku Doctor Report"
  doctor_report_line "Generated: $(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date 2>/dev/null || printf 'unknown')"
  doctor_report_line "Privacy: home path, username, hostname, and runtime UID are anonymized."
  doctor_report_line ""
  doctor_report_line "Context"
  doctor_report_value "Source" "$shell_root"
  doctor_report_value "Runtime" "$runtime_dir"
  doctor_report_value "Compositor" "$(detect_compositor 2>/dev/null || printf 'unknown')"
  doctor_report_value "Service" "$(service_state)"
  doctor_report_line ""
  doctor_report_line "Issues"
}

doctor_report_finish() {
  [[ -n $doctor_report_file && -f $doctor_report_file ]] || return 0

  if ! grep -q '^- ' "$doctor_report_file" 2>/dev/null; then
    doctor_report_issue "NONE" "No failing checks or automatic fixes were recorded."
  fi

  doctor_report_line ""
  doctor_report_value "Summary Passed" "$doctor_passed"
  doctor_report_value "Summary Fixed" "$doctor_fixed"
  doctor_report_value "Summary Warnings" "$doctor_warnings"
  doctor_report_value "Summary Failed" "$doctor_failed"
}

doctor_report_print_path() {
  [[ -n $doctor_report_file ]] || return 0
  echo "Doctor report: $doctor_report_file"
}

doctor_summary() {
  local summary="Summary: passed=$doctor_passed fixed=$doctor_fixed warnings=$doctor_warnings failed=$doctor_failed"

  if doctor_pretty; then
    ryoku-tui style \
      --border rounded \
      --border-foreground 8 \
      --foreground 15 \
      --padding "1 2" \
      "$summary"
  else
    echo "$summary"
  fi
}

doctor_pass() {
  doctor_status_line "OK" "$*"
  ((doctor_passed++)) || true
}

doctor_warn() {
  doctor_status_line "WARN" "$*"
  doctor_report_issue "WARN" "$*"
  ((doctor_warnings++)) || true
}

doctor_fix() {
  doctor_status_line "FIX" "$*"
  doctor_report_issue "FIX" "$*"
  ((doctor_fixed++)) || true
}

doctor_fail() {
  doctor_status_line "FAIL" "$*"
  doctor_report_issue "FAIL" "$*"
  ((doctor_failed++)) || true
}

run_check() {
  local label="$1"
  shift

  ((doctor_step++)) || true
  if doctor_pretty; then
    ryoku-tui style --foreground 6 "[${doctor_step}/${doctor_total}] Checking $label"
  else
    echo "[${doctor_step}/${doctor_total}] Checking $label"
  fi
  "$@" || true
}

check_dependencies() {
  local required=(qs hyprctl jq systemctl)
  local optional=(rsync git wl-copy wl-paste cliphist fuzzel grim slurp gradia wpctl nmcli notify-send playerctl python3 gdbus xdg-open)
  local missing=()
  local optional_missing=()
  local cmd

  for cmd in "${required[@]}"; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done

  for cmd in "${optional[@]}"; do
    command -v "$cmd" >/dev/null 2>&1 || optional_missing+=("$cmd")
  done

  if ((${#missing[@]} > 0)); then
    doctor_fail "Missing required shell commands: ${missing[*]}"
    return 0
  fi

  if ((${#optional_missing[@]} > 0)); then
    doctor_warn "Optional shell helpers missing: ${optional_missing[*]}"
  else
    doctor_pass "Required and optional shell commands available"
  fi
}

check_hyprland_compositor() {
  local compositor

  compositor="$(detect_compositor || true)"
  if [[ $compositor == "Hyprland" ]]; then
    doctor_pass "Hyprland compositor reachable"
  else
    doctor_fail "Hyprland compositor is not reachable"
  fi

  if command -v hyprctl >/dev/null 2>&1 && hyprctl configerrors 2>&1 | grep -q .; then
    doctor_fail "Hyprland reports config errors"
  fi
}

check_runtime_payload() {
  local critical=(
    shell.qml
    modules/Shortcuts.qml
    services/Hypr.qml
    scripts/ryoku-shell
    assets/systemd/ryoku-shell.service
  )
  local missing=()
  local file

  for file in "${critical[@]}"; do
    [[ -f $runtime_dir/$file ]] || missing+=("$file")
  done

  if ((${#missing[@]} > 0)); then
    doctor_fail "Runtime payload missing: ${missing[*]}"
  else
    doctor_pass "Runtime payload present"
  fi
}

check_launcher() {
  local launcher=""

  launcher="$(command -v ryoku-shell 2>/dev/null || true)"
  if [[ -z $launcher && -x $HOME/.local/bin/ryoku-shell ]]; then
    launcher="$HOME/.local/bin/ryoku-shell"
  fi

  if [[ -n $launcher && -x $launcher ]]; then
    doctor_pass "ryoku-shell launcher available"
  else
    doctor_fail "ryoku-shell launcher missing"
  fi
}

check_quickshell_qt_abi() {
  local qs_path=""
  local built_qt=""
  local runtime_qt=""

  qs_path="$(command -v "$qs_bin" 2>/dev/null || true)"
  if [[ -z $qs_path || ! -x $qs_path ]]; then
    doctor_warn "Quickshell binary unavailable; Qt ABI check skipped"
    return 0
  fi

  if command -v strings >/dev/null 2>&1; then
    built_qt="$(strings "$qs_path" | awk '/^[0-9]+[.][0-9]+[.][0-9]+$/ { print; exit }')"
  fi

  if command -v pacman >/dev/null 2>&1; then
    runtime_qt="$(pacman -Q qt6-base 2>/dev/null | awk '{ print $2 }')"
    runtime_qt="${runtime_qt%%-*}"
  fi

  if [[ -z $built_qt || -z $runtime_qt ]]; then
    doctor_pass "Quickshell Qt ABI check skipped; version markers unavailable"
  elif [[ $built_qt == "$runtime_qt" ]]; then
    doctor_pass "Quickshell Qt ABI current ($runtime_qt)"
  else
    doctor_warn "Quickshell was built against Qt $built_qt but system Qt is $runtime_qt; rebuild quickshell"
  fi
}

check_command_bridges() {
  local bin_home="${XDG_BIN_HOME:-$HOME/.local/bin}"
  local fixed=0
  local missing=()
  local name source target

  mkdir -p "$bin_home"
  for name in ryoku ryoku-shell ryoku-update ryoku-doctor ryoku-call911now; do
    case "$name" in
      ryoku) source="$shell_root/scripts/ryoku" ;;
      ryoku-shell) source="$shell_root/scripts/ryoku-shell" ;;
      *) source="$repo_root/bin/$name" ;;
    esac
    target="$bin_home/$name"
    [[ -e $source ]] || {
      missing+=("$name")
      continue
    }
    if [[ ! -L $target || $(readlink "$target" 2>/dev/null || true) != "$source" ]]; then
      ln -sfn "$source" "$target" 2>/dev/null && ((fixed++)) || true
    fi
    [[ -e $target ]] || missing+=("$name")
  done

  if ((${#missing[@]} > 0)); then
    doctor_fail "Command bridges missing: ${missing[*]}"
  elif ((fixed > 0)); then
    doctor_fix "Repaired $fixed command bridge(s)"
  else
    doctor_pass "Command bridges current"
  fi
}

check_runtime_env_bridge() {
  local bridge="${XDG_BIN_HOME:-$HOME/.local/bin}"
  local source="$repo_root/lib/runtime-env.sh"
  local target

  target="$(dirname "$bridge")/lib/runtime-env.sh"
  if [[ ! -f $source ]]; then
    doctor_fail "runtime-env source missing: $source"
    return 0
  fi

  mkdir -p "$(dirname "$target")"
  if [[ ! -L $target || $(readlink "$target" 2>/dev/null || true) != "$source" ]]; then
    ln -sfn "$source" "$target" 2>/dev/null || {
      doctor_fail "runtime-env bridge cannot be repaired: $target"
      return 0
    }
    doctor_fix "Repaired runtime-env bridge"
    return 0
  fi

  doctor_pass "runtime-env bridge current"
}

check_medevac_command() {
  local command_path=""

  command_path="$(command -v ryoku-call911now 2>/dev/null || true)"
  if [[ -n $command_path || -x $repo_root/bin/ryoku-call911now ]]; then
    doctor_pass "MedEvac command available"
  else
    doctor_fail "ryoku-call911now missing from installed checkout and PATH"
  fi
}

check_update_status() {
  local status_file="${XDG_STATE_HOME:-$HOME/.local/state}/quickshell/user/update-status"
  local status=""

  if [[ -r $status_file ]]; then
    status="$(<"$status_file")"
  fi

  case "$status" in
    failed:* | updating | progress:*)
      doctor_warn "Updater needs attention: ${status:-unknown}"
      ;;
    "")
      doctor_pass "No stale update status"
      ;;
    *)
      doctor_pass "Update status: $status"
      ;;
  esac
}

check_snapshot_tooling() {
  if command -v ryoku-snapshot >/dev/null 2>&1 || [[ -x $repo_root/bin/ryoku-snapshot ]]; then
    doctor_pass "Snapshot tooling available"
  else
    doctor_warn "Snapshot command missing; updates cannot create rollback points"
  fi
}

check_state_directories() {
  local dirs=(
    "${XDG_STATE_HOME:-$HOME/.local/state}/ryoku"
    "${XDG_STATE_HOME:-$HOME/.local/state}/quickshell/user"
    "$config_dir"
  )
  local created=0
  local dir

  for dir in "${dirs[@]}"; do
    if [[ ! -d $dir ]]; then
      mkdir -p "$dir" 2>/dev/null && ((created++)) || true
    fi
  done

  if ((created > 0)); then
    doctor_fix "Created $created state/config directorie(s)"
  else
    doctor_pass "State/config directories present"
  fi
}

check_script_permissions() {
  local bad=0

  bad="$(find "$shell_root/scripts" "$repo_root/bin" -maxdepth 1 -type f -name 'ryoku-*' ! -executable 2>/dev/null | wc -l)"
  if ((bad > 0)); then
    find "$shell_root/scripts" "$repo_root/bin" -maxdepth 1 -type f -name 'ryoku-*' ! -executable -exec chmod +x {} + 2>/dev/null || true
    doctor_fix "Restored executable bit on $bad Ryoku script(s)"
  else
    doctor_pass "Ryoku script permissions OK"
  fi
}

check_shell_source_pointer() {
  local pointer="$runtime_dir/.ryoku-source-path"
  local current=""

  if [[ -r $pointer ]]; then
    current="$(<"$pointer")"
  fi

  if [[ $current == "$repo_root" ]]; then
    doctor_pass "Runtime source pointer targets installed checkout"
    return 0
  fi

  if [[ -d $runtime_dir ]]; then
    printf '%s\n' "$repo_root" >"$pointer" 2>/dev/null || {
      doctor_warn "Runtime source pointer is stale and could not be rewritten"
      return 0
    }
    doctor_fix "Repaired runtime source pointer"
  else
    doctor_warn "Runtime source pointer skipped because runtime directory is missing"
  fi
}

check_portal_services() {
  local hyprland_state=""
  local portal_state=""

  command -v systemctl >/dev/null 2>&1 || {
    doctor_warn "systemctl unavailable; portal service check skipped"
    return 0
  }

  hyprland_state="$(systemctl --user is-active xdg-desktop-portal-hyprland.service 2>/dev/null || true)"
  portal_state="$(systemctl --user is-active xdg-desktop-portal.service 2>/dev/null || true)"
  if [[ $hyprland_state == "active" && $portal_state == "active" ]]; then
    doctor_pass "Hyprland portal services active"
  else
    doctor_warn "Portal services not fully active: hyprland=${hyprland_state:-unknown} portal=${portal_state:-unknown}"
  fi
}

check_clipboard_stack() {
  local missing=()
  local cmd

  for cmd in wl-copy wl-paste cliphist; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done
  if ((${#missing[@]} > 0)); then
    doctor_warn "Clipboard helpers missing: ${missing[*]}"
  else
    doctor_pass "Clipboard stack available"
  fi
}

check_screenshot_stack() {
  local missing=()
  local cmd

  for cmd in grim slurp; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done
  if ((${#missing[@]} > 0)); then
    doctor_warn "Screenshot helpers missing: ${missing[*]}"
  else
    doctor_pass "Screenshot stack available"
  fi
}

check_audio_controls() {
  if command -v wpctl >/dev/null 2>&1; then
    doctor_pass "Audio controls available"
  else
    doctor_warn "wpctl missing; shell audio controls may fail"
  fi
}

check_package_helpers() {
  if command -v ryoku-pkg-add >/dev/null 2>&1 && command -v pacman >/dev/null 2>&1; then
    doctor_pass "Package helpers available"
  else
    doctor_warn "Package helper stack incomplete"
  fi
}

check_user_config() {
  local config="$config_dir/config.json"
  local stale_metadata=(
    "$config_dir/installed_listfile"
    "$config_dir/migrations.json"
  )
  local metadata
  local stale_count=0
  local tmp=""

  if [[ ! -f $config ]]; then
    doctor_pass "User config absent; defaults will be used"
    return 0
  fi

  if ! jq empty "$config" >/dev/null 2>&1; then
    doctor_fail "User config JSON invalid: $config"
    return 0
  fi

  if jq -e '
    [
      .gameMode.disableNiriAnimations?,
      .gameMode.niriWindowListUpdateIntervalMs?,
      .gameMode.niriWindowListUpdateIntervalMsGameMode?,
      .overlay.recorder.disableNiriAnims?
    ] | map(select(. != null)) | length > 0
  ' "$config" >/dev/null 2>&1; then
    tmp="$(mktemp "${config}.XXXXXX")" || {
      doctor_warn "User config has stale Niri-era keys but no temp file could be created"
      return 0
    }
    if jq '
      del(
        .gameMode.disableNiriAnimations,
        .gameMode.niriWindowListUpdateIntervalMs,
        .gameMode.niriWindowListUpdateIntervalMsGameMode,
        .overlay.recorder.disableNiriAnims
      )
    ' "$config" >"$tmp" && mv "$tmp" "$config"; then
      ((stale_count++)) || true
    else
      rm -f "$tmp"
      doctor_warn "User config has stale Niri-era keys but could not be rewritten"
      return 0
    fi
  fi

  for metadata in "${stale_metadata[@]}"; do
    if [[ -f $metadata ]] \
      && grep -Eiq 'niri|inir|illogical-impulse|ryoku-rebirth-shell|ryoku-vroomies-shell' "$metadata"; then
      rm -f "$metadata" && ((stale_count++)) || true
    fi
  done

  if (( stale_count > 0 )); then
    doctor_fix "Removed stale Niri-era shell config metadata"
  else
    doctor_pass "User config JSON valid"
  fi
}

check_legacy_shell_env() {
  local fish_env="${XDG_CONFIG_HOME:-$HOME/.config}/fish/conf.d/ryoku-shell-env.fish"
  local stale_env="ILLOGICAL_IMPULSE_VIRTUAL_ENV"

  if [[ ! -f $fish_env ]] || ! grep -qF "$stale_env" "$fish_env"; then
    doctor_pass "No stale shell env exports"
    return 0
  fi

  if sed -i "/$stale_env/d" "$fish_env"; then
    if [[ ! -s $fish_env ]] || ! grep -qF "RYOKU_SHELL_VENV" "$fish_env"; then
      rm -f "$fish_env"
    fi
    doctor_fix "Removed stale shell env compatibility export"
  else
    doctor_fail "Stale shell env compatibility export remains: $fish_env"
  fi
}

check_hyprland_config() {
  local hypr_conf="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprland.conf"

  if [[ ! -f $hypr_conf ]]; then
    doctor_fail "Hyprland config missing: $hypr_conf"
    return 0
  fi

  if grep -Eq "systemctl --user .*start ryoku-shell[.]service" "$hypr_conf"; then
    doctor_pass "Hyprland starts ryoku-shell.service"
  elif grep -Fq "ryoku-shell run --session" "$hypr_conf"; then
    doctor_fail "Hyprland starts an unmanaged Ryoku shell; use ryoku-shell.service"
  else
    doctor_fail "Hyprland config does not start Ryoku shell"
  fi
}

check_service() {
  local service_file="$systemd_user_dir/ryoku-shell.service"
  local stale_dropin="$systemd_user_dir/ryoku-shell.service.d/qt6-fractional-scale-workaround.conf"
  local launcher=""
  local refresh_needed=0
  local state

  if ! command -v systemctl >/dev/null 2>&1; then
    doctor_warn "systemctl unavailable; service check skipped"
    return 0
  fi

  if [[ -e $stale_dropin || -L $stale_dropin ]]; then
    if rm -f "$stale_dropin"; then
      rmdir "$systemd_user_dir/ryoku-shell.service.d" >/dev/null 2>&1 || true
      systemctl --user daemon-reload >/dev/null 2>&1 || true
      doctor_fix "Removed stale Qt fractional-scale drop-in: $stale_dropin"
    else
      doctor_fail "Stale Qt fractional-scale drop-in remains: $stale_dropin"
    fi
  fi

  if [[ -f $service_file ]]; then
    grep -Fq "Environment=PATH=%h/.local/bin:%h/.local/share/ryoku/bin:" "$service_file" || refresh_needed=1
    grep -Fq "kf.xmlgui=false" "$service_file" || refresh_needed=1
    grep -Fq "Environment=QS_DISABLE_CRASH_HANDLER=1" "$service_file" || refresh_needed=1
    grep -Eq '^ExecStopPost=-.*ryoku-shell-cleanup-orphans --quiet$' "$service_file" || refresh_needed=1
    grep -Fq "IOSchedulingPriority=2" "$service_file" || refresh_needed=1
  else
    refresh_needed=1
  fi

  if (( refresh_needed == 1 )); then
    launcher="$(command -v ryoku-shell 2>/dev/null || true)"
    if [[ -z $launcher && -x $HOME/.local/bin/ryoku-shell ]]; then
      launcher="$HOME/.local/bin/ryoku-shell"
    fi

    if [[ -n $launcher ]] && "$launcher" service install >/dev/null 2>&1; then
      doctor_fix "Refreshed ryoku-shell.service from the current Ryoku runtime template"
    else
      doctor_fail "ryoku-shell.service is stale and could not be refreshed"
    fi
  fi

  state="$(systemctl --user is-active ryoku-shell.service 2>/dev/null || true)"
  if [[ $state == "active" ]]; then
    doctor_pass "ryoku-shell.service active"
  else
    doctor_fail "ryoku-shell.service is ${state:-inactive}"
  fi
}

quickshell_config_runtime_dir() {
  local config="$1"

  if [[ $config == */shell.qml ]]; then
    printf '%s\n' "${config%/shell.qml}"
  else
    dirname -- "$config"
  fi
}

quickshell_config_is_stale_runtime() {
  local config="$1"
  local runtime_path

  [[ -n $config ]] || return 1
  [[ $config == "$runtime_dir/shell.qml" ]] && return 1

  runtime_path="$(quickshell_config_runtime_dir "$config")"
  case "$runtime_path" in
    */quickshell/ryoku-shell | */quickshell/*-shell | */quickshell/inir | */quickshell/illogical-impulse)
      return 0
      ;;
  esac

  return 1
}

stop_duplicate_quickshell_runtime() {
  local runtime_path="$1"

  [[ -n $runtime_path ]] || return 1

  if env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST \
    "$qs_bin" kill -p "$runtime_path" --any-display >/dev/null 2>&1; then
    doctor_fix "Stopped duplicate/stale Quickshell runtime: $runtime_path"
    return 0
  fi

  doctor_fail "Could not stop duplicate/stale Quickshell runtime: $runtime_path"
}

# PIDs of every Quickshell instance running the canonical Ryoku runtime.
canonical_quickshell_pids() {
  local output line pid="" config=""

  output="$(env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST \
    "$qs_bin" list --all 2>/dev/null)" || return 0

  while IFS= read -r line; do
    case "$line" in
      Instance\ *) pid=""; config="" ;;
      *"Process ID:"*) pid="${line#*Process ID: }" ;;
      *"Config path:"*)
        config="${line#*Config path: }"
        if [[ $config == "$runtime_dir/shell.qml" && -n $pid ]]; then
          printf '%s\n' "$pid"
        fi
        ;;
    esac
  done <<<"$output"
}

# True when PID is genuinely a Quickshell process for our runtime. Guards the
# reaper from ever signalling an unrelated PID (e.g. a recycled list entry).
# Overridable in tests.
pid_is_our_shell() {
  local pid="$1" cmd

  [[ -n $pid && -r /proc/$pid/cmdline ]] || return 1
  cmd="$(tr '\0' ' ' </proc/"$pid"/cmdline 2>/dev/null)"
  [[ $cmd == *"$runtime_dir"* ]] || return 1
  [[ $cmd == *qs* || $cmd == *quickshell* ]]
}

# A spinning shell (saturated event loop) ignores the cooperative `qs kill`
# IPC quit, so the instances survive and accumulate one more spinning core per
# restart. Escalate to signals, which the kernel delivers regardless of the
# event-loop state. Returns 0 when it reaped at least one survivor.
reap_unresponsive_canonical() {
  local pid pids=() alive=() survivors=()

  mapfile -t pids < <(canonical_quickshell_pids)
  for pid in "${pids[@]}"; do
    pid_is_our_shell "$pid" && alive+=("$pid")
  done
  ((${#alive[@]})) || return 1

  for pid in "${alive[@]}"; do
    kill -TERM "$pid" 2>/dev/null || true
  done
  sleep 1

  for pid in "${alive[@]}"; do
    pid_is_our_shell "$pid" && survivors+=("$pid")
  done
  for pid in "${survivors[@]}"; do
    kill -KILL "$pid" 2>/dev/null || true
  done

  doctor_fix "Force-stopped unresponsive Ryoku shell runtime (PID ${alive[*]})"
  return 0
}

restart_canonical_quickshell_runtime() {
  local cooperative=0

  if ! command -v systemctl >/dev/null 2>&1; then
    doctor_fail "Multiple Ryoku shell runtimes found, but systemctl is unavailable for service restart"
    return 0
  fi

  if env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST \
    "$qs_bin" kill -p "$runtime_dir" --any-display >/dev/null 2>&1; then
    cooperative=1
  fi

  # The cooperative quit can "succeed" yet leave a spinning instance running,
  # so always check for survivors and signal-reap them.
  if ! reap_unresponsive_canonical && (( cooperative == 0 )); then
    doctor_fail "Could not stop duplicate canonical Ryoku shell runtime"
    return 0
  fi

  systemctl --user reset-failed ryoku-shell.service >/dev/null 2>&1 || true
  if systemctl --user restart ryoku-shell.service >/dev/null 2>&1 || \
    systemctl --user start ryoku-shell.service >/dev/null 2>&1; then
    doctor_fix "Restarted ryoku-shell.service to collapse duplicate Ryoku bars"
  else
    doctor_fail "Could not restart ryoku-shell.service after duplicate runtime cleanup"
  fi
}

check_quickshell_instance() {
  local output
  local line
  local current_config=""
  local canonical_count=0
  local stale_runtime
  local stale_runtimes=()

  if ! output="$(env -u QS_CONFIG_NAME -u QS_CONFIG_PATH -u QS_MANIFEST "$qs_bin" list --all 2>&1)"; then
    doctor_fail "Unable to list Quickshell instances: $output"
    return 0
  fi

  while IFS= read -r line; do
    case "$line" in
      Instance\ *)
        if [[ -n $current_config ]]; then
          if [[ $current_config == "$runtime_dir/shell.qml" ]]; then
            ((canonical_count++)) || true
          elif quickshell_config_is_stale_runtime "$current_config"; then
            stale_runtimes+=("$(quickshell_config_runtime_dir "$current_config")")
          fi
        fi
        current_config=""
        ;;
      *"Config path:"*)
        current_config="${line#*Config path: }"
        ;;
    esac
  done <<<"$output"

  if [[ -n $current_config ]]; then
    if [[ $current_config == "$runtime_dir/shell.qml" ]]; then
      ((canonical_count++)) || true
    elif quickshell_config_is_stale_runtime "$current_config"; then
      stale_runtimes+=("$(quickshell_config_runtime_dir "$current_config")")
    fi
  fi

  for stale_runtime in "${stale_runtimes[@]}"; do
    stop_duplicate_quickshell_runtime "$stale_runtime"
  done

  if (( canonical_count == 1 )); then
    doctor_pass "Quickshell is running the Ryoku shell runtime"
  elif (( canonical_count > 1 )); then
    restart_canonical_quickshell_runtime
  else
    doctor_fail "No running Quickshell instance for $runtime_dir/shell.qml"
  fi
}

check_native_plugin() {
  local qml_dir="${RYOKU_SHELL_QML_DIR:-$HOME/.local/lib/qt6/qml}"
  local services_so="$qml_dir/Ryoku/Services/libryoku-services.so"
  local linked=""

  if [[ ! -f $services_so ]]; then
    doctor_fail "Ryoku Services plugin missing: $services_so (rerun 'shell/setup install')"
    return 0
  fi

  if ! command -v ldd >/dev/null 2>&1; then
    doctor_pass "Ryoku Services plugin present (ldd unavailable; skipping linkage check)"
    return 0
  fi

  linked="$(ldd "$services_so" 2>/dev/null || true)"
  if grep -q "not found" <<<"$linked"; then
    doctor_fail "Ryoku Services plugin has unresolved libraries:$(printf '\n  %s' "$(grep 'not found' <<<"$linked")")"
    return 0
  fi

  # The cava-ryoku package must be installed AND the plugin must be linked
  # against libcava. If the plugin was built before libcava was available
  # (e.g. via a stock `cava` install), the dashboard music visualiser is
  # silently invisible at runtime — this is exactly the regression class
  # that surfaced the cava-ryoku PKGBUILD work in the first place.
  if ! grep -q 'libcava\.so' <<<"$linked"; then
    doctor_fail "Ryoku Services plugin not linked against libcava (install distro/arch/cava-ryoku and rerun 'shell/setup install')"
    return 0
  fi

  doctor_pass "Ryoku Services plugin loadable and linked against libcava"
}

check_audio_restore_service() {
  local unit="ryoku-audio-restore-mixers.service"
  local state=""

  if ! systemctl --user list-unit-files "$unit" >/dev/null 2>&1; then
    doctor_fail "$unit not installed (run install/config/ryoku-audio-restore-mixers.sh)"
    return 0
  fi

  state="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
  case "$state" in
    enabled | static | enabled-runtime)
      doctor_pass "$unit is enabled (heals silent-speakers state on each login)"
      ;;
    *)
      doctor_fail "$unit is not enabled (state: ${state:-unknown}) — run install/config/ryoku-audio-restore-mixers.sh"
      ;;
  esac
}

check_stale_compositor_wiring() {
  local niri_wants="$systemd_user_dir/niri.service.wants/ryoku-shell.service"
  local stale_dropin="$systemd_user_dir/ryoku-shell.service.d/qt6-fractional-scale-workaround.conf"
  local hypr_conf="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprland.conf"
  local stale_hypridle_config="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hypridle-rebirth.conf"
  local stale_hypridle_line="exec-once = hypridle -c ~/.config/hypr/hypridle-rebirth.conf"
  local stale_hypridle_pattern='(^|/)hypridle -c .*/hypridle-rebirth[.]conf($| )'
  local compositor
  local found=0

  if [[ -e $niri_wants || -L $niri_wants ]]; then
    found=1
    compositor="$(detect_compositor || true)"
    if [[ $compositor == "Hyprland" ]] && rm -f "$niri_wants"; then
      doctor_fix "Removed stale Niri service wiring: $niri_wants"
    else
      doctor_fail "Stale Niri service wiring remains: $niri_wants"
    fi
  fi

  if [[ -e $stale_dropin || -L $stale_dropin ]]; then
    found=1
    if rm -f "$stale_dropin"; then
      rmdir "$systemd_user_dir/ryoku-shell.service.d" >/dev/null 2>&1 || true
      systemctl --user daemon-reload >/dev/null 2>&1 || true
      doctor_fix "Removed stale Qt fractional-scale drop-in: $stale_dropin"
    else
      doctor_fail "Stale Qt fractional-scale drop-in remains: $stale_dropin"
    fi
  fi

  if [[ -f $hypr_conf ]] && grep -Fxq "$stale_hypridle_line" "$hypr_conf"; then
    found=1
    if sed -i '\#^exec-once = hypridle -c ~/\.config/hypr/hypridle-rebirth\.conf$#d' "$hypr_conf"; then
      hyprctl reload >/dev/null 2>&1 || true
      doctor_fix "Removed stale Hyprland hypridle exec-once; systemd owns hypridle.service"
    else
      doctor_fail "Stale Hyprland hypridle exec-once remains: $hypr_conf"
    fi
  fi

  if [[ -e $stale_hypridle_config || -L $stale_hypridle_config ]]; then
    found=1
    if rm -f "$stale_hypridle_config"; then
      doctor_fix "Removed stale hypridle rebirth config: $stale_hypridle_config"
    else
      doctor_fail "Stale hypridle rebirth config remains: $stale_hypridle_config"
    fi
  fi

  if command -v systemctl >/dev/null 2>&1 \
    && command -v pgrep >/dev/null 2>&1 \
    && command -v pkill >/dev/null 2>&1 \
    && systemctl --user is-active --quiet hypridle.service >/dev/null 2>&1 \
    && pgrep -f "$stale_hypridle_pattern" >/dev/null 2>&1; then
    found=1
    if pkill -f "$stale_hypridle_pattern" >/dev/null 2>&1; then
      doctor_fix "Stopped stale Hyprland-spawned hypridle instance"
    else
      doctor_fail "Stale Hyprland-spawned hypridle instance remains"
    fi
  fi

  if (( found == 0 )); then
    doctor_pass "No stale compositor service wiring"
  fi
}

run_shell_doctor() {
  doctor_report_init

  doctor_title
  echo
  run_check "dependencies" check_dependencies
  run_check "command bridges" check_command_bridges
  run_check "runtime-env bridge" check_runtime_env_bridge
  run_check "MedEvac command" check_medevac_command
  run_check "update status" check_update_status
  run_check "snapshot tooling" check_snapshot_tooling
  run_check "state directories" check_state_directories
  run_check "script permissions" check_script_permissions
  run_check "shell source pointer" check_shell_source_pointer
  run_check "Hyprland compositor" check_hyprland_compositor
  run_check "Ryoku shell runtime" check_runtime_payload
  run_check "ryoku-shell launcher" check_launcher
  run_check "Quickshell Qt ABI" check_quickshell_qt_abi
  run_check "user config" check_user_config
  run_check "shell env cleanup" check_legacy_shell_env
  run_check "Hyprland config" check_hyprland_config
  run_check "ryoku-shell service" check_service
  run_check "portal services" check_portal_services
  run_check "Quickshell instance" check_quickshell_instance
  run_check "native plugin" check_native_plugin
  run_check "audio mixer self-heal" check_audio_restore_service
  run_check "stale compositor wiring" check_stale_compositor_wiring
  run_check "clipboard stack" check_clipboard_stack
  run_check "screenshot stack" check_screenshot_stack
  run_check "audio controls" check_audio_controls
  run_check "package helpers" check_package_helpers
  echo

  doctor_report_finish
  doctor_report_print_path

  echo
  doctor_summary

  ((doctor_failed == 0))
}

if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  case "${1:-}" in
    ""|-y|-q|--skip-deps|--skip-setups|--skip-sysupdate)
      run_shell_doctor
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      echo "ryoku-shell-doctor: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
fi
