#!/bin/bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
runtime_env="${RYOKU_PATH:-$HOME/.local/share/ryoku}/lib/runtime-env.sh"
if [[ -f $runtime_env ]]; then
  # shellcheck source=/dev/null
  source "$runtime_env"
else
  ryoku-cmd-present() {
    command -v "$1" >/dev/null 2>&1
  }
fi

ryoku-cmd-present pactl || {
  echo "ryoku-cmd-audio-jack: pactl is not installed" >&2
  exit 1
}

ryoku-cmd-present jq || {
  echo "ryoku-cmd-audio-jack: jq is not installed" >&2
  exit 1
}

sinks_json="$(pactl -f json list sinks)"
sink_name="$(
  jq -r '.[] | select(any(.ports[]?; .name == "analog-output-headphones")) | .name' <<<"$sinks_json" \
    | head -n 1
)"

if [[ -z $sink_name || $sink_name == "null" ]]; then
  sink_name="$(
    jq -r '.[] | select(.name | test("analog-stereo$")) | .name' <<<"$sinks_json" \
      | head -n 1
  )"
fi

if [[ -z $sink_name || $sink_name == "null" ]]; then
  echo "ryoku-cmd-audio-jack: no analog output sink found" >&2
  exit 1
fi

port_name="$(
  jq -r --arg name "$sink_name" '
    .[] | select(.name == $name)
    | if any(.ports[]?; .name == "analog-output-headphones") then "analog-output-headphones"
      elif any(.ports[]?; .name == "analog-output-speaker") then "analog-output-speaker"
      else "" end
  ' <<<"$sinks_json" \
    | head -n 1
)"

card_id="$(
  jq -r --arg name "$sink_name" '.[] | select(.name == $name) | .properties."alsa.card" // empty' <<<"$sinks_json" \
    | head -n 1
)"

if [[ -n $port_name ]]; then
  pactl set-sink-port "$sink_name" "$port_name" >/dev/null 2>&1 || true
fi

if [[ -n $card_id && $card_id != "null" ]] && ryoku-cmd-present amixer; then
  if [[ $port_name == "analog-output-headphones" ]]; then
    amixer -c "$card_id" set Headphone 100% unmute >/dev/null 2>&1 || true
  fi
  amixer -c "$card_id" set Master 100% unmute >/dev/null 2>&1 || true
fi

"$script_dir/ryoku-cmd-audio-default" "$sink_name"

notify-send -u low "Audio output" "Using analog mini-jack" >/dev/null 2>&1 || true
if ryoku-cmd-present ryoku-shell; then
  ryoku-shell osdVolume trigger >/dev/null 2>&1 || true
fi
