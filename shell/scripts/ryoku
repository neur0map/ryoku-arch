colour_payload() {
  local name="${1:-ryoku}"
  local flavour="${2:-default}"
  local variant
  local mode
  local primary
  local secondary
  local tertiary

  variant="$(normalise_variant "${3:-tonalspot}")"
  mode="$(normalise_mode "${4:-dark}")"
  select_palette_seed "$flavour" "$variant"

  if [[ $mode == "light" ]]; then
    primary="$primary_light"
    secondary="$secondary_light"
    tertiary="$tertiary_light"
    cat <<JSON
{"primary_paletteKeyColor":"$primary_light","secondary_paletteKeyColor":"$secondary_light","tertiary_paletteKeyColor":"$tertiary_light","neutral_paletteKeyColor":"$neutral","neutral_variant_paletteKeyColor":"$neutral_variant","background":"FCF8F6","onBackground":"1F1B18","surface":"FCF8F6","surfaceDim":"DED8D3","surfaceBright":"FCF8F6","surfaceContainerLowest":"FFFFFF","surfaceContainerLow":"F7F2EE","surfaceContainer":"F1ECE8","surfaceContainerHigh":"EBE6E2","surfaceContainerHighest":"E5E0DC","onSurface":"1F1B18","surfaceVariant":"E8DCD5","onSurfaceVariant":"51443E","inverseSurface":"342F2C","inverseOnSurface":"F7EFEA","outline":"83746D","outlineVariant":"D5C3BA","shadow":"000000","scrim":"000000","surfaceTint":"$primary","primary":"$primary","onPrimary":"FFFFFF","primaryContainer":"$primary_container_light","onPrimaryContainer":"271000","inversePrimary":"$primary_dark","secondary":"$secondary","onSecondary":"FFFFFF","secondaryContainer":"$secondary_container_light","onSecondaryContainer":"111F0F","tertiary":"$tertiary","onTertiary":"FFFFFF","tertiaryContainer":"$tertiary_container_light","onTertiaryContainer":"2F1500","error":"BA1A1A","onError":"FFFFFF","errorContainer":"FFDAD6","onErrorContainer":"410002","success":"3F6B49","onSuccess":"FFFFFF","successContainer":"D1E9D6","onSuccessContainer":"00210C","primaryFixed":"$primary_container_light","primaryFixedDim":"$primary_dark","onPrimaryFixed":"271000","onPrimaryFixedVariant":"$primary_container_dark","secondaryFixed":"$secondary_container_light","secondaryFixedDim":"$secondary_dark","onSecondaryFixed":"111F0F","onSecondaryFixedVariant":"$secondary_container_dark","tertiaryFixed":"$tertiary_container_light","tertiaryFixedDim":"$tertiary_dark","onTertiaryFixed":"2F1500","onTertiaryFixedVariant":"$tertiary_container_dark"}
JSON
    return 0
  fi

  primary="$primary_dark"
  secondary="$secondary_dark"
  tertiary="$tertiary_dark"
  cat <<JSON
{"primary_paletteKeyColor":"$primary_dark","secondary_paletteKeyColor":"$secondary_dark","tertiary_paletteKeyColor":"$tertiary_dark","neutral_paletteKeyColor":"$neutral","neutral_variant_paletteKeyColor":"$neutral_variant","background":"171717","onBackground":"CCD0CF","surface":"171717","surfaceDim":"171717","surfaceBright":"333333","surfaceContainerLowest":"101010","surfaceContainerLow":"1D1D1D","surfaceContainer":"222222","surfaceContainerHigh":"2A2A2A","surfaceContainerHighest":"333333","onSurface":"CCD0CF","surfaceVariant":"333333","onSurfaceVariant":"BCBFBC","inverseSurface":"CCD0CF","inverseOnSurface":"171717","outline":"8A8A8A","outlineVariant":"4D4D4D","shadow":"000000","scrim":"000000","surfaceTint":"$primary","primary":"$primary","onPrimary":"171717","primaryContainer":"$primary_container_dark","onPrimaryContainer":"$primary_container_light","inversePrimary":"$primary_light","secondary":"$secondary","onSecondary":"171717","secondaryContainer":"$secondary_container_dark","onSecondaryContainer":"$secondary_container_light","tertiary":"$tertiary","onTertiary":"171717","tertiaryContainer":"$tertiary_container_dark","onTertiaryContainer":"$tertiary_container_light","error":"FFB4AB","onError":"690005","errorContainer":"93000A","onErrorContainer":"FFDAD6","success":"B5CCBA","onSuccess":"213528","successContainer":"374B3E","onSuccessContainer":"D1E9D6","primaryFixed":"$primary_container_light","primaryFixedDim":"$primary_dark","onPrimaryFixed":"271000","onPrimaryFixedVariant":"$primary_container_dark","secondaryFixed":"$secondary_container_light","secondaryFixedDim":"$secondary_dark","onSecondaryFixed":"111F0F","onSecondaryFixedVariant":"$secondary_container_dark","tertiaryFixed":"$tertiary_container_light","tertiaryFixedDim":"$tertiary_dark","onTertiaryFixed":"2F1500","onTertiaryFixedVariant":"$tertiary_container_dark"}
JSON
}

scheme_json() {
  local name="${1:-$(read_state name ryoku)}"
  local flavour="${2:-$(read_state flavour default)}"
  local variant
  local mode

  variant="$(normalise_variant "${3:-$(read_state variant tonalspot)}")"
  mode="$(normalise_mode "${4:-$(read_state mode dark)}")"

  printf '{"name":"%s","flavour":"%s","mode":"%s","variant":"%s","colours":%s}\n' \
    "$name" "$flavour" "$mode" "$variant" "$(colour_payload "$name" "$flavour" "$variant" "$mode")"
}

ensure_scheme_file() {
  if [[ ! -f $scheme_file ]]; then
    mkdir -p "$state_dir"
    scheme_json >"$scheme_file"
  fi
}

scheme_list() {
  local variant
  local mode

  variant="$(normalise_variant "$(read_state variant tonalspot)")"
  mode="$(normalise_mode "$(read_state mode dark)")"

  printf '{"ryoku":{"default":%s,"forest":%s,"ocean":%s,"amethyst":%s,"rose":%s,"graphite":%s}}\n' \
    "$(colour_payload ryoku default "$variant" "$mode")" \
    "$(colour_payload ryoku forest "$variant" "$mode")" \
    "$(colour_payload ryoku ocean "$variant" "$mode")" \
    "$(colour_payload ryoku amethyst "$variant" "$mode")" \
    "$(colour_payload ryoku rose "$variant" "$mode")" \
    "$(colour_payload ryoku graphite "$variant" "$mode")"
}

scheme_get() {
  local flags="${1:-}"

  ensure_scheme_file

  if [[ $flags == "-nfv" ]]; then
    read_state name ryoku
    read_state flavour default
    read_state variant tonalspot
    return 0
  fi

  if [[ $flags == "-nfvm" ]]; then
    read_state name ryoku
    read_state flavour default
    read_state variant tonalspot
    read_state mode dark
    return 0
  fi

  cat "$scheme_file"
}

scheme_preview() {
  local name
  local flavour
  local variant
  local mode
  local payload

  name="$(read_state name ryoku)"
  flavour="$(read_state flavour default)"
  variant="$(read_state variant tonalspot)"
  mode="$(read_state mode dark)"

  while (($# > 0)); do
    case "$1" in
      -n)
        shift
        name="${1:-$name}"
        ;;
      -f)
        shift
        flavour="${1:-$flavour}"
        ;;
      -v)
        shift
        variant="${1:-$variant}"
        ;;
      -m)
        shift
        mode="${1:-$mode}"
        ;;
      --notify)
        ;;
      *)
        echo "ryoku: unknown scheme preview argument: $1" >&2
        return 2
        ;;
    esac
    shift
  done

  payload="$(scheme_json "$name" "$flavour" "$variant" "$mode")"
  mkdir -p "$state_dir"
  local ptmp
  ptmp="$(mktemp)"
  printf '%s\n' "$payload" >"$ptmp"
  mv "$ptmp" "$scheme_file"
  printf '%s\n' "$payload"
}

scheme_set() {
  local name
  local flavour
  local variant
  local mode
  local explicit_flavour=0
  local tmp

  name="$(read_state name ryoku)"
  flavour="$(read_state flavour default)"
  variant="$(read_state variant tonalspot)"
  mode="$(read_state mode dark)"

  while (($# > 0)); do
    case "$1" in
      -n)
        shift
        name="${1:-$name}"
        ;;
      -f)
        shift
        flavour="${1:-$flavour}"
        explicit_flavour=1
        ;;
      -v)
        shift
        variant="${1:-$variant}"
        ;;
      -m)
        shift
        mode="${1:-$mode}"
        ;;
      --notify)
        ;;
      *)
        echo "ryoku: unknown scheme set argument: $1" >&2
        return 2
        ;;
    esac
    shift
  done

  # RYOKU: a wallpaper-derived scheme re-derives from the current wallpaper in the
  # requested mode, so the dark/light toggle switches wallpaper colours live.
  if [[ $flavour == "wallpaper" && $explicit_flavour -eq 0 ]]; then
    apply_wallpaper_scheme "$mode" && return 0
  fi

  # RYOKU: when a custom ryoku theme is the active source and the caller did not
  # explicitly pick a built-in flavour, preserve the theme (re-derive it from its
  # colors.toml in its native mode) instead of reverting to a flavour palette — so
  # the dark/light toggle never wipes an applied theme. Atomic write = live reload.
  local theme_colors="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/current/theme/colors.toml"
  if [[ $flavour == "custom" && $explicit_flavour -eq 0 && -f $theme_colors ]] \
    && command -v ryoku-theme-to-scheme >/dev/null 2>&1; then
    write_state name "$name"
    write_state flavour "custom"
    tmp="$(mktemp)"
    if ryoku-theme-to-scheme "$theme_colors" --name "$name" >"$tmp" 2>/dev/null && [[ -s $tmp ]]; then
      mv "$tmp" "$scheme_file"
      return 0
    fi
    rm -f "$tmp"
  fi

  write_state name "$name"
  write_state flavour "$flavour"
  write_state variant "$variant"
  write_state mode "$mode"
  tmp="$(mktemp)"
  scheme_json "$name" "$flavour" "$variant" "$mode" >"$tmp"
  mv "$tmp" "$scheme_file"
}

scheme_command() {
  local subcommand="${1:-}"
  (($# == 0)) || shift

  case "$subcommand" in
    list)
      scheme_list
      ;;
    get)
      scheme_get "$@"
      ;;
    preview)
      scheme_preview "$@"
      ;;
    set)
      scheme_set "$@"
      ;;
    from-wallpaper)
      apply_wallpaper_scheme "$@"
      ;;
    *)
      usage
      return 2
      ;;
  esac
}

wallpaper_type() { ryoku_wp_type "$path"; }

# RYOKU: resolve a wallpaper path to a file that actually exists. Wallpaper sets
# can record a stale extension (e.g. a ".png" path after the image was re-encoded
# to ".webp"), which leaves the wallpaper symlink + image-derived colour pipeline
# pointing at a missing file. When the given path is gone, fall back to a
# same-basename sibling with a known image extension so neither the wallpaper nor
# its colours break on an extension mismatch.
resolve_wallpaper_path() {
  local p="$1" dir stem cand
  [[ -n $p ]] || { printf '%s\n' "$p"; return 0; }
  [[ -e $p ]] && { printf '%s\n' "$p"; return 0; }
  dir="$(dirname -- "$p")"
  stem="$(basename -- "$p")"
  stem="${stem%.*}"
  for cand in "$dir/$stem".webp "$dir/$stem".png "$dir/$stem".jpg "$dir/$stem".jpeg "$dir/$stem".gif "$dir/$stem".jxl; do
    [[ -e $cand ]] && { printf '%s\n' "$cand"; return 0; }
  done
  for cand in "$dir/$stem".*; do
    [[ -e $cand ]] && { printf '%s\n' "$cand"; return 0; }
  done
  printf '%s\n' "$p"
}

current_wallpaper() {
  local wp
  wp="$(head -n1 "$wallpaper_dir/path.txt" 2>/dev/null || true)"
  [[ -n $wp ]] || wp="$(readlink -f "${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/current/background" 2>/dev/null || true)"
  wp="$(resolve_wallpaper_path "$wp")"
  printf '%s\n' "$wp"
}

wallpaper_scheme_source() {
  local t
  t="$(head -n1 "$wallpaper_dir/type.txt" 2>/dev/null || echo image)"
  local poster="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku/current/background"
  if [[ $t != image && -e $poster ]]; then
    readlink -f "$poster"
  else
    current_wallpaper
  fi
}

# RYOKU: regenerate the dashboard named-accent palette (~/.cache/ryoku/dashboard/colors.json) from the
# same wallpaper. scheme.json drives the Material-3 roles (bar/notch/dashboard/launcher/
# settings), but the named accents (dashboard metric graphs) and the external-app theme
# generators (kitty/gtk/discord/qtct/pywal/nvchad) read this matugen file. Without it those
# areas stay on static defaults, so wallpaper colours only apply to part of the shell.
# Best-effort: never fail the scheme apply if matugen is missing or hiccups.
generate_dashboard_colors() {
  local img="$1" mode="$2"
  local cfg="$ryoku_path/shell/dashboard/assets/matugen/config.toml"
  command -v matugen >/dev/null 2>&1 || return 0
  [[ -f $cfg ]] || return 0
  local scheme="scheme-tonal-spot"
  local wj="${XDG_CACHE_HOME:-$HOME/.cache}/ryoku/dashboard/wallpapers.json"
  [[ -f $wj ]] && scheme="$(jq -r '.matugenScheme // "scheme-tonal-spot"' "$wj" 2>/dev/null || printf 'scheme-tonal-spot')"
  matugen image "$img" --source-color-index 0 -c "$cfg" -t "$scheme" --mode "$mode" >/dev/null 2>&1 || true
}

# generate the live shell scheme.json from the current wallpaper's colors.
# Atomic write so Colours.qml hot-reloads. flavour="wallpaper" keeps the dark/light
# toggle enabled (a wallpaper scheme supports both modes).
apply_wallpaper_scheme() {
  local mode="${1:-$(read_state mode dark)}"
  local wp tmp
  command -v ryoku-wallpaper-to-scheme >/dev/null 2>&1 || return 1
  wp="$(wallpaper_scheme_source)"
  [[ -n $wp && -f $wp ]] || return 1
  mkdir -p "$state_dir"
  tmp="$(mktemp)"
  if ryoku-wallpaper-to-scheme "$wp" --mode "$mode" >"$tmp" 2>/dev/null && [[ -s $tmp ]]; then
    mv "$tmp" "$scheme_file"
    write_state name wallpaper
    write_state flavour wallpaper
    write_state mode "$mode"
    generate_dashboard_colors "$wp" "$mode"
    return 0
  fi
  rm -f "$tmp"
  return 1
}

wallpaper_command() {
  local preview=false
  local apply=false
  local path=""
  local smart=true

  while (($# > 0)); do
    case "$1" in
      -p)
        preview=true
        shift
        path="${1:-}"
        ;;
      -f)
        apply=true
        shift
        path="${1:-}"
        ;;
      --no-smart)
        smart=false
        ;;
      *)
        echo "ryoku: unknown wallpaper argument: $1" >&2
        return 2
        ;;
    esac
    shift
  done

  if [[ $preview == true ]]; then
    scheme_json
    return 0
  fi

  if [[ $apply == true ]]; then
    [[ -n $path ]] || {
      echo "ryoku: wallpaper path is required" >&2
      return 2
    }

    # RYOKU: correct a stale/wrong extension before recording it, so path.txt and
    # the wallpaper symlink always point at a file that exists.
    path="$(resolve_wallpaper_path "$path")"

    # Apply the wallpaper first (sets the picture, generates the video/animated poster,
    # and records type.txt) so the colour-regen trigger below only fires once the new
    # wallpaper is fully in place.
    if [[ -x $ryoku_path/bin/ryoku-wallpaper-apply ]]; then
      "$ryoku_path/bin/ryoku-wallpaper-apply" --type "$(wallpaper_type "$path")" "$path" >/dev/null || true
    elif command_present ryoku-wallpaper-apply; then
      ryoku-wallpaper-apply --type "$(wallpaper_type "$path")" "$path" >/dev/null || true
    fi

    # RYOKU: write path.txt LAST (atomic) so the shell's FileView watch fires only after
    # apply finished (poster + type.txt ready). The shell then debounces and regenerates
    # wallpaper colours from the correct source (see Wallpapers.qml). Writing path.txt
    # before apply raced the slow video poster step and recoloured from stale state.
    mkdir -p "$wallpaper_dir"
    local wptmp
    wptmp="$(mktemp)"
    printf '%s\n' "$path" >"$wptmp"
    mv "$wptmp" "$wallpaper_dir/path.txt"

    # NOTE: wallpaper-colour regeneration is handled shell-side (debounced) on the
    # path.txt change when smartScheme is on; $smart is kept for CLI compatibility.
    : "$smart"

    printf '%s\n' "$path"
    return 0
  fi

  usage
  return 2
}

doctor_command() {
  local doctor="$ryoku_path/bin/ryoku-doctor"

  if [[ -x $doctor ]]; then
    "$doctor" "$@"
    return
  fi

  if command_present ryoku-doctor; then
    ryoku-doctor "$@"
    return
  fi

  echo "ryoku: ryoku-doctor was not found" >&2
  return 127
}

record_command() {
  local recorder="$ryoku_path/bin/ryoku-cmd-screenrecord"

  if [[ -x $recorder ]]; then
    exec "$recorder" "$@"
  fi

  if command_present ryoku-cmd-screenrecord; then
    exec ryoku-cmd-screenrecord "$@"
  fi

  echo "ryoku: ryoku-cmd-screenrecord was not found" >&2
  return 127
}

# Run the control-center TUI inline in the current terminal.
run_control_center_inline() {
  if command_present ryoku-tui; then
    exec ryoku-tui "$@"
  fi
  echo "ryoku: control center (ryoku-tui) is not installed" >&2
  return 127
}

# Open the control center as a floating, centered terminal window - the same
# 1280x720 SUPER+A float, applied by a windowrule on class "ryoku-control".
# Falls back to running inline when not in a graphical Hyprland session, when
# already inside the control window, or when the terminal is unavailable.
open_control_center_window() {
  if [[ ${RYOKU_TUI_WINDOW:-0} == 1 || -z ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
    run_control_center_inline
    return
  fi
  if ! command_present ryoku-tui; then
    echo "ryoku: control center (ryoku-tui) is not installed" >&2
    return 127
  fi

  local term="${RYOKU_TUI_TERMINAL:-kitty}"
  if command_present "$term"; then
    setsid "$term" --class ryoku-control -e env RYOKU_TUI_WINDOW=1 ryoku tui >/dev/null 2>&1 &
    disown 2>/dev/null || true
    return 0
  fi
  run_control_center_inline
}

main() {
  local command="${1:-}"
  (($# == 0)) || shift

  case "$command" in
    "")
      # Bare `ryoku` in a terminal runs the control center INLINE in that
      # terminal (reliable, what you expect). Only a non-terminal caller
      # (e.g. a keybind) gets the floating window; a non-interactive pipe gets
      # the usage text.
      if [[ -t 0 && -t 1 ]]; then
        run_control_center_inline
      elif [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
        open_control_center_window
      else
        usage
        return 2
      fi
      ;;
    tui|menu|center)
      run_control_center_inline "$@"
      ;;
    scheme)
      scheme_command "$@"
      ;;
    wallpaper)
      wallpaper_command "$@"
      ;;
    record)
      record_command "$@"
      ;;
    doctor)
      doctor_command "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      usage
      return 2
      ;;
  esac
}

main "$@"
