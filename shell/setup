#!/bin/bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
runtime_dir="${RYOKU_SHELL_RUNTIME_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/ryoku-shell}"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/ryoku-shell"
bin_dir="${XDG_BIN_HOME:-$HOME/.local/bin}"
applications_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
icon_dir="${XDG_DATA_HOME:-$HOME/.local/share}/icons/hicolor/scalable/apps"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/ryoku-shell"
wallpaper_state_dir="$state_dir/wallpaper"
lib_dir="${RYOKU_SHELL_LIB_DIR:-$HOME/.local/lib/ryoku-shell}"
qml_dir="${RYOKU_SHELL_QML_DIR:-$HOME/.local/lib/qt6/qml}"
build_dir="${RYOKU_SHELL_BUILD_DIR:-$script_dir/build}"
skip_build=false

usage() {
  cat <<'EOF'
Usage: ./setup [install|reinstall|status|doctor] [options]

Options accepted for Ryoku installer compatibility:
  -y, -q, --skip-deps, --skip-setups, --skip-sysupdate

Ryoku-specific:
  --skip-build    Copy the QML runtime without building native modules
EOF
}

command_present() {
  command -v "$1" >/dev/null 2>&1
}

install_runtime_files() {
  local source_root

  mkdir -p "$runtime_dir" "$config_dir" "$bin_dir" "$applications_dir" "$icon_dir"

  # Purge stale build artifacts at the destination before sync. The rsync
  # excludes below skip transferring build/, CMakeCache.txt, etc. from the
  # source - but without --delete-excluded they also skip *deleting* those
  # paths if they already exist at the destination. That left fresh installs
  # carrying the dev box's CMakeCache.txt and binaries pinned to absolute
  # paths under /home/<dev-user>/..., which then made the rebuild fail with
  # "source does not match" and the native plugin never landed.
  rm -rf "$runtime_dir/build" "$runtime_dir/CMakeFiles" "$runtime_dir/CMakeCache.txt"

  if command_present rsync; then
    rsync -a --delete \
      --exclude='.git' \
      --exclude='build' \
      --exclude='CMakeFiles' \
      --exclude='CMakeCache.txt' \
      "$script_dir/." "$runtime_dir/"
  else
    rm -rf "$runtime_dir"
    mkdir -p "$runtime_dir"
    cp -a "$script_dir/." "$runtime_dir/"
    rm -rf "$runtime_dir/build"
  fi

  if ! source_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null)"; then
    source_root="$(cd -- "$script_dir/.." && pwd)"
  fi
  printf '%s\n' "$source_root" >"$runtime_dir/.ryoku-source-path"

  install -m 0755 "$script_dir/scripts/ryoku-shell" "$bin_dir/ryoku-shell"
  [[ -f $script_dir/scripts/ryoku ]] && install -m 0755 "$script_dir/scripts/ryoku" "$bin_dir/ryoku"
  rm -f "$bin_dir/ryoku-keybinds"
  [[ -f $script_dir/assets/logo.svg ]] && install -m 0644 "$script_dir/assets/logo.svg" "$icon_dir/ryoku-shell.svg"
  [[ -f $script_dir/assets/applications/ryoku-shell.desktop ]] && \
    install -m 0644 "$script_dir/assets/applications/ryoku-shell.desktop" "$applications_dir/ryoku-shell.desktop"
}

install_first_run_state() {
  mkdir -p "$HOME" "$state_dir" "$wallpaper_state_dir"

  if [[ ! -s $HOME/.face && -f $script_dir/assets/logo.svg ]]; then
    install -m 0644 "$script_dir/assets/logo.svg" "$HOME/.face"
  fi

  [[ -f $wallpaper_state_dir/path.txt ]] || : >"$wallpaper_state_dir/path.txt"

  if [[ ! -f $state_dir/scheme.json && -x $bin_dir/ryoku ]]; then
    "$bin_dir/ryoku" scheme get >/dev/null
  fi

}

install_service() {
  "$bin_dir/ryoku-shell" service install

  service_file="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/ryoku-shell.service"
  if [[ -f $service_file ]] && ! grep -Fq "ryoku-shell-cleanup-orphans" "$service_file"; then
    legacy_cleanup="ryoku-shell cleanup-orphans"
    if grep -Fq "$legacy_cleanup" "$service_file"; then
      sed -i "\\|$legacy_cleanup|c\\ExecStopPost=-%h/.local/share/ryoku/bin/ryoku-shell-cleanup-orphans --quiet" "$service_file"
    else
      printf '\nExecStopPost=-%%h/.local/share/ryoku/bin/ryoku-shell-cleanup-orphans --quiet\n' >>"$service_file"
    fi
  fi

  if [[ ${RYOKU_COMPOSITOR:-} == "hyprland" || -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
    "$bin_dir/ryoku-shell" service enable
  fi
}

build_native_modules() {
  if [[ $skip_build == true ]]; then
    return 0
  fi

  if ! command_present cmake || ! command_present ninja; then
    echo "setup: cmake or ninja missing; copied QML runtime only" >&2
    return 0
  fi

  cmake -S "$script_dir" -B "$build_dir" -G Ninja \
    -DCMAKE_BUILD_TYPE=Release \
    -DVERSION="${RYOKU_SHELL_VERSION:-0.1.0}" \
    -DGIT_REVISION="${RYOKU_SHELL_GIT_REVISION:-$(git -C "$script_dir" rev-parse --short HEAD 2>/dev/null || printf unknown)}" \
    -DDISTRIBUTOR="ryoku" \
    -DINSTALL_LIBDIR="$lib_dir" \
    -DINSTALL_QMLDIR="$qml_dir" \
    -DINSTALL_QSCONFDIR="$runtime_dir"
  cmake --build "$build_dir"
  cmake --install "$build_dir"
}

install_shell() {
  install_runtime_files
  install_first_run_state
  build_native_modules
  install_service
  printf 'Ryoku shell runtime: %s\n' "$runtime_dir"
}

status_shell() {
  printf 'Source: %s\n' "$script_dir"
  printf 'Runtime: %s\n' "$runtime_dir"
  printf 'Launcher: %s/ryoku-shell\n' "$bin_dir"
  [[ -f $runtime_dir/shell.qml ]] && printf 'Runtime shell.qml: present\n' || printf 'Runtime shell.qml: missing\n'
}

doctor_shell() {
  "$script_dir/scripts/ryoku-shell-doctor" "$@"
}

command="${1:-install}"
(($# == 0)) || shift

remaining=()
while (($# > 0)); do
  case "$1" in
    --skip-build)
      skip_build=true
      ;;
    -y|-q|--skip-deps|--skip-setups|--skip-sysupdate)
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      remaining+=("$1")
      ;;
  esac
  shift
done
set -- "${remaining[@]}"

case "$command" in
  install|reinstall)
    install_shell "$@"
    ;;
  status)
    status_shell
    ;;
  doctor)
    doctor_shell "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "setup: unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
