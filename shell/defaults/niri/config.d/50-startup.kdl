// ─────────────────────────────────────────────────────────────────────────────
// 50 — Processes spawned at login
// ─────────────────────────────────────────────────────────────────────────────
// Each line runs once when Niri starts. For daemons that support it,
// xdg-desktop-autostart (systemd) is an alternative.
//
// Tip: use spawn-sh-at-startup for shell pipelines or variable expansion.
// ─────────────────────────────────────────────────────────────────────────────

// Export XDG_MENU_PREFIX into the systemd user session and rebuild the
// sycoca database so KDE/Qt apps see the correct .desktop entries.
spawn-at-startup "bash" "-c" "systemctl --user import-environment XDG_MENU_PREFIX && kbuildsycoca6"

// Clipboard history: wl-paste watches the clipboard and cliphist stores it.
// Using type-specific watchers prevents duplicate entries (browsers offer both
// text/html and text/plain — without --type, cliphist stores both).
// Access via Ryoku's clipboard overlay (Mod+V).
spawn-at-startup "bash" "-c" "wl-paste --type text --watch cliphist store &"
spawn-at-startup "bash" "-c" "wl-paste --type image --watch cliphist store &"

// Polkit authentication is handled by Ryoku's layer-shell polkit module so
// password prompts can appear above Ryoku overlay windows.

// ── Ryoku shell ──────────────────────────────────────────────────────────────
// Ryoku is managed by the user systemd service (ryoku-shell.service).
// Do not add a compositor startup entry here or you'll get two shells.
