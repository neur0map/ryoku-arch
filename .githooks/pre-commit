#!/bin/bash
# Ryoku pre-commit checks on staged additions:
#   1. no em-dash in text files (prose stays plain, not machine-styled)
#   2. bash syntax on staged shell scripts
#   3. no low-value filler phrases in added comment lines
# Vendored content (ryoku/lockscreen/qylock) is exempt. Bypass with --no-verify
# only when you know what you are doing.
set -euo pipefail

fail() {
	echo "" >&2
	echo "pre-commit rejected this commit:" >&2
	echo "  $1" >&2
	echo "" >&2
	exit 1
}

exempt='^ryoku/lockscreen/qylock/'
text='\.(md|txt|sh|bash|yml|yaml|toml|json|jsonc|conf|lua|tpl|fish|desktop|rules)$|(^|/)(README|NOTICE|LICENSE)$'

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM)

# 1. em-dash scan on text files.
for f in "${staged[@]}"; do
	[[ -f $f ]] || continue
	[[ $f =~ $exempt ]] && continue
	[[ $f =~ $text ]] || continue
	if git show ":$f" | grep -q $'\xe2\x80\x94'; then
		git show ":$f" | grep -n $'\xe2\x80\x94' >&2
		fail "em-dash found in $f. Use a comma, colon, period, or parentheses."
	fi
done

# 2. bash syntax on staged shell scripts (by extension or shebang).
for f in "${staged[@]}"; do
	[[ -f $f ]] || continue
	[[ $f =~ $exempt ]] && continue
	case "$f" in
		*.sh | *.bash) ;;
		*)
			first=$(head -n1 "$f" 2>/dev/null)
			[[ $first == '#!'*bash* || $first == '#!/bin/sh' || $first == '#!/usr/bin/env sh' ]] || continue
			;;
	esac
	if ! git show ":$f" | bash -n 2>/tmp/ryoku-bashn.err; then
		cat /tmp/ryoku-bashn.err >&2
		fail "bash syntax error in $f."
	fi
done

# 3. Filler phrases in ADDED comment lines, via the shared scanner (vendored
#    tree excluded). The same check runs in CI (.github/workflows/ai-slop.yml).
bin/ryoku-dev-scan-slop --staged >/dev/null \
	|| fail "low-value filler comments found (see above); reword or drop them."

exit 0
