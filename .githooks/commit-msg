#!/bin/bash

# Ryoku Arch commit-msg hook.
# Blocks commits whose message contains generated-content attribution,
# authorship trailers, or em-dashes. Enforces project-wide commit hygiene rules.
# Bypass with --no-verify only when you know what you are doing.

set -e

msg_file="$1"
msg=$(cat "$msg_file")

fail() {
  echo "" >&2
  echo "commit-msg hook rejected this commit:" >&2
  echo "  $1" >&2
  echo "" >&2
  echo "fix the message and re-run git commit." >&2
  exit 1
}

if grep -qiE '^co-authored-by:|^[[:space:]]+co-authored-by:' <<<"$msg"; then
  fail "forbidden authorship trailer found in commit message."
fi

if grep -qiE '\b(cl[a]ude|anthr[o]pic|assist[a]nt|L[L]M|chatg[p]t|g[p]t-[0-9])\b' <<<"$msg"; then
  fail "forbidden generated-content attribution term found in commit message."
fi

if grep -qiE 'generat[e]d with|written by (cl[a]ude|a[i]|an l[l]m)|created using an A[I]' <<<"$msg"; then
  fail "forbidden generated-content attribution phrasing found in commit message."
fi

if grep -q $'\xe2\x80\x94' <<<"$msg"; then
  fail "em-dash (U+2014) found in commit message. use : or , or . instead."
fi

exit 0
