#!/bin/bash

# Ryoku Arch pre-push.
# safety net for pushes to origin:
#   1. block force-push to main (rewriting history that users pull from)
#   2. refuse pushes of upstream-tracking branches that carry pushRemote=no_push
#   3. CI-equivalent ShellCheck over non-vendored shell files in the push
# bypass with --no-verify; RYOKU_ALLOW_FORCE_MAIN=1 to override on purpose.

set -euo pipefail

zero='0000000000000000000000000000000000000000'
push_updates="$(mktemp)"
trap 'rm -f "$push_updates"' EXIT

fail() {
  echo "" >&2
  echo "pre-push hook rejected this push:" >&2
  echo "  $1" >&2
  echo "" >&2
  exit 1
}

while read -r local_ref local_sha remote_ref remote_sha; do
  printf '%s %s %s %s\n' "$local_ref" "$local_sha" "$remote_ref" "$remote_sha" >>"$push_updates"

  # skip deletions (local_sha all zeros).
  [[ $local_sha == "$zero" ]] && continue

  # 1. block force-pushes to main.
  if [[ $remote_ref == "refs/heads/main" && $remote_sha != "$zero" ]]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      if [[ -z $RYOKU_ALLOW_FORCE_MAIN ]]; then
        echo "pre-push hook: this push rewrites history on main." >&2
        echo "  local  $local_sha" >&2
        echo "  remote $remote_sha" >&2
        echo "" >&2
        echo "users who pulled the old main will have broken updates." >&2
        echo "to proceed anyway, re-run with RYOKU_ALLOW_FORCE_MAIN=1." >&2
        fail "force-push to main blocked."
      fi
    fi
  fi

  # 2. refuse pushes of upstream-tracking branches.
  # they mirror basecamp/omarchy, never land on origin.
  case "$local_ref" in
    refs/heads/upstream-dev|refs/heads/upstream-master)
      fail "refusing to push $local_ref: this branch mirrors upstream omarchy and must not be published to origin."
      ;;
  esac
done

# 3. ShellCheck shell scripts in the push (skip if shellcheck missing).
if command -v shellcheck >/dev/null 2>&1; then
	empty_tree=4b825dc642cb6eb9a060e54bf8d69288fbee4904
	files=()
	while read -r _ local_sha _ remote_sha; do
		[[ $local_sha == "$zero" ]] && continue
		base=$remote_sha
		[[ $base == "$zero" || -z $base ]] && base=$empty_tree
		while IFS= read -r f; do
			[[ -f $f ]] || continue
			case "$f" in
				*.sh | *.bash) files+=("$f") ;;
				*) [[ $(head -n1 "$f") == '#!'*bash* ]] && files+=("$f") ;;
			esac
		done < <(git diff --name-only --diff-filter=ACM "$base" "$local_sha" -- . ':(glob,exclude)**/vendor/**')
	done <"$push_updates"
	if ((${#files[@]} > 0)); then
		printf '%s\n' "${files[@]}" | sort -u | xargs -r shellcheck -x || fail "ShellCheck failed on pushed shell files."
	fi
fi

exit 0
