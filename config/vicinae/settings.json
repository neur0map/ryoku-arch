{
  // Ryoku default Vicinae configuration (JSONC). Vicinae's in-app settings UI
  // rewrites this file, so prefer editing in-app. Theme files are generated by
  // Ryoku's matugen pipeline into ~/.local/share/vicinae/themes/ryoku.toml on
  // every scheme change, so the launcher tracks the active wallpaper palette.
  "$schema": "https://vicinae.com/schemas/config.json",
  "search_files_in_root": false,
  "close_on_focus_loss": true,
  "theme": {
    "light": { "name": "ryoku", "icon_theme": "auto" },
    "dark": { "name": "ryoku", "icon_theme": "auto" }
  },
  "font": {
    "rendering": "qt",
    "normal": { "family": "auto", "size": 10.5 }
  },
  "launcher_window": {
    "opacity": 0.96,
    "blur": { "enabled": true },
    "layer_shell": {
      "enabled": true,
      // "on_demand" instead of "exclusive": exclusive is known to break mouse
      // interaction on popups (the action panel) under Hyprland, and it also
      // disables close_on_focus_loss.
      "keyboard_interactivity": "on_demand",
      "layer": "top"
    }
  },
  "favorites": ["clipboard:history"],
  "fallbacks": ["files:search"]
}
