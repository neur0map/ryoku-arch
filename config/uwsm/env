# Changes require a restart to take effect.

# Load the shared Ryoku runtime contract for desktop sessions.
for _ryoku_runtime_env in \
  "$HOME/.local/share/ryoku/lib/runtime-env.sh" \
  "$HOME/.local/share/omarchy/lib/runtime-env.sh"; do
  if [[ -r $_ryoku_runtime_env ]]; then
    source "$_ryoku_runtime_env"
    break
  fi
done
unset _ryoku_runtime_env

case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) export PATH="$PATH:$HOME/.local/bin" ;;
esac

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
omarchy-cmd-present mise && eval "$(mise activate bash --shims)"
